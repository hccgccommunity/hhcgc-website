      <input type="hidden" id="edit-event-id">

      <div class="form-group">
        <div class="toggle-row">
          <input type="checkbox" id="page-enabled">
          <label for="page-enabled">Page is live and publicly visible</label>
          <a id="page-live-link" href="#" target="_blank" rel="noopener noreferrer" class="page-url" style="display:none;">View page ↗</a>
        </div>
      </div>

      <div class="form-group">
        <label for="page-slug">URL Slug *</label>
        <input type="text" id="page-slug" placeholder="e.g. sangeet-sandhya">
        <div class="slug-preview">hccgc.org/<span id="slug-display">your-slug</span></div>

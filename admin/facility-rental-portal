<script>
const API_BASE = 'https://facility-rental-api-217911937447.us-central1.run.app';

async function authedFetch(url, options) {
  options = options || {};
  var user = window.__hccgcFirebaseUser;
  if (!user) throw new Error('Not signed in.');
  var token = await user.getIdToken();
  options.headers = Object.assign({}, options.headers, { 'Authorization': 'Bearer ' + token });
  return fetch(url, options);
}
function escHtml(str) {
  return String(str || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}
function loadPartial(id, file) {
  var target = document.getElementById(id);
  if (!target) return;
  fetch(file).then(function (r) { return r.text(); }).then(function (html) {
    target.innerHTML = html;
    if (id === 'site-header') fixHeaderLinksForSubfolder(target);
  }).catch(function () {});
}
function fixHeaderLinksForSubfolder(headerEl) {
  var logo = headerEl.querySelector('.brand-logo');
  if (logo && logo.getAttribute('src') && !logo.getAttribute('src').startsWith('/') && !logo.getAttribute('src').startsWith('http')) {
    logo.setAttribute('src', '/' + logo.getAttribute('src'));
  }
  headerEl.querySelectorAll('a[href]').forEach(function (link) {
    var href = link.getAttribute('href');
    if (!href || href.startsWith('http') || href.startsWith('/') || href.startsWith('#')) return;
    link.setAttribute('href', '/' + href);
  });
}
loadPartial('site-header', '/header.html');
loadPartial('site-footer', '/footer.html');
async function loadPendingCounts() {
  try {
    var res = await authedFetch(API_BASE + '/pending-counts');
    var data = await res.json();
    if (data.pendingRenters > 0) {
      var renterLink = document.getElementById('nav-add-renter');
      if (renterLink && !renterLink.querySelector('.nav-badge')) renterLink.insertAdjacentHTML('beforeend', ' <span class="nav-badge">' + data.pendingRenters + '</span>');
    }
    if (data.pendingBookings > 0) {
      var bookingLink = document.getElementById('nav-all-bookings');
      if (bookingLink && !bookingLink.querySelector('.nav-badge')) bookingLink.insertAdjacentHTML('beforeend', ' <span class="nav-badge">' + data.pendingBookings + '</span>');
    }
  } catch (err) {
    // Silent -- badges are a nice-to-have, not worth surfacing an error for.
  }
}

// ==================== ALL BOOKINGS TAB ====================
// ---- Sample data, standing in for a BigQuery-backed API call ----
// Real bookings are loaded from the API below (see loadBookings()).
const ALL_ROOM_NAMES = ['Surya Hall', 'Patanjali Hall', 'Nataraj Room', 'Ganesh Room'];

let BOOKINGS = [];

async function loadBookings() {
  const notice = document.getElementById('mock-notice');
  try {
    const res = await authedFetch(API_BASE + '/bookings');
    if (!res.ok) throw new Error('Server returned ' + res.status);
    BOOKINGS = await res.json();
    notice.style.display = 'none';
  } catch (err) {
    notice.textContent = 'Could not load bookings from the database (' + err.message + '). Check the database connection and try refreshing.';
    notice.style.display = 'block';
    BOOKINGS = [];
  }
  populateContactFilter();
  render();
}

let state = { contactFilter: undefined, statusFilter: undefined, room: '', month: 'default3', sortKey: 'updated_display', sortDir: 'desc', pageSize: 20, page: 1 };

// ---- Column configurator ----
// Contact Name and Actions are always shown — everything else is
// toggleable. Capped at MAX_VISIBLE so re-enabling everything can't just
// recreate the same clutter we fixed earlier.
const COLUMN_DEFS = [
  { key: 'event_name', label: 'Event Name' },
  { key: 'room', label: 'Room' },
  { key: 'event_date', label: 'Booking Date', sortable: true },
  { key: 'hours', label: 'Hours', sortable: true },
  { key: 'final_total', label: 'Total', sortable: true },
  { key: 'payment_status', label: 'Status', sortable: true },
  { key: 'organization_name', label: 'Organization' },
  { key: 'notes', label: 'Notes' },
  { key: 'created_by', label: 'Booked By' },
  { key: 'updated_display', label: 'Updated', sortable: true }
];
const DEFAULT_VISIBLE_COLUMNS = ['event_name', 'room', 'event_date', 'hours', 'final_total', 'payment_status'];
const MAX_VISIBLE_COLUMNS = 7;

function loadVisibleColumns() {
  try {
    const stored = JSON.parse(localStorage.getItem('hccgc-bookings-visible-columns'));
    if (Array.isArray(stored) && stored.length) return new Set(stored);
  } catch (err) { /* fall through to default */ }
  return new Set(DEFAULT_VISIBLE_COLUMNS);
}
let visibleColumns = loadVisibleColumns();
function saveVisibleColumns() {
  try { localStorage.setItem('hccgc-bookings-visible-columns', JSON.stringify(Array.from(visibleColumns))); } catch (err) { /* ignore storage errors */ }
}



function formatDate(iso) {
  const d = new Date(iso + 'T00:00:00');
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
// For real timestamps (invoice_sent_at, receipt_sent_at, etc.) — unlike
// formatDate above, these carry an actual time-of-day and must always
// display in Eastern regardless of the viewer's own browser location,
// since HCCGC staff anywhere need to see facility-local time consistently.
function formatTimestampDate(iso) {
  if (!iso) return '—';
  return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'America/New_York' });
}
function formatDateTime(iso) {
  if (!iso) return '—';
  const d = new Date(iso);
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', timeZone: 'America/New_York' }) + ', ' + d.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', timeZone: 'America/New_York' });
}

function isPastDue(b) {
  return (b.payment_status === 'invoiced' || b.payment_status === 'pending') && new Date(b.event_date) < new Date();
}

function statusBadge(b) {
  if (b.is_internal || b.payment_status === 'n/a') {
    return '<span class="badge badge-draft"><span class="badge-dot"></span>Internal · No charge</span>';
  }
  if (b.payment_status === 'requested') {
    return '<span class="badge badge-needs-confirm"><span class="badge-dot"></span>Requested — awaiting review</span>';
  }
  if (b.payment_status === 'rejected') {
    const reasonTag = b.rejection_reason ? '<span class="method-tag" title="' + escHtml(b.rejection_reason) + '">' + escHtml(b.rejection_reason.slice(0, 40)) + (b.rejection_reason.length > 40 ? '…' : '') + '</span>' : '';
    return '<span class="badge badge-cancelled"><span class="badge-dot"></span>Rejected</span>' + reasonTag;
  }
  if (b.payment_status === 'cancelled') {
    const feeTag = (b.cancellation_fee !== null && b.cancellation_fee !== undefined)
      ? '<span class="method-tag">Fee: $' + Number(b.cancellation_fee).toFixed(2) + ' · Refund: $' + Number(b.refund_amount).toFixed(2) + '</span>' : '';
    return '<span class="badge badge-cancelled"><span class="badge-dot"></span>Cancelled</span>' + feeTag;
  }
  if (b.receipt_sent_at) {
    return '<span class="badge badge-paid"><span class="badge-dot"></span>Receipt Sent</span><span class="method-tag">' + formatDateTime(b.receipt_sent_at) + '</span>';
  }
  if (b.payment_status === 'paid') {
    const methodLabel = b.payment_match_source === 'zeffy' ? 'Zeffy · auto-matched' :
      b.payment_match_source === 'zelle' ? 'Zelle · auto-matched' :
      b.payment_method === 'zelle' ? 'Zelle · confirmed' :
      b.payment_method === 'cash' ? 'Cash · confirmed' :
      b.payment_method === 'check' ? 'Check · confirmed' : 'Confirmed';
    return '<span class="badge badge-paid"><span class="badge-dot"></span>Paid</span><span class="method-tag">' + methodLabel + '</span>';
  }
  if (b.invoice_sent_at) {
    const label = isPastDue(b) ? 'Invoice sent · past due' : 'Invoice Sent';
    return '<span class="badge badge-needs-confirm"><span class="badge-dot"></span>' + label + '</span><span class="method-tag">' + formatDateTime(b.invoice_sent_at) + '</span>';
  }
  return '<span class="badge badge-draft"><span class="badge-dot"></span>Booked</span>';
}

// The 3 action icons — Notes, Invoice, Receipt. Invoice is "needs sending"
// (yellow) whenever there's no invoice_sent_at yet, OR the booking's been
// edited since the last send (updated_at newer than invoice_sent_at) —
// exactly the same condition send-invoice itself enforces server-side, so
// the icon never promises an action the backend would actually refuse.
function needsInvoiceSend(b) {
  if (!b.invoice_sent_at) return true;
  if (b.invoice_content_updated_at && new Date(b.invoice_content_updated_at) > new Date(b.invoice_sent_at)) return true;
  return false;
}
function notesButtonHtml(b) {
  return '<button type="button" class="btn-icon-action' + (b.notes ? ' has-content' : '') + '" title="' + (b.notes ? 'Note: ' + escHtml(b.notes) : 'Add a note') + '" data-notes-booking="' + b.booking_id + '">\ud83d\udcdd</button>';
}
function actionIcons(b) {
  if (b.is_internal) return '';
  const needsSend = needsInvoiceSend(b);
  const notesBtn = notesButtonHtml(b);
  const invoiceBtn = '<button type="button" class="btn-invoice ' + (needsSend ? 'attached' : 'sent') + '" title="' + (needsSend ? 'Invoice not sent — click to send, edit, or download' : 'Invoice sent ' + formatTimestampDate(b.invoice_sent_at) + ' — click to edit or download') + '" data-invoice-booking="' + b.booking_id + '">\ud83e\uddfe</button>';
  const receiptDisabled = b.payment_status !== 'paid';
  const receiptBtn = '<button type="button" class="btn-receipt' + (b.receipt_sent_at ? ' sent' : '') + '"' + (receiptDisabled ? ' disabled title="Mark paid in Finance first"' : ' title="' + (b.receipt_sent_at ? 'Receipt sent ' + formatTimestampDate(b.receipt_sent_at) : 'Click to send the receipt') + '"') + ' data-receipt-booking="' + b.booking_id + '">' + (b.receipt_sent_at ? '\ud83e\uddfe' : (receiptDisabled ? '\u2014' : '\u2795')) + '</button>';
  return '<div class="action-icons">' + notesBtn + invoiceBtn + receiptBtn + '</div>';
}

function isWholeFacility(b) {
  return ALL_ROOM_NAMES.every(function (r) { return b.rooms.includes(r); });
}

function monthRangeFor(monthValue) {
  const today = new Date(); today.setDate(1); today.setHours(0, 0, 0, 0);
  if (monthValue === 'all') return null;
  if (monthValue === 'default3') {
    const start = new Date(today.getFullYear(), today.getMonth() - 1, 1);
    const end = new Date(today.getFullYear(), today.getMonth() + 2, 1); // exclusive, i.e. end of next month
    return { start, end };
  }
  const [y, m] = monthValue.split('-').map(Number);
  return { start: new Date(y, m - 1, 1), end: new Date(y, m, 1) };
}

const STATUS_CATEGORIES = ['requested', 'needs-attention', 'pending', 'paid', 'internal', 'cancelled', 'rejected'];
function matchesStatusCategory(b, category) {
  if (category === 'needs-attention') return b.payment_status === 'invoiced' || b.payment_status === 'pending';
  if (category === 'paid') return b.payment_status === 'paid';
  if (category === 'pending') return b.payment_status === 'pending';
  if (category === 'cancelled') return b.payment_status === 'cancelled';
  if (category === 'internal') return b.is_internal || b.payment_status === 'n/a';
  if (category === 'requested') return b.payment_status === 'requested';
  if (category === 'rejected') return b.payment_status === 'rejected';
  return false;
}

function contactNameFor(b) { return b.is_internal ? 'HCCGC' : b.renter_name; }
function matchesFilters(b) {
  if (state.contactFilter && !state.contactFilter.has(contactNameFor(b))) return false;
  if (state.room === '__whole_facility__' && !isWholeFacility(b)) return false;
  if (state.room && state.room !== '__whole_facility__' && !b.rooms.includes(state.room)) return false;
  if (state.statusFilter && !STATUS_CATEGORIES.some(function (cat) { return state.statusFilter.has(cat) && matchesStatusCategory(b, cat); })) return false;
  const range = monthRangeFor(state.month);
  if (range) {
    const d = new Date(b.event_date + 'T00:00:00');
    if (d < range.start || d >= range.end) return false;
  }
  return true;
}

function sortDisplayItems(items) {
  const key = state.sortKey, dir = state.sortDir === 'asc' ? 1 : -1;
  return items.slice().sort(function (a, b) {
    let av = a[key], bv = b[key];
    if (key === 'renter_name') { av = (av || '').toLowerCase(); bv = (bv || '').toLowerCase(); }
    if (av === null || av === undefined) av = '';
    if (bv === null || bv === undefined) bv = '';
    if (av < bv) return -1 * dir;
    if (av > bv) return 1 * dir;
    return 0;
  });
}

// Recurring Picktime series (and real recurring bookings made through New
// Booking) share a recurring_series_id — group those into one collapsed
// summary row by default instead of showing every occurrence separately.
function groupIntoDisplayItems(list) {
  const seriesMap = {};
  const items = [];
  list.forEach(function (b) {
    if (b.recurring_series_id) {
      if (!seriesMap[b.recurring_series_id]) {
        const item = { type: 'series', seriesId: b.recurring_series_id, occurrences: [] };
        seriesMap[b.recurring_series_id] = item;
        items.push(item);
      }
      seriesMap[b.recurring_series_id].occurrences.push(b);
    } else {
      items.push({
        type: 'single', booking: b, renter_name: b.renter_name, event_date: b.event_date,
        hours: b.hours, final_total: Number(b.final_total), payment_status: b.payment_status,
        updated_display: b.updated_display
      });
    }
  });
  items.forEach(function (item) {
    if (item.type !== 'series') return;
    const occ = item.occurrences.slice().sort(function (a, b) { return a.event_date < b.event_date ? -1 : (a.event_date > b.event_date ? 1 : 0); });
    item.occurrences = occ;
    const first = occ[0];
    item.renter_name = first.renter_name;
    item.renter_email = first.renter_email;
    item.rooms = first.rooms;
    item.is_internal = first.is_internal;
    item.event_date = first.event_date;
    item.event_date_last = occ[occ.length - 1].event_date;
    item.hours = first.hours;
    item.final_total = occ.reduce(function (sum, o) { return sum + Number(o.final_total); }, 0);
    item.payment_status = occ.every(function (o) { return o.payment_status === first.payment_status; }) ? first.payment_status : 'mixed';
    item.paidCount = occ.filter(function (o) { return o.payment_status === 'paid'; }).length;
    item.notes = first.notes;
    item.event_name = first.event_name;
    item.organization_name = first.organization_name;
    item.created_by = first.created_by;
    item.updated_display = occ.reduce(function (latest, o) { return o.updated_display > latest ? o.updated_display : latest; }, first.updated_display);
    item.recurrence_summary = first.recurrence_summary || (occ.length + ' occurrences');
  });
  return items;
}

let expandedSeries = new Set();
function toggleSeries(seriesId) {
  if (expandedSeries.has(seriesId)) expandedSeries.delete(seriesId);
  else expandedSeries.add(seriesId);
  render();
}

function getColumnCellHtml(columnKey, data, isSubRow) {
  const isSeries = !!data.occurrences;
  switch (columnKey) {
    case 'event_name':
      return '<td>' + escHtml(data.event_name || '—') + '</td>';
    case 'room':
      return '<td>' + (isWholeFacility(data)
        ? '<span class="room-pill whole-facility">&#9733; Whole Facility</span>'
        : '<span class="room-pill">' + escHtml(data.rooms.join(' + ')) + '</span>') + '</td>';
    case 'event_date':
      return '<td>' + (isSeries ? formatDate(data.event_date) + ' &ndash; ' + formatDate(data.event_date_last) : formatDate(data.event_date)) + '</td>';
    case 'hours':
      return '<td>' + data.hours + '</td>';
    case 'final_total': {
      let amt = '$' + Number(data.final_total).toFixed(2);
      if (!isSeries && !isSubRow && data.manual_adjustment_type) amt += '<span class="adjusted-tag" title="' + escHtml(data.manual_adjustment_reason || '') + '">Adjusted</span>';
      if (isSeries) amt += ' <span class="method-tag">total</span>';
      return '<td class="amount">' + amt + '</td>';
    }
    case 'payment_status': {
      // Occurrences are info-only — invoice/receipt only ever apply at the
      // series level (one invoice per booking group, not per date), so an
      // individual occurrence showing its own independent status badge is
      // exactly what caused a sub-row to disagree with its own series
      // summary. Plain text here, no badge, no icon, nothing actionable.
      if (isSubRow) {
        return '<td style="color:var(--muted);font-size:0.86rem;">' + escHtml(data.payment_status) + '</td>';
      }
      let html;
      if (data.payment_status === 'mixed') {
        html = '<span class="badge badge-needs-confirm"><span class="badge-dot"></span>' + data.paidCount + ' of ' + data.occurrences.length + ' paid</span>';
      } else if (isSeries) {
        html = statusBadge({ payment_status: data.payment_status, is_internal: data.is_internal, cancellation_fee: null, event_date: data.event_date_last });
      } else {
        html = statusBadge(data);
      }
      return '<td>' + html + '</td>';
    }
    case 'organization_name':
      return '<td>' + escHtml(data.organization_name || '—') + '</td>';
    case 'notes':
      return '<td class="notes-cell" title="' + escHtml(data.notes || '') + '">' + escHtml(data.notes || '—') + '</td>';
    case 'created_by':
      return '<td style="font-size:0.8rem;color:var(--muted);">' + escHtml(data.created_by || '—') + '</td>';
    case 'updated_display':
      return '<td class="updated-cell">' + formatDateTime(data.updated_display) + '</td>';
    default:
      return '<td></td>';
  }
}

function visibleColumnCells(data, isSubRow) {
  return COLUMN_DEFS.filter(function (c) { return visibleColumns.has(c.key); })
    .map(function (c) { return getColumnCellHtml(c.key, data, isSubRow); }).join('');
}

const PAST_BOOKING_EDIT_ALLOWLIST = ['nilaj@hccgc.org', 'admin@hccgc.org'];
function currentUserEmail() { return ((window.__hccgcCurrentUser && window.__hccgcCurrentUser.email) || '').toLowerCase(); }
function isBookingPast(b) { return new Date(b.event_date + 'T00:00:00') < new Date(new Date().toDateString()); }
function isPicktimeHistoricalPaid(b) { return b.created_by === 'picktime-import' && b.payment_status === 'paid'; }

function isHistoricallyLocked(b) {
  // Anything that already happened, or was already paid via the Picktime
  // import (a real historical transaction that predates this system) — no
  // point offering to invoice, search for a payment, or (for anyone but the
  // two allowlisted admins) edit those.
  return isBookingPast(b) || isPicktimeHistoricalPaid(b);
}

function renderBookingRow(b, isSubRow, seriesIsMixed) {
  const rowClasses = (b.payment_status === 'cancelled' || b.payment_status === 'rejected' ? 'cancelled-row ' : '') + (isSubRow ? 'sub-row' : '');
  // Per-occurrence invoicing means each occurrence really is its own
  // independent billing unit — same as a standalone booking — so it gets
  // full status and actions even though it's a sub-row. Combined
  // invoicing (the default) is the only case where sub-rows stay
  // info-only, since the group above is the actual billing unit there.
  // A series showing mixed payment status (some occurrences paid,
  // others not) gets the same independent treatment regardless of
  // invoice_mode — that mix could only happen if occurrences were
  // actually operated on individually, most often historical series
  // that predate this setting existing at all.
  const actsIndependently = isSubRow && (b.invoice_mode === 'per_occurrence' || seriesIsMixed);
  const treatAsSubRow = isSubRow && !actsIndependently;

  // A public booking request awaiting review is a totally different case
  // from every other status — nothing else (Mark Paid, Edit, Cancel, etc.)
  // applies until an admin has actually approved or rejected it.
  if (b.payment_status === 'requested' || b.payment_status === 'rejected') {
    const actions = b.payment_status === 'requested'
      ? [{ label: 'Review request', fn: () => openBookingReviewModal(b.booking_id) }]
      : [];
    const actionsCell = treatAsSubRow ? '<td></td>' : '<td>' + renderActionsKebab(b.booking_id, actions) + '</td>';
    return (
      '<tr' + (rowClasses ? ' class="' + rowClasses.trim() + '"' : '') + '>' +
        '<td>' + (isSubRow ? '<div class="renter-sub">' + formatDate(b.event_date) + '</div>' : '<div class="renter-name">' + escHtml(b.renter_name) + '</div><div class="renter-sub">' + escHtml(b.renter_email) + '</div>') + '</td>' +
        visibleColumnCells(b, treatAsSubRow) +
        actionsCell +
      '</tr>'
    );
  }

  const needsAction = (b.payment_status === 'pending' || b.payment_status === 'invoiced');
  const notCancelled = b.payment_status !== 'cancelled';
  const notPaid = b.payment_status !== 'paid';
  const locked = isHistoricallyLocked(b);
  // Editing specifically has the one narrow admin override; every other
  // locked action has no override at all. Paid bookings have no override
  // at all — confirmed payment locks the invoice regardless of who's asking.
  const canEditThis = notCancelled && notPaid && (!locked || (isBookingPast(b) && !isPicktimeHistoricalPaid(b) && PAST_BOOKING_EDIT_ALLOWLIST.includes(currentUserEmail())));

  // Kebab menu is deliberately down to just Edit and Cancel now — invoice
  // send/edit/download lives in the invoice icon's popup, and marking
  // paid/matching payments moved entirely into Finance.
  const actions = [];
  if (canEditThis) actions.push({ label: 'Edit', fn: () => openEditModal(b.booking_id) });
  if (notCancelled && !locked) actions.push({ label: 'Cancel', danger: true, fn: () => cancelBookingFlow(b.booking_id) });

  const actionsCell = treatAsSubRow ? '<td></td>' : '<td><div style="display:flex;align-items:center;gap:8px;">' + actionIcons(b) + renderActionsKebab(b.booking_id, actions) + '</div></td>';
  return (
    '<tr' + (rowClasses ? ' class="' + rowClasses.trim() + '"' : '') + '>' +
      '<td>' + (isSubRow ? '<div class="renter-sub">' + formatDate(b.event_date) + '</div>' : '<div class="renter-name">' + escHtml(b.renter_name) + '</div><div class="renter-sub">' + escHtml(b.renter_email) + '</div>') + '</td>' +
      visibleColumnCells(b, treatAsSubRow) +
      actionsCell +
    '</tr>'
  );
}

function renderSeriesSummaryRow(item) {
  const isExpanded = expandedSeries.has(item.seriesId);
  const repOcc = item.occurrences[0];
  const perOccurrenceMode = repOcc && (repOcc.invoice_mode === 'per_occurrence' || item.payment_status === 'mixed');

  if (item.payment_status === 'requested' || item.payment_status === 'rejected') {
    const actions = item.payment_status === 'requested'
      ? [{ label: 'Review request (all dates)', fn: () => openBookingReviewModal(repOcc.booking_id) }]
      : [];
    return (
      '<tr class="series-summary-row">' +
        '<td onclick="toggleSeries(\'' + item.seriesId + '\')" style="cursor:pointer;"><div class="renter-name">' + (isExpanded ? '&#9660; ' : '&#9654; ') + escHtml(item.renter_name) + ' <span class="discount-chip" style="margin-left:4px;">' + item.occurrences.length + ' occurrences</span></div><div class="renter-sub">' + escHtml(item.renter_email) + '</div></td>' +
        visibleColumnCells(item) +
        '<td>' + renderActionsKebab(item.seriesId, actions) + '</td>' +
      '</tr>'
    );
  }

  const notCancelled = item.payment_status !== 'cancelled';
  const allPaid = item.payment_status === 'paid';
  const allPast = item.occurrences.every(isBookingPast);
  const allHistoricallyLocked = item.occurrences.every(isHistoricallyLocked);
  // A fully-paid series has nothing left to edit. A "mixed" series (some
  // occurrences paid, some not) still allows editing — the backend
  // already excludes the paid occurrences from whatever gets changed,
  // same as the individual-booking lock above.
  const canEditThis = notCancelled && !allPaid && (!allHistoricallyLocked || (allPast && PAST_BOOKING_EDIT_ALLOWLIST.includes(currentUserEmail())));

  const actions = [];
  if (canEditThis) actions.push({ label: 'Edit series', fn: () => openSeriesEditModal(item.seriesId) });
  if (notCancelled && !allHistoricallyLocked) actions.push({ label: 'Cancel all', danger: true, fn: () => cancelSeriesFlow(item.seriesId) });

  // Combined invoicing (default): the group IS the billing unit, so it
  // gets the exact same Notes/Invoice/Receipt icon treatment as a single
  // booking, using the first occurrence as the representative record (the
  // same one Edit Series and Download Invoice already treat as canonical).
  // Per-occurrence invoicing: invoice/receipt belong to each occurrence
  // individually now, so the group only gets a notes icon — there's still
  // a group-level note worth having even when billing is split up.
  const groupIcons = item.is_internal ? '' :
    (perOccurrenceMode ? '<div class="action-icons">' + notesButtonHtml(repOcc) + '</div>' : actionIcons(repOcc));

  return (
    '<tr class="series-summary-row">' +
      '<td onclick="toggleSeries(\'' + item.seriesId + '\')" style="cursor:pointer;"><div class="renter-name">' + (isExpanded ? '&#9660; ' : '&#9654; ') + escHtml(item.renter_name) + ' <span class="discount-chip" style="margin-left:4px;">' + item.occurrences.length + ' occurrences</span></div><div class="renter-sub">' + escHtml(item.renter_email) + '</div></td>' +
      visibleColumnCells(item) +
      '<td><div style="display:flex;align-items:center;gap:8px;">' + groupIcons + renderActionsKebab(item.seriesId, actions) + '</div></td>' +
    '</tr>'
  );
}


      if (bookingLink && !bookingLink.querySelector('.nav-badge')) bookingLink.insertAdjacentHTML('beforeend', ' <span class="nav-badge">' + data.pendingBookings + '</span>');
    }
  } catch (err) {
    // Silent -- badges are a nice-to-have, not worth surfacing an error for.
  }
}


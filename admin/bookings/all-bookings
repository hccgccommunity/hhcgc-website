    '</tr>';
  }).join('');
  tbody.querySelectorAll('.series-occ-remove').forEach(function (cb) {
    cb.addEventListener('change', function () {
      this.closest('tr').classList.toggle('marked-for-removal', this.checked);
    });
  });
}

async function openSeriesEditModal(seriesId) {
  const occurrences = BOOKINGS.filter(function (b) { return b.recurring_series_id === seriesId && b.payment_status !== 'cancelled'; })
    .sort(function (a, b) { return a.event_date < b.event_date ? -1 : 1; });
  if (!occurrences.length) return;
  editingSeriesId = seriesId;
  const first = occurrences[0];

  buildSeriesEditRoomPicker();
  await loadEditRenters();
  const select = document.getElementById('series-edit-renter-select');
  select.innerHTML = '<option value="">Choose a renter…</option>' + EDIT_RENTERS.map(function (r) {
    const label = r.contact_name + (r.email ? (' — ' + r.email) : '');
    return '<option value="' + r.renter_id + '">' + label.replace(/</g, '&lt;') + '</option>';
  }).join('');

  document.getElementById('series-edit-renter-select-field').style.display = first.is_internal ? 'none' : 'flex';
  document.getElementById('series-edit-name-field').style.display = first.is_internal ? 'flex' : 'none';
  document.getElementById('series-edit-hccg-rep-field').style.display = first.is_internal ? 'flex' : 'none';
  document.getElementById('series-edit-nonprofit-row').style.display = first.is_internal ? 'none' : 'flex';

  if (first.is_internal) {
    document.getElementById('series-edit-name').value = first.renter_name || '';
    document.getElementById('series-edit-hccg-rep').value = first.hccgc_representative_name || '';
  } else {
    select.value = first.renter_id || '';
    document.getElementById('series-edit-nonprofit').checked = !!first.is_nonprofit;
  }
  document.getElementById('series-edit-notes').value = first.notes || '';
  document.querySelectorAll('.series-edit-room-cb').forEach(function (cb) { cb.checked = first.rooms.includes(cb.value); });
  enforceSeriesEditKitchenRule();
  renderSeriesEditOccTable(occurrences);

  document.getElementById('series-edit-modal-title').textContent = (first.is_internal ? 'Edit internal series' : 'Edit series') + ' (' + occurrences.length + ' occurrences)';
  document.getElementById('series-edit-result-box').style.display = 'none';
  document.getElementById('series-edit-modal-overlay').style.display = 'flex';
}

function closeSeriesEditModal() {
  document.getElementById('series-edit-modal-overlay').style.display = 'none';
  editingSeriesId = null;
}
document.getElementById('btn-close-series-edit').addEventListener('click', closeSeriesEditModal);
document.getElementById('btn-cancel-series-edit-modal').addEventListener('click', closeSeriesEditModal);
document.getElementById('series-edit-modal-overlay').addEventListener('click', function (e) {
  if (e.target === this) closeSeriesEditModal();
});

document.getElementById('btn-save-series-edit').addEventListener('click', async function () {
  const btn = this;
  const occurrences = BOOKINGS.filter(function (b) { return b.recurring_series_id === editingSeriesId && b.payment_status !== 'cancelled'; });
  if (!occurrences.length) return;
  const isInternal = occurrences[0].is_internal;
  const rooms = Array.from(document.querySelectorAll('.series-edit-room-cb:checked')).map(function (cb) { return cb.value; });
  const resultBox = document.getElementById('series-edit-result-box');

  const occInputs = Array.from(document.querySelectorAll('#series-edit-occ-tbody tr')).map(function (tr) {
    return {
      bookingId: tr.dataset.bookingId,
      eventDate: tr.querySelector('.series-occ-date').value,
      startTime: tr.querySelector('.series-occ-start').value,
      endTime: tr.querySelector('.series-occ-end').value,
      remove: tr.querySelector('.series-occ-remove').checked
    };
  });

  const payload = {
    rooms: rooms,
    notes: document.getElementById('series-edit-notes').value,
    renterId: isInternal ? null : document.getElementById('series-edit-renter-select').value,
    renterName: isInternal ? document.getElementById('series-edit-name').value : null,
    hccgcRepresentativeName: isInternal ? document.getElementById('series-edit-hccg-rep').value : null,
    isNonprofit: isInternal ? false : document.getElementById('series-edit-nonprofit').checked,
    occurrences: occInputs
  };

  btn.disabled = true; btn.textContent = 'Saving…';
  try {
    const res = await authedFetch(API_BASE + '/bookings/series/' + encodeURIComponent(editingSeriesId), {
      method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (!res.ok) {
      resultBox.style.display = 'block'; resultBox.className = 'result-box error';
      resultBox.textContent = (data.errors || [data.error || 'Something went wrong.']).join(' ');
    } else {
      resultBox.style.display = 'block'; resultBox.className = 'result-box success';
      let msg = 'Saved — ' + data.updatedCount + ' occurrence(s) updated';
      if (data.removedCount) msg += ', ' + data.removedCount + ' removed';
      msg += '.';
      if (data.occurrenceErrors && data.occurrenceErrors.length) msg += ' Some rows had issues: ' + data.occurrenceErrors.join(' ');
      resultBox.textContent = msg;
      await loadBookings();
      setTimeout(closeSeriesEditModal, 1200);
    }
  } catch (err) {
    resultBox.style.display = 'block'; resultBox.className = 'result-box error';
    resultBox.textContent = 'Could not reach the booking system: ' + err.message;
  } finally {
    btn.disabled = false; btn.textContent = 'Save changes';
  }
});


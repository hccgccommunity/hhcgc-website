// Jump to the week containing the chosen date, same behavior the old embed had.
document.getElementById('f-date').addEventListener('change', function () {
  const chosen = this.value;
  if (!chosen) return;
  const chosenDate = new Date(chosen + 'T00:00:00');
  const today = new Date(new Date().toDateString());
  const todaySunday = new Date(today.getFullYear(), today.getMonth(), today.getDate() - today.getDay());
  const chosenSunday = new Date(chosenDate.getFullYear(), chosenDate.getMonth(), chosenDate.getDate() - chosenDate.getDay());
  availWeekOffset = Math.round((chosenSunday - todaySunday) / (7 * 86400000));
  if (availViewMode !== 'week') setAvailViewMode('week'); else loadAvailabilityCalendar();
});
renderAvailLegend();

<style>
:root {
  --bg: #fff9f1; --surface: #ffffff; --surface-soft: #fff6ea; --border: rgba(121,62,17,0.14);
  --text: #2c1b10; --muted: #6a5141; --saffron: #b55a18; --saffron-dark: #8d3e0d; --maroon: #7f2e16;
  --radius: 22px; --shadow: 0 18px 45px rgba(93,43,14,0.10);
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: Arial, Helvetica, sans-serif; background: radial-gradient(circle at top left, rgba(217,138,30,0.12), transparent 22%), radial-gradient(circle at top right, rgba(127,46,22,0.05), transparent 20%), var(--bg); color: var(--text); min-height: 100vh; }
.container { width: min(calc(100% - 32px), 1300px); margin: 0 auto; }
.site-header { position: sticky; top: 0; z-index: 50; background: rgba(255,249,241,0.92); backdrop-filter: blur(10px); border-bottom: 1px solid var(--border); }
.nav { display: flex; align-items: center; justify-content: space-between; gap: 24px; min-height: 92px; padding: 12px 0; }
.site-header a.brand, .site-header a.brand:link, .site-header a.brand:visited { text-decoration: none; color: inherit; }
.brand { display: flex; align-items: center; gap: 16px; min-width: 0; }
.brand-logo-wrap { background: #fff; border: 1px solid var(--border); border-radius: 18px; padding: 8px; box-shadow: var(--shadow); flex-shrink: 0; }
.brand-logo { width: 88px; height: auto; border-radius: 12px; object-fit: contain; }
.brand-text h1 { margin: 0; font-size: 1.2rem; line-height: 1.15; color: var(--maroon); }
.site-header nav ul { list-style: none; display: flex; flex-wrap: wrap; gap: 18px; margin: 0; padding: 0; align-items: center; justify-content: flex-end; }
.site-header nav a, .site-header nav a:link, .site-header nav a:visited { font-weight: 700; color: var(--text); font-size: 0.96rem; text-decoration: none; }
.site-header nav a:hover { color: var(--saffron-dark); }
.menu-toggle { display: none; border: 0; background: transparent; padding: 6px 0; cursor: pointer; color: #2c1b10; align-self: flex-end; }
.menu-toggle .bar { display: block; width: 26px; height: 2px; margin: 5px 0; background: currentColor; }
@media (max-width: 768px) {
  .nav { flex-direction: column; align-items: stretch; gap: 8px; } .menu-toggle { display: inline-block; }
  .site-header nav { display: none; width: 100%; background: rgba(255,249,241,0.95); padding: 10px 0; }
  .site-header nav.is-open { display: block; } .site-header nav ul { flex-direction: column; gap: 14px; }
}
.page-hero { padding: 28px 0 22px; background: linear-gradient(135deg, var(--maroon) 0%, #4e1a09 100%); color: #fff; }
.page-hero h1 { font-family: Georgia, "Times New Roman", serif; font-size: 1.9rem; color: #fff; margin-bottom: 6px; }
.page-hero p { color: #ffffff; opacity: 0.9; font-size: 0.92rem; max-width: 560px; }
.back-link { display: inline-flex; align-items: center; gap: 6px; font-size: 0.82rem; font-weight: 700; color: rgba(255,255,255,0.85); text-decoration: none; margin-bottom: 14px; }
.back-link:hover { color: #fff; text-decoration: underline; }
.module-nav { background: var(--surface); border-bottom: 1px solid var(--border); }
.module-nav ul { list-style: none; display: flex; gap: 4px; padding: 10px 0; flex-wrap: wrap; }
.module-nav a { display: inline-block; padding: 8px 16px; border-radius: 999px; font-size: 0.86rem; font-weight: 700; color: var(--muted); text-decoration: none; transition: background 0.15s, color 0.15s; }
.module-nav a.active { background: var(--surface-soft); color: var(--saffron-dark); }
.module-nav a:not(.active):hover { background: var(--surface-soft); }

.toolbar { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; padding: 24px 0 16px; }
.toolbar input[type="text"], .toolbar select {
  font-family: Arial, Helvetica, sans-serif; font-size: 0.88rem; padding: 9px 14px;
  border: 1.5px solid var(--border); border-radius: 10px; background: var(--surface); color: var(--text);
}
.toolbar input[type="text"] { flex: 1; min-width: 200px; }
.toolbar .count { margin-left: auto; font-size: 0.82rem; color: var(--muted); }
.btn-secondary {
  font-family: Arial, Helvetica, sans-serif; font-size: 0.86rem; font-weight: 700; color: var(--text);
  background: #fff; border: 1.5px solid var(--border); border-radius: 10px; padding: 9px 14px; cursor: pointer;
}

.table-wrap { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow-x: auto; box-shadow: var(--shadow); }
table { width: 100%; border-collapse: collapse; font-size: 0.84rem; }
thead th { text-align: left; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted); background: var(--surface-soft); padding: 10px 12px; border-bottom: 1px solid var(--border); white-space: nowrap; }
thead th.sortable { cursor: pointer; user-select: none; }
thead th.sortable:hover { color: var(--saffron-dark); }
thead th.sortable .sort-arrow { margin-left: 4px; opacity: 0.4; }
thead th.sortable.active .sort-arrow { opacity: 1; color: var(--saffron-dark); }
tbody td { padding: 10px 12px; border-bottom: 1px solid var(--border); vertical-align: top; }
tbody tr:last-child td { border-bottom: none; }
tbody tr:hover { background: rgba(217,138,30,0.04); }
.action-tag { display: inline-block; font-size: 0.72rem; font-weight: 700; padding: 3px 9px; border-radius: 999px; background: var(--surface-soft); color: var(--saffron-dark); white-space: nowrap; }
.actor-cell { font-size: 0.8rem; color: var(--muted); }
.details-cell { max-width: 340px; font-size: 0.78rem; color: var(--muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; cursor: help; }
.entity-cell { font-size: 0.78rem; color: var(--muted); }
.empty-state { text-align: center; padding: 60px 20px; color: var(--muted); }

.columns-panel {
  position: absolute; top: calc(100% + 6px); right: 0; background: var(--surface); border: 1px solid var(--border);
  border-radius: 12px; box-shadow: var(--shadow); padding: 12px; z-index: 30; min-width: 220px;
}
.columns-panel .columns-panel-note { font-size: 0.72rem; color: var(--muted); margin-bottom: 8px; }
.columns-panel label { display: flex; align-items: center; gap: 8px; font-size: 0.84rem; padding: 5px 4px; cursor: pointer; border-radius: 6px; }
.columns-panel label:hover { background: var(--surface-soft); }

.pagination-bar { display: flex; align-items: center; justify-content: center; gap: 10px; padding: 20px 0 50px; }
.pagination-bar button {
  font-family: Arial, Helvetica, sans-serif; font-size: 0.84rem; font-weight: 700; padding: 7px 14px;
  border-radius: 8px; border: 1.5px solid var(--border); background: #fff; color: var(--text); cursor: pointer;
}
.pagination-bar button:hover:not(:disabled) { background: var(--surface-soft); }
.pagination-bar button:disabled { opacity: 0.4; cursor: default; }
.pagination-bar .page-indicator { font-size: 0.84rem; color: var(--muted); }

#gate{padding:60px 16px;display:flex;justify-content:center;}
.gate-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:2.5rem 2rem;max-width:420px;width:100%;text-align:center;box-shadow:var(--shadow);}
.gate-card h3{font-family:Georgia,serif;font-size:1.3rem;color:var(--maroon);margin-bottom:.5rem;}
.gate-card p{color:var(--muted);font-size:.88rem;line-height:1.6;}
.gate-card a{color:var(--saffron-dark);}
</style>
</head>
<body>
<div id="site-header"></div>

<div id="gate">
  <div class="gate-card">
    <h3>Checking access&hellip;</h3>
    <p>Please sign in from the <a href="/admin/admin-portal">Admin Portal</a> first.</p>
  </div>
</div>

<div id="app">

<div class="page-hero">
  <div class="container">
    <a class="back-link" href="https://hccgc.org/admin/admin-portal">&larr; Back to apps</a>
    <h1>Change Log</h1>
    <p>Every change made across Facility Bookings — who did what, and when.</p>
  </div>
</div>

<div class="module-nav">
  <div class="container">
    <ul>
      <li><a href="new-booking">New Booking</a></li>
      <li><a href="all-bookings">All Bookings</a></li>
      <li><a href="rooms-rates">Rooms &amp; Rates</a></li>
      <li><a href="add-renter">Add A Renter</a></li>
      <li><a href="change-log" class="active">Change Log</a></li>
    </ul>
  </div>
</div>

<div class="container">
  <div class="toolbar">
    <input type="text" id="search-input" placeholder="Search by entity ID or details…">
    <select id="actor-filter"><option value="">All actors</option></select>
    <select id="action-filter"><option value="">All actions</option></select>
    <div style="position:relative;">
      <button type="button" class="btn-secondary" id="btn-columns">Columns</button>
      <div class="columns-panel" id="columns-panel" style="display:none;"></div>
    </div>
    <select id="page-size-filter">
      <option value="20">20 per page</option>
      <option value="50" selected>50 per page</option>
      <option value="100">100 per page</option>
    </select>
    <span class="count" id="result-count"></span>
  </div>

  <div class="table-wrap">
    <table>
      <thead><tr id="thead-row"></tr></thead>
      <tbody id="log-tbody"></tbody>
    </table>
    <div class="empty-state" id="empty-state" style="display:none;">No changes match your filters.</div>
  </div>
  <div class="pagination-bar" id="pagination-bar"></div>
</div>

</div>

<div id="site-footer"></div>

<script>
const API_BASE = 'https://facility-rental-api-217911937447.us-central1.run.app';

async function authedFetch(url, options) {
  options = options || {};
  var user = window.__hccgcFirebaseUser;
  if (!user) throw new Error('Not signed in.');
  var token = await user.getIdToken();
  options.headers = Object.assign({}, options.headers, { 'Authorization': 'Bearer ' + token });
  return fetch(url, options);
}

let LOG_ROWS = [];
let state = { search: '', actor: '', action: '', sortKey: 'created_at', sortDir: 'desc', pageSize: 50, page: 1 };

const COLUMN_DEFS = [
  { key: 'created_at', label: 'Timestamp', sortable: true },
  { key: 'actor_email', label: 'Actor', sortable: true },
  { key: 'action', label: 'Action', sortable: true },
  { key: 'entity_type', label: 'Entity Type', sortable: true },
  { key: 'entity_id', label: 'Entity ID', sortable: false },
  { key: 'details', label: 'Details', sortable: false }
];
const DEFAULT_VISIBLE_COLUMNS = ['created_at', 'actor_email', 'action', 'details'];
const MAX_VISIBLE_COLUMNS = 5;

function loadVisibleColumns() {
  try {
    const stored = JSON.parse(localStorage.getItem('hccgc-changelog-visible-columns'));
    if (Array.isArray(stored) && stored.length) return new Set(stored);
  } catch (err) { /* fall through to default */ }
  return new Set(DEFAULT_VISIBLE_COLUMNS);
}
let visibleColumns = loadVisibleColumns();
function saveVisibleColumns() {
  try { localStorage.setItem('hccgc-changelog-visible-columns', JSON.stringify(Array.from(visibleColumns))); } catch (err) {}
}

function escHtml(str) { return String(str || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;'); }

function formatDateTime(iso) {
  if (!iso) return '—';
  const d = new Date(iso);
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) + ', ' + d.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
}
function actionLabel(action) {
  return String(action || '').replace(/_/g, ' ').replace(/\b\w/g, function (c) { return c.toUpperCase(); });
}
function summarizeDetails(detailsStr) {
  if (!detailsStr) return '';
  try {
    const obj = JSON.parse(detailsStr);
    return Object.keys(obj).map(function (k) { return k + ': ' + obj[k]; }).join(', ');
  } catch (err) {
    return detailsStr;
  }
}

async function loadAuditLog() {
  const notice = document.getElementById('empty-state');
  try {
    const res = await authedFetch(API_BASE + '/audit-log');
    if (!res.ok) throw new Error('Server returned ' + res.status);
    LOG_ROWS = await res.json();
  } catch (err) {
    LOG_ROWS = [];
    notice.textContent = 'Could not load the change log (' + err.message + ').';
  }
  populateFilterOptions();
  render();
}

function populateFilterOptions() {
  const actors = Array.from(new Set(LOG_ROWS.map(function (r) { return r.actor_email; }).filter(Boolean))).sort();
  const actions = Array.from(new Set(LOG_ROWS.map(function (r) { return r.action; }).filter(Boolean))).sort();
  const actorSel = document.getElementById('actor-filter');
  const actionSel = document.getElementById('action-filter');
  actorSel.innerHTML = '<option value="">All actors</option>' + actors.map(function (a) { return '<option value="' + escHtml(a) + '">' + escHtml(a) + '</option>'; }).join('');
  actionSel.innerHTML = '<option value="">All actions</option>' + actions.map(function (a) { return '<option value="' + escHtml(a) + '">' + escHtml(actionLabel(a)) + '</option>'; }).join('');
}

function matchesFilters(r) {
  const q = state.search.trim().toLowerCase();
  if (q && !((r.entity_id || '').toLowerCase().includes(q) || (r.details || '').toLowerCase().includes(q))) return false;
  if (state.actor && r.actor_email !== state.actor) return false;
  if (state.action && r.action !== state.action) return false;
  return true;
}
function sortRows(list) {
  const key = state.sortKey, dir = state.sortDir === 'asc' ? 1 : -1;
  return list.slice().sort(function (a, b) {
    let av = a[key] || '', bv = b[key] || '';
    if (av < bv) return -1 * dir;
    if (av > bv) return 1 * dir;
    return 0;
  });
}

function renderTableHead() {
  const theadRow = document.getElementById('thead-row');
  let html = '';
  COLUMN_DEFS.forEach(function (col) {
    if (!visibleColumns.has(col.key)) return;
    html += col.sortable
      ? '<th class="sortable" data-sort="' + col.key + '">' + col.label + ' <span class="sort-arrow">&#8645;</span></th>'
      : '<th>' + col.label + '</th>';
  });
  theadRow.innerHTML = html;
  theadRow.querySelectorAll('th.sortable').forEach(function (th) {
    th.classList.toggle('active', th.dataset.sort === state.sortKey);
    th.querySelector('.sort-arrow').textContent = th.dataset.sort === state.sortKey ? (state.sortDir === 'asc' ? '↑' : '↓') : '⇅';
    th.addEventListener('click', function () {
      const key = th.dataset.sort;
      if (state.sortKey === key) { state.sortDir = state.sortDir === 'asc' ? 'desc' : 'asc'; } else { state.sortKey = key; state.sortDir = 'asc'; }
      render();
    });
  });
}

function getCellHtml(key, r) {
  switch (key) {
    case 'created_at': return '<td>' + formatDateTime(r.created_at) + '</td>';
    case 'actor_email': return '<td class="actor-cell">' + escHtml(r.actor_email) + '</td>';
    case 'action': return '<td><span class="action-tag">' + escHtml(actionLabel(r.action)) + '</span></td>';
    case 'entity_type': return '<td class="entity-cell">' + escHtml(r.entity_type) + '</td>';
    case 'entity_id': return '<td class="entity-cell">' + escHtml(r.entity_id) + '</td>';
    case 'details': {
      const summary = summarizeDetails(r.details);
      return '<td class="details-cell" title="' + escHtml(summary) + '">' + escHtml(summary || '—') + '</td>';
    }
    default: return '<td></td>';
  }
}

function renderColumnsPanel() {
  const panel = document.getElementById('columns-panel');
  const atCap = visibleColumns.size >= MAX_VISIBLE_COLUMNS;
  panel.innerHTML = '<div class="columns-panel-note">Up to ' + MAX_VISIBLE_COLUMNS + ' columns at a time, to keep this readable.</div>' +
    COLUMN_DEFS.map(function (col) {
      const checked = visibleColumns.has(col.key);
      const disable = !checked && atCap;
      return '<label><input type="checkbox" data-col="' + col.key + '" ' + (checked ? 'checked' : '') + (disable ? ' disabled' : '') + '><span>' + col.label + '</span></label>';
    }).join('');
  panel.querySelectorAll('input[type="checkbox"]').forEach(function (cb) {
    cb.addEventListener('change', function () {
      const key = cb.dataset.col;
      if (cb.checked) visibleColumns.add(key); else visibleColumns.delete(key);
      saveVisibleColumns();
      render();
      renderColumnsPanel();
    });
  });
}
document.getElementById('btn-columns').addEventListener('click', function (e) {
  e.stopPropagation();
  const panel = document.getElementById('columns-panel');
  const willOpen = panel.style.display === 'none';
  panel.style.display = willOpen ? 'block' : 'none';
  if (willOpen) renderColumnsPanel();
});
document.addEventListener('click', function (e) {
  const panel = document.getElementById('columns-panel');
  if (panel.style.display !== 'none' && !panel.contains(e.target) && e.target.id !== 'btn-columns') panel.style.display = 'none';
});

function renderPaginationBar(totalPages) {
  const bar = document.getElementById('pagination-bar');
  if (totalPages <= 1) { bar.innerHTML = ''; return; }
  bar.innerHTML =
    '<button ' + (state.page <= 1 ? 'disabled' : '') + ' onclick="goToPage(' + (state.page - 1) + ')">&lsaquo; Prev</button>' +
    '<span class="page-indicator">Page ' + state.page + ' of ' + totalPages + '</span>' +
    '<button ' + (state.page >= totalPages ? 'disabled' : '') + ' onclick="goToPage(' + (state.page + 1) + ')">Next &rsaquo;</button>';
}
function goToPage(p) {
  state.page = p;
  render();
  document.querySelector('.table-wrap').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function render() {
  const tbody = document.getElementById('log-tbody');
  const emptyState = document.getElementById('empty-state');
  const filtered = sortRows(LOG_ROWS.filter(matchesFilters));

  const totalPages = Math.max(1, Math.ceil(filtered.length / state.pageSize));
  if (state.page > totalPages) state.page = totalPages;
  if (state.page < 1) state.page = 1;
  const pageStart = (state.page - 1) * state.pageSize;
  const pageItems = filtered.slice(pageStart, pageStart + state.pageSize);

  document.getElementById('result-count').textContent = filtered.length + (filtered.length === 1 ? ' entry' : ' entries');
  renderTableHead();
  renderPaginationBar(totalPages);

  if (pageItems.length === 0) {
    tbody.innerHTML = '';
    emptyState.style.display = 'block';
    return;
  }
  emptyState.style.display = 'none';
  tbody.innerHTML = pageItems.map(function (r) {
    return '<tr>' + COLUMN_DEFS.filter(function (c) { return visibleColumns.has(c.key); }).map(function (c) { return getCellHtml(c.key, r); }).join('') + '</tr>';
  }).join('');
}

document.getElementById('search-input').addEventListener('input', function (e) { state.search = e.target.value; state.page = 1; render(); });
document.getElementById('actor-filter').addEventListener('change', function (e) { state.actor = e.target.value; state.page = 1; render(); });
document.getElementById('action-filter').addEventListener('change', function (e) { state.action = e.target.value; state.page = 1; render(); });
document.getElementById('page-size-filter').addEventListener('change', function (e) { state.pageSize = Number(e.target.value); state.page = 1; render(); });

function loadPartial(id, file) {
  var target = document.getElementById(id);
  if (!target) return;
  fetch(file).then(function (r) { return r.text(); }).then(function (html) {
    target.innerHTML = html;
    if (id === 'site-header') fixHeaderLinksForSubfolder(target);
  }).catch(function () {});
}
function fixHeaderLinksForSubfolder(headerEl) {
  var logo = headerEl.querySelector('.brand-logo');
  if (logo && logo.getAttribute('src') && !logo.getAttribute('src').startsWith('/') && !logo.getAttribute('src').startsWith('http')) {
    logo.setAttribute('src', '/' + logo.getAttribute('src'));
  }
  headerEl.querySelectorAll('a[href]').forEach(function (link) {
    var href = link.getAttribute('href');
    if (!href || href.startsWith('http') || href.startsWith('/') || href.startsWith('#')) return;
    link.setAttribute('href', '/' + href);
  });
}
loadPartial('site-header', '/header.html');
loadPartial('site-footer', '/footer.html');
</script>

<script type="module">
import { initializeApp } from 'https://www.gstatic.com/firebasejs/12.15.0/firebase-app.js';
import { getAuth, onAuthStateChanged } from 'https://www.gstatic.com/firebasejs/12.15.0/firebase-auth.js';
import { getFirestore, doc, getDoc } from 'https://www.gstatic.com/firebasejs/12.15.0/firebase-firestore.js';

var firebaseConfig = {
  apiKey: 'AIzaSyA6IzLjWTg7Rq04HsTH-iA3eDmSzKI7xME',
  authDomain: 'hccgc-a7a54.firebaseapp.com',
  projectId: 'hccgc-a7a54',
  storageBucket: 'hccgc-a7a54.firebasestorage.app',
  messagingSenderId: '75757201418',
  appId: '1:75757201418:web:c31e9361921242145717f3'
};

var ALLOWED_DOMAIN = 'hccgc.org';
var REQUIRED_APP_KEY = 'bookings-finance';
var PORTAL_URL = '/admin/admin-portal';

var fbApp = initializeApp(firebaseConfig);
var auth = getAuth(fbApp);
var db = getFirestore(fbApp);

function showGate(title, msg) {
  document.getElementById('gate').querySelector('h3').textContent = title;
  document.getElementById('gate').querySelector('p').innerHTML = msg;
  document.getElementById('gate').style.display = 'flex';
  document.getElementById('app').style.display = 'none';
}

onAuthStateChanged(auth, function(user) {
  if (!user) { showGate('Sign in required', 'Please sign in from the <a href="'+PORTAL_URL+'">Admin Portal</a> first.'); return; }
  var email = (user.email||'').toLowerCase();
  window.__hccgcCurrentUser = { email: email };
  window.__hccgcFirebaseUser = user;
  if (!email.endsWith('@'+ALLOWED_DOMAIN)) { showGate('Access denied', 'Please use an @'+ALLOWED_DOMAIN+' account.'); return; }
  getDoc(doc(db, 'portalUsers', email)).then(function(snap) {
    var data = snap.exists() ? snap.data() : {};
    if (!data.isAdmin && !(Array.isArray(data.allowedApps) && data.allowedApps.includes(REQUIRED_APP_KEY))) {
      showGate('Access not granted', "You don't have access to Facility Bookings. Ask an admin to grant it.");
      return;
    }
    document.getElementById('gate').style.display = 'none';
    document.getElementById('app').style.display = 'block';
    loadAuditLog();
  }).catch(function() { showGate('Error', 'Could not verify access. Please try again.'); });
});
</script>

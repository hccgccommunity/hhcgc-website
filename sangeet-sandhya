
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sangeet Sandhya | Hindu Community Center of Greater Cincinnati</title>
  <meta name="description" content="Sangeet Sandhya — a free bi-weekly karaoke night celebrating Indian languages and music. Join us as an audience member or a singer." />

  <link rel="icon" type="image/x-icon" href="favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="apple-touch-icon.png">
  <link rel="icon" type="image/svg+xml"
        href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='0.9em' x='50%25' text-anchor='middle' font-size='82'%3E%E0%A5%90%3C/text%3E%3C/svg%3E">

  <style>
    :root {
      --bg: #fff9f1;
      --surface: #ffffff;
      --surface-soft: #fff6ea;
      --border: rgba(121, 62, 17, 0.14);
      --text: #2c1b10;
      --muted: #6a5141;
      --saffron: #b55a18;
      --saffron-dark: #8d3e0d;
      --maroon: #7f2e16;
      --shadow: 0 18px 45px rgba(93, 43, 14, 0.10);
      --radius: 22px;
      --max: 1220px;
      --header-offset: 110px;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top left, rgba(217, 138, 30, 0.12), transparent 22%),
        radial-gradient(circle at top right, rgba(127, 46, 22, 0.05), transparent 20%),
        var(--bg);
      line-height: 1.65;
    }

    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }
    button, input, select, textarea { font: inherit; }

    .container {
      width: min(calc(100% - 32px), var(--max));
      margin: 0 auto;
    }

    .content-width { width: 100%; max-width: 100%; }

    /* ── HEADER ── */
    .site-header {
      position: sticky; top: 0; z-index: 50;
      background: rgba(255, 249, 241, 0.92);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
    }

    .nav {
      display: flex; align-items: center;
      justify-content: space-between;
      gap: 24px; min-height: 92px; padding: 12px 0;
    }

    .brand { display: flex; align-items: center; gap: 16px; min-width: 0; }

    .brand-logo-wrap {
      background: #fff; border: 1px solid var(--border);
      border-radius: 18px; padding: 8px;
      box-shadow: var(--shadow); flex-shrink: 0;
    }

    .brand-logo { width: 88px; height: auto; border-radius: 12px; object-fit: contain; }

    .brand-text h1 { margin: 0; font-size: 1.2rem; line-height: 1.15; color: var(--maroon); }

    .site-header nav ul {
      list-style: none; display: flex; flex-wrap: wrap;
      gap: 18px; margin: 0; padding: 0;
      align-items: center; justify-content: flex-end;
    }

    .site-header nav a { font-weight: 700; color: var(--text); font-size: 0.96rem; }
    .site-header nav a:hover { color: var(--saffron-dark); }

    /* ── FOOTER ── */
    .site-footer .footer-top {
      display: grid; grid-template-columns: 1fr auto 1fr;
      align-items: center; gap: 24px; padding: 8px 0 0;
    }

    .site-footer .footer-nav { display: flex; justify-content: flex-start; min-width: 0; }

    .site-footer .footer-nav ul {
      list-style: none; display: flex; flex-wrap: wrap;
      gap: 10px; margin: 0; padding: 0; align-items: center;
    }

    .site-footer .footer-nav a { font-weight: 700; color: var(--text); font-size: 0.95rem; }
    .site-footer .footer-nav a:hover { color: var(--saffron-dark); }

    .site-footer .footer-email { text-align: center; font-weight: 700; color: var(--text); white-space: nowrap; }
    .site-footer .footer-email a:hover { color: var(--saffron-dark); }

    .site-footer .footer-social {
      display: flex; align-items: center; justify-content: flex-end;
      gap: 12px; min-width: 220px; color: var(--text); font-weight: 700;
    }

    .site-footer .footer-social-label { white-space: nowrap; }
    .site-footer .social-icons { display: flex; align-items: center; gap: 10px; }

    .site-footer .social-icon {
      width: 42px; height: 42px; display: inline-flex;
      align-items: center; justify-content: center;
      border-radius: 50%; background: #fff;
      border: 1px solid var(--border);
      box-shadow: 0 6px 18px rgba(93, 43, 14, 0.10);
      transition: transform 0.18s ease, box-shadow 0.18s ease;
    }

    .site-footer .social-icon:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 22px rgba(93, 43, 14, 0.16);
    }

    .site-footer .social-icon svg { width: 20px; height: 20px; display: block; }

    .site-footer .footer-note {
      margin-top: 18px; padding-top: 18px;
      border-top: 1px solid var(--border);
      color: var(--muted); font-size: 0.7rem; text-align: center;
    }

    .site-footer .copyright-links a { text-decoration: none; }

    /* ── SHARED ── */
    .section { padding: 42px 0; scroll-margin-top: var(--header-offset); }

    .section-head { margin-bottom: 18px; text-align: center; }

    .section-kicker {
      display: inline-block; padding: 7px 14px; border-radius: 999px;
      background: rgba(217, 138, 30, 0.12); color: var(--saffron-dark);
      font-size: 0.83rem; font-weight: 800; text-transform: uppercase;
      letter-spacing: 0.05em; margin-bottom: 8px;
    }

    .section-head h2 {
      margin: 8px 0 10px; line-height: 1.2; color: var(--maroon);
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(2rem, 3.4vw, 3rem);
    }

    .section-copy {
      margin: 0 auto; color: var(--muted);
      font-size: 1rem; max-width: 760px; text-align: center;
    }

    /* ── HERO ── */
    .hero-grid {
      display: grid; grid-template-columns: 1.08fr 0.92fr;
      gap: 26px; align-items: stretch; margin-top: 4px;
    }

    .hero-panel, .details-panel {
      min-height: 340px; border-radius: 26px;
      background: rgba(255, 255, 255, 0.74);
      border: 1px solid var(--border);
      box-shadow: var(--shadow); padding: 34px;
      display: flex; flex-direction: column; justify-content: center;
    }

    .hero-panel h1 {
      margin: 0 0 10px; color: var(--maroon);
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(2.8rem, 6vw, 5rem);
      line-height: 0.98; letter-spacing: -0.035em;
    }

    .hero-subtitle {
      margin: 0 0 16px; color: var(--saffron-dark);
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(1.1rem, 2vw, 1.5rem); font-weight: 700;
    }

    .hero-copy { margin: 0 0 24px; color: var(--muted); font-size: 1.05rem; }

    .cta-row { display: flex; gap: 14px; flex-wrap: wrap; }

    .btn {
      display: inline-flex; align-items: center; justify-content: center;
      min-height: 46px; padding: 11px 22px; border-radius: 999px;
      border: 1px solid transparent; font-weight: 800; text-decoration: none;
      cursor: pointer;
    }

    .btn.primary {
      background: linear-gradient(135deg, var(--saffron-dark), var(--saffron));
      color: #fff; box-shadow: 0 10px 24px rgba(127, 46, 22, 0.14);
    }

    .btn.secondary {
      background: rgba(255, 255, 255, 0.7);
      border-color: var(--border); color: var(--maroon);
    }

    /* ── DETAILS PANEL ── */
    .details-panel h2 {
      margin: 0 0 16px; color: var(--maroon);
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(1.5rem, 2.5vw, 2rem);
    }

    .details-grid { display: grid; gap: 12px; }

    .detail-item {
      padding: 14px 16px; border-radius: 18px;
      background: linear-gradient(135deg, rgba(255,246,234,0.92), rgba(255,255,255,0.86));
      border: 1px solid rgba(121, 62, 17, 0.12);
    }

    .detail-label {
      display: block; margin-bottom: 2px; color: var(--saffron-dark);
      font-size: 0.76rem; font-weight: 900;
      text-transform: uppercase; letter-spacing: 0.08em;
    }

    .detail-value { display: block; color: var(--text); font-weight: 800; font-size: 1.05rem; }

    /* ── LANGUAGES STRIP ── */
    .languages-strip {
      display: flex; flex-wrap: wrap; gap: 12px;
      justify-content: center; margin-top: 28px;
    }

    .lang-pill {
      padding: 10px 22px; border-radius: 999px;
      background: rgba(255, 255, 255, 0.74);
      border: 1px solid var(--border);
      box-shadow: 0 4px 14px rgba(93, 43, 14, 0.07);
      font-weight: 800; color: var(--maroon);
      font-size: 0.95rem;
      transition: transform 0.18s, box-shadow 0.18s;
    }

    .lang-pill:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(93,43,14,0.13); }

    .lang-pill .lang-script {
      display: block; font-size: 1rem;
      color: var(--saffron); text-align: center;
      margin-bottom: 2px; font-weight: 700;
    }

    /* ── HOW IT WORKS ── */
    .how-grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 20px; margin-top: 28px;
    }

    .how-card {
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.74);
      border: 1px solid var(--border);
      padding: 28px 24px;
      box-shadow: 0 12px 30px rgba(93, 43, 14, 0.07);
      position: relative;
    }

    .how-number {
      display: inline-flex; align-items: center; justify-content: center;
      width: 36px; height: 36px; border-radius: 50%;
      background: linear-gradient(135deg, var(--saffron-dark), var(--saffron));
      color: #fff; font-weight: 900; font-size: 1rem;
      margin-bottom: 14px;
    }

    .how-card h3 {
      margin: 0 0 8px; color: var(--maroon);
      font-family: Georgia, "Times New Roman", serif; font-size: 1.2rem;
    }

    .how-card p { margin: 0; color: var(--muted); font-size: 0.93rem; line-height: 1.65; }

    .how-card a { color: var(--saffron-dark); font-weight: 700; text-decoration: underline; }

    /* ── INFO BOXES ── */
    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; }

    .info-box {
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.74);
      border: 1px solid var(--border);
      padding: 28px 24px;
      box-shadow: 0 12px 30px rgba(93, 43, 14, 0.07);
    }

    .info-box h3 {
      margin: 0 0 12px; color: var(--maroon);
      font-family: Georgia, "Times New Roman", serif; font-size: 1.25rem;
    }

    .info-box ul { margin: 0 0 0 18px; padding: 0; }
    .info-box li { color: var(--muted); margin-bottom: 8px; font-size: 0.93rem; }
    .info-box li a { color: var(--saffron-dark); font-weight: 700; text-decoration: underline; }
    .info-box li a:hover { color: var(--maroon); }

    /* ── NOTICE BOX ── */
    .notice-box {
      padding: 18px 22px; border-radius: 16px;
      background: rgba(255, 246, 234, 0.9);
      border: 1px solid rgba(121, 62, 17, 0.18);
      border-left: 4px solid var(--saffron);
      max-width: 980px; margin: 0 auto 28px;
    }

    .notice-box h4 {
      margin: 0 0 6px; color: var(--maroon);
      font-family: Georgia, "Times New Roman", serif; font-size: 1.05rem;
    }

    .notice-box p { margin: 0; color: var(--muted); font-size: 0.92rem; line-height: 1.65; }
    .notice-box a { color: var(--saffron-dark); font-weight: 700; text-decoration: underline; }
    .notice-box a:hover { color: var(--maroon); }

    /* ── FORM EMBED ── */
    .embed-card {
      overflow: hidden; background: transparent;
      border-radius: var(--radius); box-shadow: none;
      border: 0; max-width: 980px; margin: 0 auto;
    }

    .embed-frame {
      position: relative; overflow: hidden;
      height: 1475px; width: 100%; background: transparent;
    }

    .embed-frame iframe {
      position: absolute; top: 0; left: 0;
      width: 100%; height: 100%;
      border: 0; background: transparent; display: block;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 1120px) {
      .site-footer .footer-top { grid-template-columns: 1fr; justify-items: start; }
      .site-footer .footer-email,
      .site-footer .footer-social { text-align: left; justify-content: flex-start; }
    }

    @media (max-width: 900px) {
      .hero-grid { grid-template-columns: 1fr; }
      .hero-panel, .details-panel { min-height: auto; padding: 26px; }
      .how-grid { grid-template-columns: 1fr 1fr; }
      .two-col { grid-template-columns: 1fr; }
    }

    @media (max-width: 860px) {
      .nav { flex-direction: column; align-items: flex-start; }
      .site-header nav ul { justify-content: flex-start; gap: 14px; }
      .brand-logo { width: 74px; }
      .section { padding: 34px 0; }
      .embed-frame { height: 1560px; }
    }

    @media (max-width: 640px) {
      .container { width: min(calc(100% - 24px), var(--max)); }
      .hero-panel, .details-panel { padding: 22px; border-radius: 22px; }
      .how-grid { grid-template-columns: 1fr; }
      .embed-frame { height: 1640px; }
    }
  </style>
</head>
<body>

  <div id="header-placeholder"></div>

  <main>

    <!-- HERO -->
    <section class="section">
      <div class="container">
        <div class="hero-grid">

          <div class="hero-panel">
            <h1>Sangeet Sandhya</h1>
            <p class="hero-subtitle">A Bi-Weekly Karaoke Night — Free for All</p>
            <p class="hero-copy">Celebrate the joy of Indian music together — Hindi, Marathi, Telugu, Kannada, and Tamil. Every session is dedicated to one language with a unique theme. Sing your heart out or simply enjoy the music. Everyone is welcome.</p>
            <div class="cta-row">
              <a class="btn secondary" href="#how-it-works">How It Works</a>
              <a class="btn primary" href="#rsvp">RSVP for Next Session</a>
            </div>
          </div>

          <aside class="details-panel" aria-label="Event details">
            <h2>At a Glance</h2>
            <div class="details-grid">
              <div class="detail-item">
                <span class="detail-label">Frequency</span>
                <span class="detail-value">Bi-Weekly</span>
              </div>
              <div class="detail-item">
                <span class="detail-label">Duration</span>
                <span class="detail-value">2 – 2.5 Hours</span>
              </div>
              <div class="detail-item">
                <span class="detail-label">Admission</span>
                <span class="detail-value">Free — Open to All</span>
              </div>
              <div class="detail-item">
                <span class="detail-label">Kid Friendly</span>
                <span class="detail-value">Yes, All Ages Welcome</span>
              </div>
            </div>
          </aside>

        </div>
      </div>
    </section>

    <!-- LANGUAGES -->
    <section class="section" style="padding-top:0;">
      <div class="container">
        <div class="section-head content-width">
          <span class="section-kicker">Languages</span>
          <h2>One Language, One Session</h2>
          <p class="section-copy">Each Sangeet Sandhya is dedicated to a single Indian language, paired with a unique theme — making every session a fresh experience.</p>
        </div>
        <div class="languages-strip">
          <div class="lang-pill"><span class="lang-script">हिंदी</span>Hindi</div>
          <div class="lang-pill"><span class="lang-script">मराठी</span>Marathi</div>
          <div class="lang-pill"><span class="lang-script">తెలుగు</span>Telugu</div>
          <div class="lang-pill"><span class="lang-script">ಕನ್ನಡ</span>Kannada</div>
          <div class="lang-pill"><span class="lang-script">தமிழ்</span>Tamil</div>
        </div>
        <p class="section-copy" style="margin-top:22px;font-size:0.93rem;">
          Want to celebrate your language? If you'd like us to introduce a session in another Indian language, 
          we'd love to hear from you — reach out at <a href="mailto:hccgccommunity@gmail.com" style="color:var(--saffron-dark);font-weight:700;text-decoration:underline;">hccgccommunity@gmail.com</a>.
        </p>
      </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="section" id="how-it-works">
      <div class="container">
        <div class="section-head content-width">
          <span class="section-kicker">How It Works</span>
          <h2>Simple to Join, Memorable to Experience</h2>
          <p class="section-copy">Whether you're here to sing or to enjoy — the process is easy. Just fill out the RSVP form and we'll take care of the rest.</p>
        </div>

        <div class="how-grid">
          <div class="how-card">
            <div class="how-number">1</div>
            <h3>RSVP as Audience or Singer</h3>
            <p>Fill out the RSVP form below and let us know how you'd like to participate — as an audience member or as a singer for the session.</p>
          </div>
          <div class="how-card">
            <div class="how-number">2</div>
            <h3>Singers Get a Song List Link</h3>
            <p>If you RSVP as a singer, you'll receive an automated email with a link to enter your chosen song and its karaoke track — so you're all set before the event.</p>
          </div>
          <div class="how-card">
            <div class="how-number">3</div>
            <h3>Show Up &amp; Enjoy</h3>
            <p>Arrive, meet fellow community members, make new connections, and enjoy 2–2.5 hours of great music. A fun, welcoming evening for the whole family.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- GOOD TO KNOW -->
    <section class="section" style="padding-top:0;">
      <div class="container">
        <div class="section-head content-width">
          <span class="section-kicker">Good to Know</span>
          <h2>Before You Come</h2>
        </div>
        <div class="two-col">
          <div class="info-box">
            <h3>Participation Guidelines</h3>
            <ul>
              <li>This is a free, community event — no tickets needed</li>
              <li>Singers are expected to have their own karaoke track ready</li>
              <li>By participating, all attendees agree to our <a href="https://hccgc.org/sangeet-sandhya-terms-conditions" target="_blank" rel="noopener">Terms &amp; Conditions</a></li>
              <li>Kid-friendly environment — all ages are welcome</li>
              <li>Out of respect for fellow attendees, please arrive on time</li>
            </ul>
          </div>
          <div class="info-box">
            <h3>Questions &amp; Community</h3>
            <ul>
              <li>For any questions, reach out at <a href="mailto:hccgccommunity@gmail.com">hccgccommunity@gmail.com</a></li>
              <li>Stay updated on session themes, dates, and announcements via the <strong>HCCGC Sangeet Sandhya</strong> group in our WhatsApp community</li>
              <li>Sessions rotate across five Indian languages — check the RSVP form below for the next session's language and theme</li>
              <li>Each session is a fresh experience with a unique theme — no two evenings are alike</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- RSVP FORM -->
    <section class="section" id="rsvp">
      <div class="container">
        <div class="section-head content-width">
          <span class="section-kicker">RSVP</span>
          <h2>RSVP for the Next Sangeet Sandhya</h2>
          <p class="section-copy">The form below has details about the upcoming session — date, language, and theme. Fill it out to reserve your spot as an audience member or a singer.</p>
        </div>

        <div class="notice-box">
          <h4>📝 Note for Singers</h4>
          <p>Once you submit your RSVP as a singer, you will receive an automated email with a link to enter your song and karaoke track. Please check your inbox (and spam folder) after submitting. For any issues, email us at <a href="mailto:hccgccommunity@gmail.com">hccgccommunity@gmail.com</a>.</p>
        </div>

        <div class="embed-card">
          <div class="embed-frame">
            <iframe
              src="https://docs.google.com/forms/d/e/1FAIpQLScBeR6GOwn_1zNV4YiKDJ682iHroWcIAORgP-CrqJRJFdS3Qw/viewform?embedded=true"
              width="640"
              height="100%"
              frameborder="0"
              marginheight="0"
              marginwidth="0">Loading…
            </iframe>
          </div>
        </div>
      </div>
    </section>

  </main>

  <div id="footer-placeholder"></div>

  <script>
    async function loadPartial(placeholderId, filePath) {
      const target = document.getElementById(placeholderId);
      if (!target) return;
      try {
        const response = await fetch(filePath);
        if (!response.ok) throw new Error("Unable to load " + filePath);
        target.innerHTML = await response.text();
      } catch (error) {
        console.error(error);
        target.innerHTML = "";
      }
    }

    async function initializePage() {
      await loadPartial("header-placeholder", "header.html");
      await loadPartial("footer-placeholder", "footer.html");
      const year = document.getElementById("year");
      if (year) year.textContent = new Date().getFullYear();
    }

    initializePage();
  </script>

</body>
</html>

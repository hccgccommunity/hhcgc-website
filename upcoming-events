    <style>
        :root {
            --bg: #fff9f1;
            --surface: #ffffff;
            --surface-soft: #fff6ea;
            --border: rgba(121, 62, 17, 0.14);
            --text: #2c1b10;
            --muted: #6a5141;
            --saffron: #b55a18;
            --saffron-dark: #8d3e0d;
            --maroon: #7f2e16;
            --shadow: 0 18px 45px rgba(93, 43, 14, 0.10);
            --radius: 22px;
            --max: 1220px;
            --header-offset: 110px;
        }

        * { box-sizing: border-box; }
        html { scroll-behavior: smooth; }

        body {
            margin: 0;
            font-family: Arial, Helvetica, sans-serif;
            color: var(--text);
            background:
                radial-gradient(circle at top left, rgba(217, 138, 30, 0.12), transparent 22%),
                radial-gradient(circle at top right, rgba(127, 46, 22, 0.05), transparent 20%),
                var(--bg);
            line-height: 1.65;
        }

        img { max-width: 100%; display: block; }
        a { color: inherit; text-decoration: none; }
        button, input, select, textarea { font: inherit; }

        .container {
            width: min(calc(100% - 32px), var(--max));
            margin: 0 auto;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            border: none;
            cursor: pointer;
            padding: 13px 20px;
            border-radius: 999px;
            font-weight: 700;
            transition: transform 0.18s ease, box-shadow 0.18s ease;
            white-space: nowrap;
        }

        .btn:hover { transform: translateY(-1px); }

        .btn-primary {
            background: linear-gradient(135deg, var(--saffron), #d17621);
            color: #fff;
            box-shadow: 0 10px 24px rgba(181, 90, 24, 0.20);
        }

        .btn-outline {
            background: #fff;
            color: var(--saffron-dark);
            border: 1px solid rgba(181, 90, 24, 0.18);
        }

        /* Page hero */
        .page-hero {
            padding: 56px 0 36px;
            text-align: center;
        }

        .section-kicker {
            display: inline-block;
            padding: 7px 14px;
            border-radius: 999px;
            background: rgba(217, 138, 30, 0.12);
            color: var(--saffron-dark);
            font-size: 0.83rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 10px;
        }

        .page-hero h1 {
            margin: 8px 0 14px;
            line-height: 1.15;
            color: var(--maroon);
            font-family: Georgia, "Times New Roman", serif;
            font-size: clamp(2rem, 3.6vw, 3rem);
        }

        .page-hero p {
            margin: 0 auto;
            max-width: 620px;
            color: var(--muted);
            font-size: 1.05rem;
        }

        /* Events grid */
        .section { padding: 24px 0 64px; }

        .events-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 22px;
            margin-top: 8px;
        }

        .event-card {
            background: rgba(255, 255, 255, 0.55);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border: 1px solid rgba(255, 255, 255, 0.5);
            border-radius: var(--radius);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.10), inset 0 1px 1px rgba(255, 255, 255, 0.4);
            padding: 26px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            transition: transform 0.18s ease, box-shadow 0.18s ease;
        }

        .event-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 14px 36px rgba(93, 43, 14, 0.16);
        }

        .event-date-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            align-self: flex-start;
            background: linear-gradient(135deg, var(--maroon), #5a1e0a);
            color: #fff;
            padding: 7px 14px;
            border-radius: 999px;
            font-size: 0.82rem;
            font-weight: 700;
            letter-spacing: 0.02em;
        }

        .event-badges {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            align-items: center;
        }

        .event-category-badge {
            display: inline-block;
            background: rgba(217, 138, 30, 0.14);
            color: var(--saffron-dark);
            padding: 5px 12px;
            border-radius: 999px;
            font-size: 0.76rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        .event-cost-badge {
            display: inline-block;
            background: var(--surface-soft);
            color: var(--maroon);
            border: 1px solid var(--border);
            padding: 5px 12px;
            border-radius: 999px;
            font-size: 0.78rem;
            font-weight: 700;
        }

        .event-card h3 {
            margin: 0;
            color: var(--maroon);
            font-family: Georgia, "Times New Roman", serif;
            font-size: 1.3rem;
            line-height: 1.3;
        }

        .event-meta {
            display: flex;
            flex-wrap: wrap;
            gap: 14px;
            font-size: 0.88rem;
            color: var(--saffron-dark);
            font-weight: 700;
        }

        .event-meta span {
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .event-meta svg { width: 15px; height: 15px; flex-shrink: 0; }

        .event-desc {
            margin: 0;
            color: var(--muted);
            font-size: 0.95rem;
            line-height: 1.6;
            flex-grow: 1;
        }

        .event-card .btn {
            align-self: flex-start;
            margin-top: 4px;
            padding: 10px 22px;
            font-size: 0.9rem;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: var(--muted);
        }

        .empty-state svg {
            width: 56px;
            height: 56px;
            margin: 0 auto 14px;
            color: var(--saffron-dark);
            opacity: 0.5;
        }

        .loading-state {
            text-align: center;
            padding: 60px 20px;
            color: var(--muted);
            font-size: 0.95rem;
        }

        .spinner {
            width: 22px;
            height: 22px;
            border: 3px solid rgba(141, 62, 13, 0.18);
            border-top-color: var(--saffron-dark);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
            margin: 0 auto 14px;
        }

        @keyframes spin { to { transform: rotate(360deg); } }

        @media (max-width: 640px) {
            .events-grid { grid-template-columns: 1fr; }
            .page-hero { padding: 40px 0 28px; }
        }
        /* Header partial styling — required by header.html's markup.
           Copied to match the rest of the site (see khel-sandhya.html etc.)

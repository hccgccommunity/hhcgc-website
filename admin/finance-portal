// ── Expense Approvals ──
let EXPENSE_SUBMISSIONS = [];
let currentReviewSubmission = null;
let currentReviewLineItemId = null;

document.getElementById('btn-load-expenses').addEventListener('click', loadExpenseSubmissions);
document.getElementById('exp-status-filter').addEventListener('change', loadExpenseSubmissions);

async function loadExpenseSubmissions() {
  const status = document.getElementById('exp-status-filter').value;
  const list = document.getElementById('expenses-submission-list');
  list.innerHTML = '<div class="empty-state">Loading…</div>';
  try {
    const res = await authedFetch(API_BASE + '/finance/expense-submissions' + (status ? '?status=' + status : ''));
    EXPENSE_SUBMISSIONS = await res.json();
    if (!EXPENSE_SUBMISSIONS.length) { list.innerHTML = '<div class="empty-state">Nothing here.</div>'; return; }
    list.innerHTML = EXPENSE_SUBMISSIONS.map(function (s) {
      const total = s.items.reduce(function (sum, i) { return sum + i.amount; }, 0);
      return '<div class="exp-submission-card">' +
        '<div class="exp-sub-info"><strong>' + escHtml(s.firstName) + ' ' + escHtml(s.lastName) + '</strong> — ' + s.items.length + ' expense(s)<br>' +
        '<span style="color:var(--muted);font-size:0.82rem;">' + escHtml(s.email) + ' · Zelle: ' + escHtml(s.zelleId || '—') + '</span></div>' +
        '<div style="display:flex;align-items:center;gap:16px;"><span class="exp-sub-total">' + money(total) + '</span>' +
        '<button type="button" class="btn-secondary" data-review-submission="' + s.submissionId + '">Review</button></div>' +
      '</div>';
    }).join('');
  } catch (err) {
    list.innerHTML = '<div class="empty-state">Could not load: ' + escHtml(err.message) + '</div>';
  }
}
document.getElementById('expenses-submission-list').addEventListener('click', function (e) {
  const btn = e.target.closest('[data-review-submission]');
  if (!btn) return;
  openExpenseReview(btn.dataset.reviewSubmission);
});

function openExpenseReview(submissionId) {
  console.log('[openExpenseReview] called with', submissionId);
  try {
    const s = EXPENSE_SUBMISSIONS.find(function (x) { return x.submissionId === submissionId; });
    if (!s) { alert('Could not find that submission (id: ' + submissionId + '). Try Refresh and try again.'); return; }
    currentReviewSubmission = s;
    document.getElementById('exp-review-title').textContent = 'Review — ' + s.firstName + ' ' + s.lastName;
    document.getElementById('exp-review-result').style.display = 'none';
    document.getElementById('exp-review-receipt').innerHTML = '<span style="color:var(--muted);font-size:0.86rem;">Click an expense to view its receipt</span>';
    const canAct = s.items.some(function (i) { return i.status === 'submitted'; });
    document.getElementById('btn-approve-expense').style.display = canAct ? 'inline-block' : 'none';
    document.getElementById('btn-reject-expense').style.display = canAct ? 'inline-block' : 'none';
    document.getElementById('expense-review-overlay').style.display = 'flex';
    try {
      renderExpenseReviewDetails();
    } catch (err) {
      document.getElementById('exp-review-details').innerHTML = '<div class="empty-state">Could not render details: ' + escHtml(err.message) + '</div>';
    }
    if (s.items.length) selectExpenseLineItem(s.items[0].line_item_id);
  } catch (err) {
    alert('openExpenseReview failed: ' + err.message);
    console.error('[openExpenseReview] error:', err);
  }
}
function closeExpenseReview() { document.getElementById('expense-review-overlay').style.display = 'none'; }
document.getElementById('btn-close-expense-review').addEventListener('click', closeExpenseReview);
document.getElementById('expense-review-overlay').addEventListener('click', function (e) { if (e.target === this) closeExpenseReview(); });

function renderExpenseReviewDetails() {
  const s = currentReviewSubmission;
  const total = s.items.reduce(function (sum, i) { return sum + i.amount; }, 0);
  let html = '<div style="margin-bottom:14px;font-size:0.88rem;"><strong>' + escHtml(s.email) + '</strong><br>Zelle ID: <strong>' + escHtml(s.zelleId || '—') + '</strong><br>Total: <strong>' + money(total) + '</strong></div>';
  const pendingCount = s.items.filter(function (i) { return i.status === 'submitted'; }).length;
  if (pendingCount > 1) {
    html += '<div style="font-size:0.8rem;color:var(--muted);margin-bottom:10px;">Uncheck any expense you don\'t want to include in this action — Approve/Reject only apply to the checked ones.</div>';
  }
  html += s.items.map(function (i) {
    const catOptions = '<option value="">Choose category…</option>' + CATEGORIES.filter(function (c) { return c.type === 'expense' && c.active; }).map(function (c) {
      return '<option value="' + c.category_id + '"' + (c.category_id === i.category_id ? ' selected' : '') + '>' + escHtml(c.name) + '</option>';
    }).join('');
    const checkbox = i.status === 'submitted'
      ? '<input type="checkbox" class="exp-item-select" data-select-checkbox="' + i.line_item_id + '" checked style="margin-right:10px;width:16px;height:16px;flex-shrink:0;">'
      : '';
    return '<div class="exp-line-item' + (i.line_item_id === currentReviewLineItemId ? ' active' : '') + '" data-line-id="' + i.line_item_id + '" data-select-line="' + i.line_item_id + '" style="display:flex;align-items:flex-start;">' +
      checkbox +
      '<div style="flex:1;">' +
        '<div class="exp-top-row"><span>' + escHtml(i.expense_for) + '</span><span>' + money(i.amount) + '</span></div>' +
        '<div class="exp-date">' + formatDate(i.expense_date) + ' · <span class="source-tag">' + i.status + '</span></div>' +
        (i.status === 'submitted' ? '<select class="cat-select' + (i.category_id ? '' : ' uncategorized') + '" data-set-expense-category="' + i.line_item_id + '">' + catOptions + '</select>' : '') +
      '</div>' +
    '</div>';
  }).join('');
  document.getElementById('exp-review-details').innerHTML = html;
}
function getSelectedPendingLineItemIds() {
  return Array.from(document.querySelectorAll('.exp-item-select:checked')).map(function (cb) { return cb.dataset.selectCheckbox; });
}
document.getElementById('exp-review-details').addEventListener('click', function (e) {
  if (e.target.closest('select') || e.target.closest('input[type="checkbox"]')) return; // interacting with the dropdown or checkbox shouldn't also re-select the line
  const el = e.target.closest('[data-select-line]');
  if (!el) return;
  selectExpenseLineItem(el.dataset.selectLine);
});
document.getElementById('exp-review-details').addEventListener('change', function (e) {
  const sel = e.target.closest('[data-set-expense-category]');
  if (!sel) return;
  setExpenseCategory(sel.dataset.setExpenseCategory, sel.value);
});

async function selectExpenseLineItem(lineItemId) {
  currentReviewLineItemId = lineItemId;
  document.querySelectorAll('.exp-line-item').forEach(function (el) { el.classList.toggle('active', el.dataset.lineId === lineItemId); });
  const receiptBox = document.getElementById('exp-review-receipt');
  receiptBox.innerHTML = '<span style="color:var(--muted);font-size:0.86rem;">Loading receipt…</span>';
  try {
    const res = await authedFetch(API_BASE + '/finance/expense-receipt-image/' + encodeURIComponent(lineItemId));
    if (!res.ok) {
      const data = await res.json().catch(function () { return {}; });
      receiptBox.innerHTML = '<span style="color:var(--red);font-size:0.86rem;">' + escHtml((data.errors || ['Could not load receipt.']).join(' ')) + '</span>';
      return;
    }
    const contentType = res.headers.get('content-type') || '';
    if (contentType.includes('application/json')) {
      // Historical import — an external link we can't proxy, so it's a
      // plain "open" link instead of an inline preview.
      const data = await res.json();
      if (!data.externalUrl) { receiptBox.innerHTML = '<span style="color:var(--muted);font-size:0.86rem;">No receipt on file.</span>'; return; }
      receiptBox.innerHTML = '<a href="' + data.externalUrl + '" target="_blank" rel="noopener" style="color:var(--saffron-dark);font-weight:700;font-size:1rem;">📄 Open receipt &rarr;</a>';
      return;
    }
    const blob = await res.blob();
    const objectUrl = URL.createObjectURL(blob);
    if (contentType.includes('pdf')) {
      receiptBox.innerHTML = '<iframe src="' + objectUrl + '" style="width:100%;height:65vh;border:none;border-radius:8px;"></iframe>';
    } else {
      receiptBox.innerHTML = '<img src="' + objectUrl + '" style="max-width:100%;max-height:65vh;border-radius:8px;">';
    }
  } catch (err) {
    receiptBox.innerHTML = '<span style="color:var(--red);font-size:0.86rem;">Could not load receipt: ' + escHtml(err.message) + '</span>';
  }
}

async function setExpenseCategory(lineItemId, categoryId) {
  if (!categoryId) return;
  await authedFetch(API_BASE + '/finance/expense-line-items/' + encodeURIComponent(lineItemId) + '/categorize', {
    method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ categoryId: categoryId })
  });
  const item = currentReviewSubmission.items.find(function (i) { return i.line_item_id === lineItemId; });
  if (item) item.category_id = categoryId;
}

document.getElementById('btn-approve-expense').addEventListener('click', async function () {
  const box = document.getElementById('exp-review-result');
  const lineItemIds = getSelectedPendingLineItemIds();
  if (!lineItemIds.length) { box.style.display = 'block'; box.className = 'result-box error'; box.textContent = 'Check at least one expense to approve.'; return; }
  try {
    const res = await authedFetch(API_BASE + '/finance/expense-submissions/' + encodeURIComponent(currentReviewSubmission.submissionId) + '/approve', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ lineItemIds: lineItemIds })
    });
    const data = await res.json();
    box.style.display = 'block';
    if (!res.ok) {
      box.className = 'result-box error'; box.textContent = (data.errors || [data.error]).join(' ');
    } else {
      box.className = 'result-box success'; box.textContent = 'Approved ' + data.approvedCount + ' expense(s), total ' + money(data.total) + '. Email sent to the approver.';
      await loadExpenseSubmissions();
      setTimeout(closeExpenseReview, 1400);
    }
  } catch (err) {
    box.style.display = 'block'; box.className = 'result-box error'; box.textContent = 'Could not reach the server: ' + err.message;
  }
});
document.getElementById('btn-reject-expense').addEventListener('click', async function () {
  const lineItemIds = getSelectedPendingLineItemIds();
  const box = document.getElementById('exp-review-result');
  if (!lineItemIds.length) { box.style.display = 'block'; box.className = 'result-box error'; box.textContent = 'Check at least one expense to reject.'; return; }
  const reason = prompt('Reason for rejecting ' + (lineItemIds.length === 1 ? 'this expense' : 'these ' + lineItemIds.length + ' expenses') + '? This will be emailed to the submitter.');
  if (reason === null) return;
  if (!reason.trim()) { alert('A reason is required.'); return; }
  try {
    const res = await authedFetch(API_BASE + '/finance/expense-submissions/' + encodeURIComponent(currentReviewSubmission.submissionId) + '/reject', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ reason: reason, lineItemIds: lineItemIds })
    });
    const data = await res.json();
    box.style.display = 'block';
    if (!res.ok) {
      box.className = 'result-box error'; box.textContent = (data.errors || [data.error]).join(' ');
    } else {
      box.className = 'result-box success'; box.textContent = 'Rejected.';
      await loadExpenseSubmissions();
      setTimeout(closeExpenseReview, 1000);
    }
  } catch (err) {
    box.style.display = 'block'; box.className = 'result-box error'; box.textContent = 'Could not reach the server: ' + err.message;
  }
});

function loadPartial(id, file) {
  var target = document.getElementById(id);
  if (!target) return;
  fetch(file).then(function (r) { return r.text(); }).then(function (html) {
    target.innerHTML = html;
    if (id === 'site-header') fixHeaderLinksForSubfolder(target);
  }).catch(function () {});
}
function fixHeaderLinksForSubfolder(headerEl) {
  var logo = headerEl.querySelector('.brand-logo');
  if (logo && logo.getAttribute('src') && !logo.getAttribute('src').startsWith('/') && !logo.getAttribute('src').startsWith('http')) {
    logo.setAttribute('src', '/' + logo.getAttribute('src'));
  }
  headerEl.querySelectorAll('a[href]').forEach(function (link) {
    var href = link.getAttribute('href');
    if (!href || href.startsWith('http') || href.startsWith('/') || href.startsWith('#')) return;
    link.setAttribute('href', '/' + href);
  });
}
loadPartial('site-header', '/header.html');
loadPartial('site-footer', '/footer.html');

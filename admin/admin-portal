async function submitExpenses(req, res) {
  const b = req.body || {};
  const errors = [];
  if (!b.email) errors.push('Email is required.');
  if (!b.firstName) errors.push('First name is required.');
  if (!b.lastName) errors.push('Last name is required.');
  if (!b.zelleId) errors.push('Zelle ID is required.');
  if (!Array.isArray(b.expenses) || !b.expenses.length) errors.push('At least one expense is required.');
  if (Array.isArray(b.expenses)) {
    b.expenses.forEach((e, i) => {
      if (!e.expenseFor) errors.push(`Expense ${i + 1}: description is required.`);
      if (!e.expenseDate) errors.push(`Expense ${i + 1}: date is required.`);
      if (e.amount === undefined || e.amount === null || isNaN(Number(e.amount)) || Number(e.amount) <= 0) errors.push(`Expense ${i + 1}: a valid amount is required.`);
      if (!e.receiptBase64) errors.push(`Expense ${i + 1}: a receipt is required.`);
    });
  }
  if (errors.length) return res.status(400).json({ errors });

  const submissionId = randomUUID();
  let total = 0;
  const lineItemRows = [];

  for (const e of b.expenses) {
    let receiptUrl = null;
    try {
      receiptUrl = await uploadReceiptToDrive(e.receiptBase64, e.receiptFilename || 'receipt', e.receiptMimeType || 'application/octet-stream');
    } catch (err) {
      return res.status(500).json({ errors: ['Could not upload a receipt: ' + err.message] });
    }
    const lineItemId = 'EXP-' + randomUUID().slice(0, 8);
    total += Number(e.amount);
    await bigquery.query({
      query: `INSERT INTO \`${DATASET}.expense_line_items\`
        (line_item_id, submission_id, submitter_email, submitter_first_name, submitter_last_name, zelle_id,
         expense_for, expense_date, amount, receipt_url, status, submitted_at, created_by, created_at)
        VALUES (@lineItemId, @submissionId, @email, @firstName, @lastName, @zelleId,
         @expenseFor, @expenseDate, @amount, @receiptUrl, 'submitted', CURRENT_TIMESTAMP(), 'public-form', CURRENT_TIMESTAMP())`,
      params: {
        lineItemId, submissionId, email: b.email, firstName: b.firstName, lastName: b.lastName, zelleId: b.zelleId,
        expenseFor: e.expenseFor, expenseDate: e.expenseDate, amount: Number(e.amount), receiptUrl
      },
      types: { amount: 'NUMERIC' }
    });
    lineItemRows.push({ expenseFor: e.expenseFor, expenseDate: e.expenseDate, amount: Number(e.amount) });
  }

  await logAudit({ action: 'expenses_submitted', entityType: 'expense_submission', entityId: submissionId, actorEmail: 'public-form', details: { email: b.email, count: b.expenses.length, total } });

  try {
    const rowsHtml = lineItemRows.map(r => `<tr><td style="padding:4px 10px 4px 0;">${escapeHtml(r.expenseFor)}</td><td style="padding:4px 10px 4px 0;">${escapeHtml(r.expenseDate)}</td><td>${money(r.amount)}</td></tr>`).join('');
    await sendEmail({
      to: FINANCE_INBOX, cc: null, subject: `New expense submitted — ${escapeHtml(b.firstName)} ${escapeHtml(b.lastName)} (${money(total)})`,
      htmlBody: `
        <div style="font-family: Arial, Helvetica, sans-serif; max-width: 560px;">
          <h2 style="color:#7f2e16;">New expense reimbursement submitted</h2>
          <p><strong>${escapeHtml(b.firstName)} ${escapeHtml(b.lastName)}</strong> (${escapeHtml(b.email)}) submitted ${lineItemRows.length} expense(s) totaling <strong>${money(total)}</strong>, awaiting review.</p>
          <table style="border-collapse: collapse; font-size: 0.9rem; margin: 12px 0;">
            <thead><tr><th style="text-align:left; padding:4px 10px 4px 0;">For</th><th style="text-align:left; padding:4px 10px 4px 0;">Date</th><th style="text-align:left;">Amount</th></tr></thead>
            <tbody>${rowsHtml}</tbody>

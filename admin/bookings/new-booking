function resetForm() {
  ['f-name','f-event-name','f-notes','f-adj-value','f-adj-reason','f-hccg-rep'].forEach(function (id) { document.getElementById(id).value = ''; });
  document.getElementById('nonprofit-row').style.display = 'none';

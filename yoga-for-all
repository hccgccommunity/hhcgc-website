

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Yoga for All | Hindu Community Center of Greater Cincinnati</title>
  <meta name="description" content="Yoga for All - 12-week holistic healing course at Hindu Community Center of Greater Cincinnati." />

  <link rel="icon" type="image/x-icon" href="favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="apple-touch-icon.png">
  <link rel="icon" type="image/svg+xml"
        href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='0.9em' x='50%25' text-anchor='middle' font-size='82'%3E%E0%A5%90%3C/text%3E%3C/svg%3E">

  <style>
    :root {
      --bg: #fff9f1;
      --surface: #ffffff;
      --surface-soft: #fff6ea;
      --border: rgba(121, 62, 17, 0.14);
      --text: #2c1b10;
      --muted: #6a5141;
      --saffron: #b55a18;
      --saffron-dark: #8d3e0d;
      --maroon: #7f2e16;
      --shadow: 0 18px 45px rgba(93, 43, 14, 0.10);
      --radius: 22px;
      --max: 1220px;
      --header-offset: 110px;
      --gold: #d9a441;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top left, rgba(217, 138, 30, 0.12), transparent 22%),
        radial-gradient(circle at top right, rgba(127, 46, 22, 0.05), transparent 20%),
        var(--bg);
      line-height: 1.65;
    }

    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }
    button, input, select, textarea { font: inherit; }

    .container {
      width: min(calc(100% - 32px), var(--max));
      margin: 0 auto;
    }

    .content-width {
      width: 100%;
      max-width: 100%;
    }

    /* Same shared header/footer support as Khel Sandhya */
    .site-header {
      position: sticky;
      top: 0;
      z-index: 50;
      background: rgba(255, 249, 241, 0.92);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
    }

    .nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      min-height: 92px;
      padding: 12px 0;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 16px;
      min-width: 0;
    }

    .brand-logo-wrap {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 8px;
      box-shadow: var(--shadow);
      flex-shrink: 0;
    }

    .brand-logo {
      width: 88px;
      height: auto;
      border-radius: 12px;
      object-fit: contain;
    }

    .brand-text h1 {
      margin: 0;
      font-size: 1.2rem;
      line-height: 1.15;
      color: var(--maroon);
    }

    .site-header nav ul {
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      gap: 18px;
      margin: 0;
      padding: 0;
      align-items: center;
      justify-content: flex-end;
    }

    .site-header nav a {
      font-weight: 700;
      color: var(--text);
      font-size: 0.96rem;
    }

    .site-header nav a:hover {
      color: var(--saffron-dark);
    }

    .site-footer .footer-top {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: 24px;
      padding: 8px 0 0;
    }

    .site-footer .footer-nav {
      display: flex;
      justify-content: flex-start;
      min-width: 0;
    }

    .site-footer .footer-nav ul {
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin: 0;
      padding: 0;
      justify-content: flex-start;
      align-items: center;
    }

    .site-footer .footer-nav a {
      font-weight: 700;
      color: var(--text);
      font-size: 0.95rem;
    }

    .site-footer .footer-nav a:hover {
      color: var(--saffron-dark);
    }

    .site-footer .footer-email {
      text-align: center;
      font-weight: 700;
      color: var(--text);
      white-space: nowrap;
    }

    .site-footer .footer-email a:hover {
      color: var(--saffron-dark);
    }

    .site-footer .footer-social {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 12px;
      min-width: 220px;
      color: var(--text);
      font-weight: 700;
    }

    .site-footer .footer-social-label {
      white-space: nowrap;
    }

    .site-footer .social-icons {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .site-footer .social-icon {
      width: 42px;
      height: 42px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      background: #fff;
      border: 1px solid var(--border);
      box-shadow: 0 6px 18px rgba(93, 43, 14, 0.10);
      transition: transform 0.18s ease, box-shadow 0.18s ease;
    }

    .site-footer .social-icon:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 22px rgba(93, 43, 14, 0.16);
    }

    .site-footer .social-icon svg {
      width: 20px;
      height: 20px;
      display: block;
    }

    .site-footer .footer-note {
      margin-top: 18px;
      padding-top: 18px;
      border-top: 1px solid var(--border);
      color: var(--muted);
      font-size: 0.7rem;
      text-align: center;
    }

    .site-footer .copyright-links a {
      text-decoration: none;
    }

    .section {
      padding: 42px 0;
      scroll-margin-top: var(--header-offset);
    }

    .section-head {
      margin-bottom: 18px;
      text-align: center;
    }

    .section-kicker {
      display: inline-block;
      padding: 7px 14px;
      border-radius: 999px;
      background: rgba(217, 138, 30, 0.12);
      color: var(--saffron-dark);
      font-size: 0.83rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 8px;
    }

    .section-head h2,
    .section-title {
      margin: 8px 0 10px;
      line-height: 1.2;
      color: var(--maroon);
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(2rem, 3.4vw, 3rem);
    }

    .section-copy {
      margin: 0 auto;
      color: var(--muted);
      font-size: 1rem;
      max-width: 820px;
      text-align: center;
    }

    /* Yoga page content only */
    .hero-grid {
      display: grid;
      grid-template-columns: 1.08fr 0.92fr;
      gap: 26px;
      align-items: stretch;
      margin-top: 4px;
    }

    .hero-panel,
    .details-panel {
      min-height: 360px;
      border-radius: 26px;
      background: rgba(255, 255, 255, 0.74);
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
      padding: 34px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .hero-panel h1 {
      margin: 0 0 10px;
      color: var(--maroon);
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(2.8rem, 6vw, 5rem);
      line-height: 0.98;
      letter-spacing: -0.035em;
    }

    .hero-subtitle {
      margin: 0 0 16px;
      color: var(--saffron-dark);
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(1.35rem, 2.5vw, 1.9rem);
      font-weight: 700;
    }

    .hero-copy {
      margin: 0 0 24px;
      color: var(--muted);
      max-width: 720px;
      font-size: 1.05rem;
    }

    .cta-row {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 46px;
      padding: 11px 22px;
      border-radius: 999px;
      border: 1px solid transparent;
      font-weight: 800;
      text-decoration: none;
    }

    .btn.primary {
      background: linear-gradient(135deg, var(--saffron-dark), var(--saffron));
      color: #fff;
      box-shadow: 0 10px 24px rgba(127, 46, 22, 0.14);
    }

    .btn.secondary {
      background: rgba(255, 255, 255, 0.7);
      border-color: var(--border);
      color: var(--maroon);
    }

    .details-panel h2 {
      margin: 0 0 16px;
      color: var(--maroon);
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(1.7rem, 3vw, 2.35rem);
    }

    .details-grid {
      display: grid;
      gap: 12px;
    }

    .detail-item {
      padding: 14px 16px;
      border-radius: 18px;
      background: linear-gradient(135deg, rgba(255,246,234,0.92), rgba(255,255,255,0.86));
      border: 1px solid rgba(121, 62, 17, 0.12);
    }

    .detail-label {
      display: block;
      margin-bottom: 2px;
      color: var(--saffron-dark);
      font-size: 0.76rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .detail-value {
      display: block;
      color: var(--text);
      font-weight: 800;
      font-size: 1.08rem;
    }

    .pill-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
      margin-top: 28px;
    }

    .pill-card,
    .info-box {
      border-radius: 24px;
      background: rgba(255,255,255,.74);
      border: 1px solid var(--border);
      padding: 24px;
      box-shadow: 0 12px 30px rgba(93,43,14,.08);
    }

    .pill-icon {
      font-size: 2rem;
      margin-bottom: 8px;
    }

    .pill-card h3,
    .info-box h3 {
      margin: 0 0 8px;
      color: var(--maroon);
      font-family: Georgia, "Times New Roman", serif;
      font-size: 1.45rem;
    }

    .pill-card p,
    .info-box p {
      margin: 0;
      color: var(--muted);
    }

    .months {
      display: grid;
      gap: 18px;
      margin-top: 28px;
    }

    .month-card {
      display: grid;
      grid-template-columns: 280px 1fr;
      border-radius: 26px;
      overflow: hidden;
      background: rgba(255,255,255,.84);
      border: 1px solid var(--border);
      box-shadow: 0 16px 36px rgba(93,43,14,.09);
    }

    .month-head {
      padding: 24px;
      background: linear-gradient(135deg, var(--maroon), var(--saffron));
      color: white;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .weeks {
      display: inline-flex;
      width: fit-content;
      margin-bottom: 8px;
      font-size: 0.78rem;
      font-weight: 900;
      letter-spacing: 0.10em;
      text-transform: uppercase;
      white-space: nowrap;
      opacity: 0.92;
    }

    .month-head h3 {
      margin: 0;
      font-family: Georgia, "Times New Roman", serif;
      font-size: 1.5rem;
      line-height: 1.2;
    }

    .month-body {
      padding: 24px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }

    .month-body h4 {
      margin: 0 0 8px;
      color: var(--saffron-dark);
      font-size: 0.82rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .goals {
      border-left: 1px solid rgba(121, 62, 17, 0.14);
      padding-left: 24px;
    }

    ul {
      margin: 0 0 0 20px;
      padding: 0;
    }

    li {
      color: var(--muted);
      margin-bottom: 7px;
    }

    .two-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 22px;
    }

    .register-card {
      border-radius: 28px;
      background: linear-gradient(180deg, rgba(255,255,255,.86), rgba(255,246,234,.94));
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
      padding: 30px;
    }

    .register-card .section-head {
      margin-bottom: 20px;
    }

    .zeffy-wrap {
      border-radius: 22px;
      background: rgba(255,246,234,.9);
      border: 1px solid rgba(121,62,17,.12);
      overflow: hidden;
    }

    [data-zeffy-embed] {
      min-height: 450px;
      background: rgba(255,246,234,.9);
    }

    @media (max-width: 1120px) {
      .site-footer .footer-top {
        grid-template-columns: 1fr;
        justify-items: start;
      }

      .site-footer .footer-email,
      .site-footer .footer-social {
        text-align: left;
        justify-content: flex-start;
      }
    }

    @media (max-width: 900px) {
      .hero-grid,
      .pill-row,
      .month-card,
      .month-body,
      .two-col {
        grid-template-columns: 1fr;
      }

      .hero-panel,
      .details-panel {
        min-height: auto;
        padding: 26px;
      }

      .goals {
        border-left: 0;
        border-top: 1px solid rgba(121, 62, 17, 0.14);
        padding-left: 0;
        padding-top: 18px;
      }
    }

    @media (max-width: 860px) {
      .nav {
        flex-direction: column;
        align-items: flex-start;
      }

      .site-header nav ul {
        justify-content: flex-start;
        gap: 14px;
      }

      .brand-logo {
        width: 74px;
      }

      .section {
        padding: 34px 0;
      }
    }

    @media (max-width: 640px) {
      .container {
        width: min(calc(100% - 24px), var(--max));
      }

      .hero-panel,
      .details-panel,
      .register-card {
        padding: 22px;
        border-radius: 22px;
      }
    }
  </style>
</head>
<body>
  <div id="header-placeholder"></div>

  <main>
    <section class="section">
      <div class="container">
        <div class="hero-grid">
          <div class="hero-panel">
            <h1>Yoga for All</h1>
            <p class="hero-subtitle">3 Month Holistic Healing Course</p>
            <p class="hero-copy">A structured 12-week journey designed to help participants reset the body, build strength and balance, and integrate mindful practices for long-term wellness.</p>
            <div class="cta-row">
              <a class="btn primary" href="#join">Register</a>
              <a class="btn secondary" href="#course">Learn More</a>
            </div>
          </div>

          <aside class="details-panel" aria-label="Workshop details">
            <h2>Workshop Details</h2>
            <div class="details-grid">
              <div class="detail-item">
                <span class="detail-label">Duration</span>
                <span class="detail-value">12 Weeks / 3 Months</span>
              </div>
              <div class="detail-item">
                <span class="detail-label">Level</span>
                <span class="detail-value">Beginner → Intermediate</span>
              </div>
              <div class="detail-item">
                <span class="detail-label">Approach</span>
                <span class="detail-value">Reset → Build → Integrate</span>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="section" id="about">
      <div class="container">
        <div class="section-head content-width">
          <span class="section-kicker">About the course</span>
          <h2>Build wellness one mindful step at a time.</h2>
          <p class="section-copy">Yoga for All is a progressive holistic healing course focused on gentle movement, breathwork, meditation, strength, balance, and emotional well-being. The course is designed to support participants across different fitness levels while maintaining a calm, safe, and respectful practice environment.</p>
        </div>

        <div class="pill-row">
          <div class="pill-card">
            <div class="pill-icon">🌱</div>
            <h3>Reset</h3>
            <p>Start with mobility, breathing, relaxation, and body awareness.</p>
          </div>
          <div class="pill-card">
            <div class="pill-icon">🌿</div>
            <h3>Build</h3>
            <p>Develop strength, stability, balance, stamina, and metabolic support.</p>
          </div>
          <div class="pill-card">
            <div class="pill-icon">🌸</div>
            <h3>Integrate</h3>
            <p>Bring together breath, movement, meditation, clarity, and recovery.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section" id="course">
      <div class="container">
        <div class="section-head content-width">
          <span class="section-kicker">Course details</span>
          <h2>12-week progressive wellness journey</h2>
          <p class="section-copy">The program moves gradually from foundation and nervous-system reset to strength, balance, and integrated holistic wellness.</p>
        </div>

        <div class="months">
          <article class="month-card">
            <div class="month-head">
              <div class="weeks">Weeks 1–4</div>
              <h3>🌱 Foundation & Reset</h3>
            </div>
            <div class="month-body">
              <div>
                <h4>Practice Focus</h4>
                <ul>
                  <li>Sookshma Vyayam / joint rotations</li>
                  <li>Basic asanas: Tadasana, Cat-Cow, Child’s Pose</li>
                  <li>Slow, controlled movements with no forceful stretching</li>
                  <li>Deep breathing and abdominal breathing</li>
                  <li>Compulsory Shavasana and 5-minute breath awareness meditation</li>
                  <li>Daily practice time: 20–30 minutes</li>
                </ul>
              </div>
              <div class="goals">
                <h4>Goals</h4>
                <ul>
                  <li>Reduce stress, improve sleep, and calm the nervous system</li>
                  <li>Improve joint mobility and reduce stiffness or pain</li>
                  <li>Build body awareness and a healthier daily rhythm</li>
                </ul>
              </div>
            </div>
          </article>

          <article class="month-card">
            <div class="month-head">
              <div class="weeks">Weeks 5–8</div>
              <h3>🌿 Strength & Metabolic Balance</h3>
            </div>
            <div class="month-body">
              <div>
                <h4>Practice Focus</h4>
                <ul>
                  <li>Warm-up practice for 5–7 minutes</li>
                  <li>Chair squats, wall push-ups, and supported lunges</li>
                  <li>Balance poses including Vrikshasana</li>
                  <li>Slow Surya Namaskar with modifications if needed</li>
                  <li>Anulom Vilom and Ujjayi pranayama</li>
                  <li>Practice time: 30–40 minutes</li>
                </ul>
              </div>
              <div class="goals">
                <h4>Goals</h4>
                <ul>
                  <li>Improve muscle strength, joint stability, and balance</li>
                  <li>Support blood sugar control and metabolism</li>
                  <li>Help regulate blood pressure and stamina</li>
                </ul>
              </div>
            </div>
          </article>

          <article class="month-card">
            <div class="month-head">
              <div class="weeks">Weeks 9–12</div>
              <h3>🌸 Integration & Hormonal Balance</h3>
            </div>
            <div class="month-body">
              <div>
                <h4>Practice Focus</h4>
                <ul>
                  <li>Combine strength and balance into flow sequences</li>
                  <li>Gentle continuous yoga flow with no fast transitions</li>
                  <li>Bhramari pranayama for 5–7 minutes</li>
                  <li>10–15 minutes of meditation</li>
                  <li>Breath-synchronized movement and light posture holds</li>
                  <li>Practice time: 40–45 minutes</li>
                </ul>
              </div>
              <div class="goals">
                <h4>Goals</h4>
                <ul>
                  <li>Improve hormonal balance and cycle regularity</li>
                  <li>Boost energy, endurance, and recovery</li>
                  <li>Enhance mental clarity, focus, and emotional stability</li>
                </ul>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="two-col">
          <div class="info-box">
            <h3>What to Expect</h3>
            <ul>
              <li>A calm, structured, and beginner-friendly environment</li>
              <li>Gentle progression from basic movements to integrated flows</li>
              <li>Breathing techniques, meditation, relaxation, and mindful movement</li>
              <li>Modifications where needed for comfort and safety</li>
              <li>A wellness-focused community experience at HCCGC</li>
            </ul>
          </div>
          <div class="info-box">
            <h3>Who Can Join</h3>
            <ul>
              <li>Open to beginners and intermediate participants</li>
              <li>Suitable for anyone looking to improve flexibility, strength, balance, and stress management</li>
              <li>Ideal for participants seeking a slower, mindful, holistic yoga practice</li>
              <li>No prior advanced yoga experience required</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="section" id="join">
      <div class="container">
        <div class="register-card">
          <div class="section-head content-width">
            <span class="section-kicker">Registration</span>
            <h2>Register</h2>
            <p class="section-copy">Please complete the registration form below. Additional instructions, participation details, and any required updates will be shared with registered participants.</p>
          </div>

          <div class="zeffy-wrap">
            <div style="position:relative;overflow:hidden;width:100%;padding-top:650px;background:#fff6ea;">
              <iframe
                title="Registration form powered by Zeffy"
                src="https://www.zeffy.com/embed/ticketing/yoga-for-all-2"
                style="position:absolute;border:0;top:0;left:0;width:100%;height:100%;background:#fff6ea;"
                allow="payment"
                allowpaymentrequest
                allowtransparency="true">
              </iframe>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <div id="footer-placeholder"></div>

  <script>
    async function loadPartial(placeholderId, filePath) {
      const target = document.getElementById(placeholderId);
      if (!target) return;
      try {
        const response = await fetch(filePath);
        if (!response.ok) throw new Error("Unable to load " + filePath);
        target.innerHTML = await response.text();
      } catch (error) {
        console.error(error);
        target.innerHTML = "";
      }
    }

    async function initializePage() {
      await loadPartial("header-placeholder", "header.html");
      await loadPartial("footer-placeholder", "footer.html");

      const year = document.getElementById("year");
      if (year) {
        year.textContent = new Date().getFullYear();
      }
    }

    initializePage();
  </script>
</body>
</html>

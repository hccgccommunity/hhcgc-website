  collection,
  getDocs,
  addDoc,
  updateDoc,
  deleteDoc,
  doc,
  getDoc,
  serverTimestamp
} from "https://www.gstatic.com/firebasejs/12.15.0/firebase-firestore.js";

const firebaseConfig = {
  apiKey: "AIzaSyA6IzLjWTg7Rq04HsTH-iA3eDmSzKI7xME",
  authDomain: "hccgc-a7a54.firebaseapp.com",
  projectId: "hccgc-a7a54",
  storageBucket: "hccgc-a7a54.firebasestorage.app",
  messagingSenderId: "75757201418",
  appId: "1:75757201418:web:c31e9361921242145717f3",
  measurementId: "G-F9K6GVD5CS"
};

const ALLOWED_DOMAIN = "hccgc.org";
const REQUIRED_APP_KEY = "manage-events";
const USERS_COLLECTION = "portalUsers";
const PORTAL_URL = "/admin/admin-portal";

const fbApp = initializeApp(firebaseConfig);
const auth = getAuth(fbApp);
const db = getFirestore(fbApp);

const EVENTS_COLLECTION = "events";

window.__hccgc = {
  auth, db,
  collection, getDocs, addDoc, updateDoc, deleteDoc, doc, serverTimestamp,
  EVENTS_COLLECTION, ALLOWED_DOMAIN
};

function showGateMessage(title, message, showPortalButton) {
  document.getElementById("gate-title").textContent = title;
  document.getElementById("gate-message").textContent = message;
  document.getElementById("btn-go-portal").style.display = showPortalButton ? "flex" : "none";
}

document.getElementById("btn-signout").addEventListener("click", function () {
  signOut(auth).then(function () {
    window.location.href = PORTAL_URL;
  });
});

// Authentication is handled centrally by the Admin Portal (admin/admin-portal).
// This page does NOT show its own sign-in UI — it silently checks whether
// the person already has a Firebase session (since both pages share the
// same Firebase project and origin, the session carries over automatically
// once they've signed in at the portal), then checks Firestore to confirm
// they've specifically been granted access to this app.
onAuthStateChanged(auth, function (user) {
  console.log("[HCCGC AUTH] onAuthStateChanged fired. User:", user ? user.email : null);

  if (!user) {
    showGateMessage(
      "Sign in required",
      "Please sign in through the Admin Portal first.",
      true
    );
    return;
  }

  var email = (user.email || "").toLowerCase();

  if (!email.endsWith("@" + ALLOWED_DOMAIN)) {
    showGateMessage(
      "Access denied",
      "Please sign in with an @" + ALLOWED_DOMAIN + " account through the Admin Portal.",
      true
    );
    return;
  }

  // Check the portal's per-app permission list before showing anything.
  getDoc(doc(db, USERS_COLLECTION, email)).then(function (snap) {
    var allowedApps = snap.exists() && Array.isArray(snap.data().allowedApps) ? snap.data().allowedApps : [];
    var isAdmin = snap.exists() && !!snap.data().isAdmin;

    if (!isAdmin && allowedApps.indexOf(REQUIRED_APP_KEY) === -1) {
      showGateMessage(
        "Access not granted",
        "You don't have access to Manage Events yet. Ask an admin to grant it from User Management.",
        true
      );
      return;
    }

    console.log("[HCCGC AUTH] Access confirmed. Showing app.");

    document.getElementById("gate").style.display = "none";
    document.getElementById("app").style.display = "block";
    document.getElementById("user-name").textContent = user.displayName || email;

    var avatarEl = document.getElementById("user-avatar");
    if (user.photoURL) {
      avatarEl.innerHTML = '<img src="' + user.photoURL + '" alt="">';
    } else {
      avatarEl.textContent = (user.displayName || email).charAt(0).toUpperCase();
    }

    // Store user globally so regular script can access it
    window.__hccgcUser = user;
    // Dispatch event AND call loadEvents directly if regular script already ready
    window.dispatchEvent(new CustomEvent("hccgc-signed-in", { detail: { user: user } }));
    // Fallback: if listener missed the event, trigger directly
    if (typeof window.__hccgcLoadEvents === 'function') {
      window.__hccgcLoadEvents(user);
    }
  }).catch(function (err) {
    console.error("[HCCGC AUTH] Permission check failed:", err);
    showGateMessage(
      "Something went wrong",
      "We couldn't verify your access. Please try again or contact admin@hccgc.org.",
      true
    );
  });
});
</script>

<script>
function loadPartial(id, file) {
  var target = document.getElementById(id);
  if (!target) return;
  fetch(file)
    .then(function (r) { return r.text(); })
    .then(function (html) {
      target.innerHTML = html;
      if (id === 'site-header') {
        fixHeaderLinksForSubfolder(target);
      }
    })
    .catch(function () {});
}

// header.html uses relative paths (e.g. src="hccgc-logo.jpeg") that break
// when loaded from a subfolder like /admin/. This patches the loaded copy
// to use root-relative paths without touching the shared header.html file.
function fixHeaderLinksForSubfolder(headerEl) {
  var logo = headerEl.querySelector('.brand-logo');
  if (logo) {
    var src = logo.getAttribute('src');
    if (src && !src.startsWith('/') && !src.startsWith('http')) {
      logo.setAttribute('src', '/' + src);
    }
  }
  var links = headerEl.querySelectorAll('a[href]');
  links.forEach(function (link) {
    var href = link.getAttribute('href');
    if (!href) return;
    if (href.startsWith('http') || href.startsWith('/') || href.startsWith('#')) return;
    link.setAttribute('href', '/' + href);
  });
}

loadPartial('site-header', '/header.html');
loadPartial('site-footer', '/footer.html');

var allEvents = [];
var currentUser = null;

function __hccgcTriggerLoad(user) {
  if (currentUser) return; // already loaded
  currentUser = user;
  loadEvents();
}

// Register as fallback for module script to call directly
window.__hccgcLoadEvents = __hccgcTriggerLoad;

// Also listen for the event in case it fires after this script loads
window.addEventListener('hccgc-signed-in', function (e) {
  __hccgcTriggerLoad(e.detail.user);
});

// In case module already fired before this script registered the listener
if (window.__hccgcUser) {
  __hccgcTriggerLoad(window.__hccgcUser);
}

function showStatus(message, type) {
  var bar = document.getElementById('status-bar');
  bar.textContent = message;
  bar.className = 'status-bar show ' + type;
  if (type !== 'error') {
    setTimeout(function () { bar.classList.remove('show'); }, 3500);
  }
}

function loadEvents() {
  var fb = window.__hccgc;
  fb.getDocs(fb.collection(fb.db, fb.EVENTS_COLLECTION))
    .then(function (snapshot) {
      allEvents = [];
      snapshot.forEach(function (docSnap) {
        var data = docSnap.data();
        data.id = docSnap.id;
        allEvents.push(data);
      });
      renderEventsList();
      if (currentView === 'calendar') renderCalendar();
    })
    .catch(function (err) {
      console.error(err);
      document.getElementById('events-list').innerHTML =
        '<div class="empty-state">Could not load events. ' + (err.message || '') + '</div>';
    });
}

function escHtml(str) {
  return String(str || '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

function formatDateDisplay(dateStr) {
  var parts = (dateStr || '').split('-');
  if (parts.length !== 3) return dateStr;
  var d = new Date(Number(parts[0]), Number(parts[1]) - 1, Number(parts[2]));
  if (isNaN(d.getTime())) return dateStr;
  return d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' });
}

function formatTimeRange(fromTime, toTime) {
  if (toTime && toTime.trim() !== '') {
    return fromTime + ' \u2013 ' + toTime;
  }
  return fromTime + ' onward';
}

function isPastDate(e) {
  // For initiatives, use endDate; for events (or legacy records), use date.
  var dateStr = (e.type === 'initiative' && e.endDate) ? e.endDate : (e.date || '');
  if (!dateStr || dateStr.length !== 10) return false;
  var today = new Date();
  var yyyy = today.getFullYear();
  var mm = String(today.getMonth() + 1).padStart(2, '0');
  var dd = String(today.getDate()).padStart(2, '0');
  return dateStr < (yyyy + '-' + mm + '-' + dd);
}

function buildEventRowHtml(e, isPast) {
  var isInitiative = e.type === 'initiative';
  var createdLine = '';
  if (e.createdByName || e.createdByEmail) {
    createdLine =
      '<div class="event-row-created">Added by ' +
      escHtml(e.createdByName || e.createdByEmail) +
      (e.createdByName && e.createdByEmail ? ' (' + escHtml(e.createdByEmail) + ')' : '') +
      '</div>';
  }

  var typeBadge = isInitiative
    ? '<span class="initiative-badge">Initiative</span>'
    : '';

  var dateLine = isInitiative
    ? formatDateDisplay(e.date) + ' \u2013 ' + (e.endDate ? formatDateDisplay(e.endDate) : 'TBD')
    : formatDateDisplay(e.date);

  var timeLine = isInitiative
    ? (e.schedule ? escHtml(e.schedule) : '')
    : escHtml(formatTimeRange(e.fromTime, e.toTime));

  var rsvpLine = e.rsvpUrl
    ? '<div class="event-row-link">RSVP: <a href="' + escHtml(e.rsvpUrl) + '" target="_blank" rel="noopener noreferrer">' + escHtml(e.rsvpUrl) + '</a></div>'
    : '<div class="event-row-link" style="color:var(--saffron-dark);">Registrations will open soon!</div>';


  return (
    '<div class="event-row' + (isPast ? ' is-past' : '') + '">' +
      '<div class="event-row-main">' +
        '<h4>' + escHtml(e.name) + typeBadge + (isPast ? '<span class="past-badge">Past</span>' : '') + '</h4>' +
        '<div class="event-row-meta">' +
          '<span>&#128197; ' + dateLine + '</span>' +
          (timeLine ? '<span>&#128340; ' + timeLine + '</span>' : '') +
          (e.category ? '<span>&#127991; ' + escHtml(e.category) + '</span>' : '') +
          (e.cost ? '<span>&#128176; ' + escHtml(e.cost) + '</span>' : '') +
        '</div>' +
        '<p class="event-row-desc">' + escHtml(e.description) + '</p>' +
        rsvpLine +
        createdLine +
      '</div>' +
      '<div class="event-row-actions">' +
        '<button class="btn-icon btn-edit-event" data-event-id="' + escHtml(e.id) + '">' +
          '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 113 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>' +
          ' Edit' +
        '</button>' +
        '<button class="btn-icon danger btn-delete-event" data-event-id="' + escHtml(e.id) + '">' +
          '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6"/></svg>' +
          ' Delete' +
        '</button>' +
      '</div>' +
    '</div>'
  );
}

/* ── View toggle ─────────────────────────────────────────── */
var currentView = 'list';
var calYear, calMonth;

function setView(view) {
  currentView = view;
  document.getElementById('btn-view-list').classList.toggle('active', view === 'list');
  document.getElementById('btn-view-calendar').classList.toggle('active', view === 'calendar');
  document.getElementById('events-list').style.display = view === 'list' ? 'flex' : 'none';
  document.getElementById('past-events-section').style.display = view === 'list' ? 'block' : 'none';
  document.getElementById('calendar-view').style.display = view === 'calendar' ? 'block' : 'none';
  if (view === 'calendar') renderCalendar();
}

document.getElementById('btn-view-calendar').addEventListener('click', function() { setView('calendar'); });
document.getElementById('btn-view-list').addEventListener('click', function() { setView('list'); });

/* ── Calendar ────────────────────────────────────────────── */
var DAY_NAMES = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
var DAY_MAP = { 'monday':1,'tuesday':2,'wednesday':3,'thursday':4,'friday':5,'saturday':6,'sunday':0,
                'mon':1,'tue':2,'wed':3,'thu':4,'fri':5,'sat':6,'sun':0 };
var MONTH_NAMES = ['January','February','March','April','May','June','July','August','September','October','November','December'];

// Parse schedule text like "Tuesdays 6–7 PM, Thursdays 7–8 PM" → [2, 4] (JS day numbers)
function parseDaysFromSchedule(scheduleText) {
  if (!scheduleText) return [];
  var days = [];
  var words = scheduleText.toLowerCase().replace(/s\b/g, '').split(/[\s,&+/]+/);
  words.forEach(function(w) {
    if (DAY_MAP[w] !== undefined) days.push(DAY_MAP[w]);
  });
  return days;
}

// Generate all occurrence dates for an initiative between startDate and endDate
function getInitiativeOccurrences(e) {
  var days = parseDaysFromSchedule(e.schedule);
  if (!days.length || !e.date) return [];
  var startParts = e.date.split('-');
  var endDateStr = e.endDate;
  if (!endDateStr) return [];
  var endParts = endDateStr.split('-');
  var start = new Date(+startParts[0], +startParts[1]-1, +startParts[2]);
  var end = new Date(+endParts[0], +endParts[1]-1, +endParts[2]);
  var occurrences = [];
  var cur = new Date(start);
  while (cur <= end) {
    var jsDay = cur.getDay(); // 0=Sun, 1=Mon...
    if (days.indexOf(jsDay) !== -1) {
      occurrences.push(cur.getFullYear() + '-' +
        String(cur.getMonth()+1).padStart(2,'0') + '-' +
        String(cur.getDate()).padStart(2,'0'));
    }
    cur.setDate(cur.getDate() + 1);
  }
  return occurrences;
}

// Build a map of dateStr → [events] for the given month
function buildCalendarMap(year, month) {
  var map = {};
  allEvents.forEach(function(e) {
    if (e.type === 'initiative') {
      var occurrences = getInitiativeOccurrences(e);
      occurrences.forEach(function(dateStr) {
        var d = new Date(dateStr.split('-')[0], dateStr.split('-')[1]-1, dateStr.split('-')[2]);
        if (d.getFullYear() === year && d.getMonth() === month) {
          if (!map[dateStr]) map[dateStr] = [];
          map[dateStr].push(e);
        }
      });
    } else {
      var dateStr = e.date;
      if (!dateStr) return;
      var parts = dateStr.split('-');
      if (+parts[0] === year && +parts[1]-1 === month) {
        if (!map[dateStr]) map[dateStr] = [];
        map[dateStr].push(e);
      }
    }
  });
  return map;
}

function renderCalendar() {
  var today = new Date();
  if (calYear === undefined) { calYear = today.getFullYear(); calMonth = today.getMonth(); }

  document.getElementById('cal-month-label').textContent = MONTH_NAMES[calMonth] + ' ' + calYear;
  document.getElementById('day-detail').classList.remove('show');

  var map = buildCalendarMap(calYear, calMonth);
  var grid = document.getElementById('cal-grid');

  // Day headers (Mon–Sun)
  var html = DAY_NAMES.map(function(d) { return '<div class="cal-day-label">' + d + '</div>'; }).join('');

  // First day of month (adjust so week starts Monday)
  var firstDay = new Date(calYear, calMonth, 1);
  var startDow = (firstDay.getDay() + 6) % 7; // 0=Mon
  var daysInMonth = new Date(calYear, calMonth+1, 0).getDate();
  var daysInPrevMonth = new Date(calYear, calMonth, 0).getDate();

  var todayStr = today.getFullYear() + '-' + String(today.getMonth()+1).padStart(2,'0') + '-' + String(today.getDate()).padStart(2,'0');

  // Previous month filler
  for (var i = startDow - 1; i >= 0; i--) {
    html += '<div class="cal-cell other-month"><div class="cal-date" style="opacity:.4;">' + (daysInPrevMonth - i) + '</div></div>';
  }

  // Current month days
  for (var day = 1; day <= daysInMonth; day++) {
    var dateStr = calYear + '-' + String(calMonth+1).padStart(2,'0') + '-' + String(day).padStart(2,'0');
    var isToday = dateStr === todayStr;
    var dayEvents = map[dateStr] || [];

    var dotsHtml = '';
    var maxVisible = 3;
    dayEvents.slice(0, maxVisible).forEach(function(e) {
      var isInit = e.type === 'initiative';
      var label = e.name.length > 16 ? e.name.substring(0, 14) + '…' : e.name;
      dotsHtml += '<div class="cal-event-dot type-' + (isInit?'initiative':'event') + '" data-date="' + dateStr + '" data-id="' + escHtml(e.id) + '">' + escHtml(label) + '</div>';
    });
    if (dayEvents.length > maxVisible) {
      dotsHtml += '<div class="cal-more" data-date="' + dateStr + '">+' + (dayEvents.length - maxVisible) + ' more</div>';
    }

    html += '<div class="cal-cell' + (isToday?' today':'') + '" data-date="' + dateStr + '">' +
      '<div class="cal-date">' + day + '</div>' +
      dotsHtml +
    '</div>';
  }

  // Next month filler
  var totalCells = startDow + daysInMonth;
  var remainder = 7 - (totalCells % 7);
  if (remainder < 7) {
    for (var i = 1; i <= remainder; i++) {
      html += '<div class="cal-cell other-month"><div class="cal-date" style="opacity:.4;">' + i + '</div></div>';
    }
  }

  grid.innerHTML = html;

  // Click on day cell or event dot → show detail panel
  grid.addEventListener('click', function(evt) {
    var dateStr = evt.target.closest('[data-date]') && evt.target.closest('[data-date]').getAttribute('data-date');
    if (!dateStr) return;
    showDayDetail(dateStr, map[dateStr] || []);
  });
}

function showDayDetail(dateStr, events) {
  var panel = document.getElementById('day-detail');
  var parts = dateStr.split('-');
  var d = new Date(+parts[0], +parts[1]-1, +parts[2]);
  document.getElementById('day-detail-title').textContent =
    d.toLocaleDateString('en-US', { weekday:'long', month:'long', day:'numeric', year:'numeric' });

  if (!events.length) {
    document.getElementById('day-detail-events').innerHTML = '<p style="font-size:.86rem;color:var(--muted);padding:8px 0;">No events on this day.</p>';
  } else {
    document.getElementById('day-detail-events').innerHTML = events.map(function(e) {
      var isInit = e.type === 'initiative';
      var time = isInit ? (e.schedule || '') : ((e.fromTime || '') + (e.toTime ? ' – ' + e.toTime : ''));
      return '<div class="day-event-row">' +
        '<div>' +
          '<div class="day-event-name">' + escHtml(e.name) + (isInit ? ' <span style="font-size:.7rem;color:var(--saffron-dark);font-weight:800;text-transform:uppercase;">Initiative</span>' : '') + '</div>' +
          (time ? '<div class="day-event-time">' + escHtml(time) + '</div>' : '') +
        '</div>' +
        '<div class="day-event-actions">' +
          '<button class="btn-icon btn-edit-event" data-event-id="' + escHtml(e.id) + '">Edit</button>' +
        '</div>' +
      '</div>';
    }).join('');
  }
  panel.classList.add('show');
}

document.getElementById('cal-prev').addEventListener('click', function() {
  calMonth--; if (calMonth < 0) { calMonth = 11; calYear--; }
  renderCalendar();
});
document.getElementById('cal-next').addEventListener('click', function() {
  calMonth++; if (calMonth > 11) { calMonth = 0; calYear++; }
  renderCalendar();
});
document.getElementById('cal-today-btn').addEventListener('click', function() {
  var today = new Date(); calYear = today.getFullYear(); calMonth = today.getMonth();
  renderCalendar();
});

function renderEventsList() {
  var upcomingContainer = document.getElementById('events-list');
  var pastSection = document.getElementById('past-events-section');
  var pastContainer = document.getElementById('past-events-list');
  var pastLabel = document.getElementById('past-events-label');

  if (allEvents.length === 0) {
    upcomingContainer.innerHTML = '<div class="empty-state">No events yet. Click "Add Event" to create the first one.</div>';
    pastSection.style.display = 'none';
    return;
  }

  var sorted = allEvents.slice().sort(function (a, b) {
    return (a.date || '').localeCompare(b.date || '');
  });

  var upcoming = sorted.filter(function (e) { return !isPastDate(e); });
  var past = sorted.filter(function (e) { return isPastDate(e); }).reverse();

  if (upcoming.length === 0) {
    upcomingContainer.innerHTML = '<div class="empty-state">No upcoming events. Click "Add Event" to create one.</div>';
  } else {
    upcomingContainer.innerHTML = upcoming.map(function (e) { return buildEventRowHtml(e, false); }).join('');
  }

  if (past.length === 0) {
    pastSection.style.display = 'none';
  } else {
    pastSection.style.display = 'block';
    pastLabel.textContent = 'Past Events (' + past.length + ') \u2014 hidden from public page';
    pastContainer.innerHTML = past.map(function (e) { return buildEventRowHtml(e, true); }).join('');
  }
}

document.getElementById('past-events-toggle').addEventListener('click', function () {
  document.getElementById('past-events-toggle').classList.toggle('collapsed');
  document.getElementById('past-events-list').classList.toggle('collapsed');
});

/* ── Type toggle ─────────────────────────────────────────── */
function setType(type) {
  document.getElementById('event-type').value = type;

  // Toggle buttons
  document.getElementById('type-btn-event').classList.toggle('active', type === 'event');
  document.getElementById('type-btn-initiative').classList.toggle('active', type === 'initiative');

  // Show/hide fields
  var isInit = type === 'initiative';
  document.getElementById('event-time-group').style.display = isInit ? 'none' : 'block';
  document.getElementById('initiative-schedule-group').style.display = isInit ? 'block' : 'none';
  document.getElementById('end-date-group').style.display = isInit ? 'block' : 'none';
  document.getElementById('category-group').style.display = isInit ? 'none' : 'block';

  // Update labels and title
  var nameLabel = document.getElementById('label-name');
  var dateLabel = document.getElementById('label-date');
  nameLabel.textContent = isInit ? 'Initiative Name *' : 'Event Name *';
  dateLabel.textContent = isInit ? 'Start Date *' : 'Date *';

  var modalTitle = document.getElementById('modal-title');
  var id = document.getElementById('event-id').value;
  if (!id) {
    modalTitle.textContent = isInit ? 'Add Initiative' : 'Add Event';
  }
}

document.getElementById('type-btn-event').addEventListener('click', function() { setType('event'); });
document.getElementById('type-btn-initiative').addEventListener('click', function() { setType('initiative'); });

function openModal(eventId) {
  var overlay = document.getElementById('modal-overlay');
  var title = document.getElementById('modal-title');

  clearFieldErrors();

  if (eventId) {
    var e = allEvents.find(function (ev) { return ev.id === eventId; });
    if (!e) return;
    var type = e.type || 'event';
    setType(type);
    title.textContent = type === 'initiative' ? 'Edit Initiative' : 'Edit Event';
    document.getElementById('event-id').value = e.id;
    document.getElementById('event-name').value = e.name || '';
    document.getElementById('event-description').value = e.description || '';
    document.getElementById('event-date').value = e.date || '';
    document.getElementById('event-end-date').value = e.endDate || '';
    document.getElementById('event-from-time').value = e.fromTime || '';
    document.getElementById('event-to-time').value = e.toTime || '';
    document.getElementById('event-schedule').value = e.schedule || '';
    document.getElementById('event-category').value = e.category || '';
    document.getElementById('event-cost').value = e.cost || '';
    document.getElementById('event-rsvp').value = e.rsvpUrl || '';
  } else {
    setType('event');
    document.getElementById('event-id').value = '';
    document.getElementById('event-name').value = '';
    document.getElementById('event-description').value = '';
    document.getElementById('event-date').value = '';
    document.getElementById('event-end-date').value = '';
    document.getElementById('event-from-time').value = '';
    document.getElementById('event-to-time').value = '';
    document.getElementById('event-schedule').value = '';
    document.getElementById('event-category').value = '';
    document.getElementById('event-cost').value = '';
    document.getElementById('event-rsvp').value = '';
    title.textContent = 'Add Event';
  }

  overlay.classList.add('show');
}

function closeModal() {
  document.getElementById('modal-overlay').classList.remove('show');
}

document.getElementById('events-list').addEventListener('click', handleEventListClick);
document.getElementById('past-events-list').addEventListener('click', handleEventListClick);

function handleEventListClick(evt) {
  var editBtn = evt.target.closest('.btn-edit-event');
  if (editBtn) {
    openModal(editBtn.getAttribute('data-event-id'));
    return;
  }
  var deleteBtn = evt.target.closest('.btn-delete-event');
  if (deleteBtn) {
    deleteEventById(deleteBtn.getAttribute('data-event-id'));
  }
}

function clearFieldErrors() {
  ['name', 'description', 'date', 'end-date', 'from-time', 'schedule'].forEach(function (f) {
    var el = document.getElementById('err-' + f);
    if (el) el.classList.remove('show');
  });
}

document.getElementById('btn-add-event').addEventListener('click', function () { openModal(); });
document.getElementById('modal-close-btn').addEventListener('click', closeModal);
document.getElementById('modal-cancel-btn').addEventListener('click', closeModal);

document.getElementById('btn-save-event').addEventListener('click', function () {
  clearFieldErrors();

  var id = document.getElementById('event-id').value;
  var type = document.getElementById('event-type').value || 'event';
  var name = document.getElementById('event-name').value.trim();
  var description = document.getElementById('event-description').value.trim();
  var date = document.getElementById('event-date').value;
  var endDate = document.getElementById('event-end-date').value;
  var fromTime = document.getElementById('event-from-time').value.trim();
  var toTime = document.getElementById('event-to-time').value.trim();
  var schedule = document.getElementById('event-schedule').value.trim();
  var category = document.getElementById('event-category').value;
  var cost = document.getElementById('event-cost').value.trim();
  var rsvpUrl = document.getElementById('event-rsvp').value.trim();

  var hasError = false;
  if (!name) { document.getElementById('err-name').classList.add('show'); hasError = true; }
  if (!description) { document.getElementById('err-description').classList.add('show'); hasError = true; }
  if (!date) { document.getElementById('err-date').classList.add('show'); hasError = true; }
  if (type === 'event' && !fromTime) { document.getElementById('err-from-time').classList.add('show'); hasError = true; }
  if (type === 'initiative' && !endDate) { document.getElementById('err-end-date').classList.add('show'); hasError = true; }
  if (type === 'initiative' && !schedule) { document.getElementById('err-schedule').classList.add('show'); hasError = true; }
  if (hasError) return;

  var eventData = {
    type: type,
    name: name,
    description: description,
    date: date,
    category: category,
    cost: cost,
    rsvpUrl: rsvpUrl
  };

  if (type === 'event') {
    eventData.fromTime = fromTime;
    eventData.toTime = toTime;
  } else {
    eventData.endDate = endDate;
    eventData.schedule = schedule;
  }

  var btn = document.getElementById('btn-save-event');
  var origHTML = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<div class="spinner"></div> Saving\u2026';

  var fb = window.__hccgc;

  var savePromise;
  if (id) {
    savePromise = fb.updateDoc(fb.doc(fb.db, fb.EVENTS_COLLECTION, id), eventData);
  } else {
    eventData.createdByName = currentUser ? (currentUser.displayName || '') : '';
    eventData.createdByEmail = currentUser ? (currentUser.email || '') : '';
    eventData.createdAt = fb.serverTimestamp();
    savePromise = fb.addDoc(fb.collection(fb.db, fb.EVENTS_COLLECTION), eventData);
  }

  var label = type === 'initiative' ? 'Initiative' : 'Event';

  savePromise
    .then(function () {
      closeModal();
      showStatus(label + ' saved successfully.', 'success');
      loadEvents();
    })
    .catch(function (err) {
      console.error(err);
      showStatus('Error saving event: ' + (err.message || 'unknown error'), 'error');
    })
    .finally(function () {
      btn.disabled = false;
      btn.innerHTML = origHTML;
    });
});

function deleteEventById(id) {
  if (!confirm('Delete this event? This cannot be undone.')) return;

  var fb = window.__hccgc;
  fb.deleteDoc(fb.doc(fb.db, fb.EVENTS_COLLECTION, id))
    .then(function () {
      showStatus('Event deleted.', 'success');
      loadEvents();
    })
    .catch(function (err) {
      console.error(err);
      showStatus('Error deleting event: ' + (err.message || 'unknown error'), 'error');
    });
}
</script>
</body>

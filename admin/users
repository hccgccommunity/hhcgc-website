<style>
:root {
  --bg: #fff9f1;
  --surface: #ffffff;
  --surface-soft: #fff6ea;
  --border: rgba(121,62,17,0.14);
  --text: #2c1b10;
  --muted: #6a5141;
  --saffron: #b55a18;
  --saffron-dark: #8d3e0d;
  --maroon: #7f2e16;
  --radius: 22px;
  --shadow: 0 18px 45px rgba(93,43,14,0.10);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: Arial, Helvetica, sans-serif;
  background:
    radial-gradient(circle at top left, rgba(217,138,30,0.12), transparent 22%),
    radial-gradient(circle at top right, rgba(127,46,22,0.05), transparent 20%),
    var(--bg);
  color: var(--text);
  min-height: 100vh;
}

.container { width: min(calc(100% - 32px), 1000px); margin: 0 auto; }

/* Header partial styling — required by header.html's markup. */
.site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 249, 241, 0.92);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
}
.nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    min-height: 92px;
    padding: 12px 0;
}
.brand { display: flex; align-items: center; gap: 16px; min-width: 0; }
.brand-logo-wrap {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 8px;
    box-shadow: var(--shadow);
    flex-shrink: 0;
}
.brand-logo { width: 88px; height: auto; border-radius: 12px; object-fit: contain; }
.brand-text h1 { margin: 0; font-size: 1.2rem; line-height: 1.15; color: var(--maroon); }
.site-header nav ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    margin: 0;
    padding: 0;
    align-items: center;
    justify-content: flex-end;
}
.site-header nav a { font-weight: 700; color: var(--text); font-size: 0.96rem; }
.site-header nav a:hover { color: var(--saffron-dark); }
.menu-toggle {
    display: none;
    border: 0;
    background: transparent;
    padding: 6px 0;
    cursor: pointer;
    color: #2c1b10;
    align-self: flex-end;
}
.menu-toggle .bar { display: block; width: 26px; height: 2px; margin: 5px 0; background: currentColor; }
@media (max-width: 768px) {
    .nav { flex-direction: column; align-items: stretch; gap: 8px; }
    .menu-toggle { display: inline-block; }
    .site-header nav {
        display: none;
        width: 100%;
        background: rgba(255, 249, 241, 0.95);
        padding: 10px 0;
    }
    .site-header nav.is-open { display: block; }
    .site-header nav ul { flex-direction: column; gap: 14px; }
}

.back-link-row {
  padding: 16px 0 0;
  font-size: 0.82rem;
}
.back-link-row a { color: var(--saffron-dark); text-decoration: none; }
.back-link-row a:hover { text-decoration: underline; }

#gate { padding: 60px 16px; display: flex; justify-content: center; }
.gate-card {
  background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius);
  padding: 2.5rem 2rem; max-width: 420px; width: 100%; text-align: center; box-shadow: var(--shadow);
}
.gate-card h3 { font-family: Georgia, serif; font-size: 1.3rem; color: var(--maroon); margin-bottom: 0.5rem; }
.gate-card p { color: var(--muted); font-size: 0.88rem; line-height: 1.6; }
.gate-card a { color: var(--saffron-dark); }

#app { display: none; }

.page-header { padding: 40px 0 20px; }
.page-header h1 { font-family: Georgia, "Times New Roman", serif; font-size: 1.8rem; color: var(--maroon); margin-bottom: 8px; }
.page-header p { color: var(--muted); font-size: 0.9rem; }

.status-bar {
  display: none; align-items: center; gap: 10px;
  padding: 0.75rem 1.1rem; border-radius: 12px;
  font-size: 0.86rem; font-weight: 600; margin: 0 0 1.25rem;
}
.status-bar.show { display: flex; }
.status-bar.success { background: #e8f5e9; color: #2e7d32; border: 1px solid #c8e6c9; }
.status-bar.error { background: #fdecea; color: #c0392b; border: 1px solid #f5c6cb; }

.btn-add {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 0.7rem 1.4rem; background: var(--maroon); color: #fff;
  border: none; border-radius: 999px; font-size: 0.9rem; font-weight: 700;
  cursor: pointer; font-family: Arial, Helvetica, sans-serif; margin-bottom: 1.5rem;
}
.btn-add:hover { background: #5a1e0a; }

.user-table { display: flex; flex-direction: column; gap: 12px; padding-bottom: 60px; }

.user-row {
  background: #fff; border: 1px solid var(--border); border-radius: 14px;
  padding: 1.1rem 1.4rem; display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
}

.user-avatar-sm {
  width: 38px; height: 38px; border-radius: 50%;
  background: var(--maroon); color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.8rem; font-weight: 700; flex-shrink: 0;
}

.user-info { flex: 1; min-width: 180px; }
.user-info .name { font-weight: 700; font-size: 0.92rem; }
.user-info .email { font-size: 0.8rem; color: var(--muted); }

.admin-pill {
  font-size: 0.68rem; font-weight: 800; text-transform: uppercase;
  letter-spacing: 0.04em; color: var(--saffron-dark);
  background: rgba(217,138,30,0.14); padding: 2px 9px; border-radius: 999px; margin-left: 8px;
}

.app-checkboxes { display: flex; flex-wrap: wrap; gap: 10px; flex: 2; min-width: 220px; }

.app-check {
  display: flex; align-items: center; gap: 6px;
  font-size: 0.82rem; color: var(--text);
  background: var(--surface-soft); border: 1px solid var(--border);
  padding: 5px 10px; border-radius: 8px; cursor: pointer;
}
.app-check input { cursor: pointer; }

.row-actions { display: flex; align-items: center; gap: 8px; }
.admin-toggle { display: flex; align-items: center; gap: 6px; font-size: 0.78rem; color: var(--muted); cursor: pointer; }

.btn-icon {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 0.4rem 0.75rem; border: 1px solid var(--border); border-radius: 8px;
  background: #fff; font-size: 0.76rem; font-weight: 600; color: var(--muted);
  cursor: pointer; font-family: Arial, Helvetica, sans-serif;
}
.btn-icon:hover { border-color: var(--saffron); color: var(--saffron-dark); }
.btn-icon.danger:hover { border-color: #c0392b; color: #c0392b; }
.btn-icon:disabled { opacity: 0.4; cursor: not-allowed; }

.empty-state {
  text-align: center; padding: 50px 20px; color: var(--muted);
  background: #fff; border: 1px dashed var(--border); border-radius: 16px;
}

.modal-overlay {
  display: none; position: fixed; inset: 0; background: rgba(44,27,16,0.45);
  z-index: 200; align-items: center; justify-content: center; padding: 20px;
}
.modal-overlay.show { display: flex; }
.modal-card { background: #fff; border-radius: 18px; max-width: 460px; width: 100%; box-shadow: var(--shadow); }
.modal-header {
  padding: 1.4rem 1.6rem; border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
}
.modal-header h3 { font-family: Georgia, serif; color: var(--maroon); font-size: 1.15rem; }
.modal-close { background: none; border: none; cursor: pointer; color: var(--muted); font-size: 1.3rem; }
.modal-body { padding: 1.5rem 1.6rem; }
.form-group { margin-bottom: 1.1rem; }
label { display: block; font-size: 0.82rem; font-weight: 700; margin-bottom: 0.4rem; }
input[type="text"], input[type="email"] {
  width: 100%; padding: 0.6rem 0.85rem; border: 1.5px solid var(--border);
  border-radius: 10px; font-size: 0.9rem; font-family: Arial, Helvetica, sans-serif;
}
input:focus { outline: none; border-color: var(--saffron); box-shadow: 0 0 0 3px rgba(181,90,24,0.14); }
.modal-footer {
  padding: 1.2rem 1.6rem 1.5rem; display: flex; justify-content: flex-end;
  gap: 10px; border-top: 1px solid var(--border);
}
.btn-secondary {
  padding: 0.6rem 1.2rem; border-radius: 10px; border: 1.5px solid var(--border);
  background: #fff; color: var(--muted); font-weight: 700; font-size: 0.86rem; cursor: pointer;
}
.btn-save {
  padding: 0.6rem 1.4rem; border-radius: 10px; border: none;
  background: var(--maroon); color: #fff; font-weight: 700; font-size: 0.86rem; cursor: pointer;
}
.btn-save:hover { background: #5a1e0a; }
.field-hint { font-size: 0.76rem; color: var(--muted); margin-top: 4px; }

@media (max-width: 640px) {
  .user-row { flex-direction: column; align-items: stretch; }
}
</style>
</head>
<body>
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TPBF5VKB" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

<div id="site-header"></div>

<div class="container back-link-row">
  <a href="index">&larr; Back to apps</a>
</div>

<div id="gate">
  <div class="gate-card">
    <h3>Checking access&hellip;</h3>
    <p>Please sign in from the <a href="index">main portal page</a> first.</p>
  </div>
</div>

<div id="app">
  <div class="container">
    <div class="page-header">
      <h1>User Management</h1>
      <p>Grant or revoke access to portal apps for HCCGC members.</p>
    </div>

    <div class="status-bar" id="status-bar"></div>

    <button class="btn-add" id="btn-add-user">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Add User
    </button>

    <div class="user-table" id="user-table">
      <div class="empty-state">Loading users&hellip;</div>
    </div>
  </div>
</div>

<div id="site-footer"></div>

<div class="modal-overlay" id="modal-overlay">
  <div class="modal-card">
    <div class="modal-header">
      <h3 id="modal-title">Add User</h3>
      <button class="modal-close" id="modal-close-btn">&times;</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label for="user-email">Email address *</label>
        <input type="email" id="user-email" placeholder="name@hccgc.org">
        <div class="field-hint">Must be an @hccgc.org address. They'll get access the next time they sign in.</div>
      </div>
      <div class="form-group">
        <label for="user-name">Name (optional)</label>
        <input type="text" id="user-name" placeholder="Full name">
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn-secondary" id="modal-cancel-btn">Cancel</button>
      <button class="btn-save" id="btn-save-user">Add User</button>
    </div>
  </div>
</div>

<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/12.15.0/firebase-app.js";
import { getAuth, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/12.15.0/firebase-auth.js";
import {
  getFirestore, doc, getDoc, setDoc, deleteDoc, collection, getDocs, serverTimestamp
} from "https://www.gstatic.com/firebasejs/12.15.0/firebase-firestore.js";

const firebaseConfig = {
  apiKey: "AIzaSyA6IzLjWTg7Rq04HsTH-iA3eDmSzKI7xME",
  authDomain: "hccgc-a7a54.firebaseapp.com",
  projectId: "hccgc-a7a54",
  storageBucket: "hccgc-a7a54.firebasestorage.app",
  messagingSenderId: "75757201418",
  appId: "1:75757201418:web:c31e9361921242145717f3",
  measurementId: "G-F9K6GVD5CS"
};

const ALLOWED_DOMAIN = "hccgc.org";
const USERS_COLLECTION = "portalUsers";

const fbApp = initializeApp(firebaseConfig);
const auth = getAuth(fbApp);
const db = getFirestore(fbApp);

window.__hccgcUM = { auth, db, doc, getDoc, setDoc, deleteDoc, collection, getDocs, serverTimestamp, USERS_COLLECTION };

onAuthStateChanged(auth, function (user) {
  if (!user) {
    document.getElementById('app').style.display = 'none';
    document.getElementById('gate').style.display = 'flex';
    return;
  }

  var email = (user.email || '').toLowerCase();
  if (!email.endsWith('@' + ALLOWED_DOMAIN)) {
    document.getElementById('gate').innerHTML =
      '<div class="gate-card"><h3>Access denied</h3><p>Please sign in with an @' + ALLOWED_DOMAIN + ' account.</p></div>';
    return;
  }

  getDoc(doc(db, USERS_COLLECTION, email)).then(function (snap) {
    var isAdmin = snap.exists() && !!snap.data().isAdmin;
    if (!isAdmin) {
      document.getElementById('gate').innerHTML =
        '<div class="gate-card"><h3>Admins only</h3><p>You do not have permission to manage users. Contact an existing admin if you believe this is a mistake.</p></div>';
      document.getElementById('gate').style.display = 'flex';
      return;
    }

    document.getElementById('gate').style.display = 'none';
    document.getElementById('app').style.display = 'block';
    window.dispatchEvent(new CustomEvent('hccgc-um-ready', { detail: { currentUserEmail: email } }));
  });
});
</script>

<script>
var APP_REGISTRY = [
  { key: 'manage-events', name: 'Manage Events' },
  { key: 'marketing-assistant', name: 'Marketing Assistant' }
];

var allUsers = [];
var currentUserEmail = null;

window.addEventListener('hccgc-um-ready', function (e) {
  currentUserEmail = e.detail.currentUserEmail;
  loadUsers();
});

function showStatus(message, type) {
  var bar = document.getElementById('status-bar');
  bar.textContent = message;
  bar.className = 'status-bar show ' + type;
  if (type !== 'error') {
    setTimeout(function () { bar.classList.remove('show'); }, 3500);
  }
}

function escHtml(str) {
  return String(str || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

function loadUsers() {
  var fb = window.__hccgcUM;
  fb.getDocs(fb.collection(fb.db, fb.USERS_COLLECTION))
    .then(function (snapshot) {
      allUsers = [];
      snapshot.forEach(function (docSnap) {
        var data = docSnap.data();
        data.id = docSnap.id;
        allUsers.push(data);
      });
      renderUsers();
    })
    .catch(function (err) {
      console.error(err);
      document.getElementById('user-table').innerHTML = '<div class="empty-state">Could not load users.</div>';
    });
}

function renderUsers() {
  var container = document.getElementById('user-table');

  if (allUsers.length === 0) {
    container.innerHTML = '<div class="empty-state">No users yet.</div>';
    return;
  }

  var sorted = allUsers.slice().sort(function (a, b) {
    return (a.email || '').localeCompare(b.email || '');
  });

  var html = '';
  sorted.forEach(function (u) {
    var allowedApps = Array.isArray(u.allowedApps) ? u.allowedApps : [];
    var initials = (u.name || u.email || '?').charAt(0).toUpperCase();

    var checkboxes = APP_REGISTRY.map(function (app) {
      var checked = allowedApps.indexOf(app.key) !== -1 ? 'checked' : '';
      return (
        '<label class="app-check">' +
          '<input type="checkbox" data-user-id="' + escHtml(u.id) + '" data-app-key="' + escHtml(app.key) + '" ' + checked + '>' +
          escHtml(app.name) +
        '</label>'
      );
    }).join('');

    html +=
      '<div class="user-row">' +
        '<div class="user-avatar-sm">' + initials + '</div>' +
        '<div class="user-info">' +
          '<div class="name">' + escHtml(u.name || u.email) + (u.isAdmin ? '<span class="admin-pill">Admin</span>' : '') + '</div>' +
          '<div class="email">' + escHtml(u.email) + '</div>' +
        '</div>' +
        '<div class="app-checkboxes">' + checkboxes + '</div>' +
        '<div class="row-actions">' +
          '<label class="admin-toggle">' +
            '<input type="checkbox" class="admin-checkbox" data-user-id="' + escHtml(u.id) + '" ' + (u.isAdmin ? 'checked' : '') + (u.id === currentUserEmail ? ' disabled title="You cannot remove your own admin access"' : '') + '>' +
            'Admin' +
          '</label>' +
          '<button class="btn-icon danger btn-remove-user" data-user-id="' + escHtml(u.id) + '"' + (u.id === currentUserEmail ? ' disabled title="You cannot remove yourself"' : '') + '>Remove</button>' +
        '</div>' +
      '</div>';
  });

  container.innerHTML = html;
}

document.getElementById('user-table').addEventListener('change', function (evt) {
  if (evt.target.matches('input[data-app-key]')) {
    var userId = evt.target.getAttribute('data-user-id');
    var appKey = evt.target.getAttribute('data-app-key');
    toggleAppAccess(userId, appKey, evt.target.checked);
  } else if (evt.target.matches('.admin-checkbox')) {
    var userId = evt.target.getAttribute('data-user-id');
    toggleAdmin(userId, evt.target.checked);
  }
});

document.getElementById('user-table').addEventListener('click', function (evt) {
  var btn = evt.target.closest('.btn-remove-user');
  if (btn && !btn.disabled) {
    removeUser(btn.getAttribute('data-user-id'));
  }
});

function toggleAppAccess(userId, appKey, granted) {
  var fb = window.__hccgcUM;
  var user = allUsers.find(function (u) { return u.id === userId; });
  if (!user) return;

  var allowedApps = Array.isArray(user.allowedApps) ? user.allowedApps.slice() : [];
  if (granted && allowedApps.indexOf(appKey) === -1) {
    allowedApps.push(appKey);
  } else if (!granted) {
    allowedApps = allowedApps.filter(function (k) { return k !== appKey; });
  }

  fb.setDoc(fb.doc(fb.db, fb.USERS_COLLECTION, userId), { allowedApps: allowedApps }, { merge: true })
    .then(function () {
      user.allowedApps = allowedApps;
      showStatus('Access updated for ' + user.email + '.', 'success');
    })
    .catch(function (err) {
      console.error(err);
      showStatus('Error updating access: ' + (err.message || 'unknown error'), 'error');
      renderUsers();
    });
}

function toggleAdmin(userId, isAdmin) {
  var fb = window.__hccgcUM;
  var user = allUsers.find(function (u) { return u.id === userId; });
  if (!user) return;

  fb.setDoc(fb.doc(fb.db, fb.USERS_COLLECTION, userId), { isAdmin: isAdmin }, { merge: true })
    .then(function () {
      user.isAdmin = isAdmin;
      showStatus((isAdmin ? 'Granted' : 'Removed') + ' admin access for ' + user.email + '.', 'success');
      renderUsers();
    })
    .catch(function (err) {
      console.error(err);
      showStatus('Error updating admin status: ' + (err.message || 'unknown error'), 'error');
      renderUsers();
    });
}

function removeUser(userId) {
  if (!confirm('Remove ' + userId + ' from the portal? They will lose all app access.')) return;

  var fb = window.__hccgcUM;
  fb.deleteDoc(fb.doc(fb.db, fb.USERS_COLLECTION, userId))
    .then(function () {
      showStatus('User removed.', 'success');
      loadUsers();
    })
    .catch(function (err) {
      console.error(err);
      showStatus('Error removing user: ' + (err.message || 'unknown error'), 'error');
    });
}

document.getElementById('btn-add-user').addEventListener('click', function () {
  document.getElementById('user-email').value = '';
  document.getElementById('user-name').value = '';
  document.getElementById('modal-overlay').classList.add('show');
});
document.getElementById('modal-close-btn').addEventListener('click', closeAddModal);
document.getElementById('modal-cancel-btn').addEventListener('click', closeAddModal);

function closeAddModal() {
  document.getElementById('modal-overlay').classList.remove('show');
}

document.getElementById('btn-save-user').addEventListener('click', function () {
  var email = document.getElementById('user-email').value.trim().toLowerCase();
  var name = document.getElementById('user-name').value.trim();

  if (!email || !email.endsWith('@hccgc.org')) {
    alert('Please enter a valid @hccgc.org email address.');
    return;
  }

  var fb = window.__hccgcUM;
  fb.setDoc(fb.doc(fb.db, fb.USERS_COLLECTION, email), {
    email: email,
    name: name,
    allowedApps: [],
    isAdmin: false,
    createdAt: fb.serverTimestamp()
  }, { merge: true })
    .then(function () {
      closeAddModal();
      showStatus('User added. Grant them app access below.', 'success');
      loadUsers();
    })
    .catch(function (err) {
      console.error(err);
      alert('Error adding user: ' + (err.message || 'unknown error'));
    });
});

function loadPartial(id, file) {
  var target = document.getElementById(id);
  if (!target) return;
  fetch(file)
    .then(function (r) { return r.text(); })
    .then(function (html) { target.innerHTML = html; })
    .catch(function () {});
}
loadPartial('site-header', '../header.html');
loadPartial('site-footer', '../footer.html');
</script>
</body>
</html>

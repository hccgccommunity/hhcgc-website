<body>
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TPBF5VKB" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<div id="site-header"></div>

<main>
  <div class="container">
    <div class="page-hero">
      <span class="section-kicker">HCCGC Facility</span>
      <h1>Facility Calendar</h1>
      <p>View room availability and scheduled events at the Hindu Community Center of Greater Cincinnati.</p>
      <div class="hero-actions">
        <a class="btn-primary" href="/facility-rental">Rent a Space</a>
        <a class="btn-secondary" href="/contact-us">Contact Us</a>
      </div>
    </div>

    <div class="rooms-strip">
      <div class="legend-label">Calendar Color Legend</div>
      <div class="rooms-grid">
        <div class="room-info-card">
          <div class="room-color-swatch" style="background:#e67c73;"></div>
          <h3>Surya Hall</h3>
          <p>Main hall &middot; Large events &amp; celebrations</p>
        </div>
        <div class="room-info-card">
          <div class="room-color-swatch" style="background:#3f51b5;"></div>
          <h3>Patanjali Hall</h3>
          <p>Medium hall &middot; Classes &amp; gatherings</p>
        </div>
        <div class="room-info-card">
          <div class="room-color-swatch" style="background:#795548;"></div>
          <h3>Nataraj Room</h3>
          <p>Dance &amp; practice space</p>
        </div>
        <div class="room-info-card">
          <div class="room-color-swatch" style="background:#3f51b5;"></div>
          <h3>Ganesh Room</h3>
          <p>Small meeting room</p>
        </div>
      </div>
    </div>

    <div class="calendar-wrap">
      <iframe
        src="https://calendar.google.com/calendar/embed?height=600&wkst=1&ctz=America%2FNew_York&showPrint=0&title=HCCGC%20Facility%20Calendar&src=Y18xODhjMGNlN3RvcmNtaG5ubGs0b21vbGs0bjliNkByZXNvdXJjZS5jYWxlbmRhci5nb29nbGUuY29t&src=Y18xODg0MzN0aDFwa3E2aTF0bG00aG1rZ3VkczE3YUByZXNvdXJjZS5jYWxlbmRhci5nb29nbGUuY29t&src=Y18xODg0MjhvYTdvZW5nanIzbXJoc3NlMG40dXU1ZUByZXNvdXJjZS5jYWxlbmRhci5nb29nbGUuY29t&src=Y18xODg4bXAwYjNrZHRpajdxazg5MXBxc3Y5amxsMkByZXNvdXJjZS5jYWxlbmRhci5nb29nbGUuY29t&color=%23e67c73&color=%233f51b5&color=%23795548&color=%233f51b5"
        title="HCCGC Facility Calendar"
        width="100%"
        height="680"
        frameborder="0"
        scrolling="no"
        loading="lazy">
      </iframe>
    </div>
  </div>
</main>

<div id="site-footer"></div>

<script>
function loadPartial(id, file) {
  var el = document.getElementById(id);
  if (!el) return;
  fetch(file).then(function(r){return r.text();}).then(function(html){el.innerHTML=html;}).catch(function(){});
}
loadPartial('site-header', '/header.html');
loadPartial('site-footer', '/footer.html');
</script>

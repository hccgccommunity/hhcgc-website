  <div id="header-placeholder"></div>

  <main>

    <!-- ── HERO ── -->
    <section class="hero">
      <div class="container">
        <div class="hero-card">

          <div>
            <span class="hero-kicker">HCCGC Presents</span>
            <h1 class="hero-title">
              IPL Final
              <span class="hero-title-sub">Live Screening</span>
            </h1>
            <p class="hero-tagline">Community &amp; Fun. Big Match. Great Company.</p>
            <p class="hero-copy">
              Watch the IPL 2026 Final live on the big screen at HCCGC. Join your community for an exciting morning of cricket, samosas, tea, and celebration — a ticketed event with limited seats.
            </p>
            <div class="hero-actions">
              <button class="btn btn-primary"
                zeffy-form-link="https://www.zeffy.com/embed/ticketing/ipl-2026-final-live-streaming?modal=true">
                Register Now
              </button>
              <a class="btn btn-secondary" href="#about">About the Event</a>
            </div>
          </div>

          <div class="hero-panel">

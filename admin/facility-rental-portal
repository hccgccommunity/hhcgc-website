document.getElementById('btn-save-series-edit').addEventListener('click', async function () {
  const btn = this;
  const occurrences = BOOKINGS.filter(function (b) { return b.recurring_series_id === editingSeriesId && b.payment_status !== 'cancelled'; });
  if (!occurrences.length) return;
  const isInternal = occurrences[0].is_internal;
  const rooms = Array.from(document.querySelectorAll('.series-edit-room-cb:checked')).map(function (cb) { return cb.value; });
  const resultBox = document.getElementById('series-edit-result-box');

  const occInputs = Array.from(document.querySelectorAll('#series-edit-occ-tbody tr')).map(function (tr) {
    const bookingId = tr.dataset.bookingId;
    if (tr.classList.contains('past-occ-row')) {
      // Past occurrences are read-only here — submit their existing values
      // unchanged rather than trying to read inputs that don't exist on
      // this row, and they can never be marked for removal.
      const existing = occurrences.find(function (o) { return o.booking_id === bookingId; });
      return { bookingId: bookingId, eventDate: existing.event_date, startTime: (existing.start_time || '').slice(11, 16), endTime: (existing.end_time || '').slice(11, 16), remove: false };
    }
    return {
      bookingId: bookingId,
      eventDate: tr.querySelector('.series-occ-date').value,
      startTime: tr.querySelector('.series-occ-start').value,
      endTime: tr.querySelector('.series-occ-end').value,
      remove: tr.querySelector('.series-occ-remove').checked
    };
  });

  const payload = {
    rooms: rooms,
    notes: document.getElementById('series-edit-notes').value,
    renterId: isInternal ? null : document.getElementById('series-edit-renter-select').value,
    renterName: isInternal ? document.getElementById('series-edit-name').value : null,
    hccgcRepresentativeName: isInternal ? document.getElementById('series-edit-hccg-rep').value : null,
    isNonprofit: isInternal ? false : document.getElementById('series-edit-nonprofit').checked,
    occurrences: occInputs
  };

  btn.disabled = true; btn.textContent = 'Saving…';
  try {
    const res = await authedFetch(API_BASE + '/bookings/series/' + encodeURIComponent(editingSeriesId), {
      method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (!res.ok) {
      resultBox.style.display = 'block'; resultBox.className = 'result-box error';
      resultBox.textContent = (data.errors || [data.error || 'Something went wrong.']).join(' ');
    } else {
      resultBox.style.display = 'block'; resultBox.className = 'result-box success';
      let msg = 'Saved — ' + data.updatedCount + ' occurrence(s) updated';
      if (data.removedCount) msg += ', ' + data.removedCount + ' removed';
      msg += '.';
      if (data.occurrenceErrors && data.occurrenceErrors.length) msg += ' Some rows had issues: ' + data.occurrenceErrors.join(' ');
      resultBox.textContent = msg;
      await loadBookings();
      setTimeout(closeSeriesEditModal, 1200);
    }
  } catch (err) {
    resultBox.style.display = 'block'; resultBox.className = 'result-box error';
    resultBox.textContent = 'Could not reach the booking system: ' + err.message;
  } finally {
    btn.disabled = false; btn.textContent = 'Save changes';
  }
});


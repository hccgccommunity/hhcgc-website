const auth = getAuth(fbApp);
const db = getFirestore(fbApp);

window.__hccgcMP = { db, collection, getDocs, doc, getDoc, setDoc, serverTimestamp, EVENTS_COLLECTION };

async function loadPartial(id, file) {
  const el = document.getElementById(id);
  if (!el) return;
  try {
    const r = await fetch(file);
    if (r.ok) {
      el.innerHTML = await r.text();
      if (id === 'site-header') fixHeaderLinks(el);
    }
  } catch (e) {}
}
function fixHeaderLinks(el) {
  const logo = el.querySelector('.brand-logo');
  if (logo) { const s = logo.getAttribute('src'); if (s && !s.startsWith('/') && !s.startsWith('http')) logo.setAttribute('src', '/' + s); }
  el.querySelectorAll('a[href]').forEach(function(a) {
    const h = a.getAttribute('href');
    if (h && !h.startsWith('http') && !h.startsWith('/') && !h.startsWith('#')) a.setAttribute('href', '/' + h);
  });
}
loadPartial('site-header', '/header.html');
loadPartial('site-footer', '/footer.html');

function showGate(title, msg) {
  document.getElementById('gate').querySelector('h3').textContent = title;
  document.getElementById('gate').querySelector('p').innerHTML = msg;
  document.getElementById('gate').style.display = 'flex';
  document.getElementById('app').style.display = 'none';
}

onAuthStateChanged(auth, async function(user) {
  if (!user) { showGate('Sign in required', 'Please sign in from the <a href="' + PORTAL_URL + '">Admin Portal</a> first.'); return; }
  const email = (user.email || '').toLowerCase();
  if (!email.endsWith('@' + ALLOWED_DOMAIN)) { showGate('Access denied', 'Please sign in with an @' + ALLOWED_DOMAIN + ' account.'); return; }

  try {
    const snap = await getDoc(doc(db, USERS_COLLECTION, email));
    const data = snap.exists() ? snap.data() : {};
    const isAdmin = !!data.isAdmin;
    const allowed = Array.isArray(data.allowedApps) && data.allowedApps.includes(REQUIRED_APP_KEY);
    if (!isAdmin && !allowed) {
      showGate('Access not granted', "You don't have access to Manage Pages. Ask an admin to grant it from User Management.");
      return;
    }
  } catch(e) {
    showGate('Error', 'Could not verify your access. Please try again.');
    return;
  }

  document.getElementById('gate').style.display = 'none';
  document.getElementById('app').style.display = 'block';
  window.dispatchEvent(new CustomEvent('hccgc-mp-ready'));
});
</script>

<script>
var allRecords = [];

window.addEventListener('hccgc-mp-ready', function() {
  loadPages();
});

function escHtml(str) {
  return String(str || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function formatDate(dateStr) {
  if (!dateStr) return '';
  var p = dateStr.split('-');
  if (p.length !== 3) return dateStr;
  var d = new Date(Number(p[0]), Number(p[1]) - 1, Number(p[2]));
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function showStatus(msg, type) {
  var bar = document.getElementById('status-bar');
  bar.textContent = msg;
  bar.className = 'status-bar show ' + type;
  if (type !== 'error') setTimeout(function() { bar.classList.remove('show'); }, 3500);
}

function loadPages() {
  var fb = window.__hccgcMP;
  fb.getDocs(fb.collection(fb.db, fb.EVENTS_COLLECTION)).then(function(snapshot) {
    allRecords = [];
    snapshot.forEach(function(docSnap) {
      var d = docSnap.data(); d.id = docSnap.id;
      allRecords.push(d);
    });
    allRecords.sort(function(a, b) { return (a.date || '').localeCompare(b.date || ''); });
    renderPagesList();
  }).catch(function(err) {
    document.getElementById('pages-list').innerHTML = '<div class="empty-state">Could not load records. ' + escHtml(err.message) + '</div>';
  });
}

function renderPagesList() {
  var container = document.getElementById('pages-list');
  if (!allRecords.length) {
    container.innerHTML = '<div class="empty-state">No events or initiatives found. Add some in Manage Events first.</div>';
    return;
  }

  var html = '';
  allRecords.forEach(function(e) {
    var isInit = e.type === 'initiative';
    var isLive = e.pageEnabled && e.slug;
    var dateStr = isInit
      ? (formatDate(e.date) + (e.endDate ? ' – ' + formatDate(e.endDate) : ''))
      : formatDate(e.date);

    var pageUrlHtml = isLive
      ? '<a href="/' + escHtml(e.slug) + '" target="_blank" rel="noopener noreferrer">hccgc.org/' + escHtml(e.slug) + ' ↗</a>'
      : '<span>No page yet</span>';

    html +=
      '<div class="page-row">' +
        '<div class="page-row-status' + (isLive ? ' live' : '') + '" title="' + (isLive ? 'Live' : 'No page') + '"></div>' +
        '<div class="page-row-info">' +
          '<h4>' + escHtml(e.name) + ' <span class="type-badge ' + (isInit ? 'initiative' : 'event') + '">' + (isInit ? 'Initiative' : 'Event') + '</span></h4>' +
          '<div class="meta">' + escHtml(dateStr) + ' &nbsp;·&nbsp; ' + pageUrlHtml + '</div>' +
        '</div>' +
        '<button class="btn-edit-page" data-id="' + escHtml(e.id) + '">' +
          '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 113 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>' +
          (isLive ? ' Edit Page' : ' Set Up Page') +
        '</button>' +
      '</div>';
  });

  container.innerHTML = html;
}

// Tab switching
document.querySelectorAll('.modal-tab').forEach(function(btn) {
  btn.addEventListener('click', function() {
    document.querySelectorAll('.modal-tab').forEach(function(b) { b.classList.remove('active'); });
    document.querySelectorAll('.modal-panel').forEach(function(p) { p.classList.remove('active'); });
    btn.classList.add('active');
    document.getElementById('panel-' + btn.getAttribute('data-tab')).classList.add('active');
  });
});

// Slug sanitize + preview
document.getElementById('page-slug').addEventListener('input', function() {
  var clean = this.value.toLowerCase().replace(/[^a-z0-9-]/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '');
  document.getElementById('slug-display').textContent = clean || 'your-slug';
  updateLiveLink(clean, document.getElementById('page-enabled').checked);
});

document.getElementById('page-enabled').addEventListener('change', function() {
  var slug = document.getElementById('page-slug').value.trim();
  updateLiveLink(slug, this.checked);
});

function updateLiveLink(slug, enabled) {
  var link = document.getElementById('page-live-link');
  if (enabled && slug) {
    link.href = '/' + slug;
    link.style.display = 'inline';
  } else {
    link.style.display = 'none';
  }
}

// Open modal
document.getElementById('pages-list').addEventListener('click', function(evt) {
  var btn = evt.target.closest('.btn-edit-page');
  if (!btn) return;
  var id = btn.getAttribute('data-id');
  var e = allRecords.find(function(r) { return r.id === id; });
  if (!e) return;
  openModal(e);
});

function openModal(e) {
  var isInit = e.type === 'initiative';
  var pg = e.page || {};

  document.getElementById('modal-title').textContent = 'Page Setup — ' + (e.name || '');
  document.getElementById('modal-event-name-display').textContent = (isInit ? 'Initiative' : 'Event') + ': ' + (e.name || '');
  document.getElementById('edit-event-id').value = e.id;

  // Reset to basics tab
  document.querySelectorAll('.modal-tab').forEach(function(b) { b.classList.remove('active'); });
  document.querySelectorAll('.modal-panel').forEach(function(p) { p.classList.remove('active'); });
  document.querySelector('.modal-tab[data-tab="basics"]').classList.add('active');
  document.getElementById('panel-basics').classList.add('active');

  // Show/hide people and curriculum sections
  document.getElementById('people-event-section').style.display = isInit ? 'none' : 'block';
  document.getElementById('people-initiative-section').style.display = isInit ? 'block' : 'none';
  document.getElementById('curriculum-event-section').style.display = isInit ? 'none' : 'block';
  document.getElementById('curriculum-initiative-section').style.display = isInit ? 'block' : 'none';

  // Update curriculum tab label
  document.querySelector('.modal-tab[data-tab="curriculum"]').textContent = isInit ? 'Curriculum' : 'Schedule';

  // Basics
  var slug = e.slug || '';
  document.getElementById('page-enabled').checked = !!e.pageEnabled;
  document.getElementById('page-slug').value = slug;
  document.getElementById('slug-display').textContent = slug || 'your-slug';
  updateLiveLink(slug, !!e.pageEnabled);
  document.getElementById('page-tagline').value = pg.tagline || '';
  document.getElementById('page-hero-desc').value = pg.heroDescription || '';
  document.getElementById('page-venue').value = pg.venue || '';
  document.getElementById('page-cost-display').value = pg.costDisplay || '';
  document.getElementById('page-contact-name').value = (pg.contact && pg.contact.name) || '';
  document.getElementById('page-contact-phone').value = (pg.contact && pg.contact.phone) || '';

  // Content
  document.getElementById('page-about-title').value = pg.aboutTitle || '';
  document.getElementById('page-about-body').value = pg.aboutBody || '';
  document.getElementById('page-what-to-expect').value = (pg.whatToExpect || []).join('\n');
  document.getElementById('page-who-should-attend').value = (pg.whoShouldAttend || []).join('\n');
  document.getElementById('page-registration-note').value = pg.registrationNote || '';

  // People
  if (!isInit) {
    document.getElementById('page-performers').value = (pg.performers || []).map(function(p) {
      return [p.name, p.role, p.location].filter(Boolean).join(' | ');
    }).join('\n');
  } else {
    var inst = pg.instructor || {};
    document.getElementById('page-instructor-name').value = inst.name || '';
    document.getElementById('page-instructor-role').value = inst.role || '';
    document.getElementById('page-instructor-photo').value = inst.photoUrl || '';
    document.getElementById('page-instructor-bio').value = inst.bio || '';
  }

  // Schedule / Curriculum
  if (!isInit) {
    document.getElementById('page-schedule-items').value = (pg.scheduleItems || []).map(function(s) {
      return [s.time, s.label, s.duration].filter(Boolean).join(' | ');
    }).join('\n');
  } else {
    document.getElementById('page-curriculum-title').value = pg.curriculumTitle || '';
    document.getElementById('page-curriculum').value = (pg.curriculum || []).map(function(w) {
      return [w.weekLabel, w.title, w.description].filter(Boolean).join(' | ');
    }).join('\n');
  }

  // Media
  document.getElementById('page-zeffy-url').value = pg.zeffyUrl || '';
  document.getElementById('page-flyer-url').value = pg.flyerImageUrl || '';
  document.getElementById('page-meta-desc').value = pg.metaDescription || '';

  // Clear errors
  document.getElementById('err-slug').classList.remove('show');

  document.getElementById('modal-overlay').classList.add('show');
}

function closeModal() {
  document.getElementById('modal-overlay').classList.remove('show');
}

document.getElementById('modal-close-btn').addEventListener('click', closeModal);
document.getElementById('modal-cancel-btn').addEventListener('click', closeModal);

// Save
document.getElementById('btn-save-page').addEventListener('click', function() {
  var id = document.getElementById('edit-event-id').value;
  var e = allRecords.find(function(r) { return r.id === id; });
  if (!e) return;
  var isInit = e.type === 'initiative';

  var slug = document.getElementById('page-slug').value.trim()
    .toLowerCase().replace(/[^a-z0-9-]/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '');
  var pageEnabled = document.getElementById('page-enabled').checked;

  if (pageEnabled && !slug) {
    document.getElementById('err-slug').classList.add('show');
    document.querySelector('.modal-tab[data-tab="basics"]').click();
    return;
  }

  function parseLines(id) {
    return document.getElementById(id).value.split('\n').map(function(l) { return l.trim(); }).filter(Boolean);
  }
  function parsePiped(id, keys) {
    return parseLines(id).map(function(line) {
      var parts = line.split('|').map(function(p) { return p.trim(); });
      var obj = {};
      keys.forEach(function(k, i) { obj[k] = parts[i] || ''; });
      return obj;
    });
  }

  var pageData = {
    tagline: document.getElementById('page-tagline').value.trim(),
    heroDescription: document.getElementById('page-hero-desc').value.trim(),
    aboutTitle: document.getElementById('page-about-title').value.trim(),
    aboutBody: document.getElementById('page-about-body').value.trim(),
    venue: document.getElementById('page-venue').value.trim(),
    costDisplay: document.getElementById('page-cost-display').value.trim(),
    contact: {
      name: document.getElementById('page-contact-name').value.trim(),
      phone: document.getElementById('page-contact-phone').value.trim()
    },
    whatToExpect: parseLines('page-what-to-expect'),
    whoShouldAttend: parseLines('page-who-should-attend'),
    registrationNote: document.getElementById('page-registration-note').value.trim(),
    zeffyUrl: document.getElementById('page-zeffy-url').value.trim(),
    flyerImageUrl: document.getElementById('page-flyer-url').value.trim(),
    metaDescription: document.getElementById('page-meta-desc').value.trim()
  };

  if (!isInit) {
    pageData.performers = parsePiped('page-performers', ['name', 'role', 'location']);
    pageData.scheduleItems = parsePiped('page-schedule-items', ['time', 'label', 'duration']);
  } else {
    pageData.instructor = {
      name: document.getElementById('page-instructor-name').value.trim(),
      role: document.getElementById('page-instructor-role').value.trim(),
      photoUrl: document.getElementById('page-instructor-photo').value.trim(),
      bio: document.getElementById('page-instructor-bio').value.trim()
    };
    pageData.curriculumTitle = document.getElementById('page-curriculum-title').value.trim();
    pageData.curriculum = parsePiped('page-curriculum', ['weekLabel', 'title', 'description']);
  }

  var btn = document.getElementById('btn-save-page');
  var origHTML = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<div class="spinner"></div> Saving\u2026';

  var fb = window.__hccgcMP;
  fb.setDoc(fb.doc(fb.db, fb.EVENTS_COLLECTION, id), {
    pageEnabled: pageEnabled,
    slug: slug,
    page: pageData
  }, { merge: true }).then(function() {
    // Update local record
    e.pageEnabled = pageEnabled;
    e.slug = slug;
    e.page = pageData;
    btn.disabled = false;
    btn.innerHTML = origHTML;
    closeModal();
    showStatus('Page saved. ' + (pageEnabled && slug ? 'Live at hccgc.org/' + slug : 'Page disabled.'), 'success');
    renderPagesList();
  }).catch(function(err) {
    btn.disabled = false;
    btn.innerHTML = origHTML;
    showStatus('Error saving: ' + (err.message || 'unknown error'), 'error');
  });
});
</script>
</body>
</html>

  })));
}

async function getZeffyReconciliation(req, res) {
  const unwrap = v => (v && typeof v === 'object' && 'value' in v) ? v.value : v;
  const [bankDeposits] = await bigquery.query(
    `SELECT date, description, amount
     FROM \`${PAYMENTS_DATASET}.bank_transactions\`
     WHERE LOWER(description) LIKE '%zeffy%' AND amount >= 0
     ORDER BY date DESC
     LIMIT 26`
  );
  // Refunds arrive as their own separate withdrawal from Zeffy, not netted
  // into the following revenue payout — confirmed from an actual Zeffy
  // payout export, where a refund shows up as its own negative entry days
  // apart from the nearest revenue payout. So the deposit comparison below
  // uses gross payment totals, un-netted — and refunds get their own
  // separate check against the matching negative bank lines instead.
  const [bankRefunds] = await bigquery.query(
    `SELECT date, amount FROM \`${PAYMENTS_DATASET}.bank_transactions\`
     WHERE LOWER(description) LIKE '%zeffy%' AND amount < 0
     ORDER BY date DESC LIMIT 26`
  );

  const results = [];
  for (const d of bankDeposits) {
    const payoutDate = new Date(unwrap(d.date) + 'T00:00:00');
    const weekEnd = new Date(payoutDate); weekEnd.setDate(weekEnd.getDate() - 3);
    const weekStart = new Date(weekEnd); weekStart.setDate(weekStart.getDate() - 6);
    const weekEndStr = weekEnd.toISOString().slice(0, 10);
    const weekStartStr = weekStart.toISOString().slice(0, 10);

    const [[paymentTotals]] = await bigquery.query({
      query: `SELECT
                SUM(IF(campaign_id = @donationId, net_amount, 0)) / 100 AS donation_total,
                SUM(IF(campaign_id = @rentalId, net_amount, 0)) / 100 AS rental_total,
                SUM(IF(campaign_id NOT IN (@donationId, @rentalId), net_amount, 0)) / 100 AS fundraising_total,
                COUNT(*) AS txn_count
              FROM \`${PAYMENTS_DATASET}.fact_payments\`
              WHERE payment_date BETWEEN @weekStart AND @weekEnd`,
      params: { donationId: DONATION_CAMPAIGN_ID, rentalId: RENTAL_CAMPAIGN_ID, weekStart: weekStartStr, weekEnd: weekEndStr }
    });

    const buckets = [
      { label: 'Donations & Contributions', total: Math.round(Number(paymentTotals.donation_total || 0) * 100) / 100 },
      { label: 'Facility Rental Income', total: Math.round(Number(paymentTotals.rental_total || 0) * 100) / 100 },
      { label: 'Fundraising Revenue', total: Math.round(Number(paymentTotals.fundraising_total || 0) * 100) / 100 }
    ];
    const bucketsTotal = Math.round(buckets.reduce((s, b) => s + b.total, 0) * 100) / 100;
    const depositAmount = Number(d.amount);
    const isMatching = Math.abs(bucketsTotal - depositAmount) < 1;

    results.push({
      payoutDate: unwrap(d.date), depositAmount,
      weekStart: weekStartStr, weekEnd: weekEndStr,
      buckets, bucketsTotal, difference: Math.round((depositAmount - bucketsTotal) * 100) / 100,
      txnCount: paymentTotals.txn_count || 0, isMatching
    });
  }

  // Refunds — reconciled separately, matched to the nearest few days of
  // fact_refunds_outgoing activity rather than a payout window, since a
  // refund isn't on the same weekly revenue cadence as a payout.
  const refundResults = [];
  for (const r of bankRefunds) {
    const refundDate = new Date(unwrap(r.date) + 'T00:00:00');
    const windowStart = new Date(refundDate); windowStart.setDate(windowStart.getDate() - 3);
    const windowEnd = new Date(refundDate); windowEnd.setDate(windowEnd.getDate() + 1);
    const [[refundTotal]] = await bigquery.query({
      query: `SELECT SUM(amount) / 100 AS total, COUNT(*) AS count FROM \`${PAYMENTS_DATASET}.fact_refunds_outgoing\`
              WHERE outgoing_date BETWEEN @windowStart AND @windowEnd AND status != 'failed'`,
      params: { windowStart: windowStart.toISOString().slice(0, 10), windowEnd: windowEnd.toISOString().slice(0, 10) }
    });
    const expected = Math.round((Number(refundTotal.total) || 0) * 100) / 100;
    const actual = Math.abs(Number(r.amount));
    refundResults.push({
      refundDate: unwrap(r.date), bankAmount: actual, expectedFromRecords: expected,
      count: refundTotal.count || 0, isMatching: Math.abs(expected - actual) < 1
    });
  }

  res.json({ payouts: results, refunds: refundResults });
}

// ── Balance Sheet ──
// Cash comes from a running total of bank_transactions (everything recorded
// to date, signed +/-) — this is a computed figure from what's actually in
// the data, not a bank-verified balance. If the true starting balance is
// known, add it as a manual asset item below labeled something like
// "Starting balance adjustment" so the total lines up with reality.
// Everything else a real balance sheet needs (receivables, fixed assets,
// loans, deferred revenue) has no source of truth anywhere in this system —
// this interface is exactly for filling that gap by hand.
async function listBalanceSheetItems(req, res) {
  const [rows] = await bigquery.query(
    `SELECT item_id, name, category, amount, as_of_date, notes, active FROM \`${DATASET}.balance_sheet_items\` ORDER BY category, name`
  );
  const unwrap = v => (v && typeof v === 'object' && 'value' in v) ? v.value : v;
  res.json(rows.map(r => ({ ...r, amount: Number(r.amount), as_of_date: unwrap(r.as_of_date) })));
}

async function addBalanceSheetItem(req, res, actor) {
  const b = req.body || {};
  if (!b.name) return res.status(400).json({ errors: ['Name is required.'] });
  if (!['asset', 'liability'].includes(b.category)) return res.status(400).json({ errors: ['Category must be asset or liability.'] });
  if (b.amount === undefined || b.amount === null || isNaN(Number(b.amount))) return res.status(400).json({ errors: ['A numeric amount is required.'] });
  const itemId = randomUUID();
  await bigquery.query({
    query: `INSERT INTO \`${DATASET}.balance_sheet_items\` (item_id, name, category, amount, as_of_date, notes, active, created_by, created_at)
            VALUES (@itemId, @name, @category, @amount, @asOfDate, @notes, TRUE, @actorEmail, CURRENT_TIMESTAMP())`,
    params: { itemId, name: b.name, category: b.category, amount: Number(b.amount), asOfDate: b.asOfDate || null, notes: b.notes || null, actorEmail: actor.email },
    types: { amount: 'NUMERIC', asOfDate: 'DATE', notes: 'STRING' }
  });
  await logAudit({ action: 'balance_sheet_item_added', entityType: 'balance_sheet_item', entityId: itemId, actorEmail: actor.email, details: { name: b.name, category: b.category, amount: b.amount } });
  res.json({ itemId });
}

async function updateBalanceSheetItem(req, res, itemId, actor) {
  const b = req.body || {};
  const [rows] = await bigquery.query({ query: `SELECT item_id FROM \`${DATASET}.balance_sheet_items\` WHERE item_id = @itemId`, params: { itemId } });
  if (!rows.length) return res.status(404).json({ errors: ['Item not found.'] });
  const sets = []; const params = { itemId };
  if (b.name !== undefined) { sets.push('name = @name'); params.name = b.name; }
  if (b.amount !== undefined) { sets.push('amount = @amount'); params.amount = Number(b.amount); }
  if (b.active !== undefined) { sets.push('active = @active'); params.active = !!b.active; }
  if (!sets.length) return res.status(400).json({ errors: ['Nothing to update.'] });
  await bigquery.query({ query: `UPDATE \`${DATASET}.balance_sheet_items\` SET ${sets.join(', ')} WHERE item_id = @itemId`, params, types: { amount: 'NUMERIC' } });
  await logAudit({ action: 'balance_sheet_item_updated', entityType: 'balance_sheet_item', entityId: itemId, actorEmail: actor.email, details: b });
  res.json({ itemId, ok: true });
}

async function getBalanceSheet(req, res) {
  const asOfDate = (req.query && req.query.asOfDate) || new Date().toISOString().slice(0, 10);
  const [[cashRow]] = await bigquery.query({
    query: `SELECT SUM(amount) AS cash FROM \`${PAYMENTS_DATASET}.bank_transactions\` WHERE date <= @asOfDate`,
    params: { asOfDate }
  });
  const cash = Number(cashRow.cash) || 0;

  const [items] = await bigquery.query(
    `SELECT item_id, name, category, amount FROM \`${DATASET}.balance_sheet_items\` WHERE active = TRUE ORDER BY category, name`
  );
  const assets = items.filter(i => i.category === 'asset').map(i => ({ itemId: i.item_id, name: i.name, amount: Number(i.amount) }));
  const liabilities = items.filter(i => i.category === 'liability').map(i => ({ itemId: i.item_id, name: i.name, amount: Number(i.amount) }));
  const otherAssetsTotal = assets.reduce((s, a) => s + a.amount, 0);
  const liabilitiesTotal = liabilities.reduce((s, l) => s + l.amount, 0);
  const totalAssets = cash + otherAssetsTotal;
  const netAssets = totalAssets - liabilitiesTotal;

  res.json({
    asOfDate, cash: Math.round(cash * 100) / 100, assets, liabilities,
    totalAssets: Math.round(totalAssets * 100) / 100,
    totalLiabilities: Math.round(liabilitiesTotal * 100) / 100,
    netAssets: Math.round(netAssets * 100) / 100
  });
}

// ── Cross-linked invoice matching (Finance-side) ──
// Same idea as the per-booking "Find payment" in All Bookings, but flipped:
// starts from an unmatched rental-campaign Zeffy payment and searches for
// which open booking it probably belongs to. Confirming a match here is
// deliberately a SOFT link — it records which payment goes with which
// booking (so All Bookings can highlight it) but does NOT flip the booking
// to paid. That final step stays a manual Mark Paid click in All Bookings,
// on purpose — this is a suggestion, not an authority to change money status.
// GET /finance/invoice-candidates?amount=&excludeBookingId=
// Bookings whose total is close to a given transaction's amount — used by
// the attach picker, whether triggered from a Zeffy line item, a Zelle
// transaction, or an "other" bank transaction. Includes already-invoiced
// bookings too (not just open ones), since attaching after an invoice was
// already sent is a completely normal sequence.
async function getInvoiceCandidates(req, res) {
  const q = req.query || {};
  const amount = Number(q.amount);
  if (!amount) return res.status(400).json({ errors: ['amount is required.'] });
  const unwrap = v => (v && typeof v === 'object' && 'value' in v) ? v.value : v;
  const [rows] = await bigquery.query(
    `SELECT booking_id, renter_name, final_total, event_date, payment_status, invoice_sent_at
     FROM \`${DATASET}.bookings\`
     WHERE is_internal = FALSE AND payment_match_source IS NULL`
  );
  const candidates = rows
    .map(b => ({ bookingId: b.booking_id, renterName: b.renter_name, amount: Number(b.final_total), eventDate: unwrap(b.event_date), paymentStatus: b.payment_status, invoiceSentAt: unwrap(b.invoice_sent_at) }))
    .filter(b => Math.abs(b.amount - amount) < 1)
    .sort((a, b) => (a.eventDate < b.eventDate ? 1 : -1))
    .slice(0, 8);
  res.json(candidates);
}

// POST /finance/attach-invoice — the soft link, generalized to any
// transaction source (Zeffy line item, Zelle, or other bank transaction).
async function attachInvoice(req, res, actor) {
  const b = req.body || {};
  if (!b.source || !b.sourceKey || !b.bookingId || b.amount === undefined) return res.status(400).json({ errors: ['source, sourceKey, bookingId, and amount are required.'] });
  const [rows] = await bigquery.query({ query: `SELECT booking_id FROM \`${DATASET}.bookings\` WHERE booking_id = @bookingId`, params: { bookingId: b.bookingId } });
  if (!rows.length) return res.status(404).json({ errors: ['Booking not found.'] });

  const details = `${b.source} transaction $${Number(b.amount).toFixed(2)} on ${b.date || 'unknown date'} (attached via Finance)`;
  await bigquery.query({
    query: `UPDATE \`${DATASET}.bookings\` SET payment_match_source = @source, payment_match_id = @sourceKey,
            payment_match_details = @details, updated_at = CURRENT_TIMESTAMP()
            WHERE booking_id = @bookingId`,
    params: { source: b.source, sourceKey: b.sourceKey, details, bookingId: b.bookingId }
  });
  await logAudit({ action: 'invoice_attached', entityType: 'booking', entityId: b.bookingId, actorEmail: actor.email, details: { source: b.source, sourceKey: b.sourceKey, amount: b.amount } });
  res.json({ bookingId: b.bookingId, attached: true });
}

// POST /finance/detach-invoice — undo an attach, in case the wrong booking
// was picked.
async function detachInvoice(req, res, actor) {
  const b = req.body || {};
  if (!b.bookingId) return res.status(400).json({ errors: ['bookingId is required.'] });
  await bigquery.query({
    query: `UPDATE \`${DATASET}.bookings\` SET payment_match_source = NULL, payment_match_id = NULL, payment_match_details = NULL, updated_at = CURRENT_TIMESTAMP() WHERE booking_id = @bookingId`,
    params: { bookingId: b.bookingId }
  });
  await logAudit({ action: 'invoice_detached', entityType: 'booking', entityId: b.bookingId, actorEmail: actor.email, details: {} });
  res.json({ bookingId: b.bookingId, detached: true });
}

// GET /finance/invoices?startDate=&endDate=&status=
// Every invoice actually issued (invoice_sent_at set) in range — the
// single place to see attach/send/paid/receipt status across every
// invoiced booking, whether or not it's matched to a Zeffy/Zelle/other
// transaction yet. Notes shown here are read from the SAME categorization
// record a matched transaction's notes live in — editing from either
// place updates the one underlying row, not a separate copy.
async function listInvoices(req, res) {
  const q = req.query || {};
  const startDate = q.startDate || '2000-01-01';
  const endDate = q.endDate || '2100-01-01';
  const unwrap = v => (v && typeof v === 'object' && 'value' in v) ? v.value : v;

  const [rows] = await bigquery.query({
    query: `SELECT booking_id, renter_name, renter_email, event_name, event_date, final_total, payment_status,
                   invoice_sent_at, receipt_sent_at, payment_match_source, payment_match_id, payment_match_details
            FROM \`${DATASET}.bookings\`
            WHERE invoice_sent_at IS NOT NULL AND event_date BETWEEN @startDate AND @endDate
            ORDER BY invoice_sent_at DESC`,
    params: { startDate, endDate }
  });

  const [catRows] = await bigquery.query(
    `SELECT source, source_key, notes FROM \`${DATASET}.transaction_categorizations\``
  );
  const notesMap = {};
  catRows.forEach(c => { notesMap[`${c.source}|${c.source_key}`] = c.notes; });

  let invoices = rows.map(r => ({
    bookingId: r.booking_id, renterName: r.renter_name, renterEmail: r.renter_email,
    eventName: r.event_name, eventDate: unwrap(r.event_date), amount: Number(r.final_total),
    paymentStatus: r.payment_status, invoiceSentAt: unwrap(r.invoice_sent_at), receiptSentAt: unwrap(r.receipt_sent_at),
    matchSource: r.payment_match_source, matchKey: r.payment_match_id,
    notes: r.payment_match_source ? (notesMap[`${r.payment_match_source}|${r.payment_match_id}`] || null) : null
  }));

  if (q.status === 'paid') invoices = invoices.filter(i => i.paymentStatus === 'paid');
  if (q.status === 'unpaid') invoices = invoices.filter(i => i.paymentStatus !== 'paid');

  res.json(invoices);
}



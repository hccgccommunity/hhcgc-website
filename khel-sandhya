
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Khel Sandhya | Hindu Community Center of Greater Cincinnati</title>
  <meta name="description" content="Khel Sandhya is HCCGC’s community indoor games evening featuring carrom, table tennis, chess, and friendly community connection." />

  <link rel="icon" type="image/x-icon" href="favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="apple-touch-icon.png">
  <link rel="icon" type="image/svg+xml"
        href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='0.9em' x='50%25' text-anchor='middle' font-size='82'%3E%E0%A5%90%3C/text%3E%3C/svg%3E">

  <style>
    :root {
      --bg: #fff9f1;
      --surface: #ffffff;
      --surface-soft: #fff6ea;
      --border: rgba(121, 62, 17, 0.14);
      --text: #2c1b10;
      --muted: #6a5141;
      --saffron: #b55a18;
      --saffron-bright: #c65a12;
      --saffron-dark: #8d3e0d;
      --maroon: #7f2e16;
      --shadow: 0 18px 45px rgba(93, 43, 14, 0.10);
      --shadow-soft: 0 10px 28px rgba(93, 43, 14, 0.08);
      --radius: 22px;
      --max: 1220px;
      --header-offset: 110px;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top left, rgba(217, 138, 30, 0.12), transparent 22%),
        radial-gradient(circle at top right, rgba(127, 46, 22, 0.05), transparent 20%),
        var(--bg);
      line-height: 1.65;
    }

    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }
    button, input, select, textarea { font: inherit; }

    .container {
      width: min(calc(100% - 32px), var(--max));
      margin: 0 auto;
    }

    .content-width {
      width: 100%;
      max-width: 100%;
    }

    /* Keep existing HCCGC header/footer partials styled */
    .site-header {
      position: sticky;
      top: 0;
      z-index: 50;
      background: rgba(255, 249, 241, 0.92);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
    }

    .nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      min-height: 92px;
      padding: 12px 0;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 16px;
      min-width: 0;
    }

    .brand-logo-wrap {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 8px;
      box-shadow: var(--shadow);
      flex-shrink: 0;
    }

    .brand-logo {
      width: 88px;
      height: auto;
      border-radius: 12px;
      object-fit: contain;
    }

    .brand-text h1 {
      margin: 0;
      font-size: 1.2rem;
      line-height: 1.15;
      color: var(--maroon);
    }

    .site-header nav ul {
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      gap: 18px;
      margin: 0;
      padding: 0;
      align-items: center;
      justify-content: flex-end;
    }

    .site-header nav a {
      font-weight: 700;
      color: var(--text);
      font-size: 0.96rem;
    }

    .site-header nav a:hover {
      color: var(--saffron-dark);
    }

    .hero {
      position: relative;
      padding: 56px 0 28px;
      overflow: hidden;
    }

    .hero::before,
    .hero::after {
      content: "";
      position: absolute;
      width: 360px;
      height: 360px;
      border-radius: 50%;
      pointer-events: none;
      opacity: 0.8;
    }

    .hero::before {
      top: -190px;
      left: -150px;
      background: radial-gradient(circle, rgba(198, 90, 18, 0.10), transparent 68%);
    }

    .hero::after {
      right: -160px;
      bottom: -190px;
      background: radial-gradient(circle, rgba(127, 46, 22, 0.08), transparent 68%);
    }

    .hero-card {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.9fr);
      gap: 28px;
      align-items: center;
      padding: clamp(24px, 4vw, 44px);
      background:
        linear-gradient(135deg, rgba(255,255,255,0.92), rgba(255,246,234,0.92));
      border: 1px solid var(--border);
      border-radius: 30px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .hero-card::before {
      content: "ॐ";
      position: absolute;
      right: 30px;
      top: 14px;
      font-family: Georgia, "Times New Roman", serif;
      font-size: 7rem;
      line-height: 1;
      color: rgba(181, 90, 24, 0.055);
      pointer-events: none;
    }

    .section-kicker,
    .hero-kicker {
      display: inline-block;
      padding: 7px 14px;
      border-radius: 999px;
      background: rgba(217, 138, 30, 0.12);
      color: var(--saffron-dark);
      font-size: 0.83rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 8px;
    }

    .hero-title {
      margin: 8px 0 10px;
      line-height: 1.02;
      color: var(--maroon);
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(2.8rem, 6vw, 5.1rem);
      letter-spacing: -0.045em;
    }

    .hero-copy {
      margin: 0;
      color: var(--muted);
      font-size: clamp(1.05rem, 1.5vw, 1.22rem);
      max-width: 680px;
    }

    .hero-actions {
      margin-top: 24px;
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 46px;
      padding: 12px 18px;
      border-radius: 999px;
      font-weight: 800;
      border: 1px solid transparent;
      transition: transform 0.18s ease, box-shadow 0.18s ease;
    }

    .btn:hover {
      transform: translateY(-1px);
      box-shadow: 0 12px 22px rgba(93, 43, 14, 0.13);
    }

    .btn-primary {
      color: #fff;
      background: linear-gradient(135deg, var(--saffron-bright), var(--saffron-dark));
    }

    .btn-secondary {
      color: var(--saffron-dark);
      background: #fff;
      border-color: var(--border);
    }

    .hero-panel {
      display: grid;
      gap: 14px;
      position: relative;
      z-index: 1;
    }

    .quick-card,
    .game-card,
    .content-card,
    .expect-card,
    .join-card,
    .info-card {
      background: rgba(255,255,255,0.88);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow-soft);
    }

    .quick-card {
      padding: 18px;
    }

    .quick-card h2 {
      margin: 0 0 6px;
      color: var(--maroon);
      font-family: Georgia, "Times New Roman", serif;
      font-size: 1.35rem;
      line-height: 1.2;
    }

    .quick-card p {
      margin: 0;
      color: var(--muted);
      font-size: 0.98rem;
    }

    .game-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }

    .game-card {
      min-height: 72px;
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 14px;
      font-weight: 800;
      color: var(--saffron-dark);
      background: var(--surface-soft);
    }

    .game-icon {
      width: 30px;
      height: 30px;
      flex: 0 0 30px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: var(--saffron-bright);
    }

    .game-icon svg {
      width: 30px;
      height: 30px;
      display: block;
    }

    .game-emoji {
      font-size: 1.55rem;
      line-height: 1;
      color: var(--saffron-bright);
    }

    .section {
      padding: 42px 0;
      scroll-margin-top: var(--header-offset);
    }

    .section-head {
      margin-bottom: 24px;
      text-align: center;
    }

    .section-head h2 {
      margin: 8px 0 10px;
      line-height: 1.2;
      color: var(--maroon);
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(2rem, 3.4vw, 3rem);
    }

    .section-copy {
      margin: 0 auto;
      color: var(--muted);
      font-size: 1.05rem;
      max-width: 820px;
      text-align: center;
    }

    .about-grid {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      gap: 24px;
      align-items: stretch;
    }

    .content-card {
      padding: clamp(24px, 3vw, 34px);
    }

    .content-card p {
      margin: 0 0 16px;
      color: var(--muted);
      font-size: 1.04rem;
    }

    .content-card p:last-child {
      margin-bottom: 0;
    }

    .highlight-line {
      padding: 16px 18px;
      border-left: 5px solid var(--saffron-bright);
      background: var(--surface-soft);
      border-radius: 16px;
      margin-top: 18px;
      color: var(--maroon);
      font-weight: 800;
    }

    .side-stack {
      display: grid;
      gap: 18px;
    }

    .expect-card,
    .join-card {
      padding: 22px;
    }

    .expect-card h3,
    .join-card h3 {
      margin: 0 0 14px;
      font-size: 1.55rem;
      line-height: 1.2;
      font-family: Georgia, "Times New Roman", serif;
      color: var(--maroon);
    }

    .clean-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 12px;
    }

    .clean-list li {
      display: grid;
      grid-template-columns: 28px 1fr;
      gap: 10px;
      color: var(--muted);
      align-items: start;
    }

    .clean-list li::before {
      content: "✓";
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background: rgba(198, 90, 18, 0.12);
      color: var(--saffron-dark);
      font-weight: 900;
      line-height: 1;
      margin-top: 2px;
    }

    .info-band {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
      margin-top: 24px;
    }

    .info-card {
      background: #fff;
      border-radius: 20px;
      padding: 20px;
      text-align: center;
    }

    .info-icon {
      font-size: 2rem;
      margin-bottom: 8px;
      color: var(--saffron-bright);
    }

    .info-card h3 {
      margin: 0 0 4px;
      color: var(--maroon);
      font-size: 1.05rem;
    }

    .info-card p {
      margin: 0;
      color: var(--muted);
      font-size: 0.95rem;
    }

    .form-section {
      padding-top: 24px;
    }

    .form-intro {
      max-width: 1040px;
      margin: 0 auto 18px;
      text-align: center;
      padding: 24px 26px;
      background:
        linear-gradient(135deg, rgba(198, 90, 18, 0.10), rgba(255, 246, 234, 0.9));
      border: 1px solid var(--border);
      border-radius: 26px;
      box-shadow: var(--shadow-soft);
    }

    .form-intro h2 {
      margin: 0 0 8px;
      color: var(--maroon);
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(1.8rem, 3vw, 2.45rem);
    }

    .form-intro p {
      margin: 0 auto;
      color: var(--muted);
      max-width: 720px;
    }

    /* Seamless Zeffy area: no white wrapper/card sides */
    .embed-card {
      overflow: visible;
      background: transparent;
      border-radius: 0;
      box-shadow: none;
      border: 0;
      max-width: 1040px;
      margin: 0 auto;
    }

    .embed-frame {
      position: relative;
      overflow: hidden;
      min-height: 680px;
      width: 100%;
      background: transparent;
    }

    .embed-frame [data-zeffy-embed] {
      width: 100%;
      min-height: 680px;
      background: transparent;
    }

    .embed-frame iframe {
      width: 100%;
      height: 680px;
      border: 0;
      background: transparent;
      display: block;
    }

    .site-footer .footer-top {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: 24px;
      padding: 8px 0 0;
    }

    .site-footer .footer-nav {
      display: flex;
      justify-content: flex-start;
      min-width: 0;
    }

    .site-footer .footer-nav ul {
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin: 0;
      padding: 0;
      justify-content: flex-start;
      align-items: center;
    }

    .site-footer .footer-nav a {
      font-weight: 700;
      color: var(--text);
      font-size: 0.95rem;
    }

    .site-footer .footer-nav a:hover {
      color: var(--saffron-dark);
    }

    .site-footer .footer-email {
      text-align: center;
      font-weight: 700;
      color: var(--text);
      white-space: nowrap;
    }

    .site-footer .footer-email a:hover {
      color: var(--saffron-dark);
    }

    .site-footer .footer-social {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 12px;
      min-width: 220px;
      color: var(--text);
      font-weight: 700;
    }

    .site-footer .footer-social-label {
      white-space: nowrap;
    }

    .site-footer .social-icons {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .site-footer .social-icon {
      width: 42px;
      height: 42px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      background: #fff;
      border: 1px solid var(--border);
      box-shadow: 0 6px 18px rgba(93, 43, 14, 0.10);
      transition: transform 0.18s ease, box-shadow 0.18s ease;
    }

    .site-footer .social-icon:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 22px rgba(93, 43, 14, 0.16);
    }

    .site-footer .social-icon svg {
      width: 20px;
      height: 20px;
      display: block;
    }

    .site-footer .footer-note {
      margin-top: 18px;
      padding-top: 18px;
      border-top: 1px solid var(--border);
      color: var(--muted);
      font-size: 0.7rem;
      text-align: center;
    }

    .site-footer .copyright-links a {
      text-decoration: none;
    }

    @media (max-width: 1120px) {
      .site-footer .footer-top {
        grid-template-columns: 1fr;
        justify-items: start;
      }

      .site-footer .footer-email,
      .site-footer .footer-social {
        text-align: left;
        justify-content: flex-start;
      }
    }

    @media (max-width: 980px) {
      .hero-card,
      .about-grid {
        grid-template-columns: 1fr;
      }

      .info-band,
      .game-row {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 860px) {
      .nav {
        flex-direction: column;
        align-items: flex-start;
      }

      .site-header nav ul {
        justify-content: flex-start;
        gap: 14px;
      }

      .brand-logo {
        width: 74px;
      }

      .section {
        padding: 34px 0;
      }

      .hero {
        padding: 38px 0 22px;
      }
    }

    @media (max-width: 640px) {
      .container {
        width: min(calc(100% - 24px), var(--max));
      }

      .hero-card {
        border-radius: 24px;
        padding: 22px;
      }

      .hero-actions .btn {
        width: 100%;
      }

      .embed-frame,
      .embed-frame [data-zeffy-embed],
      .embed-frame iframe {
        min-height: 760px;
        height: 760px;
      }
    }
  </style>
</head>
<body>
  <div id="header-placeholder"></div>

  <main>
    <section class="hero">
      <div class="container">
        <div class="hero-card">
          <div>
            <span class="hero-kicker">HCCGC Community Initiative</span>
            <h1 class="hero-title">Khel Sandhya</h1>
            <p class="hero-copy">
              A warm community evening of indoor games, friendly competition, and meaningful connection.
            </p>
            <div class="hero-actions">
              <a class="btn btn-primary" href="#rsvp">RSVP / Register</a>
              <a class="btn btn-secondary" href="#about">Learn More</a>
            </div>
          </div>

          <div class="hero-panel">
            <div class="quick-card">
              <h2>Come for the games. Stay for the community.</h2>
              <p>
                Enjoy structured play, meet fellow community members, and be part of a welcoming HCCGC gathering.
              </p>
            </div>

            <div class="game-row" aria-label="Featured games">
              <div class="game-card">
                <span class="game-emoji">🏓</span>
                <span>Table Tennis</span>
              </div>

              <div class="game-card">
                <span class="game-icon" aria-hidden="true">
                  <svg viewBox="0 0 100 100" fill="none" role="img">
                    <circle cx="68" cy="68" r="18" stroke="currentColor" stroke-width="6"/>
                    <circle cx="68" cy="68" r="6" fill="currentColor"/>
                    <circle cx="31" cy="34" r="11" stroke="currentColor" stroke-width="5"/>
                    <circle cx="53" cy="29" r="11" stroke="currentColor" stroke-width="5"/>
                    <path d="M42 46 L59 60" stroke="currentColor" stroke-width="5" stroke-linecap="round"/>
                  </svg>
                </span>
                <span>Carrom</span>
              </div>

              <div class="game-card">
                <span class="game-emoji">♟</span>
                <span>Chess</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="about" class="section">
      <div class="container">
        <div class="section-head">
          <span class="section-kicker">About the initiative</span>
          <h2>What is Khel Sandhya?</h2>
          <p class="section-copy">
            Khel Sandhya is HCCGC’s signature community evening dedicated to bringing people together through simple, engaging indoor games.
          </p>
        </div>

        <div class="about-grid">
          <article class="content-card">
            <p>
              Designed for participants across age groups, Khel Sandhya offers a welcoming space to unwind, connect, and enjoy friendly competition.
            </p>
            <p>
              From classic games like carrom, table tennis, and chess, to moments of laughter and camaraderie, Khel Sandhya is less about winning and more about building a sense of belonging within our community.
            </p>
            <p>
              Each session is thoughtfully organized with structured formats such as knockout tournaments, ensuring fair play, minimal wait times, and an engaging experience for all participants. Whether you are a seasoned player or just looking to have a good time, there is something for everyone.
            </p>
            <div class="highlight-line">
              Beyond the games, Khel Sandhya reflects HCCGC’s larger vision — creating a space where our community can come together, connect, and feel at home.
            </div>
          </article>

          <div class="side-stack">
            <article class="expect-card">
              <h3>What to Expect</h3>
              <ul class="clean-list">
                <li>Organized gameplay with simple formats</li>
                <li>Opportunities to participate or simply watch and socialize</li>
                <li>A friendly, respectful, and family-friendly environment</li>
                <li>Well-managed schedules designed to maximize playtime</li>
                <li>A chance to meet and connect with fellow community members</li>
              </ul>
            </article>

            <article class="join-card">
              <h3>Who Can Join</h3>
              <ul class="clean-list">
                <li>Open to participants 12 years and above</li>
                <li>Suitable for all skill levels — beginners to experienced players</li>
                <li>Games may vary by session based on community interest</li>
              </ul>
            </article>
          </div>
        </div>

        <div class="info-band">
          <div class="info-card">
            <div class="info-icon">🤝</div>
            <h3>Community First</h3>
            <p>A relaxed space to build connections and enjoy time together.</p>
          </div>
          <div class="info-card">
            <div class="info-icon">🏆</div>
            <h3>Friendly Play</h3>
            <p>Structured formats that keep the evening engaging and fair.</p>
          </div>
          <div class="info-card">
            <div class="info-icon">🏠</div>
            <h3>HCCGC Spirit</h3>
            <p>A space our community can call its own.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="rsvp" class="section form-section">
      <div class="container">
        <div class="form-intro">
          <h2>Join the Next Khel Sandhya</h2>
          <p>
            Please complete the RSVP form below. Details and available games may vary by session.
          </p>
        </div>

        <div class="embed-card">
          <div class="embed-frame">
            <div data-zeffy-embed data-form-url="/embed/ticketing/khel-sandhya-ravps-for--58"></div>
            <div data-zeffy-embed-fallback style="display:none;">
              <iframe title="Khel Sandhya RSVP form powered by Zeffy"
                      src="https://www.zeffy.com/embed/ticketing/khel-sandhya-ravps-for--58"
                      allowpaymentrequest
                      allowTransparency="true"></iframe>
            </div>
          </div>
        </div>

        <script
          src="https://www.zeffy.com/embed/v2/zeffy-embed.js"
          onerror="document.querySelectorAll('[data-zeffy-embed-fallback]').forEach(function(el){el.style.display='block';});">
        </script>
      </div>
    </section>
  </main>

  <div id="footer-placeholder"></div>

  <script>
    async function loadPartial(placeholderId, filePath) {
      const target = document.getElementById(placeholderId);
      if (!target) return;
      try {
        const response = await fetch(filePath);
        if (!response.ok) throw new Error("Unable to load " + filePath);
        target.innerHTML = await response.text();
      } catch (error) {
        console.error(error);
        target.innerHTML = "";
      }
    }

    async function initializePage() {
      await loadPartial("header-placeholder", "header.html");
      await loadPartial("footer-placeholder", "footer.html");

      const year = document.getElementById("year");
      if (year) {
        year.textContent = new Date().getFullYear();
      }
    }

    initializePage();
  </script>
</body>
</html>

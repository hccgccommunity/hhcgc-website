  <style>
    :root {
      --bg: #fff9f1;
      --surface: #ffffff;
      --surface-soft: #fff6ea;
      --border: rgba(121, 62, 17, 0.14);
      --text: #2c1b10;
      --muted: #6a5141;
      --saffron: #b55a18;
      --saffron-bright: #c65a12;
      --saffron-dark: #8d3e0d;
      --maroon: #7f2e16;
      --shadow: 0 18px 45px rgba(93, 43, 14, 0.10);
      --shadow-soft: 0 10px 28px rgba(93, 43, 14, 0.08);
      --radius: 22px;
      --max: 1220px;
      --header-offset: 110px;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top left, rgba(217, 138, 30, 0.12), transparent 22%),
        radial-gradient(circle at top right, rgba(127, 46, 22, 0.05), transparent 20%),
        var(--bg);
      line-height: 1.65;
    }

    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }
    button, input, select, textarea { font: inherit; }

    .container {
      width: min(calc(100% - 32px), var(--max));
      margin: 0 auto;
    }

    /* ── SITE HEADER ── */
    .site-header {
      position: sticky;
      top: 0;
      z-index: 50;
      background: rgba(255, 249, 241, 0.92);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
    }

    .nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      min-height: 92px;
      padding: 12px 0;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 16px;
      min-width: 0;
    }

    .brand-logo-wrap {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 8px;
      box-shadow: var(--shadow);
      flex-shrink: 0;
    }

    .brand-logo {
      width: 88px;
      height: auto;
      border-radius: 12px;
      object-fit: contain;
    }

    .brand-text h1 {
      margin: 0;
      font-size: 1.2rem;
      line-height: 1.15;
      color: var(--maroon);
    }

    .site-header nav ul {
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      gap: 18px;
      margin: 0;
      padding: 0;
      align-items: center;
      justify-content: flex-end;
    }

    .site-header nav a {
      font-weight: 700;
      color: var(--text);
      font-size: 0.96rem;
    }

    .site-header nav a:hover { color: var(--saffron-dark); }
    .site-header nav a.active { color: var(--saffron-bright); }

    /* ── HERO ── */
    .hero {
      position: relative;
      padding: 56px 0 28px;
      overflow: hidden;
    }

    .hero::before,
    .hero::after {
      content: "";
      position: absolute;
      width: 360px;
      height: 360px;
      border-radius: 50%;
      pointer-events: none;
      opacity: 0.8;
    }

    .hero::before {
      top: -190px;
      left: -150px;
      background: radial-gradient(circle, rgba(198, 90, 18, 0.10), transparent 68%);
    }

    .hero::after {
      right: -160px;
      bottom: -190px;
      background: radial-gradient(circle, rgba(127, 46, 22, 0.08), transparent 68%);
    }

    .hero-card {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
      gap: 28px;
      align-items: center;
      padding: clamp(24px, 4vw, 44px);
      background: linear-gradient(135deg, rgba(255,255,255,0.92), rgba(255,246,234,0.92));
      border: 1px solid var(--border);
      border-radius: 30px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .hero-kicker {
      display: inline-block;
      padding: 7px 14px;
      border-radius: 999px;
      background: rgba(217, 138, 30, 0.12);
      color: var(--saffron-dark);
      font-size: 0.83rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 8px;
    }

    .hero-title {
      margin: 8px 0 6px;
      line-height: 1.02;
      color: var(--maroon);
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(2.4rem, 5vw, 4.2rem);
      letter-spacing: -0.03em;
    }

    .hero-title-sub {
      display: block;
      font-size: clamp(1rem, 1.8vw, 1.35rem);
      color: var(--saffron-dark);
      letter-spacing: 0.06em;
      margin-top: 6px;
      font-style: normal;
      font-weight: 600;
      opacity: 0.8;
      text-transform: uppercase;
    }

    .hero-tagline {
      margin: 10px 0 18px;
      color: var(--muted);
      font-size: 1.08rem;
      font-style: italic;
    }

    .hero-copy {
      margin: 0;
      color: var(--muted);
      font-size: clamp(1rem, 1.4vw, 1.12rem);
      max-width: 640px;
      line-height: 1.7;
    }

    .hero-actions {
      margin-top: 24px;
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 46px;
      padding: 12px 22px;
      border-radius: 999px;
      font-weight: 800;
      border: 1px solid transparent;
      transition: transform 0.18s ease, box-shadow 0.18s ease;
      cursor: pointer;
    }

    .btn:hover {
      transform: translateY(-1px);
      box-shadow: 0 12px 22px rgba(93, 43, 14, 0.13);
    }

    .btn-primary {
      color: #fff;
      background: linear-gradient(135deg, var(--saffron-bright), var(--saffron-dark));
    }

    .btn-secondary {
      color: var(--saffron-dark);
      background: #fff;
      border-color: var(--border);
    }

    .hero-panel {
      display: grid;
      gap: 14px;
      position: relative;
      z-index: 1;
    }

    .quick-card {
      background: rgba(255,255,255,0.88);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow-soft);
      padding: 18px 20px;
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .quick-card-icon {
      font-size: 1.6rem;
      flex-shrink: 0;
      line-height: 1;
    }

    .quick-card-body h3 {
      margin: 0 0 3px;
      color: var(--maroon);
      font-family: Georgia, "Times New Roman", serif;
      font-size: 0.88rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .quick-card-body p {
      margin: 0;
      color: var(--text);
      font-size: 1rem;
      font-weight: 700;
      line-height: 1.3;
    }

    .quick-card-body p small {
      display: block;
      font-size: 0.8rem;
      font-weight: 400;
      color: var(--muted);
      margin-top: 2px;
    }

    /* ── SECTIONS ── */
    .section {
      padding: 42px 0;
      scroll-margin-top: var(--header-offset);
    }

    .section-head {
      margin-bottom: 24px;
      text-align: center;
    }

    .section-kicker {
      display: inline-block;
      padding: 7px 14px;
      border-radius: 999px;
      background: rgba(217, 138, 30, 0.12);
      color: var(--saffron-dark);
      font-size: 0.83rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 8px;
    }

    .section-head h2 {
      margin: 8px 0 10px;
      line-height: 1.2;
      color: var(--maroon);
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(2rem, 3.4vw, 3rem);
    }

    .section-copy {
      margin: 0 auto;
      color: var(--muted);
      font-size: 1.05rem;
      max-width: 100%;
      text-align: center;
    }

    /* ── INFO BAND ── */
    .info-band {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-top: 24px;
    }

    .info-card {
      background: rgba(255,255,255,0.88);
      border: 1px solid var(--border);
      border-radius: 20px;
      box-shadow: var(--shadow-soft);
      padding: 20px;
      text-align: center;
    }

    .info-icon {
      font-size: 2rem;
      margin-bottom: 8px;
      color: var(--saffron-bright);
    }

    .info-card h3 {
      margin: 0 0 4px;
      color: var(--maroon);
      font-size: 1.05rem;
    }

    .info-card p {
      margin: 0;
      color: var(--muted);
      font-size: 0.95rem;
    }

    /* ── ABOUT ── */
    .about-grid {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      gap: 24px;
      align-items: stretch;
    }

    .content-card,
    .expect-card,
    .join-card {
      background: rgba(255,255,255,0.88);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow-soft);
    }

    .content-card {
      padding: clamp(24px, 3vw, 34px);
    }

    .content-card p {
      margin: 0 0 16px;
      color: var(--muted);
      font-size: 1.04rem;
    }

    .content-card p:last-child { margin-bottom: 0; }

    .highlight-line {
      padding: 16px 18px;
      border-left: 5px solid var(--saffron-bright);
      background: var(--surface-soft);
      border-radius: 16px;
      margin-top: 18px;
      color: var(--maroon);
      font-weight: 800;
    }

    .side-stack { display: grid; gap: 18px; }

    .expect-card,
    .join-card { padding: 22px; }

    .expect-card h3,
    .join-card h3 {
      margin: 0 0 14px;
      font-size: 1.55rem;
      line-height: 1.2;
      font-family: Georgia, "Times New Roman", serif;
      color: var(--maroon);
    }

    .clean-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 12px;
    }

    .clean-list li {
      display: grid;
      grid-template-columns: 28px 1fr;
      gap: 10px;
      color: var(--muted);
      align-items: start;
    }

    .clean-list li::before {
      content: "✓";
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background: rgba(198, 90, 18, 0.12);
      color: var(--saffron-dark);
      font-weight: 900;
      line-height: 1;
      margin-top: 2px;
    }

    /* ── HIGHLIGHTS ROW ── */
    .highlights-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-top: 0;
    }

    .highlight-card {
      background: rgba(255,255,255,0.88);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow-soft);
      padding: 24px 20px;
      text-align: center;
    }

    .highlight-card-icon {
      font-size: 2.2rem;
      margin-bottom: 10px;
      line-height: 1;
    }

    .highlight-card h3 {
      margin: 0 0 6px;
      color: var(--maroon);
      font-family: Georgia, "Times New Roman", serif;
      font-size: 1rem;
      font-weight: 700;
      line-height: 1.25;
    }

    .highlight-card p {
      margin: 0;
      color: var(--muted);
      font-size: 0.88rem;
      line-height: 1.5;
    }

    /* ── TICKETS ── */
    .form-section {
      padding-top: 24px;
      padding-bottom: 0;
    }

    .form-intro {
      max-width: 100%;
      margin: 0;
      text-align: center;
      padding: 24px 26px;
      background: linear-gradient(135deg, rgba(198, 90, 18, 0.10), rgba(255, 246, 234, 0.9));
      border: 1px solid var(--border);
      border-radius: 26px;
      box-shadow: var(--shadow-soft);
    }

    .form-intro h2 {
      margin: 0 0 8px;
      color: var(--maroon);
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(1.8rem, 3vw, 2.45rem);
    }

    .form-intro p {
      margin: 0 auto;
      color: var(--muted);
      max-width: 100%;
    }

    .form-notices {
      display: grid;
      gap: 10px;
      margin-top: 16px;
      text-align: left;
    }

    .form-notice {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      background: rgba(255,255,255,0.7);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 12px 16px;
      font-size: 0.95rem;
      color: var(--muted);
      line-height: 1.55;
    }

    .form-notice-icon {
      font-size: 1.1rem;
      flex-shrink: 0;
      margin-top: 1px;
    }

    /* Two-column: flyer left, Zeffy right */
    .tickets-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 28px;
      align-items: stretch;
      margin-top: 24px;
    }

    .tickets-flyer { display: flex; }

    .tickets-flyer .flyer-frame {
      border-radius: 20px;
      overflow: hidden;
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
      position: sticky;
      top: calc(var(--header-offset) + 16px);
      width: 100%;
    }

    .tickets-flyer .flyer-frame img {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
    }

    .embed-card {
      overflow: visible;
      background: transparent;
      border-radius: 0;
      box-shadow: none;
      border: 0;
      max-width: 100%;
      margin: 0;
      padding: 0;
    }

    .zeffy-responsive-frame {
      position: relative;
      overflow: hidden;
      height: 0;
      width: 100%;
      padding-top: 1250px;
      background: transparent;
    }

    .zeffy-responsive-frame iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: 0;
      background: transparent;
      display: block;
      overflow: hidden;
    }

    /* ── FOOTER ── */
    .site-footer .footer-top {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: 24px;
      padding: 8px 0 0;
    }

    .site-footer .footer-nav { display: flex; justify-content: flex-start; min-width: 0; }
    .site-footer .footer-nav ul { list-style: none; display: flex; flex-wrap: wrap; gap: 10px; margin: 0; padding: 0; }
    .site-footer .footer-nav a { font-weight: 700; color: var(--text); font-size: 0.95rem; }
    .site-footer .footer-nav a:hover { color: var(--saffron-dark); }
    .site-footer .footer-email { text-align: center; font-weight: 700; color: var(--text); white-space: nowrap; }
    .site-footer .footer-email a:hover { color: var(--saffron-dark); }
    .site-footer .footer-social { display: flex; align-items: center; justify-content: flex-end; gap: 12px; min-width: 220px; color: var(--text); font-weight: 700; }
    .site-footer .footer-social-label { white-space: nowrap; }
    .site-footer .social-icons { display: flex; align-items: center; gap: 10px; }
    .site-footer .social-icon { width: 42px; height: 42px; display: inline-flex; align-items: center; justify-content: center; border-radius: 50%; background: #fff; border: 1px solid var(--border); box-shadow: 0 6px 18px rgba(93,43,14,.10); transition: transform 0.18s ease, box-shadow 0.18s ease; }
    .site-footer .social-icon:hover { transform: translateY(-2px); box-shadow: 0 10px 22px rgba(93,43,14,.16); }
    .site-footer .social-icon svg { width: 20px; height: 20px; display: block; }
    .site-footer .footer-note { margin-top: 18px; padding-top: 18px; border-top: 1px solid var(--border); color: var(--muted); font-size: 0.7rem; text-align: center; }
    .site-footer .copyright-links a { text-decoration: none; }

    /* ── RESPONSIVE ── */
    @media (max-width: 1120px) {
      .site-footer .footer-top { grid-template-columns: 1fr; justify-items: start; }
      .site-footer .footer-email, .site-footer .footer-social { text-align: left; justify-content: flex-start; }
    }

    @media (max-width: 980px) {
      .hero-card { grid-template-columns: 1fr; }
      .about-grid { grid-template-columns: 1fr; }
      .info-band { grid-template-columns: repeat(2, 1fr); }
      .highlights-row { grid-template-columns: repeat(2, 1fr); }
      .tickets-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 860px) {
      .nav { flex-direction: column; align-items: flex-start; }
      .site-header nav ul { justify-content: flex-start; gap: 14px; }
      .brand-logo { width: 74px; }
      .section { padding: 34px 0; }
      .hero { padding: 38px 0 22px; }
    }

    @media (max-width: 640px) {
      .container { width: min(calc(100% - 24px), var(--max)); }
      .hero-card { border-radius: 24px; padding: 22px; }
      .info-band { grid-template-columns: repeat(2, 1fr); }
      .highlights-row { grid-template-columns: 1fr 1fr; }
      .hero-actions .btn { width: 100%; }
    }
  </style>
</head>

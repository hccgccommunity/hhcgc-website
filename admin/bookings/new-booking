  document.getElementById('recurring-fields').classList.remove('open');
  document.getElementById('f-internal-enabled').checked = false;
  document.getElementById('f-publish-event').checked = true;
  document.getElementById('f-internal-enabled').dispatchEvent(new Event('change'));
  document.querySelectorAll('.room-cb').forEach(function (cb) { cb.checked = false; });
  occurrences = [];
  renderOccTable();
  recalc();
}


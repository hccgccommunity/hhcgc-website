<style>
:root{--bg:#fff9f1;--surface:#fff;--surface-soft:#fff6ea;--border:rgba(121,62,17,0.14);--text:#2c1b10;--muted:#6a5141;--saffron:#b55a18;--saffron-dark:#8d3e0d;--maroon:#7f2e16;--shadow:0 18px 45px rgba(93,43,14,0.10);}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{font-family:Arial,Helvetica,sans-serif;background:radial-gradient(circle at top left,rgba(217,138,30,0.12),transparent 22%),radial-gradient(circle at top right,rgba(127,46,22,0.05),transparent 20%),var(--bg);color:var(--text);min-height:100vh;}
.container{width:min(calc(100% - 32px),1200px);margin:0 auto;}
.site-header{position:sticky;top:0;z-index:50;background:rgba(255,249,241,0.92);backdrop-filter:blur(10px);border-bottom:1px solid var(--border);}
.nav{display:flex;align-items:center;justify-content:space-between;gap:24px;min-height:92px;padding:12px 0;}
.brand{display:flex;align-items:center;gap:16px;min-width:0;}
.brand-logo-wrap{background:#7f2e16;border-radius:18px;padding:8px;flex-shrink:0;}
.brand-logo{width:88px;height:auto;border-radius:12px;object-fit:contain;}
.brand-text h1{margin:0;font-size:1.2rem;line-height:1.15;color:var(--maroon);font-family:Georgia,serif;}
.site-header a.brand,.site-header a.brand:link,.site-header a.brand:visited{text-decoration:none;color:inherit;}
.site-header nav ul{list-style:none;display:flex;flex-wrap:wrap;gap:18px;margin:0;padding:0;align-items:center;justify-content:flex-end;}
.site-header nav a,.site-header nav a:link,.site-header nav a:visited{font-weight:700;color:var(--text);font-size:0.96rem;text-decoration:none;}
.site-header nav a:hover{color:var(--saffron-dark);}
.menu-toggle{display:none;border:0;background:transparent;padding:6px 0;cursor:pointer;color:#2c1b10;align-self:flex-end;}
.menu-toggle .bar{display:block;width:26px;height:2px;margin:5px 0;background:currentColor;}
@media(max-width:768px){.nav{flex-direction:column;align-items:stretch;gap:8px;}.menu-toggle{display:inline-block;}.site-header nav{display:none;width:100%;background:rgba(255,249,241,0.95);padding:10px 0;}.site-header nav.is-open{display:block;}.site-header nav ul{flex-direction:column;gap:14px;}}
.page-hero{padding:44px 0 32px;text-align:center;}
.section-kicker{display:inline-block;padding:6px 14px;border-radius:999px;background:rgba(217,138,30,0.12);color:var(--saffron-dark);font-size:.78rem;font-weight:800;text-transform:uppercase;letter-spacing:.06em;margin-bottom:12px;}
.page-hero h1{font-family:Georgia,serif;font-size:clamp(1.8rem,4vw,2.6rem);color:var(--maroon);margin-bottom:10px;}
.page-hero p{color:var(--muted);font-size:.95rem;max-width:540px;margin:0 auto 20px;}
.hero-actions{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;}
.btn-primary{display:inline-flex;align-items:center;gap:8px;padding:.7rem 1.4rem;background:var(--maroon);color:#fff;border:none;border-radius:999px;font-size:.9rem;font-weight:700;text-decoration:none;cursor:pointer;}
.btn-primary:hover{background:#5a1e0a;}
.btn-secondary{display:inline-flex;align-items:center;gap:8px;padding:.7rem 1.4rem;background:#fff;color:var(--saffron-dark);border:1.5px solid var(--border);border-radius:999px;font-size:.9rem;font-weight:700;text-decoration:none;}
.btn-secondary:hover{border-color:var(--saffron);background:var(--surface-soft);}
.rooms-strip{padding:0 0 28px;}
.legend-label{font-size:.78rem;font-weight:800;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);margin-bottom:10px;}
.rooms-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;}
.room-info-card{background:#fff;border:1px solid var(--border);border-radius:16px;padding:1.2rem 1.4rem;text-align:center;box-shadow:0 4px 14px rgba(93,43,14,.06);display:flex;flex-direction:column;align-items:center;gap:8px;}
.room-color-swatch{width:32px;height:10px;border-radius:999px;flex-shrink:0;}
.room-info-card h3{font-family:Georgia,serif;font-size:1rem;color:var(--maroon);margin:0;}
.room-info-card p{font-size:.78rem;color:var(--muted);margin:0;}
.calendar-wrap{background:#fff;border:1px solid var(--border);border-radius:22px;overflow:hidden;box-shadow:var(--shadow);margin-bottom:48px;}
.calendar-wrap iframe{width:100%;border:0;display:block;min-height:680px;}
@media(max-width:700px){.rooms-grid{grid-template-columns:1fr 1fr;}.calendar-wrap iframe{min-height:500px;}}
</style>

<style>
:root {
  --bg: #fff9f1;
  --surface: #ffffff;
  --surface-soft: #fff6ea;
  --border: rgba(121,62,17,0.14);
  --text: #2c1b10;
  --muted: #6a5141;
  --saffron: #b55a18;
  --saffron-dark: #8d3e0d;
  --maroon: #7f2e16;
  --radius: 22px;
  --shadow: 0 18px 45px rgba(93,43,14,0.10);
  --green: #2e7d4f;
  --green-bg: #e8f5ec;
  --amber: #a15c00;
  --amber-bg: #fdf1de;
  --grey-bg: #f1ede8;
  --red: #b3382c;
  --red-bg: #fbe9e7;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: Arial, Helvetica, sans-serif;
  background:
    radial-gradient(circle at top left, rgba(217,138,30,0.12), transparent 22%),
    radial-gradient(circle at top right, rgba(127,46,22,0.05), transparent 20%),
    var(--bg);
  color: var(--text);
  min-height: 100vh;
}
.container { width: min(calc(100% - 32px), 1200px); margin: 0 auto; }

/* Header partial styling, copied from portal shell so header.html renders identically */
.site-header { position: sticky; top: 0; z-index: 50; background: rgba(255,249,241,0.92); backdrop-filter: blur(10px); border-bottom: 1px solid var(--border); }
.nav { display: flex; align-items: center; justify-content: space-between; gap: 24px; min-height: 92px; padding: 12px 0; }
.site-header a.brand, .site-header a.brand:link, .site-header a.brand:visited { text-decoration: none; color: inherit; }
.brand { display: flex; align-items: center; gap: 16px; min-width: 0; }
.brand-logo-wrap { background: #fff; border: 1px solid var(--border); border-radius: 18px; padding: 8px; box-shadow: var(--shadow); flex-shrink: 0; }
.brand-logo { width: 88px; height: auto; border-radius: 12px; object-fit: contain; }
.brand-text h1 { margin: 0; font-size: 1.2rem; line-height: 1.15; color: var(--maroon); }
.site-header nav ul { list-style: none; display: flex; flex-wrap: wrap; gap: 18px; margin: 0; padding: 0; align-items: center; justify-content: flex-end; }
.site-header nav a, .site-header nav a:link, .site-header nav a:visited { font-weight: 700; color: var(--text); font-size: 0.96rem; text-decoration: none; }
.site-header nav a:hover { color: var(--saffron-dark); }
.menu-toggle { display: none; border: 0; background: transparent; padding: 6px 0; cursor: pointer; color: #2c1b10; align-self: flex-end; }
.menu-toggle .bar { display: block; width: 26px; height: 2px; margin: 5px 0; background: currentColor; }
@media (max-width: 768px) {
  .nav { flex-direction: column; align-items: stretch; gap: 8px; }
  .menu-toggle { display: inline-block; }
  .site-header nav { display: none; width: 100%; background: rgba(255,249,241,0.95); padding: 10px 0; }
  .site-header nav.is-open { display: block; }
  .site-header nav ul { flex-direction: column; gap: 14px; }
}

/* Page hero */
.page-hero { padding: 40px 0 28px; background: linear-gradient(135deg, var(--maroon) 0%, #4e1a09 100%); color: #fff; position: relative; }
.page-hero .eyebrow { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(255,255,255,0.75); margin-bottom: 6px; }
.page-hero h1 { font-family: Georgia, "Times New Roman", serif; font-size: 1.9rem; color: #fff; margin-bottom: 6px; }
.page-hero p { color: #ffffff; opacity: 0.9; font-size: 0.92rem; max-width: 560px; }

/* Sub-nav across the Facility Bookings module */
.module-nav { background: var(--surface); border-bottom: 1px solid var(--border); }
.module-nav ul { list-style: none; display: flex; gap: 4px; padding: 10px 0; flex-wrap: wrap; }
.module-nav a {
  display: inline-block; padding: 8px 16px; border-radius: 999px; font-size: 0.86rem; font-weight: 700;
  color: var(--muted); text-decoration: none; transition: background 0.15s, color 0.15s;
}
.module-nav a.active { background: var(--surface-soft); color: var(--saffron-dark); }
.module-nav a.disabled { color: rgba(106,81,65,0.4); cursor: default; }
.module-nav a:not(.disabled):not(.active):hover { background: var(--surface-soft); }

/* Toolbar */
.toolbar { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; padding: 24px 0 16px; }
.toolbar input[type="text"], .toolbar select {
  font-family: Arial, Helvetica, sans-serif; font-size: 0.88rem; padding: 9px 14px;
  border: 1.5px solid var(--border); border-radius: 10px; background: var(--surface); color: var(--text);
}
.toolbar input[type="text"] { flex: 1; min-width: 200px; }
.toolbar .count { margin-left: auto; font-size: 0.82rem; color: var(--muted); }

/* Table */
.table-wrap { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow-x: auto; box-shadow: var(--shadow); margin-bottom: 60px; }
thead th:last-child, tbody td:last-child { position: sticky; right: 0; background: var(--surface); box-shadow: -6px 0 8px -6px rgba(0,0,0,0.08); }
thead th:last-child { background: var(--surface-soft); }
tbody tr.cancelled-row td:last-child { background: var(--red-bg); }
table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
thead th {
  text-align: left; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;
  color: var(--muted); background: var(--surface-soft); padding: 10px 10px; border-bottom: 1px solid var(--border);
}
tbody td { padding: 10px 10px; border-bottom: 1px solid var(--border); vertical-align: middle; }
tbody tr:last-child td { border-bottom: none; }
tbody tr:hover { background: rgba(217,138,30,0.04); }
tbody tr.cancelled-row { background: var(--red-bg); }
tbody tr.cancelled-row:hover { background: rgba(179,56,44,0.12); }
tbody tr.cancelled-row td { color: var(--muted); }
tr.series-summary-row { cursor: pointer; background: var(--surface-soft); }
tr.series-summary-row:hover { background: rgba(217,138,30,0.10); }
tr.sub-row td { background: rgba(0,0,0,0.015); }
tr.sub-row td:first-child { padding-left: 28px; }
.btn-expand-series {
  font-family: Arial, Helvetica, sans-serif; font-size: 0.7rem; font-weight: 700;
  padding: 5px 8px; border-radius: 7px; border: 1.5px solid var(--saffron-dark);
  background: #fff; color: var(--saffron-dark); cursor: pointer; white-space: nowrap;
}
.btn-expand-series:hover { background: var(--surface-soft); }
.renter-name { font-weight: 700; color: var(--text); }
.renter-sub { font-size: 0.78rem; color: var(--muted); }
.room-pill { font-size: 0.78rem; font-weight: 700; color: var(--saffron-dark); }
.room-pill.whole-facility {
  display: inline-flex; align-items: center; gap: 4px; color: var(--maroon);
  background: linear-gradient(135deg, rgba(217,138,30,0.16), rgba(127,46,22,0.10));
  padding: 3px 9px; border-radius: 999px; font-size: 0.74rem;
}
.amount { font-weight: 700; font-variant-numeric: tabular-nums; }
.amount .adjusted-tag {
  display: block; font-weight: 700; font-size: 0.68rem; color: var(--saffron-dark);
  text-transform: uppercase; letter-spacing: 0.03em; margin-top: 2px;
}

.badge {
  display: inline-flex; align-items: center; gap: 6px; font-size: 0.74rem; font-weight: 700;
  padding: 4px 10px; border-radius: 999px; white-space: nowrap;
}
.badge-paid { background: var(--green-bg); color: var(--green); }
.badge-needs-confirm { background: var(--amber-bg); color: var(--amber); }
.badge-draft { background: var(--grey-bg); color: var(--muted); }
.badge-cancelled { background: var(--red-bg); color: var(--red); }
.badge-dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; flex-shrink: 0; }
.method-tag { font-size: 0.72rem; color: var(--muted); display: block; margin-top: 2px; }

.empty-state { text-align: center; padding: 60px 20px; color: var(--muted); }
.pagination-bar { display: flex; align-items: center; justify-content: center; gap: 10px; padding: 20px 0 50px; }
.pagination-bar button {
  font-family: Arial, Helvetica, sans-serif; font-size: 0.84rem; font-weight: 700; padding: 7px 14px;
  border-radius: 8px; border: 1.5px solid var(--border); background: #fff; color: var(--text); cursor: pointer;
}
.pagination-bar button:hover:not(:disabled) { background: var(--surface-soft); }
.pagination-bar button:disabled { opacity: 0.4; cursor: default; }
.pagination-bar .page-indicator { font-size: 0.84rem; color: var(--muted); }

.mock-notice {
  background: var(--amber-bg); color: var(--amber); border: 1px solid rgba(161,92,0,0.2);
  border-radius: 12px; padding: 12px 16px; font-size: 0.82rem; margin: 20px 0 0;
}


.discount-chip { display: inline-block; font-size: 0.68rem; font-weight: 700; color: var(--saffron-dark); background: var(--surface-soft); border-radius: 999px; padding: 2px 8px; }

thead th.sortable { cursor: pointer; user-select: none; white-space: nowrap; }
thead th.sortable:hover { color: var(--saffron-dark); }
thead th.sortable .sort-arrow { margin-left: 4px; opacity: 0.4; }
thead th.sortable.active .sort-arrow { opacity: 1; color: var(--saffron-dark); }
.notes-cell { max-width: 130px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 0.78rem; color: var(--muted); }
.updated-cell { font-size: 0.8rem; color: var(--muted); white-space: nowrap; }

.btn-kebab {
  width: 32px; height: 32px; border-radius: 8px; border: 1.5px solid var(--border); background: #fff;
  color: var(--text); font-size: 1.1rem; line-height: 1; cursor: pointer; transition: background 0.15s;
}
.btn-kebab:hover { background: var(--surface-soft); }
.actions-menu {
  position: fixed; background: var(--surface); border: 1px solid var(--border); border-radius: 12px;
  box-shadow: var(--shadow); padding: 8px; z-index: 9999; display: none; min-width: 180px;
}
.actions-menu.open { display: block; }
.actions-menu button {
  display: block; width: 100%; text-align: left; padding: 8px 10px; border: none; background: none;
  font-size: 0.84rem; color: var(--text); cursor: pointer; border-radius: 6px; font-family: Arial, Helvetica, sans-serif;
}
.actions-menu button:hover { background: var(--surface-soft); }
.actions-menu button.danger { color: var(--red); }
.actions-menu .menu-divider { border-top: 1px solid var(--border); margin: 6px 2px; }

.modal-overlay { position: fixed; inset: 0; background: rgba(44,27,16,0.5); z-index: 100; display: flex; align-items: flex-start; justify-content: center; padding: 40px 16px; overflow-y: auto; }
.modal-panel { background: var(--surface); border-radius: var(--radius); box-shadow: var(--shadow); width: 100%; max-width: 640px; }
.modal-header { display: flex; align-items: center; justify-content: space-between; padding: 22px 26px; border-bottom: 1px solid var(--border); }
.modal-header h2 { font-family: Georgia, "Times New Roman", serif; font-size: 1.2rem; color: var(--maroon); }
.modal-close { background: none; border: none; font-size: 1.4rem; color: var(--muted); cursor: pointer; line-height: 1; }
.modal-body { padding: 22px 26px; max-height: 65vh; overflow-y: auto; }
.modal-footer { display: flex; justify-content: flex-end; gap: 10px; padding: 18px 26px; border-top: 1px solid var(--border); }
.modal-body .field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px; }
.modal-body .field label { font-size: 0.78rem; font-weight: 700; color: var(--muted); }
.modal-body .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.modal-body input:not([type="checkbox"]), .modal-body select, .modal-body textarea {
  font-family: Arial, Helvetica, sans-serif; font-size: 0.9rem; padding: 9px 12px; border: 1.5px solid var(--border);
  border-radius: 10px; background: #fff; color: var(--text); width: 100%; box-sizing: border-box;
}
.modal-body textarea { resize: vertical; min-height: 56px; }
.modal-room-picker { display: grid; grid-template-columns: minmax(0,1fr) minmax(0,1fr); gap: 8px; margin-bottom: 8px; }
.modal-room-check { display: flex; align-items: center; gap: 8px; padding: 9px 10px; border: 1.5px solid var(--border); border-radius: 10px; cursor: pointer; font-size: 0.84rem; }
.modal-room-check input[type="checkbox"] { width: 16px; height: 16px; flex-shrink: 0; margin: 0; }
.modal-room-check:has(input:checked) { border-color: var(--saffron-dark); background: var(--surface-soft); font-weight: 700; }
.modal-room-check .rate { margin-left: auto; font-size: 0.72rem; color: var(--muted); flex-shrink: 0; }
.occ-table { border-collapse: collapse; margin: 10px 0 16px; }
.occ-table th { text-align: left; font-size: 0.7rem; text-transform: uppercase; color: var(--muted); padding: 6px 8px; }
.occ-table td { padding: 5px 8px; }
.occ-table input[type="date"], .occ-table input[type="time"] { font-family: Arial, Helvetica, sans-serif; font-size: 0.82rem; padding: 6px 8px; border: 1.5px solid var(--border); border-radius: 8px; width: 100%; box-sizing: border-box; }
.occ-table input[type="checkbox"] { width: 16px; height: 16px; }
.occ-table tr.marked-for-removal td { opacity: 0.4; text-decoration: line-through; }
.columns-panel {
  position: absolute; top: calc(100% + 6px); right: 0; background: var(--surface); border: 1px solid var(--border);
  border-radius: 12px; box-shadow: var(--shadow); padding: 12px; z-index: 30; min-width: 220px;
}
.columns-panel .columns-panel-note { font-size: 0.72rem; color: var(--muted); margin-bottom: 8px; }
.columns-panel label { display: flex; align-items: center; gap: 8px; font-size: 0.84rem; padding: 5px 4px; cursor: pointer; border-radius: 6px; }
.columns-panel label:hover { background: var(--surface-soft); }
.columns-panel input:disabled + span { color: var(--muted); }
.match-candidate { border: 1.5px solid var(--border); border-radius: 12px; padding: 12px 14px; margin-bottom: 10px; }
.match-candidate.high-confidence { border-color: var(--saffron-dark); background: var(--surface-soft); }
.match-candidate .match-label { font-weight: 700; font-size: 0.9rem; }
.match-candidate .match-reason { font-size: 0.78rem; color: var(--muted); margin: 2px 0 8px; }
.match-candidate .match-source-tag { display: inline-block; font-size: 0.68rem; font-weight: 700; text-transform: uppercase; padding: 2px 8px; border-radius: 999px; background: var(--surface-soft); color: var(--saffron-dark); margin-bottom: 6px; }
.month-calendar-panel {
  position: absolute; top: calc(100% + 6px); left: 0; background: var(--surface); border: 1px solid var(--border);
  border-radius: 14px; box-shadow: var(--shadow); padding: 14px; z-index: 30; width: 260px;
}
.month-calendar-quick { display: flex; flex-direction: column; gap: 4px; margin-bottom: 12px; padding-bottom: 12px; border-bottom: 1px solid var(--border); }
.month-calendar-quick button {
  text-align: left; padding: 7px 10px; border-radius: 8px; border: none; background: none; cursor: pointer;
  font-size: 0.84rem; font-family: Arial, Helvetica, sans-serif; color: var(--text);
}
.month-calendar-quick button:hover, .month-calendar-quick button.active { background: var(--surface-soft); color: var(--saffron-dark); font-weight: 700; }
.month-calendar-year-nav { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
.month-calendar-year-nav button { border: none; background: var(--surface-soft); border-radius: 6px; width: 26px; height: 26px; cursor: pointer; font-size: 0.9rem; }
.month-calendar-year-nav span { font-weight: 700; color: var(--maroon); font-family: Georgia, serif; }
.month-calendar-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; }
.month-calendar-grid button {
  padding: 8px 4px; border-radius: 8px; border: 1.5px solid var(--border); background: #fff; cursor: pointer;
  font-size: 0.8rem; font-family: Arial, Helvetica, sans-serif; color: var(--text);
}
.month-calendar-grid button:hover { background: var(--surface-soft); }
.month-calendar-grid button.active { border-color: var(--saffron-dark); background: var(--surface-soft); color: var(--saffron-dark); font-weight: 700; }
.checkbox-row { display: flex; align-items: center; gap: 8px; margin-bottom: 14px; font-size: 0.86rem; }
.btn-secondary {
  font-family: Arial, Helvetica, sans-serif; font-size: 0.86rem; font-weight: 700; color: var(--text);
  background: #fff; border: 1.5px solid var(--border); border-radius: 10px; padding: 10px 18px; cursor: pointer;
}
.btn-primary {
  font-family: Arial, Helvetica, sans-serif; font-size: 0.86rem; font-weight: 700; color: #fff;
  background: linear-gradient(135deg, var(--saffron-dark), var(--maroon)); border: none; border-radius: 10px; padding: 10px 18px; cursor: pointer;
}
.result-box { margin-top: 12px; border-radius: 12px; padding: 10px 14px; font-size: 0.82rem; }
.result-box.success { background: #e8f5ec; color: #2e7d4f; border: 1px solid rgba(46,125,79,0.25); }
.result-box.error { background: #fbe9e7; color: #b3382c; border: 1px solid rgba(179,56,44,0.25); }

#gate{padding:60px 16px;display:flex;justify-content:center;}
.gate-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:2.5rem 2rem;max-width:420px;width:100%;text-align:center;box-shadow:var(--shadow);}
.gate-card h3{font-family:Georgia,serif;font-size:1.3rem;color:var(--maroon);margin-bottom:.5rem;}
.gate-card p{color:var(--muted);font-size:.88rem;line-height:1.6;}
.gate-card a{color:var(--saffron-dark);}
.back-link { display: inline-flex; align-items: center; gap: 6px; font-size: 0.82rem; font-weight: 700; color: rgba(255,255,255,0.85); text-decoration: none; margin-bottom: 14px; }
.back-link:hover { color: #fff; text-decoration: underline; }
</style>
</head>
<body>

<div id="site-header"></div>

<div id="gate">
  <div class="gate-card">
    <h3>Checking access&hellip;</h3>
    <p>Please sign in from the <a href="/admin/admin-portal">Admin Portal</a> first.</p>
  </div>
</div>

<div id="app">

<div class="page-hero">
  <div class="container">
    <a class="back-link" href="https://hccgc.org/admin/admin-portal">&larr; Back to apps</a>
    <div class="eyebrow">Facility Bookings</div>
    <h1>All Bookings</h1>
    <p>Every facility booking, its payment status, and who still owes what.</p>
  </div>
</div>

<div class="module-nav">
  <div class="container">
    <ul>
      <li><a href="new-booking">New Booking</a></li>
      <li><a href="all-bookings" class="active">All Bookings</a></li>
      <li><a href="rooms-rates">Rooms &amp; Rates</a></li>
      <li><a href="change-log">Change Log</a></li>
      <li><a href="add-renter">Add A Renter</a></li>
    </ul>
  </div>
</div>

<div class="container">
  <div class="mock-notice" id="mock-notice" style="display:none;"></div>

  <div class="toolbar">
    <input type="text" id="search-input" placeholder="Search by contact name or email…">
    <select id="room-filter">
      <option value="">All rooms</option>
      <option value="Surya Hall">Surya Hall</option>
      <option value="Patanjali Hall">Patanjali Hall</option>
      <option value="Nataraj Room">Nataraj Room</option>
      <option value="Ganesh Room">Ganesh Room</option>
      <option value="__whole_facility__">Whole Facility</option>
    </select>
    <select id="status-filter">
      <option value="">All statuses</option>
      <option value="needs-attention">Needs attention</option>
      <option value="paid">Paid</option>
      <option value="pending">Pending (not yet invoiced)</option>
      <option value="cancelled">Cancelled</option>
      <option value="internal">Internal / No charge</option>
    </select>
    <div style="position:relative;">
      <button type="button" class="btn-secondary" id="btn-month-filter" style="padding:9px 14px;font-size:0.86rem;"></button>
      <div class="month-calendar-panel" id="month-calendar-panel" style="display:none;"></div>
    </div>
    <div style="position:relative;">
      <button type="button" class="btn-secondary" id="btn-columns" style="padding:9px 14px;font-size:0.86rem;">Columns</button>
      <div class="columns-panel" id="columns-panel" style="display:none;"></div>
    </div>
    <select id="page-size-filter" style="font-family: Arial, Helvetica, sans-serif; font-size: 0.86rem; padding: 9px 10px; border: 1.5px solid var(--border); border-radius: 10px;">
      <option value="10">10 per page</option>
      <option value="20" selected>20 per page</option>
      <option value="30">30 per page</option>
      <option value="50">50 per page</option>
    </select>
    <span class="count" id="result-count"></span>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr id="thead-row"></tr>
      </thead>
      <tbody id="bookings-tbody"></tbody>
    </table>
    <div class="empty-state" id="empty-state" style="display:none;">No bookings match your filters.</div>
  </div>
  <div class="pagination-bar" id="pagination-bar"></div>
</div>

</div>

<datalist id="common-times">
  <option value="06:00"><option value="06:30"><option value="07:00"><option value="07:30">
  <option value="08:00"><option value="08:30"><option value="09:00"><option value="09:30">
  <option value="10:00"><option value="10:30"><option value="11:00"><option value="11:30">
  <option value="12:00"><option value="12:30"><option value="13:00"><option value="13:30">
  <option value="14:00"><option value="14:30"><option value="15:00"><option value="15:30">
  <option value="16:00"><option value="16:30"><option value="17:00"><option value="17:30">
  <option value="18:00"><option value="18:30"><option value="19:00"><option value="19:30">
  <option value="20:00"><option value="20:30"><option value="21:00"><option value="21:30">
  <option value="22:00">
</datalist>

<div class="modal-overlay" id="edit-modal-overlay" style="display:none;">
  <div class="modal-panel">
    <div class="modal-header">
      <h2 id="edit-modal-title">Edit booking</h2>
      <button class="modal-close" id="btn-close-edit">&times;</button>

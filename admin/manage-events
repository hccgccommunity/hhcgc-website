<body>
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TPBF5VKB" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

<div id="site-header"></div>

<div class="page-hero">
  <div class="container">
    <span class="hero-badge">Internal Tool</span>
    <h2>Manage Events</h2>
    <p>Add, edit, and remove events shown on the public Upcoming Events page.</p>
  </div>
</div>

<div id="gate">
  <div class="gate-card">
    <img src="/hccgc-logo.jpeg" alt="HCCGC Logo" style="width:100px;height:100px;object-fit:contain;border-radius:50%;margin:0 auto 1.25rem;display:block;border:3px solid var(--border);">

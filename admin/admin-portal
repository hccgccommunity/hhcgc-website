         @eventDate, @startTime, @endTime, @hours, FALSE, FALSE,
         @baseTotal, @mult, @subtotal, @finalTotal,
         'requested', @seriesId, @recurrenceSummary, @eventName, @notes, 'public-form', CURRENT_TIMESTAMP())`,
      params: {
        bookingId, rooms: normalizedRooms, renterId, renterName: contactName, renterEmail: renterEmail || null,
        renterPhone: renterPhone || null, renterAddress: renterAddress || null, organizationName: renterOrg || null,
        eventDate: occ.date, startTime: `${occ.date} ${occ.startTime}:00`, endTime: `${occ.date} ${occ.endTime}:00`,
        hours, baseTotal: priced.baseTotal, mult: priced.mult, subtotal: priced.subtotal, finalTotal: priced.subtotal,
        seriesId, recurrenceSummary, eventName: b.eventDetails.slice(0, 100), notes: notesText

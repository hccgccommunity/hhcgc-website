<style>
:root {
  --bg: #fff9f1;
  --surface: #ffffff;
  --surface-soft: #fff6ea;
  --border: rgba(121,62,17,0.14);
  --text: #2c1b10;
  --muted: #6a5141;
  --saffron: #b55a18;
  --saffron-dark: #8d3e0d;
  --maroon: #7f2e16;
  --radius: 22px;
  --shadow: 0 18px 45px rgba(93,43,14,0.10);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: Arial, Helvetica, sans-serif;
  background:
    radial-gradient(circle at top left, rgba(217,138,30,0.12), transparent 22%),
    radial-gradient(circle at top right, rgba(127,46,22,0.05), transparent 20%),
    var(--bg);
  color: var(--text);
  min-height: 100vh;
}

.container { width: min(calc(100% - 32px), 1100px); margin: 0 auto; }

/* HERO */
.page-hero {
  padding: 48px 0 36px;
  text-align: center;
}
.page-hero h1 {
  font-family: Georgia, "Times New Roman", serif;
  font-size: 2rem;
  color: var(--maroon);
  margin-bottom: 10px;
}
.page-hero p {
  color: var(--muted);
  font-size: 0.95rem;
  max-width: 480px;
  margin: 0 auto;
}

/* GATE */
#gate { padding: 40px 16px 80px; display: flex; justify-content: center; }
.gate-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 2.5rem 2rem;
  max-width: 420px;
  width: 100%;
  text-align: center;
  box-shadow: var(--shadow);
}
.gate-card img.logo {
  width: 90px; height: 90px;
  object-fit: contain;
  border-radius: 50%;
  margin: 0 auto 1.25rem;
  display: block;
  border: 3px solid var(--border);
}
.gate-card h3 {
  font-family: Georgia, "Times New Roman", serif;
  font-size: 1.3rem;
  color: var(--maroon);
  margin-bottom: 0.5rem;
}
.gate-card > p { color: var(--muted); font-size: 0.86rem; line-height: 1.6; margin-bottom: 1.6rem; }

.btn-google {
  display: flex; align-items: center; justify-content: center; gap: 10px;
  width: 100%; padding: 0.72rem 1rem; background: #fff;
  border: 1.5px solid var(--border); border-radius: 10px;
  font-size: 0.95rem; font-weight: 600; color: #3c4043;
  cursor: pointer; transition: background 0.15s, box-shadow 0.15s;
  font-family: Arial, Helvetica, sans-serif;
}
.btn-google:hover { background: #f8f9fa; box-shadow: 0 1px 8px rgba(0,0,0,0.13); }

#signin-error {
  display: none;
  color: #c0392b;
  background: #fdecea;
  border: 1px solid #f5c6cb;
  border-radius: 8px;
  padding: 10px 14px;
  font-size: 0.82rem;
  margin-top: 1rem;
  text-align: left;
}

.gate-note { margin-top: 1.2rem; font-size: 0.78rem; color: var(--muted); }
.gate-note a { color: var(--saffron-dark); text-decoration: none; }
.gate-note a:hover { text-decoration: underline; }

/* APP GRID */
#app { display: none; }

.app-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 20px;
  padding: 8px 0 60px;
}

.app-tile {
  background: #fff;
  border: 1px solid var(--border);
  border-radius: 18px;
  padding: 1.75rem 1.5rem;
  text-decoration: none;
  color: var(--text);
  display: flex;
  flex-direction: column;
  gap: 10px;
  box-shadow: 0 4px 16px rgba(93,43,14,0.06);
  transition: transform 0.15s, box-shadow 0.15s;
}
.app-tile:hover {
  transform: translateY(-3px);
  box-shadow: 0 10px 28px rgba(93,43,14,0.14);
}

.app-tile-icon {
  width: 48px; height: 48px;
  border-radius: 14px;
  background: var(--surface-soft);
  display: flex; align-items: center; justify-content: center;
  color: var(--saffron-dark);
}
.app-tile-icon svg { width: 24px; height: 24px; }

.app-tile h3 {
  font-family: Georgia, "Times New Roman", serif;
  font-size: 1.15rem;
  color: var(--maroon);
}
.app-tile p {
  font-size: 0.85rem;
  color: var(--muted);
  line-height: 1.5;
}

.app-tile-badge {
  align-self: flex-start;
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  color: var(--saffron-dark);
  background: rgba(217,138,30,0.12);
  padding: 3px 10px;
  border-radius: 999px;
}

.no-apps {
  text-align: center;
  padding: 60px 20px;
  color: var(--muted);
  background: #fff;
  border: 1px dashed var(--border);
  border-radius: 16px;
}

.loading-state {
  text-align: center;
  padding: 60px 20px;
  color: var(--muted);
}
.spinner {
  width: 20px; height: 20px;
  border: 3px solid rgba(141,62,13,0.18);
  border-top-color: var(--saffron-dark);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 0 auto 12px;
}
@keyframes spin { to { transform: rotate(360deg); } }
/* Header partial styling — required by header.html's markup.
   Copied to match the rest of the site so header.html renders
   identically here as it does everywhere else. */
.site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 249, 241, 0.92);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
}
.nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    min-height: 92px;
    padding: 12px 0;
}
.brand { display: flex; align-items: center; gap: 16px; min-width: 0; }
.brand-logo-wrap {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 8px;
    box-shadow: var(--shadow);
    flex-shrink: 0;
}
.brand-logo { width: 88px; height: auto; border-radius: 12px; object-fit: contain; }
.brand-text h1 { margin: 0; font-size: 1.2rem; line-height: 1.15; color: var(--maroon); }
.site-header nav ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    margin: 0;
    padding: 0;
    align-items: center;
    justify-content: flex-end;
}
.site-header nav a { font-weight: 700; color: var(--text); font-size: 0.96rem; }
.site-header nav a:hover { color: var(--saffron-dark); }
.menu-toggle {
    display: none;
    border: 0;
    background: transparent;
    padding: 6px 0;
    cursor: pointer;
    color: #2c1b10;
    align-self: flex-end;
}
.menu-toggle .bar { display: block; width: 26px; height: 2px; margin: 5px 0; background: currentColor; }
@media (max-width: 768px) {
    .nav { flex-direction: column; align-items: stretch; gap: 8px; }
    .menu-toggle { display: inline-block; }
    .site-header nav {
        display: none;
        width: 100%;
        background: rgba(255, 249, 241, 0.95);
        padding: 10px 0;
    }
    .site-header nav.is-open { display: block; }
    .site-header nav ul { flex-direction: column; gap: 14px; }
}

/* Simple signed-in status row (replaces a custom topbar so the page
   keeps the standard site header/footer instead of its own chrome) */
.user-status-row {
  display: none;
  align-items: center;
  justify-content: center;
  gap: 10px;
  font-size: 0.82rem;
  color: var(--muted);
  margin-top: -8px;
  margin-bottom: 8px;
}
.user-status-row.show { display: flex; }
.user-status-avatar {
  width: 24px; height: 24px;
  border-radius: 50%;
  overflow: hidden;
  background: var(--surface-soft);
  display: flex; align-items: center; justify-content: center;
  font-size: 0.68rem; font-weight: 700; color: var(--saffron-dark);
}
.user-status-avatar img { width: 100%; height: 100%; object-fit: cover; }
.btn-signout-inline {
  background: none;
  border: none;
  color: var(--saffron-dark);
  font-size: 0.78rem;
  cursor: pointer;
  text-decoration: underline;
  font-family: Arial, Helvetica, sans-serif;
}
</style>
</head>
<body>
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TPBF5VKB" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

<div id="site-header"></div>

<div class="page-hero">
  <div class="container">
    <h1>Welcome to the Admin Portal</h1>
    <p>Sign in with your HCCGC Google account to access the tools you've been granted.</p>
    <div class="user-status-row" id="user-status-row">
      <div class="user-status-avatar" id="status-avatar">?</div>
      <span id="status-name"></span>
      &middot;
      <button class="btn-signout-inline" id="btn-signout">Sign out</button>
    </div>
  </div>
</div>

<div id="gate">
  <div class="gate-card">
    <img class="logo" src="../hccgc-logo.jpeg" alt="HCCGC Logo">
    <h3>Sign in to continue</h3>
    <p>This portal is for authorized HCCGC members only.</p>
    <button class="btn-google" id="btn-signin">
      <svg width="20" height="20" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
        <path d="M19.6 10.23c0-.68-.06-1.36-.17-2H10v3.77h5.4a4.63 4.63 0 01-2.01 3.04v2.52h3.25c1.9-1.75 3-4.33 3-7.33z" fill="#4285F4"/>
        <path d="M10 20c2.7 0 4.97-.9 6.63-2.44l-3.25-2.52c-.9.6-2.05.96-3.38.96-2.6 0-4.8-1.75-5.59-4.11H1.07v2.6A10 10 0 0010 20z" fill="#34A853"/>
        <path d="M4.41 11.89A5.98 5.98 0 014.1 10c0-.65.11-1.29.31-1.89V5.51H1.07A10 10 0 000 10c0 1.61.38 3.13 1.07 4.49l3.34-2.6z" fill="#FBBC05"/>
        <path d="M10 3.98c1.46 0 2.77.5 3.8 1.49l2.85-2.85C14.96.99 12.7 0 10 0A10 10 0 001.07 5.51l3.34 2.6C5.2 5.73 7.4 3.98 10 3.98z" fill="#EA4335"/>
      </svg>
      Sign in with Google
    </button>
    <div id="signin-error"></div>
    <p class="gate-note">Need access? Contact <a href="mailto:admin@hccgc.org">admin@hccgc.org</a></p>
  </div>
</div>

<div id="app">
  <div class="container">
    <div id="apps-container" class="loading-state">
      <div class="spinner"></div>
      Loading your apps&hellip;
    </div>
  </div>
</div>

<div id="site-footer"></div>

<!-- App registry: every app available in the portal lives here.
     "key" must match an entry in each user's allowedApps array in Firestore. -->
<script id="app-registry" type="application/json">
[
  {
    "key": "manage-events",
    "name": "Manage Events",
    "description": "Add, edit, and remove events shown on the public Upcoming Events page.",
    "url": "../manage-events",
    "icon": "calendar"
  },
  {
    "key": "marketing-assistant",
    "name": "Marketing Assistant",
    "description": "Generate flyers, social captions, emails, and announcements with AI.",
    "url": "../marketing-assistant",
    "icon": "sparkles"
  },
  {
    "key": "user-management",
    "name": "User Management",
    "description": "Grant or revoke portal access for HCCGC members. Admins only.",
    "url": "user-management",
    "icon": "users"
  }
]
</script>

<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/12.15.0/firebase-app.js";
import {
  getAuth, GoogleAuthProvider, signInWithPopup, signInWithRedirect,
  signOut, onAuthStateChanged
} from "https://www.gstatic.com/firebasejs/12.15.0/firebase-auth.js";
import {
  getFirestore, doc, getDoc, setDoc, serverTimestamp
} from "https://www.gstatic.com/firebasejs/12.15.0/firebase-firestore.js";

const firebaseConfig = {
  apiKey: "AIzaSyA6IzLjWTg7Rq04HsTH-iA3eDmSzKI7xME",
  authDomain: "hccgc-a7a54.firebaseapp.com",
  projectId: "hccgc-a7a54",
  storageBucket: "hccgc-a7a54.firebasestorage.app",
  messagingSenderId: "75757201418",
  appId: "1:75757201418:web:c31e9361921242145717f3",
  measurementId: "G-F9K6GVD5CS"
};

const ALLOWED_DOMAIN = "hccgc.org";
const USERS_COLLECTION = "portalUsers";

const fbApp = initializeApp(firebaseConfig);
const auth = getAuth(fbApp);
const db = getFirestore(fbApp);
const provider = new GoogleAuthProvider();
provider.setCustomParameters({ hd: ALLOWED_DOMAIN });

window.__hccgcPortal = { auth, db, doc, getDoc, setDoc, serverTimestamp, USERS_COLLECTION, ALLOWED_DOMAIN };

function isMobileDevice() {
  return /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);
}

document.getElementById("btn-signin").addEventListener("click", function () {
  var errorBox = document.getElementById("signin-error");
  errorBox.style.display = "none";

  if (isMobileDevice()) {
    signInWithRedirect(auth, provider).catch(function (err) {
      console.error(err);
      errorBox.textContent = "Sign-in failed. Please try again.";
      errorBox.style.display = "block";
    });
    return;
  }

  signInWithPopup(auth, provider).catch(function (err) {
    console.error(err);
    if (err.code === "auth/popup-closed-by-user" || err.code === "auth/cancelled-popup-request") return;
    errorBox.textContent = "Sign-in failed. Please try again.";
    errorBox.style.display = "block";
  });
});

document.getElementById("btn-signout").addEventListener("click", function () {
  signOut(auth);
});

onAuthStateChanged(auth, function (user) {
  var errorBox = document.getElementById("signin-error");

  if (!user) {
    document.getElementById("app").style.display = "none";
    document.getElementById("gate").style.display = "flex";
    document.getElementById("user-status-row").classList.remove("show");
    return;
  }

  var email = (user.email || "").toLowerCase();
  if (!email.endsWith("@" + ALLOWED_DOMAIN)) {
    errorBox.textContent = "Please sign in with your @" + ALLOWED_DOMAIN + " account.";
    errorBox.style.display = "block";
    signOut(auth);
    return;
  }

  document.getElementById("gate").style.display = "none";
  document.getElementById("app").style.display = "block";

  var statusRow = document.getElementById("user-status-row");
  statusRow.classList.add("show");
  document.getElementById("status-name").textContent = user.displayName || email;
  var avatarEl = document.getElementById("status-avatar");
  if (user.photoURL) {
    avatarEl.innerHTML = '<img src="' + user.photoURL + '" alt="">';
  } else {
    avatarEl.textContent = (user.displayName || email).charAt(0).toUpperCase();
  }

  window.dispatchEvent(new CustomEvent("hccgc-portal-signed-in", { detail: { user: user } }));
});
</script>

<script>
var ICONS = {
  calendar: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>',
  sparkles: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3 7h7l-5.5 4 2 7L12 16l-6.5 4 2-7L2 9h7z"/></svg>',
  users: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>',
  default: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/></svg>'
};

function escHtml(str) {
  return String(str || '')
    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

function getAppRegistry() {
  var el = document.getElementById('app-registry');
  try {
    return JSON.parse(el.textContent);
  } catch (e) {
    console.error('Could not parse app registry', e);
    return [];
  }
}

window.addEventListener('hccgc-portal-signed-in', function (e) {
  loadUserApps(e.detail.user);
});

function loadUserApps(user) {
  var fb = window.__hccgcPortal;
  var container = document.getElementById('apps-container');

  fb.getDoc(fb.doc(fb.db, fb.USERS_COLLECTION, user.email.toLowerCase()))
    .then(function (snap) {
      var allowedApps = [];
      var isAdmin = false;

      if (snap.exists()) {
        var data = snap.data();
        allowedApps = Array.isArray(data.allowedApps) ? data.allowedApps : [];
        isAdmin = !!data.isAdmin;
      } else {
        // First-time sign-in: create a record with no app access yet.
        // An existing admin will need to grant access via User Management.
        fb.setDoc(fb.doc(fb.db, fb.USERS_COLLECTION, user.email.toLowerCase()), {
          email: user.email,
          name: user.displayName || '',
          allowedApps: [],
          isAdmin: false,
          createdAt: fb.serverTimestamp(),
          lastSignIn: fb.serverTimestamp()
        });
      }

      renderApps(allowedApps, isAdmin);
    })
    .catch(function (err) {
      console.error(err);
      container.innerHTML = '<div class="no-apps">Could not load your apps. Please try refreshing.</div>';
    });
}

function renderApps(allowedApps, isAdmin) {
  var container = document.getElementById('apps-container');
  var registry = getAppRegistry();

  var visibleApps = registry.filter(function (app) {
    if (app.key === 'user-management') return isAdmin;
    return isAdmin || allowedApps.indexOf(app.key) !== -1;
  });

  if (visibleApps.length === 0) {
    container.innerHTML =
      '<div class="no-apps">' +
        "<p>You're signed in, but don't have access to any tools yet.</p>" +
        '<p style="margin-top:8px; font-size:0.8rem;">Contact <a href="mailto:admin@hccgc.org" style="color:var(--saffron-dark)">admin@hccgc.org</a> to request access.</p>' +
      '</div>';
    return;
  }

  var html = '<div class="app-grid">';
  visibleApps.forEach(function (app) {
    var icon = ICONS[app.icon] || ICONS.default;
    html +=
      '<a class="app-tile" href="' + escHtml(app.url) + '">' +
        (app.key === 'user-management' ? '<span class="app-tile-badge">Admin</span>' : '') +
        '<div class="app-tile-icon">' + icon + '</div>' +
        '<h3>' + escHtml(app.name) + '</h3>' +
        '<p>' + escHtml(app.description) + '</p>' +
      '</a>';
  });
  html += '</div>';

  container.className = '';
  container.innerHTML = html;
}

function loadPartial(id, file) {
  var target = document.getElementById(id);
  if (!target) return;
  fetch(file)
    .then(function (r) { return r.text(); })
    .then(function (html) {
      target.innerHTML = html;
      if (id === 'site-header') {
        fixHeaderLinksForSubfolder(target);
      }
    })
    .catch(function () {});
}

// header.html uses paths that are relative to the page calling it
// (e.g. src="hccgc-logo.jpeg", href="index.html#about"). That works fine
// for pages at the site root, but breaks when header.html is loaded from
// a subfolder like /admin/. Rather than edit the shared header.html file
// itself, we patch the loaded copy here so it points to the right place.
function fixHeaderLinksForSubfolder(headerEl) {
  var logo = headerEl.querySelector('.brand-logo');
  if (logo && logo.getAttribute('src') && !logo.getAttribute('src').startsWith('/') && !logo.getAttribute('src').startsWith('http')) {
    logo.setAttribute('src', '/' + logo.getAttribute('src'));
  }

  var links = headerEl.querySelectorAll('a[href]');
  links.forEach(function (link) {
    var href = link.getAttribute('href');
    if (!href) return;
    // Leave absolute URLs (http/https) and already-root-relative links alone.
    if (href.startsWith('http') || href.startsWith('/') || href.startsWith('#')) return;
    link.setAttribute('href', '/' + href);
  });
}

loadPartial('site-header', '../header.html');
loadPartial('site-footer', '../footer.html');
</script>
</body>

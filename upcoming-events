            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 24px;
            min-height: 92px;
            padding: 12px 0;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 16px;
            min-width: 0;
        }

        .brand-logo-wrap {
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 18px;
            padding: 8px;
            box-shadow: var(--shadow);
            flex-shrink: 0;
        }

        .brand-logo {
            width: 88px;
            height: auto;
            border-radius: 12px;
            object-fit: contain;
        }

        .brand-text h1 {
            margin: 0;
            font-size: 1.2rem;
            line-height: 1.15;
            color: var(--maroon);
        }

        .site-header nav ul {
            list-style: none;
            display: flex;
            flex-wrap: wrap;
            gap: 18px;
            margin: 0;
            padding: 0;
            align-items: center;
            justify-content: flex-end;
        }

        .site-header nav a {
            font-weight: 700;
            color: var(--text);
            font-size: 0.96rem;
        }

        .site-header nav a:hover {
            color: var(--saffron-dark);
        }

        .menu-toggle {
            display: none;
            border: 0;
            background: transparent;
            padding: 6px 0;
            cursor: pointer;
            color: #2c1b10;
            align-self: flex-end;
        }

        .menu-toggle .bar {
            display: block;
            width: 26px;
            height: 2px;
            margin: 5px 0;
            background: currentColor;
        }

        @media (max-width: 768px) {
            .nav {
                flex-direction: column;
                align-items: stretch;
                gap: 8px;
            }

            .menu-toggle {
                display: inline-block;
            }

            .site-header nav {
                display: none;
                width: 100%;
                background: rgba(255, 249, 241, 0.95);
                padding: 10px 0;
            }

            .site-header nav.is-open {
                display: block;
            }

            .site-header nav ul {
                flex-direction: column;
                gap: 14px;
            }
        }
    </style>
</head>
<body>

    <div id="header-placeholder"></div>

    <main>
        <section class="page-hero">
            <div class="container">
                <span class="section-kicker">Stay Connected</span>
                <h1>Upcoming Events</h1>
                <p>Join us for cultural programs, community gatherings, and celebrations throughout the year. Check back often — new events are added regularly.</p>
            </div>
        </section>

        <section class="section">
            <div class="container">
                <div id="events-container">
                    <div class="loading-state">
                        <div class="spinner"></div>
                        Loading upcoming events&hellip;
                    </div>
                </div>
            </div>
        </section>
    </main>

    <div id="footer-placeholder"></div>



    <!-- Single self-contained module: loads Firebase and renders events directly.
         No polling, no window.__hccgc, no timing dependency between scripts. -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/12.15.0/firebase-app.js";
        import { getFirestore, collection, getDocs } from "https://www.gstatic.com/firebasejs/12.15.0/firebase-firestore.js";

        const firebaseConfig = {
            apiKey: "AIzaSyA6IzLjWTg7Rq04HsTH-iA3eDmSzKI7xME",
            authDomain: "hccgc-a7a54.firebaseapp.com",
            projectId: "hccgc-a7a54",
            storageBucket: "hccgc-a7a54.firebasestorage.app",
            messagingSenderId: "75757201418",
            appId: "1:75757201418:web:c31e9361921242145717f3",
            measurementId: "G-F9K6GVD5CS"
        };

        const fbApp = initializeApp(firebaseConfig);
        const db = getFirestore(fbApp);

        // Load header/footer in background — failure never blocks event loading.
        async function loadPartial(id, file) {
            const target = document.getElementById(id);
            if (!target) return;
            try {
                const r = await fetch(file);
                if (!r.ok) throw new Error("Unable to load " + file);
                target.innerHTML = await r.text();
            } catch (e) {
                console.error(e);
            }
        }
        loadPartial("header-placeholder", "/header.html");
        loadPartial("footer-placeholder", "/footer.html");

        const year = document.getElementById("year");
        if (year) year.textContent = new Date().getFullYear();

        function escHtml(str) {
            return String(str || '')
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;');
        }

        function isPast(dateStr) {
            if (!dateStr || dateStr.length !== 10) return false;
            const today = new Date();
            const yyyy = today.getFullYear();
            const mm = String(today.getMonth() + 1).padStart(2, '0');
            const dd = String(today.getDate()).padStart(2, '0');
            return dateStr < `${yyyy}-${mm}-${dd}`;
        }

        function formatDate(dateStr) {
            const parts = dateStr.split('-');
            if (parts.length !== 3) return dateStr;
            const d = new Date(Number(parts[0]), Number(parts[1]) - 1, Number(parts[2]));
            if (isNaN(d.getTime())) return dateStr;
            return d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' });
        }

        function formatTimeRange(fromTime, toTime) {
            if (toTime && toTime.trim() !== '') return fromTime + ' \u2013 ' + toTime;
            return fromTime + ' onward';
        }

        function renderEvents(events) {
            const container = document.getElementById('events-container');
            const upcoming = events.filter(e => !isPast(e.date));

            if (upcoming.length === 0) {
                container.innerHTML =
                    '<div class="empty-state">' +
                        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>' +
                        '<p>No upcoming events at the moment. Please check back soon!</p>' +
                    '</div>';
                return;
            }

            let html = '<div class="events-grid">';
            upcoming.forEach(e => {
                html +=
                    '<article class="event-card">' +
                        '<span class="event-date-badge">' +
                            '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>' +
                            formatDate(e.date) +
                        '</span>' +
                        '<h3>' + escHtml(e.name) + '</h3>' +
                        '<div class="event-meta">' +
                            '<span><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>' +
                            escHtml(formatTimeRange(e.fromTime, e.toTime)) + '</span>' +
                        '</div>' +
                        '<div class="event-badges">' +
                            (e.category ? '<span class="event-category-badge">' + escHtml(e.category) + '</span>' : '') +
                            (e.cost ? '<span class="event-cost-badge">' + escHtml(e.cost) + '</span>' : '') +
                        '</div>' +
                        '<p class="event-desc">' + escHtml(e.description) + '</p>' +
                        (e.rsvpUrl ? '<a class="btn btn-primary" href="' + escHtml(e.rsvpUrl) + '" target="_blank" rel="noopener noreferrer">RSVP Now</a>' : '') +
                    '</article>';
            });
            html += '</div>';
            container.innerHTML = html;
        }

        // Fetch events and render — all in one module, no cross-script coordination needed.
        try {
            const snapshot = await getDocs(collection(db, "events"));
            const events = [];
            snapshot.forEach(docSnap => {
                const data = docSnap.data();
                data.id = docSnap.id;
                events.push(data);
            });
            renderEvents(events);
        } catch (err) {
            console.error(err);
            document.getElementById('events-container').innerHTML =
                '<div class="empty-state"><p>We couldn\'t load events right now. Please try again later.</p></div>';
        }
    </script>
</body>
</html>


<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Finance — HCCGC Admin Portal</title>
<link rel="icon" type="image/x-icon" href="/favicon.ico">
<script async src="https://www.googletagmanager.com/gtag/js?id=G-F5ZHQ4CDR9"></script>
<script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-F5ZHQ4CDR9');</script>
<style>
:root {
  --bg: #fff9f1; --surface: #ffffff; --surface-soft: #fff6ea; --border: rgba(121,62,17,0.14);
  --text: #2c1b10; --muted: #6a5141; --saffron: #b55a18; --saffron-dark: #8d3e0d; --maroon: #7f2e16;
  --green: #2e7d4f; --green-bg: #e8f5ec; --red: #b3382c; --red-bg: #fbe9e7;
  --radius: 22px; --shadow: 0 18px 45px rgba(93,43,14,0.10);
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: Arial, Helvetica, sans-serif; background: radial-gradient(circle at top left, rgba(217,138,30,0.12), transparent 22%), radial-gradient(circle at top right, rgba(127,46,22,0.05), transparent 20%), var(--bg); color: var(--text); min-height: 100vh; }
.container { width: min(calc(100% - 32px), 1300px); margin: 0 auto; }
.site-header { position: sticky; top: 0; z-index: 50; background: rgba(255,249,241,0.92); backdrop-filter: blur(10px); border-bottom: 1px solid var(--border); }
.nav { display: flex; align-items: center; justify-content: space-between; gap: 24px; min-height: 92px; padding: 12px 0; }
.site-header a.brand, .site-header a.brand:link, .site-header a.brand:visited { text-decoration: none; color: inherit; }
.brand { display: flex; align-items: center; gap: 16px; min-width: 0; }
.brand-logo-wrap { background: #fff; border: 1px solid var(--border); border-radius: 18px; padding: 8px; box-shadow: var(--shadow); flex-shrink: 0; }
.brand-logo { width: 88px; height: auto; border-radius: 12px; object-fit: contain; }
.brand-text h1 { margin: 0; font-size: 1.2rem; line-height: 1.15; color: var(--maroon); }
.site-header nav ul { list-style: none; display: flex; flex-wrap: wrap; gap: 18px; margin: 0; padding: 0; align-items: center; justify-content: flex-end; }
.site-header nav a, .site-header nav a:link, .site-header nav a:visited { font-weight: 700; color: var(--text); font-size: 0.96rem; text-decoration: none; }
.site-header nav a:hover { color: var(--saffron-dark); }
.menu-toggle { display: none; border: 0; background: transparent; padding: 6px 0; cursor: pointer; color: #2c1b10; align-self: flex-end; }
.menu-toggle .bar { display: block; width: 26px; height: 2px; margin: 5px 0; background: currentColor; }
@media (max-width: 768px) {
  .nav { flex-direction: column; align-items: stretch; gap: 8px; } .menu-toggle { display: inline-block; }
  .site-header nav { display: none; width: 100%; background: rgba(255,249,241,0.95); padding: 10px 0; }
  .site-header nav.is-open { display: block; } .site-header nav ul { flex-direction: column; gap: 14px; }
}
.page-hero { padding: 28px 0 22px; background: linear-gradient(135deg, var(--maroon) 0%, #4e1a09 100%); color: #fff; }
.page-hero h1 { font-family: Georgia, "Times New Roman", serif; font-size: 1.9rem; color: #fff; margin-bottom: 6px; }
.page-hero p { color: #ffffff; opacity: 0.9; font-size: 0.92rem; max-width: 620px; }
.back-link { display: inline-flex; align-items: center; gap: 6px; font-size: 0.82rem; font-weight: 700; color: rgba(255,255,255,0.85); text-decoration: none; margin-bottom: 14px; }
.back-link:hover { color: #fff; text-decoration: underline; }

.tab-nav { background: var(--surface); border-bottom: 1px solid var(--border); }
.tab-nav ul { list-style: none; display: flex; gap: 4px; padding: 10px 0; flex-wrap: wrap; }
.tab-nav button { display: inline-block; padding: 8px 16px; border-radius: 999px; font-size: 0.86rem; font-weight: 700; color: var(--muted); background: none; border: none; cursor: pointer; transition: background 0.15s, color 0.15s; font-family: inherit; }
.tab-nav button.active { background: var(--surface-soft); color: var(--saffron-dark); }
.tab-nav button:not(.active):hover { background: var(--surface-soft); }

.tab-panel { display: none; padding: 24px 0 60px; }
.tab-panel.active { display: block; }

.sub-tab-nav { display: flex; gap: 8px; margin-bottom: 20px; border-bottom: 1px solid var(--border); padding-bottom: 14px; }
.sub-tab-btn { padding: 8px 16px; border-radius: 999px; font-size: 0.84rem; font-weight: 700; color: var(--muted); background: #fff; border: 1.5px solid var(--border); cursor: pointer; font-family: inherit; }
.sub-tab-btn.active { background: var(--saffron-dark); color: #fff; border-color: var(--saffron-dark); }
.sub-tab-panel { display: none; }
.sub-tab-panel.active { display: block; }

.toolbar { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; margin-bottom: 16px; }

.gauge-track { background: var(--surface-soft); border-radius: 999px; height: 28px; overflow: hidden; position: relative; margin-bottom: 10px; }
.gauge-fill { height: 100%; border-radius: 999px; transition: width 0.3s ease; display: flex; align-items: center; justify-content: flex-end; padding-right: 10px; }
.gauge-fill.positive { background: linear-gradient(90deg, var(--green), #4caf7d); }
.gauge-fill.negative { background: linear-gradient(90deg, var(--red), #d9564a); }
.gauge-marker { position: absolute; top: -4px; bottom: -4px; width: 2px; background: var(--maroon); }
.gauge-labels { display: flex; justify-content: space-between; font-size: 0.82rem; color: var(--muted); }
.gauge-stats { display: flex; gap: 24px; margin-top: 16px; flex-wrap: wrap; }
.gauge-stat { flex: 1; min-width: 140px; }
.gauge-stat .label { font-size: 0.76rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 4px; }
.gauge-stat .value { font-size: 1.4rem; font-weight: 800; }
.gauge-stat .value.positive { color: var(--green); }
.gauge-stat .value.negative { color: var(--red); }

.bar-chart-row { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
.bar-chart-label { width: 190px; flex-shrink: 0; font-size: 0.86rem; font-weight: 700; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.bar-chart-track { flex: 1; background: var(--surface-soft); border-radius: 8px; height: 26px; position: relative; overflow: hidden; }
.bar-chart-fill { height: 100%; border-radius: 8px; background: linear-gradient(90deg, var(--saffron-dark), var(--saffron)); }
.bar-chart-value { width: 110px; flex-shrink: 0; text-align: right; font-weight: 700; font-size: 0.88rem; }

.stat-card-big { text-align: center; padding: 20px; }
.stat-card-big .value { font-size: 2.2rem; font-weight: 800; color: var(--maroon); }
.stat-card-big .sub { font-size: 0.86rem; color: var(--muted); margin-top: 6px; }
.toolbar input, .toolbar select {
  font-family: Arial, Helvetica, sans-serif; font-size: 0.88rem; padding: 9px 14px;
  border: 1.5px solid var(--border); border-radius: 10px; background: var(--surface); color: var(--text);
}
.toolbar .count { margin-left: auto; font-size: 0.82rem; color: var(--muted); }
.btn-primary {
  font-family: Arial, Helvetica, sans-serif; font-size: 0.88rem; font-weight: 700; color: #fff;
  background: linear-gradient(135deg, var(--saffron-dark), var(--maroon)); border: none; border-radius: 10px;
  padding: 10px 16px; cursor: pointer;
}
.btn-secondary {
  font-family: Arial, Helvetica, sans-serif; font-size: 0.86rem; font-weight: 700; color: var(--text);
  background: #fff; border: 1.5px solid var(--border); border-radius: 10px; padding: 9px 14px; cursor: pointer;
}

.table-wrap { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow-x: auto; box-shadow: var(--shadow); }
table { width: 100%; border-collapse: collapse; font-size: 0.84rem; }
thead th { text-align: left; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted); background: var(--surface-soft); padding: 10px 12px; border-bottom: 1px solid var(--border); white-space: nowrap; }
tbody td { padding: 10px 12px; border-bottom: 1px solid var(--border); vertical-align: middle; }
tbody tr:last-child td { border-bottom: none; }
tbody tr:hover { background: rgba(217,138,30,0.04); }
.amount { font-weight: 700; }
.amount.income { color: var(--green); }
.amount.expense { color: var(--red); }
.source-tag { display: inline-block; font-size: 0.68rem; font-weight: 700; text-transform: uppercase; padding: 2px 8px; border-radius: 999px; background: var(--surface-soft); color: var(--saffron-dark); }
.cat-select { font-family: inherit; font-size: 0.82rem; padding: 6px 10px; border: 1.5px solid var(--border); border-radius: 8px; background: #fff; }
.cat-select.uncategorized { border-color: var(--red); background: var(--red-bg); }
.empty-state { text-align: center; padding: 60px 20px; color: var(--muted); }

.card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 26px; box-shadow: var(--shadow); margin-bottom: 20px; }
.stmt-section-title { font-family: Georgia, "Times New Roman", serif; color: var(--maroon); font-size: 1.1rem; margin: 18px 0 8px; }
.stmt-row { display: flex; justify-content: space-between; padding: 7px 0; border-bottom: 1px solid var(--border); font-size: 0.92rem; }
.stmt-row .count { color: var(--muted); font-size: 0.78rem; margin-left: 6px; }
.stmt-total { display: flex; justify-content: space-between; padding: 12px 0; font-weight: 800; font-size: 1rem; border-top: 2px solid var(--border); margin-top: 6px; }
.stmt-net { display: flex; justify-content: space-between; padding: 16px 20px; border-radius: 14px; font-weight: 800; font-size: 1.2rem; margin-top: 16px; }
.stmt-net.positive { background: var(--green-bg); color: var(--green); }
.stmt-net.negative { background: var(--red-bg); color: var(--red); }

.recon-week-card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 18px 20px; margin-bottom: 12px; }
.recon-week-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
.recon-week-header .week-label { font-weight: 700; font-size: 0.94rem; }
.recon-week-header .expected { color: var(--muted); font-size: 0.84rem; }
.recon-candidate { display: flex; justify-content: space-between; align-items: center; padding: 8px 12px; border-radius: 10px; font-size: 0.86rem; margin-bottom: 6px; }
.recon-candidate.match { background: var(--green-bg); }
.recon-candidate.mismatch { background: var(--red-bg); }
.recon-none { color: var(--muted); font-size: 0.84rem; font-style: italic; }

.category-pill { display: inline-flex; align-items: center; gap: 6px; padding: 8px 14px; border: 1.5px solid var(--border); border-radius: 999px; font-size: 0.86rem; }
.category-pill.inactive { opacity: 0.5; }
.category-pill .type-dot { width: 8px; height: 8px; border-radius: 50%; }
.category-pill .type-dot.income { background: var(--green); }
.category-pill .type-dot.expense { background: var(--red); }
.category-pill button { border: none; background: none; cursor: pointer; font-size: 0.76rem; font-weight: 700; color: var(--saffron-dark); padding: 0; margin-left: 4px; }
.category-list { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 10px; }

#gate{padding:60px 16px;display:flex;justify-content:center;}
.gate-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:2.5rem 2rem;max-width:420px;width:100%;text-align:center;box-shadow:var(--shadow);}
.gate-card h3{font-family:Georgia,serif;font-size:1.3rem;color:var(--maroon);margin-bottom:.5rem;}
.gate-card p{color:var(--muted);font-size:.88rem;line-height:1.6;}
.gate-card a{color:var(--saffron-dark);}
</style>
</head>
<body>
<div id="site-header"></div>

<div id="gate">
  <div class="gate-card">
    <h3>Checking access&hellip;</h3>
    <p>Please sign in from the <a href="/admin/admin-portal">Admin Portal</a> first.</p>
  </div>
</div>

<div id="app" style="display:none;">

<div class="page-hero">
  <div class="container">
    <a class="back-link" href="https://hccgc.org/admin/admin-portal">&larr; Back to apps</a>
    <h1>Finance</h1>
    <p>Categorize every transaction, reconcile Zeffy payouts, and generate the Statement of Activities — one place for all of it.</p>
  </div>
</div>

<div class="tab-nav">
  <div class="container">
    <ul>
      <li><button class="tab-btn active" data-tab="dashboard">Dashboard</button></li>
      <li><button class="tab-btn" data-tab="transactions">Transactions</button></li>
      <li><button class="tab-btn" data-tab="categories">Categories</button></li>
      <li><button class="tab-btn" data-tab="statements">Statements</button></li>
      <li><button class="tab-btn" data-tab="reconciliation">Zeffy Reconciliation</button></li>
      <li><button class="tab-btn" data-tab="matching">Invoice Matching</button></li>
      <li><button class="tab-btn" data-tab="expenses">Expense Approvals</button></li>
    </ul>
  </div>
</div>

<div class="container">

  <!-- ── TRANSACTIONS TAB ── -->
  <!-- ── DASHBOARD TAB ── -->
  <div class="tab-panel active" id="tab-dashboard">
    <div class="toolbar">
      <input type="date" id="dash-start-date">
      <input type="date" id="dash-end-date">
      <button type="button" class="btn-secondary" id="btn-load-dashboard">Refresh</button>
    </div>

    <div class="card" style="margin-bottom:20px;">
      <h2 style="font-family:Georgia,serif;color:var(--maroon);margin-bottom:14px;">Cash position</h2>
      <div id="dash-balance-gauge"></div>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px;">
      <div class="card">
        <h2 style="font-family:Georgia,serif;color:var(--maroon);margin-bottom:14px;font-size:1.05rem;">Income by source</h2>
        <div id="dash-income-chart"></div>
      </div>
      <div class="card">
        <h2 style="font-family:Georgia,serif;color:var(--maroon);margin-bottom:14px;font-size:1.05rem;">Future booked facility rental revenue</h2>
        <div id="dash-future-revenue"></div>
      </div>
    </div>

    <div class="card">
      <h2 style="font-family:Georgia,serif;color:var(--maroon);margin-bottom:14px;font-size:1.05rem;">Fundraising events breakdown</h2>
      <div id="dash-fundraising-chart"></div>
    </div>
  </div>

  <div class="tab-panel" id="tab-transactions">
    <div class="card" style="margin-bottom:16px;">
      <p style="font-size:0.86rem;color:var(--muted);line-height:1.6;margin:0;">Sourced entirely from bank transactions — the single source of truth for accounting, so nothing gets double-counted. Zeffy's weekly payout deposit is automatically split into Individual Donations, Facility Rental Income, and Fundraising Event Income based on that week's underlying campaign activity, each pre-tagged — override any of them below if a suggestion looks wrong.</p>
    </div>
    <div class="toolbar">
      <input type="date" id="tx-start-date">
      <input type="date" id="tx-end-date">
      <select id="tx-status-filter">
        <option value="">All</option>
        <option value="uncategorized">Uncategorized only</option>
        <option value="categorized">Categorized only</option>
      </select>
      <button type="button" class="btn-secondary" id="btn-load-tx">Refresh</button>
      <span class="count" id="tx-count"></span>
    </div>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Date</th><th>Description</th><th>Amount</th><th>Category</th></tr></thead>
        <tbody id="tx-tbody"></tbody>
      </table>
      <div class="empty-state" id="tx-empty" style="display:none;">No transactions in this range.</div>
    </div>
  </div>

  <!-- ── CATEGORIES TAB ── -->
  <div class="tab-panel" id="tab-categories">
    <div class="card">
      <h2 style="font-family:Georgia,serif;color:var(--maroon);margin-bottom:14px;">Income categories</h2>
      <div class="category-list" id="income-category-list"></div>
      <h2 style="font-family:Georgia,serif;color:var(--maroon);margin:22px 0 14px;">Expense categories</h2>
      <div class="category-list" id="expense-category-list"></div>

      <div style="margin-top:24px;padding-top:20px;border-top:1px solid var(--border);display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end;">
        <div style="flex:1;min-width:200px;">
          <label style="font-size:0.82rem;font-weight:700;color:var(--muted);display:block;margin-bottom:6px;">New category name</label>
          <input type="text" id="new-cat-name" style="width:100%;font-family:inherit;font-size:0.9rem;padding:10px 14px;border:1.5px solid var(--border);border-radius:10px;">
        </div>
        <select id="new-cat-type" style="font-family:inherit;font-size:0.9rem;padding:10px 14px;border:1.5px solid var(--border);border-radius:10px;">
          <option value="income">Income</option>
          <option value="expense">Expense</option>
        </select>
        <button type="button" class="btn-primary" id="btn-add-category">Add category</button>
      </div>
      <div class="result-box" id="cat-result-box" style="display:none;margin-top:12px;border-radius:10px;padding:10px 14px;font-size:0.85rem;"></div>
    </div>
  </div>

  <!-- ── STATEMENT OF ACTIVITIES TAB ── -->
  <div class="tab-panel" id="tab-statements">
    <div class="sub-tab-nav">
      <button class="sub-tab-btn active" data-subtab="income-statement">Income Statement (P&amp;L)</button>
      <button class="sub-tab-btn" data-subtab="balance-sheet-sub">Balance Sheet</button>
    </div>

    <div class="sub-tab-panel active" id="subtab-income-statement">
      <div class="toolbar">
        <input type="date" id="stmt-start-date">
        <input type="date" id="stmt-end-date">
        <button type="button" class="btn-secondary" id="btn-load-statement">Generate</button>
      </div>
      <div class="card" id="statement-card">
        <div class="empty-state">Choose a date range and click Generate.</div>
      </div>
    </div>

    <div class="sub-tab-panel" id="subtab-balance-sheet-sub">
      <div class="card" style="margin-bottom:20px;">
        <p style="font-size:0.88rem;color:var(--muted);line-height:1.6;">Cash is computed from every recorded bank transaction to date — it's only as accurate as that history is complete. If you know the real starting balance before this data began, add it below as an asset (e.g. "Starting balance adjustment") so the total lines up. Receivables, fixed assets, loans, and anything else a real balance sheet needs has no source of truth in this system yet — add it manually below.</p>
      </div>
      <div class="toolbar">
        <input type="date" id="bs-as-of-date">
        <button type="button" class="btn-secondary" id="btn-load-balance-sheet">Generate</button>
      </div>
      <div class="card" id="balance-sheet-card" style="margin-bottom:20px;">
        <div class="empty-state">Choose a date and click Generate.</div>
      </div>
      <div class="card">
        <h2 style="font-family:Georgia,serif;color:var(--maroon);margin-bottom:14px;">Manual assets &amp; liabilities</h2>
        <div id="bs-items-list" style="margin-bottom:16px;"></div>
        <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:flex-end;padding-top:16px;border-top:1px solid var(--border);">
          <div style="flex:1;min-width:180px;">
            <label style="font-size:0.82rem;font-weight:700;color:var(--muted);display:block;margin-bottom:6px;">Item name</label>
            <input type="text" id="bs-new-name" placeholder="e.g. Starting balance adjustment" style="width:100%;font-family:inherit;font-size:0.9rem;padding:10px 14px;border:1.5px solid var(--border);border-radius:10px;">
          </div>
          <select id="bs-new-category" style="font-family:inherit;font-size:0.9rem;padding:10px 14px;border:1.5px solid var(--border);border-radius:10px;">
            <option value="asset">Asset</option>
            <option value="liability">Liability</option>
          </select>
          <div>
            <label style="font-size:0.82rem;font-weight:700;color:var(--muted);display:block;margin-bottom:6px;">Amount</label>
            <input type="number" step="0.01" id="bs-new-amount" style="width:140px;font-family:inherit;font-size:0.9rem;padding:10px 14px;border:1.5px solid var(--border);border-radius:10px;">
          </div>
          <button type="button" class="btn-primary" id="btn-add-bs-item">Add item</button>
        </div>
        <div class="result-box" id="bs-result-box" style="display:none;margin-top:12px;border-radius:10px;padding:10px 14px;font-size:0.85rem;"></div>
      </div>
    </div>
  </div>

  <!-- ── RECONCILIATION TAB ── -->
  <div class="tab-panel" id="tab-reconciliation">
    <div class="card" style="margin-bottom:20px;">
      <p style="font-size:0.88rem;color:var(--muted);line-height:1.6;">Zeffy pays out once a week (Mondays) as one lump deposit, covering all the individual transactions logged that week. This compares each week's expected payout (sum of that week's Zeffy transactions) against the bank deposits that showed up around the same time — review and confirm the match yourself, nothing here links automatically.</p>
    </div>
    <div id="reconciliation-list"></div>
  </div>

  <!-- ── INVOICE MATCHING TAB ── -->
  <div class="tab-panel" id="tab-matching">
    <div class="card" style="margin-bottom:20px;">
      <p style="font-size:0.88rem;color:var(--muted);line-height:1.6;">Rental-campaign Zeffy payments that look like they belong to an open, unpaid booking. Confirming a match here links the payment to that booking and highlights it in All Bookings — it does <strong>not</strong> mark the booking paid by itself. That final step is still a manual Mark Paid click in All Bookings, on purpose.</p>
    </div>
    <div id="matching-list"></div>
  </div>

  <!-- ── EXPENSE APPROVALS TAB ── -->
  <div class="tab-panel" id="tab-expenses">
    <div class="toolbar">
      <select id="exp-status-filter">
        <option value="submitted">Awaiting review</option>
        <option value="approved">Approved (not yet paid)</option>
        <option value="paid">Paid</option>
        <option value="rejected">Rejected</option>
        <option value="">All</option>
      </select>
      <button type="button" class="btn-secondary" id="btn-load-expenses">Refresh</button>
    </div>
    <div id="expenses-submission-list"></div>
  </div>

</div>
</div>

<div class="modal-overlay" id="expense-review-overlay" style="display:none;">
  <div class="modal-panel" style="max-width:1000px;width:95%;">
    <div class="modal-header">
      <h2 id="exp-review-title">Review submission</h2>
      <button class="modal-close" id="btn-close-expense-review">&times;</button>
    </div>
    <div class="modal-body" style="display:grid;grid-template-columns:1fr 1fr;gap:24px;max-height:70vh;overflow-y:auto;">
      <div id="exp-review-details"></div>
      <div>
        <div style="font-size:0.82rem;font-weight:700;color:var(--muted);margin-bottom:8px;">Receipt</div>
        <div id="exp-review-receipt" style="border:1.5px solid var(--border);border-radius:12px;min-height:300px;display:flex;align-items:center;justify-content:center;background:var(--surface-soft);">
          <span style="color:var(--muted);font-size:0.86rem;">Click an expense to view its receipt</span>
        </div>
      </div>
    </div>
    <div class="result-box" id="exp-review-result" style="display:none;margin:0 26px 16px;"></div>
    <div class="modal-footer">
      <button type="button" class="btn-secondary" id="btn-reject-expense">Reject selected</button>
      <button type="button" class="btn-primary" id="btn-approve-expense" style="margin-top:0;">Approve selected</button>
    </div>
  </div>
</div>

<div id="site-footer"></div>

<style>
.modal-overlay { position: fixed; inset: 0; background: rgba(44,27,16,0.5); z-index: 100; display: flex; align-items: flex-start; justify-content: center; padding: 40px 16px; overflow-y: auto; }
.modal-panel { background: var(--surface); border-radius: var(--radius); box-shadow: var(--shadow); }
.modal-header { display: flex; align-items: center; justify-content: space-between; padding: 22px 26px; border-bottom: 1px solid var(--border); }
.modal-header h2 { font-family: Georgia, "Times New Roman", serif; font-size: 1.15rem; color: var(--maroon); }
.modal-close { background: none; border: none; font-size: 1.4rem; color: var(--muted); cursor: pointer; line-height: 1; }
.modal-body { padding: 22px 26px; }
.modal-footer { display: flex; justify-content: flex-end; gap: 10px; padding: 18px 26px; border-top: 1px solid var(--border); }
.exp-line-item { border: 1.5px solid var(--border); border-radius: 12px; padding: 12px 14px; margin-bottom: 10px; cursor: pointer; }
.exp-line-item:hover, .exp-line-item.active { border-color: var(--saffron-dark); background: var(--surface-soft); }
.exp-line-item .exp-top-row { display: flex; justify-content: space-between; font-weight: 700; font-size: 0.9rem; margin-bottom: 4px; }
.exp-line-item .exp-date { font-size: 0.78rem; color: var(--muted); margin-bottom: 8px; }
.exp-submission-card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 16px 20px; margin-bottom: 12px; display: flex; justify-content: space-between; align-items: center; }
.exp-submission-card .exp-sub-info { font-size: 0.9rem; }
.exp-submission-card .exp-sub-total { font-weight: 700; color: var(--maroon); font-size: 1rem; }
.result-box.success { background: var(--green-bg); color: var(--green); border: 1px solid rgba(46,125,79,0.25); }
.result-box.error { background: var(--red-bg); color: var(--red); border: 1px solid rgba(179,56,44,0.25); }
</style>

<script>
const API_BASE = 'https://facility-rental-api-217911937447.us-central1.run.app';

async function authedFetch(url, options) {
  options = options || {};
  var user = window.__hccgcFirebaseUser;
  if (!user) throw new Error('Not signed in.');
  var token = await user.getIdToken();
  options.headers = Object.assign({}, options.headers, { 'Authorization': 'Bearer ' + token });
  return fetch(url, options);
}
function escHtml(str) { return String(str || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;'); }
function formatDate(d) { if (!d) return '—'; return new Date(d + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }); }
function money(n) { return '$' + Number(n).toFixed(2); }

// ── Tabs ──
document.querySelectorAll('.tab-btn').forEach(function (btn) {
  btn.addEventListener('click', function () {
    document.querySelectorAll('.tab-btn').forEach(function (b) { b.classList.remove('active'); });
    document.querySelectorAll('.tab-panel').forEach(function (p) { p.classList.remove('active'); });
    btn.classList.add('active');
    document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
    if (btn.dataset.tab === 'dashboard') loadDashboard();
    if (btn.dataset.tab === 'reconciliation' && !window.__reconLoaded) loadReconciliation();
    if (btn.dataset.tab === 'matching' && !window.__matchingLoaded) loadUnmatchedRentalPayments();
    if (btn.dataset.tab === 'statements' && !window.__bsItemsLoaded) loadBalanceSheetItems();
    if (btn.dataset.tab === 'expenses') loadExpenseSubmissions();
  });
});
document.querySelectorAll('.sub-tab-btn').forEach(function (btn) {
  btn.addEventListener('click', function () {
    document.querySelectorAll('.sub-tab-btn').forEach(function (b) { b.classList.remove('active'); });
    document.querySelectorAll('.sub-tab-panel').forEach(function (p) { p.classList.remove('active'); });
    btn.classList.add('active');
    document.getElementById('subtab-' + btn.dataset.subtab).classList.add('active');
  });
});

// ── Categories (shared across tabs) ──
let CATEGORIES = [];
async function loadCategories() {
  const res = await authedFetch(API_BASE + '/finance/categories');
  CATEGORIES = await res.json();
  renderCategoriesTab();
}
function renderCategoriesTab() {
  const income = CATEGORIES.filter(function (c) { return c.type === 'income'; });
  const expense = CATEGORIES.filter(function (c) { return c.type === 'expense'; });
  document.getElementById('income-category-list').innerHTML = income.map(renderCategoryPill).join('');
  document.getElementById('expense-category-list').innerHTML = expense.map(renderCategoryPill).join('');
}
function renderCategoryPill(c) {
  return '<div class="category-pill' + (c.active ? '' : ' inactive') + '">' +
    '<span class="type-dot ' + c.type + '"></span>' + escHtml(c.name) +
    '<button data-toggle-category="' + c.category_id + '" data-active="' + !c.active + '">' + (c.active ? 'Deactivate' : 'Activate') + '</button>' +
    '</div>';
}
async function toggleCategoryActive(categoryId, active) {
  await authedFetch(API_BASE + '/finance/categories/' + encodeURIComponent(categoryId), {
    method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ active: active })
  });
  await loadCategories();
}
['income-category-list', 'expense-category-list'].forEach(function (id) {
  document.getElementById(id).addEventListener('click', function (e) {
    const btn = e.target.closest('[data-toggle-category]');
    if (!btn) return;
    toggleCategoryActive(btn.dataset.toggleCategory, btn.dataset.active === 'true');
  });
});
document.getElementById('btn-add-category').addEventListener('click', async function () {
  const name = document.getElementById('new-cat-name').value.trim();
  const type = document.getElementById('new-cat-type').value;
  const box = document.getElementById('cat-result-box');
  if (!name) { box.style.display = 'block'; box.style.background = 'var(--red-bg)'; box.style.color = 'var(--red)'; box.textContent = 'Category name is required.'; return; }
  try {
    const res = await authedFetch(API_BASE + '/finance/categories', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name: name, type: type })
    });
    const data = await res.json();
    box.style.display = 'block';
    if (!res.ok) {
      box.style.background = 'var(--red-bg)'; box.style.color = 'var(--red)';
      box.textContent = (data.errors || [data.error]).join(' ');
    } else {
      box.style.background = 'var(--green-bg)'; box.style.color = 'var(--green)';
      box.textContent = 'Added "' + name + '".';
      document.getElementById('new-cat-name').value = '';
      await loadCategories();
      populateCategorySelects();
    }
  } catch (err) {
    box.style.display = 'block'; box.style.background = 'var(--red-bg)'; box.style.color = 'var(--red)';
    box.textContent = 'Could not reach the server: ' + err.message;
  }
});

// ── Transactions ──
let TRANSACTIONS = [];
function defaultDateRange() {
  const end = new Date();
  const start = new Date(); start.setMonth(start.getMonth() - 1);
  return { start: start.toISOString().slice(0, 10), end: end.toISOString().slice(0, 10) };
}
(function initDateFields() {
  const range = defaultDateRange();
  ['tx-start-date', 'stmt-start-date', 'dash-start-date'].forEach(function (id) { document.getElementById(id).value = range.start; });
  ['tx-end-date', 'stmt-end-date', 'dash-end-date'].forEach(function (id) { document.getElementById(id).value = range.end; });
})();

// ── Dashboard ──
document.getElementById('btn-load-dashboard').addEventListener('click', loadDashboard);
async function loadDashboard() {
  const start = document.getElementById('dash-start-date').value;
  const end = document.getElementById('dash-end-date').value;
  try {
    const res = await authedFetch(API_BASE + '/finance/dashboard?startDate=' + start + '&endDate=' + end);
    const data = await res.json();
    renderBalanceGauge(data);
    renderIncomeChart(data.incomeBreakdown);
    renderFutureRevenue(data);
    renderFundraisingChart(data.fundraisingBreakdown);
  } catch (err) {
    document.getElementById('dash-balance-gauge').innerHTML = '<div class="empty-state">Could not load dashboard: ' + escHtml(err.message) + '</div>';
  }
}
function renderBalanceGauge(data) {
  const min = data.minimumBalanceRequirement;
  const cash = data.currentCash;
  const isAbove = cash >= min;
  // Scale the bar so the minimum-requirement marker sits at roughly the
  // 40% mark, giving room to show being comfortably above it too.
  const scaleMax = Math.max(cash, min) * 1.4;
  const cashPct = Math.max(0, Math.min(100, (cash / scaleMax) * 100));
  const minPct = Math.max(0, Math.min(100, (min / scaleMax) * 100));
  document.getElementById('dash-balance-gauge').innerHTML =
    '<div class="gauge-track"><div class="gauge-fill ' + (isAbove ? 'positive' : 'negative') + '" style="width:' + cashPct + '%;">' +
      '<span style="color:#fff;font-size:0.78rem;font-weight:700;">' + money(cash) + '</span>' +
    '</div><div class="gauge-marker" style="left:' + minPct + '%;"></div></div>' +
    '<div class="gauge-labels"><span>$0</span><span>Minimum required: ' + money(min) + '</span></div>' +
    '<div class="gauge-stats">' +
      '<div class="gauge-stat"><div class="label">Current cash</div><div class="value">' + money(cash) + '</div></div>' +
      '<div class="gauge-stat"><div class="label">' + (isAbove ? 'Above minimum' : 'Below minimum') + '</div><div class="value ' + (isAbove ? 'positive' : 'negative') + '">' + money(Math.abs(data.aboveMinimum)) + '</div></div>' +
    '</div>';
}
function renderBarChart(containerId, items, emptyMessage) {
  const container = document.getElementById(containerId);
  if (!items.length) { container.innerHTML = '<div class="empty-state" style="padding:20px;">' + emptyMessage + '</div>'; return; }
  const max = Math.max.apply(null, items.map(function (i) { return i.total; }));
  container.innerHTML = items.map(function (i) {
    const pct = max > 0 ? Math.max(2, (i.total / max) * 100) : 0;
    return '<div class="bar-chart-row">' +
      '<div class="bar-chart-label" title="' + escHtml(i.name) + '">' + escHtml(i.name) + '</div>' +
      '<div class="bar-chart-track"><div class="bar-chart-fill" style="width:' + pct + '%;"></div></div>' +
      '<div class="bar-chart-value">' + money(i.total) + '</div>' +
    '</div>';
  }).join('');
}
function renderIncomeChart(incomeBreakdown) {
  renderBarChart('dash-income-chart', incomeBreakdown, 'No categorized income in this range yet.');
}
function renderFundraisingChart(fundraisingBreakdown) {
  renderBarChart('dash-fundraising-chart', fundraisingBreakdown, 'No fundraising campaign activity in this range.');
}
function renderFutureRevenue(data) {
  document.getElementById('dash-future-revenue').innerHTML =
    '<div class="stat-card-big"><div class="value">' + money(data.futureBookedRevenue) + '</div>' +
    '<div class="sub">' + data.futureBookingsCount + ' upcoming booking' + (data.futureBookingsCount === 1 ? '' : 's') + ', not yet paid</div></div>';
}

async function loadTransactions() {
  const start = document.getElementById('tx-start-date').value;
  const end = document.getElementById('tx-end-date').value;
  const status = document.getElementById('tx-status-filter').value;
  const params = new URLSearchParams({ startDate: start, endDate: end });
  if (status) params.set('status', status);

  const tbody = document.getElementById('tx-tbody');
  const emptyState = document.getElementById('tx-empty');
  tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;color:var(--muted);padding:30px;">Loading…</td></tr>';
  try {
    const res = await authedFetch(API_BASE + '/finance/transactions?' + params.toString());
    TRANSACTIONS = await res.json();
    document.getElementById('tx-count').textContent = TRANSACTIONS.length + ' transactions';
    if (!TRANSACTIONS.length) { tbody.innerHTML = ''; emptyState.style.display = 'block'; return; }
    emptyState.style.display = 'none';
    tbody.innerHTML = TRANSACTIONS.map(renderTxRow).join('');
    populateCategorySelects();
  } catch (err) {
    tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;color:var(--red);padding:30px;">Could not load: ' + escHtml(err.message) + '</td></tr>';
  }
}
function renderTxRow(t) {
  const rowId = t.source + '|' + t.sourceKey;
  return '<tr>' +
    '<td>' + formatDate(t.date) + '</td>' +
    '<td>' + escHtml(t.description) + '</td>' +
    '<td class="amount">' + money(t.amount) + '</td>' +
    '<td><select class="cat-select' + (t.categoryId ? '' : ' uncategorized') + '" data-row="' + rowId + '" data-assign-category-source="' + t.source + '" data-assign-category-key="' + t.sourceKey + '"><option value="">Uncategorized</option></select></td>' +
  '</tr>';
}
function categoryOptionsHtml(currentCatId) {
  const incomeOpts = CATEGORIES.filter(function (c) { return c.type === 'income' && (c.active || c.category_id === currentCatId); })
    .map(function (c) { return '<option value="' + c.category_id + '"' + (c.category_id === currentCatId ? ' selected' : '') + '>' + escHtml(c.name) + '</option>'; }).join('');
  const expenseOpts = CATEGORIES.filter(function (c) { return c.type === 'expense' && (c.active || c.category_id === currentCatId); })
    .map(function (c) { return '<option value="' + c.category_id + '"' + (c.category_id === currentCatId ? ' selected' : '') + '>' + escHtml(c.name) + '</option>'; }).join('');
  return '<option value="">Uncategorized</option>' +
    (incomeOpts ? '<optgroup label="Income">' + incomeOpts + '</optgroup>' : '') +
    (expenseOpts ? '<optgroup label="Expense">' + expenseOpts + '</optgroup>' : '');
}
function populateCategorySelects() {
  document.querySelectorAll('.cat-select').forEach(function (sel) {
    const rowId = sel.dataset.row;
    const tx = TRANSACTIONS.find(function (t) { return (t.source + '|' + t.sourceKey) === rowId; });
    const currentCatId = tx ? tx.categoryId : null;
    sel.innerHTML = categoryOptionsHtml(currentCatId);
    sel.classList.toggle('uncategorized', !currentCatId);
  });
}
async function assignCategory(source, sourceKey, categoryId) {
  if (!categoryId) return;
  try {
    await authedFetch(API_BASE + '/finance/categorize', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ source: source, sourceKey: sourceKey, categoryId: categoryId })
    });
    const tx = TRANSACTIONS.find(function (t) { return t.source === source && t.sourceKey === sourceKey; });
    if (tx) tx.categoryId = categoryId;
    populateCategorySelects();
  } catch (err) {
    alert('Could not save category: ' + err.message);
  }
}
document.getElementById('tx-tbody').addEventListener('change', function (e) {
  const sel = e.target.closest('[data-assign-category-source]');
  if (!sel) return;
  assignCategory(sel.dataset.assignCategorySource, sel.dataset.assignCategoryKey, sel.value);
});
document.getElementById('btn-load-tx').addEventListener('click', loadTransactions);

// ── Statement of Activities ──
document.getElementById('btn-load-statement').addEventListener('click', async function () {
  const start = document.getElementById('stmt-start-date').value;
  const end = document.getElementById('stmt-end-date').value;
  const card = document.getElementById('statement-card');
  card.innerHTML = '<div class="empty-state">Generating…</div>';
  try {
    const res = await authedFetch(API_BASE + '/finance/statement-of-activities?startDate=' + start + '&endDate=' + end);
    const data = await res.json();
    let html = '<div style="font-size:0.82rem;color:var(--muted);margin-bottom:6px;">' + formatDate(start) + ' – ' + formatDate(end) + '</div>';
    html += '<div class="stmt-section-title">Income</div>';
    html += data.income.map(function (r) { return '<div class="stmt-row"><span>' + escHtml(r.name) + '<span class="count">(' + r.count + ')</span></span><span class="amount income">' + money(r.total) + '</span></div>'; }).join('') || '<div class="empty-state" style="padding:14px;">No categorized income yet.</div>';
    html += '<div class="stmt-total"><span>Total Income</span><span>' + money(data.totalIncome) + '</span></div>';
    html += '<div class="stmt-section-title">Expenses</div>';
    html += data.expense.map(function (r) { return '<div class="stmt-row"><span>' + escHtml(r.name) + '<span class="count">(' + r.count + ')</span></span><span class="amount expense">' + money(r.total) + '</span></div>'; }).join('') || '<div class="empty-state" style="padding:14px;">No categorized expenses yet.</div>';
    html += '<div class="stmt-total"><span>Total Expenses</span><span>' + money(data.totalExpense) + '</span></div>';
    html += '<div class="stmt-net ' + (data.netIncome >= 0 ? 'positive' : 'negative') + '"><span>Net Income</span><span>' + money(data.netIncome) + '</span></div>';
    card.innerHTML = html;
  } catch (err) {
    card.innerHTML = '<div class="empty-state">Could not generate: ' + escHtml(err.message) + '</div>';
  }
});

// ── Reconciliation ──
async function loadReconciliation() {
  window.__reconLoaded = true;
  const list = document.getElementById('reconciliation-list');
  list.innerHTML = '<div class="empty-state">Loading…</div>';
  try {
    const res = await authedFetch(API_BASE + '/finance/reconciliation');
    const weeks = await res.json();
    if (!weeks.length) { list.innerHTML = '<div class="empty-state">No Zeffy activity found.</div>'; return; }
    list.innerHTML = weeks.map(function (w) {
      const candidatesHtml = w.candidates.length
        ? w.candidates.map(function (c) {
            const diff = Math.abs(c.amount - w.expectedPayout);
            const isMatch = diff < 1;
            return '<div class="recon-candidate ' + (isMatch ? 'match' : 'mismatch') + '">' +
              '<span>' + formatDate(c.date) + ' — ' + escHtml(c.description) + '</span>' +
              '<span class="amount">' + money(c.amount) + (isMatch ? ' ✓' : ' (diff: ' + money(diff) + ')') + '</span>' +
            '</div>';
          }).join('')
        : '<div class="recon-none">No matching bank deposit found yet — may not have landed.</div>';
      return '<div class="recon-week-card">' +
        '<div class="recon-week-header"><span class="week-label">Week of ' + formatDate(w.weekStart) + '</span><span class="expected">Expected payout: ' + money(w.expectedPayout) + ' (' + w.txnCount + ' transactions)</span></div>' +
        candidatesHtml +
      '</div>';
    }).join('');
  } catch (err) {
    list.innerHTML = '<div class="empty-state">Could not load: ' + escHtml(err.message) + '</div>';
  }
}

// ── Invoice Matching ──
async function loadUnmatchedRentalPayments() {
  window.__matchingLoaded = true;
  const list = document.getElementById('matching-list');
  list.innerHTML = '<div class="empty-state">Loading…</div>';
  try {
    const res = await authedFetch(API_BASE + '/finance/unmatched-rental-payments');
    const payments = await res.json();
    if (!payments.length) { list.innerHTML = '<div class="empty-state">No unmatched rental payments with a plausible booking match right now.</div>'; return; }
    list.innerHTML = payments.map(function (p) {
      const candidatesHtml = p.candidates.map(function (c) {
        return '<div class="recon-candidate match" style="cursor:pointer;" data-confirm-match-payment="' + p.paymentId + '" data-confirm-match-booking="' + c.bookingId + '" data-confirm-match-amount="' + p.amount + '" data-confirm-match-date="' + p.date + '">' +
          '<span>' + escHtml(c.renterName) + ' — ' + formatDate(c.eventDate) + ' (' + escHtml(c.bookingId) + ')</span>' +
          '<span class="amount">' + money(c.amount) + ' — click to confirm</span>' +
        '</div>';
      }).join('');
      return '<div class="recon-week-card">' +
        '<div class="recon-week-header"><span class="week-label">' + escHtml(p.donor) + ' — ' + formatDate(p.date) + '</span><span class="expected">' + money(p.amount) + '</span></div>' +
        candidatesHtml +
      '</div>';
    }).join('');
  } catch (err) {
    list.innerHTML = '<div class="empty-state">Could not load: ' + escHtml(err.message) + '</div>';
  }
}
async function confirmFinanceMatch(paymentId, bookingId, amount, date) {
  if (!confirm('Link this Zeffy payment to booking ' + bookingId + '? This highlights it in All Bookings — you still confirm Mark Paid there.')) return;
  try {
    const res = await authedFetch(API_BASE + '/finance/confirm-match', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ bookingId: bookingId, paymentId: paymentId, amount: amount, date: date })
    });
    const data = await res.json();
    if (!res.ok) { alert('Could not confirm: ' + ((data.errors || [data.error]).join(' ') || 'unknown error')); return; }
    await loadUnmatchedRentalPayments();
  } catch (err) {
    alert('Could not reach the server: ' + err.message);
  }
}
document.getElementById('matching-list').addEventListener('click', function (e) {
  const el = e.target.closest('[data-confirm-match-payment]');
  if (!el) return;
  confirmFinanceMatch(el.dataset.confirmMatchPayment, el.dataset.confirmMatchBooking, Number(el.dataset.confirmMatchAmount), el.dataset.confirmMatchDate);
});

// ── Balance Sheet ──
document.getElementById('bs-as-of-date').value = new Date().toISOString().slice(0, 10);
document.getElementById('btn-load-balance-sheet').addEventListener('click', async function () {
  const asOfDate = document.getElementById('bs-as-of-date').value;
  const card = document.getElementById('balance-sheet-card');
  card.innerHTML = '<div class="empty-state">Generating…</div>';
  try {
    const res = await authedFetch(API_BASE + '/finance/balance-sheet?asOfDate=' + asOfDate);
    const data = await res.json();
    let html = '<div style="font-size:0.82rem;color:var(--muted);margin-bottom:6px;">As of ' + formatDate(data.asOfDate) + '</div>';
    html += '<div class="stmt-section-title">Assets</div>';
    html += '<div class="stmt-row"><span>Cash (from bank transaction history)</span><span class="amount income">' + money(data.cash) + '</span></div>';
    html += data.assets.map(function (a) { return '<div class="stmt-row"><span>' + escHtml(a.name) + '</span><span class="amount income">' + money(a.amount) + '</span></div>'; }).join('');
    html += '<div class="stmt-total"><span>Total Assets</span><span>' + money(data.totalAssets) + '</span></div>';
    html += '<div class="stmt-section-title">Liabilities</div>';
    html += data.liabilities.length ? data.liabilities.map(function (l) { return '<div class="stmt-row"><span>' + escHtml(l.name) + '</span><span class="amount expense">' + money(l.amount) + '</span></div>'; }).join('') : '<div class="empty-state" style="padding:14px;">None recorded.</div>';
    html += '<div class="stmt-total"><span>Total Liabilities</span><span>' + money(data.totalLiabilities) + '</span></div>';
    html += '<div class="stmt-net ' + (data.netAssets >= 0 ? 'positive' : 'negative') + '"><span>Net Assets</span><span>' + money(data.netAssets) + '</span></div>';
    card.innerHTML = html;
  } catch (err) {
    card.innerHTML = '<div class="empty-state">Could not generate: ' + escHtml(err.message) + '</div>';
  }
});

async function loadBalanceSheetItems() {
  window.__bsItemsLoaded = true;
  const list = document.getElementById('bs-items-list');
  list.innerHTML = '<div class="empty-state">Loading…</div>';
  try {
    const res = await authedFetch(API_BASE + '/finance/balance-sheet-items');
    const items = await res.json();
    if (!items.length) { list.innerHTML = '<div class="empty-state" style="padding:14px;">No manual items yet.</div>'; return; }
    list.innerHTML = items.map(function (i) {
      return '<div class="stmt-row"><span><span class="type-dot ' + (i.category === 'asset' ? 'income' : 'expense') + '" style="display:inline-block;width:8px;height:8px;border-radius:50%;margin-right:8px;"></span>' + escHtml(i.name) + (i.active ? '' : ' (inactive)') + '</span>' +
        '<span>' + money(i.amount) + ' <button data-toggle-bs-item="' + i.item_id + '" data-active="' + !i.active + '" style="border:none;background:none;color:var(--saffron-dark);font-weight:700;font-size:0.78rem;cursor:pointer;margin-left:10px;">' + (i.active ? 'Deactivate' : 'Activate') + '</button></span></div>';
    }).join('');

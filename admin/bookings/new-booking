  });
  params.set('ctz', 'America/New_York');
  params.set('wkst', '1');
  params.set('height', '490');
  params.set('showTitle', '0'); params.set('showPrint', '0'); params.set('showTabs', '0');

  // Once a date is picked, jump the embed to the week containing that date.
  // Note: Google's embed only supports WEEK/AGENDA/MONTH as valid mode
  // values — DAY isn't one of them, which is why an earlier version of this
  // silently fell back to month view. WEEK + a `dates` range pointed at the
  // chosen date reliably jumps to the right week instead.
  const chosenDate = document.getElementById('f-date').value;
  params.set('mode', 'WEEK');
  if (chosenDate) {
    const compact = chosenDate.replace(/-/g, '');
    params.set('dates', compact + '/' + compact);

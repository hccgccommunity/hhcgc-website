<style>
:root {
  --bg: #fff9f1;
  --surface: #ffffff;
  --surface-soft: #fff6ea;
  --border: rgba(121,62,17,0.14);
  --text: #2c1b10;
  --muted: #6a5141;
  --saffron: #b55a18;
  --saffron-dark: #8d3e0d;
  --maroon: #7f2e16;
  --radius: 22px;
  --shadow: 0 18px 45px rgba(93,43,14,0.10);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: Arial, Helvetica, sans-serif;
  background: radial-gradient(circle at top left, rgba(217,138,30,0.12), transparent 22%),
              radial-gradient(circle at top right, rgba(127,46,22,0.05), transparent 20%),
              var(--bg);
  color: var(--text);
  min-height: 100vh;
}

.container { width: min(calc(100% - 32px), 1100px); margin: 0 auto; }

/* HEADER */
.site-header {
  position: sticky; top: 0; z-index: 50;
  background: rgba(255,249,241,0.92); backdrop-filter: blur(10px);
  border-bottom: 1px solid var(--border);
}
.nav { display: flex; align-items: center; justify-content: space-between; gap: 24px; min-height: 92px; padding: 12px 0; }
.brand { display: flex; align-items: center; gap: 16px; min-width: 0; }
.brand-logo-wrap { background: #7f2e16; border-radius: 18px; padding: 8px; flex-shrink: 0; }
.brand-logo { width: 88px; height: auto; border-radius: 12px; object-fit: contain; }
.brand-text h1 { margin: 0; font-size: 1.2rem; line-height: 1.15; color: var(--maroon); font-family: Georgia, serif; }
.site-header a.brand, .site-header a.brand:link, .site-header a.brand:visited { text-decoration: none; color: inherit; }
.site-header nav ul { list-style: none; display: flex; flex-wrap: wrap; gap: 18px; margin: 0; padding: 0; align-items: center; justify-content: flex-end; }
.site-header nav a, .site-header nav a:link, .site-header nav a:visited { font-weight: 700; color: var(--text); font-size: 0.96rem; text-decoration: none; }
.site-header nav a:hover { color: var(--saffron-dark); }
.menu-toggle { display: none; border: 0; background: transparent; padding: 6px 0; cursor: pointer; color: #2c1b10; align-self: flex-end; }
.menu-toggle .bar { display: block; width: 26px; height: 2px; margin: 5px 0; background: currentColor; }
@media (max-width: 768px) {
  .nav { flex-direction: column; align-items: stretch; gap: 8px; }
  .menu-toggle { display: inline-block; }
  .site-header nav { display: none; width: 100%; background: rgba(255,249,241,0.95); padding: 10px 0; }
  .site-header nav.is-open { display: block; }
  .site-header nav ul { flex-direction: column; gap: 14px; }
}

/* GATE */
#gate { padding: 60px 16px; display: flex; justify-content: center; }
.gate-card {
  background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius);
  padding: 2.5rem 2rem; max-width: 420px; width: 100%; text-align: center; box-shadow: var(--shadow);
}
.gate-card h3 { font-family: Georgia, serif; font-size: 1.3rem; color: var(--maroon); margin-bottom: 0.5rem; }
.gate-card p { color: var(--muted); font-size: 0.88rem; line-height: 1.6; }
.gate-card a { color: var(--saffron-dark); }

#app { display: none; }

/* PAGE HEADER */
.page-header { padding: 36px 0 20px; }
.page-header h1 { font-family: Georgia, serif; font-size: 1.8rem; color: var(--maroon); margin-bottom: 6px; }
.page-header p { color: var(--muted); font-size: 0.9rem; }
.back-link { font-size: 0.82rem; color: var(--saffron-dark); text-decoration: none; display: inline-block; margin-bottom: 10px; }
.back-link:hover { text-decoration: underline; }

/* STATUS BAR */
.status-bar { display: none; align-items: center; gap: 10px; padding: 0.75rem 1.1rem; border-radius: 12px; font-size: 0.86rem; font-weight: 600; margin: 0 0 1.25rem; }
.status-bar.show { display: flex; }
.status-bar.success { background: #e8f5e9; color: #2e7d32; border: 1px solid #c8e6c9; }
.status-bar.error { background: #fdecea; color: #c0392b; border: 1px solid #f5c6cb; }

/* PAGES LIST */
.pages-list { display: flex; flex-direction: column; gap: 14px; padding-bottom: 60px; }

.page-row {
  background: #fff; border: 1px solid var(--border); border-radius: 16px;
  padding: 1.2rem 1.5rem; display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
}
.page-row-status {
  width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0;
  background: #c8e6c9;
}
.page-row-status.live { background: #4caf50; }
.page-row-info { flex: 1; min-width: 200px; }
.page-row-info h4 { font-family: Georgia, serif; font-size: 1rem; color: var(--maroon); margin-bottom: 3px; }
.page-row-info .meta { font-size: 0.78rem; color: var(--muted); }
.page-row-info .meta a { color: var(--saffron-dark); text-decoration: none; }
.page-row-info .meta a:hover { text-decoration: underline; }
.type-badge {
  font-size: 0.68rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em;
  padding: 2px 9px; border-radius: 999px;
}
.type-badge.event { background: rgba(127,46,22,0.1); color: var(--maroon); }
.type-badge.initiative { background: rgba(181,90,24,0.12); color: var(--saffron-dark); }

.btn-edit-page {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 0.45rem 0.9rem; border: 1px solid var(--border); border-radius: 8px;
  background: #fff; font-size: 0.8rem; font-weight: 600; color: var(--muted);
  cursor: pointer; font-family: Arial, Helvetica, sans-serif; white-space: nowrap;
}
.btn-edit-page:hover { border-color: var(--saffron); color: var(--saffron-dark); }

.empty-state {
  text-align: center; padding: 50px 20px; color: var(--muted);
  background: #fff; border: 1px dashed var(--border); border-radius: 16px;
}

/* MODAL */
.modal-overlay {
  display: none; position: fixed; inset: 0; background: rgba(44,27,16,0.45);
  z-index: 200; align-items: flex-start; justify-content: center; padding: 20px;
  overflow-y: auto;
}
.modal-overlay.show { display: flex; }
.modal-card {
  background: #fff; border-radius: 18px; max-width: 620px; width: 100%;
  box-shadow: var(--shadow); margin: auto;
}
.modal-header {
  padding: 1.4rem 1.6rem; border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; background: #fff; border-radius: 18px 18px 0 0; z-index: 1;
}
.modal-header h3 { font-family: Georgia, serif; color: var(--maroon); font-size: 1.15rem; }
.modal-close { background: none; border: none; cursor: pointer; color: var(--muted); font-size: 1.3rem; }
.modal-close:hover { color: var(--maroon); }

/* TABS */
.modal-tabs { display: flex; border-bottom: 1px solid var(--border); padding: 0 1.6rem; background: #fff; }
.modal-tab {
  padding: 0.75rem 1rem; font-size: 0.84rem; font-weight: 700; color: var(--muted);
  cursor: pointer; border: none; background: none; border-bottom: 2.5px solid transparent;
  margin-bottom: -1px; font-family: Arial, Helvetica, sans-serif;
}
.modal-tab.active { color: var(--maroon); border-bottom-color: var(--maroon); }
.modal-tab:hover { color: var(--saffron-dark); }
.modal-panel { display: none; padding: 1.4rem 1.6rem; }
.modal-panel.active { display: block; }

.modal-footer {
  padding: 1.2rem 1.6rem 1.5rem; display: flex; justify-content: space-between;
  align-items: center; gap: 10px; border-top: 1px solid var(--border);
}
.modal-footer-actions { display: flex; gap: 10px; }

/* FORM */
.form-group { margin-bottom: 1.1rem; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
label { display: block; font-size: 0.82rem; font-weight: 700; color: var(--text); margin-bottom: 0.4rem; }
label .hint { font-weight: 400; color: var(--muted); }
input[type="text"], input[type="url"], textarea, select {
  width: 100%; padding: 0.6rem 0.85rem; border: 1.5px solid var(--border);
  border-radius: 10px; font-size: 0.9rem; font-family: Arial, Helvetica, sans-serif;
  background: #fff; color: var(--text);
}
input:focus, textarea:focus, select:focus {
  outline: none; border-color: var(--saffron);
  box-shadow: 0 0 0 3px rgba(181,90,24,0.14);
}
textarea { resize: vertical; }
.field-hint { font-size: 0.76rem; color: var(--muted); margin-top: 4px; }
.field-error { font-size: 0.76rem; color: #c0392b; margin-top: 4px; display: none; }
.field-error.show { display: block; }

.slug-preview {
  font-size: 0.78rem; color: var(--muted); margin-top: 4px;
}
.slug-preview span { font-weight: 700; color: var(--saffron-dark); }

.toggle-row {
  display: flex; align-items: center; gap: 10px;
  padding: 12px 14px; background: var(--surface-soft);
  border: 1px solid var(--border); border-radius: 10px; cursor: pointer;
}
.toggle-row label { margin: 0; cursor: pointer; font-size: 0.9rem; }
.toggle-row input[type="checkbox"] { width: auto; cursor: pointer; }
.toggle-row .page-url { font-size: 0.78rem; color: var(--saffron-dark); margin-left: auto; text-decoration: none; }

.btn-secondary {
  padding: 0.6rem 1.2rem; border-radius: 10px; border: 1.5px solid var(--border);
  background: #fff; color: var(--muted); font-weight: 700; font-size: 0.86rem; cursor: pointer; font-family: Arial, Helvetica, sans-serif;
}
.btn-save {
  padding: 0.6rem 1.4rem; border-radius: 10px; border: none;
  background: var(--maroon); color: #fff; font-weight: 700; font-size: 0.86rem; cursor: pointer; font-family: Arial, Helvetica, sans-serif;
  display: inline-flex; align-items: center; gap: 8px;
}
.btn-save:hover { background: #5a1e0a; }
.btn-save:disabled { background: #b8907e; cursor: not-allowed; }
.spinner {
  width: 14px; height: 14px; border: 2px solid rgba(255,255,255,0.4);
  border-top-color: #fff; border-radius: 50%; animation: spin 0.7s linear infinite;
  display: inline-block;
}
@keyframes spin { to { transform: rotate(360deg); } }

.section-divider {
  font-size: 0.72rem; font-weight: 800; text-transform: uppercase;
  letter-spacing: 0.07em; color: var(--saffron-dark); margin: 1.4rem 0 0.8rem;
  padding-bottom: 6px; border-bottom: 1px dashed var(--border);
}

@media (max-width: 600px) {
  .form-row { grid-template-columns: 1fr; }
  .page-row { flex-direction: column; align-items: stretch; }
}
</style>

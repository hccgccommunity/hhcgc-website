document.getElementById('btn-generate').addEventListener('click', async function () {
  const rooms = selectedRooms();
  const btn = this;
  if (rooms.length === 0) { showResult('error', 'Select at least one room first.'); return; }
  if (!occurrences.length) regenerateOccurrences();
  if (!occurrences.length) { showResult('error', 'Add a date and time first.'); return; }
  const isInternal = document.getElementById('f-internal-enabled').checked;
  const selectedRenterId = document.getElementById('f-renter-select').value;
  if (isInternal) {
    if (!document.getElementById('f-name').value.trim()) { showResult('error', 'Program/event name is required.'); return; }
    if (!document.getElementById('f-hccg-rep').value.trim()) { showResult('error', 'HCCGC representative name is required for internal bookings.'); return; }
    if (!document.getElementById('f-notes').value.trim()) { showResult('error', 'A description is required for internal bookings.'); return; }
  } else if (!selectedRenterId) {
    showResult('error', 'Select a renter from the list first.');
    return;
  }

  const payload = {
    rooms: rooms,
    isInternal: isInternal,
    renterId: !isInternal ? selectedRenterId : null,
    renterName: isInternal ? document.getElementById('f-name').value : null,
    hccgcRepresentativeName: isInternal ? document.getElementById('f-hccg-rep').value : null,
    publishAsEvent: isInternal ? document.getElementById('f-publish-event').checked : false,
    isNonprofit: document.getElementById('f-nonprofit').checked,
    notes: document.getElementById('f-notes').value,
    manualAdjustmentType: (!isInternal && document.getElementById('f-adjustment-enabled').checked) ? document.getElementById('f-adj-type').value : null,
    manualAdjustmentValue: (!isInternal && document.getElementById('f-adjustment-enabled').checked) ? parseFloat(document.getElementById('f-adj-value').value) || null : null,
    manualAdjustmentReason: (!isInternal && document.getElementById('f-adjustment-enabled').checked) ? document.getElementById('f-adj-reason').value : null,
    occurrences: occurrences,
    enteredBy: (window.__hccgcCurrentUser && window.__hccgcCurrentUser.email) || 'Unknown'
  };

  btn.disabled = true;
  btn.textContent = 'Creating booking…';
  try {
    const res = await authedFetch(API_BASE + '/bookings', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (!res.ok) {
      showResult('error', (data.errors || [data.error || 'Something went wrong.']).join(' '));
    } else {
      const occText = data.occurrenceCount > 1 ? (data.occurrenceCount + ' occurrences created, total $' + data.totalAcrossAllOccurrences.toFixed(2)) : ('Booking created — ID ' + data.bookingIds[0]);
      const syncWarning = data.calendarSyncErrors ? (' (Calendar sync had issues: ' + data.calendarSyncErrors.join('; ') + ')') : '';
      const eventNote = data.eventListingCreated ? ' Also added to Manage Events as a draft — edit it there if needed.'
        : (data.eventListingError ? (' Note: could not add to Manage Events (' + data.eventListingError + ') — add it there manually if needed.') : '');
      const statusNote = data.isInternal ? ' No charge — internal booking.' : ' Marked as Pending until invoiced.';
      showResult('success', occText + '.' + statusNote + syncWarning + eventNote);
      resetForm();
    }
  } catch (err) {
    showResult('error', 'Could not reach the booking system. ' + err.message);
  } finally {
    btn.disabled = false;
    btn.textContent = 'Create booking';
  }
});

function showResult(type, message) {

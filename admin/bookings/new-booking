<div class="container">
  <div class="layout">
    <div class="calendar-col">
      <div class="card calendar-card">
        <h2>Room availability</h2>
        <div class="card-sub">Live from Google Calendar, so you can check before you book.</div>
        <select id="calendar-room-select">
          <option value="all">All rooms (overlaid)</option>
          <option value="Surya Hall">Surya Hall</option>
          <option value="Patanjali Hall">Patanjali Hall</option>
          <option value="Nataraj Room">Nataraj Room</option>
          <option value="Ganesh Room">Ganesh Room</option>
        </select>
        <div id="calendar-embed-wrap"></div>
      </div>
    </div>

    <div class="form-col">
      <div class="internal-toggle-strip full-span">
        <div class="checkbox-row" style="margin-bottom:0;"><input type="checkbox" id="f-internal-enabled"><label for="f-internal-enabled">This is an HCCGC program/initiative <span class="muted-inline">— no charge, no customer</span></label></div>
        <div class="collapsible" id="publish-event-field">
          <div class="checkbox-row" style="margin-bottom:0;">
            <input type="checkbox" id="f-publish-event" checked>
            <label for="f-publish-event">Also list this on the public Upcoming Events page</label>
          </div>
        </div>
      </div>

      <div class="card" id="renter-details-card">
        <h2 id="renter-details-title">Renter</h2>
        <div class="card-sub" id="renter-details-sub">Who's booking, and what for.</div>
        <div class="field" id="f-renter-select-field">

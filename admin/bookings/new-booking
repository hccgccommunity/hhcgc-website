// when overlaid here, so Ganesh gets its own green.
const ROOM_COLORS = { 'Surya Hall': 'e67c73', 'Patanjali Hall': '3f51b5', 'Nataraj Room': '795548', 'Ganesh Room': '0b8043' };
function renderCalendarEmbed() {
  const selected = document.getElementById('calendar-room-select').value;
  const wrap = document.getElementById('calendar-embed-wrap');
  const rooms = selected === 'all' ? Object.keys(ROOM_CALENDAR_IDS) : [selected];
  const params = new URLSearchParams();
  rooms.forEach(function (room) {
    params.append('src', ROOM_CALENDAR_IDS[room]);
    params.append('color', '%23' + (ROOM_COLORS[room] || '1'));
  });
  params.set('ctz', 'America/New_York');
  params.set('wkst', '1');
  params.set('height', '460');
  params.set('showTitle', '0'); params.set('showPrint', '0'); params.set('showTabs', '0');

  // Once a date is picked, jump the embed to the week containing that date.
  // Note: Google's embed only supports WEEK/AGENDA/MONTH as valid mode
  // values — DAY isn't one of them, which is why an earlier version of this
  // silently fell back to month view. WEEK + a `dates` range pointed at the
  // chosen date reliably jumps to the right week instead.
  const chosenDate = document.getElementById('f-date').value;
  params.set('mode', 'WEEK');
  if (chosenDate) {
    const compact = chosenDate.replace(/-/g, '');
    params.set('dates', compact + '/' + compact);
  }

  const url = 'https://calendar.google.com/calendar/embed?' + params.toString();
  wrap.innerHTML = '<iframe src="' + url + '" frameborder="0" scrolling="no"></iframe>' +
    '<div class="calendar-note">Same live calendar as hccgc.org/facility-calendar' + (chosenDate ? ', showing the week of your selected date' : '') + '. If it appears blank for you, you may need "See all event details" access to these resource calendars in Google Calendar.</div>';
}

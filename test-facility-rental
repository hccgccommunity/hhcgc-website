          </div>

          <!-- Hours & Days steppers -->
          <div class="select-group">
            <label>Number of Days</label>
            <div class="hours-stepper">
              <button class="stepper-btn" id="stepDaysDown" aria-label="Decrease days">−</button>
              <input type="number" class="stepper-input" id="daysInput" value="1" min="1" step="1" inputmode="numeric">
              <button class="stepper-btn" id="stepDaysUp" aria-label="Increase days">+</button>
            </div>
          </div>
          <div class="select-group">
            <label>Number of Hours (per day)</label>
            <div class="hours-stepper">
              <button class="stepper-btn" id="stepDown" aria-label="Decrease hours">−</button>
              <input type="number" class="stepper-input" id="hoursInput" value="2" min="0.5" step="0.5" inputmode="decimal">

                </div>
              </div>
            </div>
            <p class="card-sub" style="margin-top:6px;font-size:0.78rem;color:var(--muted);" id="extendedHoursNote">Applies automatically once you select 4 or more hours below.</p>
          </div>

          <div class="result-box">
            <div class="result-label">Estimated Total</div>
            <div class="result-amount" id="totalAmount">$90.00</div>
            <div class="result-breakdown" id="breakdown">Surya Hall · 2 hours · $45/hr = $90.00</div>
            <div class="discount-pills" id="discountPills"></div>
          </div>
        </div>
        </div>
      </div>
    </section>

    <!-- AVAILABILITY CALENDAR -->
    <section class="section" id="availability">
      <div class="container">
        <div class="section-head content-width">
          <span class="section-kicker">Availability</span>

// GET /bookings
async function listBookings(req, res) {
  const [rows] = await bigquery.query(
    `SELECT booking_id, rooms, renter_id, renter_name, renter_email, renter_phone, renter_address, organization_name,
            hccgc_representative_name, event_date, start_time, end_time, hours, final_total, is_nonprofit,
            payment_status, payment_method, is_internal, manual_adjustment_type, manual_adjustment_value, manual_adjustment_reason,
            recurring_series_id, recurrence_summary, event_name, notes, cancellation_fee, refund_amount, cancelled_at, cancelled_by, rejection_reason,
            invoice_sent_at, receipt_sent_at, payment_match_source, payment_match_id, payment_match_details, payment_date,
            created_by, created_at, updated_at
     FROM \`${DATASET}.bookings\`
     ORDER BY created_at DESC
     LIMIT 300`
  );
  // The BigQuery client wraps DATE/TIMESTAMP/NUMERIC fields in objects like
  // { value: "2026-07-07" } rather than plain strings/numbers — harmless
  // server-side, but breaks any frontend code expecting a plain value once
  // it round-trips through JSON. Unwrap explicitly rather than let it leak.
  const unwrap = v => (v && typeof v === 'object' && 'value' in v) ? v.value : v;
  const clean = rows.map(r => ({
    ...r,
    event_date: unwrap(r.event_date),
    start_time: unwrap(r.start_time),
    end_time: unwrap(r.end_time),
    created_at: unwrap(r.created_at),
    updated_at: unwrap(r.updated_at),
    cancelled_at: unwrap(r.cancelled_at),
    invoice_sent_at: unwrap(r.invoice_sent_at),
    receipt_sent_at: unwrap(r.receipt_sent_at),
    payment_date: unwrap(r.payment_date),
    // "Updated" as shown to the user: the most recent real change, falling
    // back to creation time if nothing's been edited since.
    updated_display: unwrap(r.updated_at) || unwrap(r.created_at),
    hours: r.hours !== null && r.hours !== undefined ? Number(r.hours) : r.hours,
    final_total: r.final_total !== null && r.final_total !== undefined ? Number(r.final_total) : r.final_total,
    cancellation_fee: r.cancellation_fee !== null && r.cancellation_fee !== undefined ? Number(r.cancellation_fee) : r.cancellation_fee,
    refund_amount: r.refund_amount !== null && r.refund_amount !== undefined ? Number(r.refund_amount) : r.refund_amount
  }));
  res.json(clean);
}


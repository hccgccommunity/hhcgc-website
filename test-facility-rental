    <!-- POLICIES -->
    <section class="section">
      <div class="container">
        <div class="section-head content-width">
          <span class="section-kicker">Guidelines</span>
          <h2>What You Need to Know</h2>
          <p class="section-copy">To ensure a welcoming experience for everyone, please review our rental policies before submitting your booking.</p>
        </div>

        <div class="two-col" style="grid-template-columns:1fr 1fr;">
          <div class="info-box">
            <h3>Discounts &amp; Pricing</h3>
            <ul>
              <li><strong>Weekday discount:</strong> 20% off Mon–Fri bookings</li>
              <li><strong>Extended booking:</strong> additional 20% off for 4+ hours</li>
              <li><strong>Nonprofit rate:</strong> additional 25% off for registered nonprofits</li>
              <li>Discounts stack — multiple savings can apply to a single booking</li>
              <li>Contact us via email at <a href="mailto:hccgccommunity@gmail.com">hccgccommunity@gmail.com</a> for custom nonprofit pricing</li>
            </ul>
          </div>
          <div class="info-box">
            <h3>Booking &amp; Setup</h3>
            <ul>
              <li>Bookings are confirmed via email within 2–3 business days</li>
              <li>Setup and breakdown time must be included in booked hours</li>
              <li>Renters are responsible for leaving the space clean and in its original condition. Please review the <a href="https://hccgc.org/hccgc_rental_conditions.html" target="_blank" rel="noopener">Terms &amp; Conditions</a></li>
              <li>All renters agree to HCCGC's community standards of respect and inclusivity</li>
              <li>For questions, reach out via email at <a href="mailto:hccgccommunity@gmail.com">hccgccommunity@gmail.com</a></li>
            </ul>
          </div>
          <div class="info-box">
            <h3>Visit the Facility</h3>
            <ul>
              <li>Open hours to tour the spaces: <strong>Monday &amp; Tuesday, 5 – 6 PM</strong></li>
              <li>Visits are by appointment — please confirm your visit via email at <a href="mailto:hccgccommunity@gmail.com">hccgccommunity@gmail.com</a> before coming</li>
              <li>We'll walk you through the available rooms and answer any questions you may have</li>
            </ul>
          </div>
          <div class="info-box">
            <h3>Food &amp; Beverage Policy</h3>
            <ul>
              <li>🚫 <strong>No alcoholic beverages</strong> are permitted anywhere on the premises</li>
              <li>🚫 <strong>No non-vegetarian food</strong> is permitted in the facility</li>
              <li>Renters are responsible for proper cleanup of all food and beverages after their event</li>
            </ul>
          </div>
        </div>

        <p style="margin-top:20px;font-size:0.88rem;color:var(--muted);text-align:center;">
          💬 You can also reach us and stay updated via the <strong>HCCGC Facility Rental group</strong> in our WhatsApp community.
        </p>
      </div>
    </section>

    <!-- BOOKING FORM -->
    <section class="section" id="booking">
      <div class="container">
        <div class="section-head content-width">
          <span class="section-kicker">Reserve Your Space</span>
          <h2>Submit Your Booking Request</h2>
          <p class="section-copy">Complete the social screening form below to initiate your rental. Our team will review and confirm within 2–3 business days.</p>
        </div>

        <div class="notice-box" style="max-width:980px;margin:0 auto 28px;">
          <h4>📋 Before You Submit</h4>
          <p>Please check the <a href="#availability">availability calendar</a> above to confirm your preferred date and time are open. This form is a screening request — your booking is only confirmed after you receive an email confirmation. For questions, email us at <a href="mailto:facility-rental@hccgc.org">facility-rental@hccgc.org</a>.</p>
        </div>

        <div class="request-form-card" id="requestFormCard">
          <form id="requestForm">
            <div class="request-section-title">Let's get started</div>
            <div class="request-field">

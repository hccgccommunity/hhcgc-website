}

// Looks up (or creates, first time) the category ID for one of the three
// exact names used for auto-tagging the Zeffy payout split — so the
// pre-suggested category actually exists as a real, selectable category
// rather than a hardcoded label the dropdown doesn't recognize.
async function getCategoryIdByName(name, type) {

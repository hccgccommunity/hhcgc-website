// Month filter — a real popup calendar (quick picks + a navigable
// year/month grid) rather than a long flat dropdown list.
const MONTH_NAMES = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const MONTH_NAMES_SHORT = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
let monthCalendarViewYear = new Date().getFullYear();

function monthFilterLabel(value) {
  if (value === 'default3') return 'This, last & next month';
  if (value === 'all') return 'All time';
  const [y, m] = value.split('-').map(Number);
  return MONTH_NAMES[m - 1] + ' ' + y;
}

function renderMonthCalendarPanel() {
  const panel = document.getElementById('month-calendar-panel');
  const selectedIsSpecificMonth = /^\d{4}-\d{2}$/.test(state.month);
  const selectedYear = selectedIsSpecificMonth ? Number(state.month.split('-')[0]) : null;

  let html = '<div class="month-calendar-quick">' +
    '<button class="' + (state.month === 'default3' ? 'active' : '') + '" onclick="selectMonthFilter(\'default3\')">This, last &amp; next month</button>' +
    '<button class="' + (state.month === 'all' ? 'active' : '') + '" onclick="selectMonthFilter(\'all\')">All time</button>' +
    '</div>';
  html += '<div class="month-calendar-year-nav">' +
    '<button onclick="shiftMonthCalendarYear(-1)">&lsaquo;</button>' +
    '<span>' + monthCalendarViewYear + '</span>' +
    '<button onclick="shiftMonthCalendarYear(1)">&rsaquo;</button>' +
    '</div>';
  html += '<div class="month-calendar-grid">' +
    MONTH_NAMES_SHORT.map(function (name, i) {
      const value = monthCalendarViewYear + '-' + String(i + 1).padStart(2, '0');
      const isActive = selectedIsSpecificMonth && selectedYear === monthCalendarViewYear && Number(state.month.split('-')[1]) === i + 1;
      return '<button class="' + (isActive ? 'active' : '') + '" onclick="selectMonthFilter(\'' + value + '\')">' + name + '</button>';
    }).join('') +
    '</div>';
  panel.innerHTML = html;
}
function shiftMonthCalendarYear(delta) {
  monthCalendarViewYear += delta;
  renderMonthCalendarPanel();
}
function selectMonthFilter(value) {
  state.month = value;
  state.page = 1;
  document.getElementById('btn-month-filter').textContent = monthFilterLabel(value);
  document.getElementById('month-calendar-panel').style.display = 'none';
  render();
}
document.getElementById('btn-month-filter').textContent = monthFilterLabel(state.month);
document.getElementById('btn-month-filter').addEventListener('click', function (e) {
  e.stopPropagation();
  const panel = document.getElementById('month-calendar-panel');
  const willOpen = panel.style.display === 'none';
  if (willOpen) renderMonthCalendarPanel();
  panel.style.display = willOpen ? 'block' : 'none';
});
document.addEventListener('click', function (e) {
  const panel = document.getElementById('month-calendar-panel');
  if (panel.style.display !== 'none' && !panel.contains(e.target) && e.target.id !== 'btn-month-filter') panel.style.display = 'none';
});
// loadBookings() is intentionally NOT called here — moved into the auth
// gate's success handler below, since it needs a valid sign-in token first.

function loadPartial(id, file) {
  var target = document.getElementById(id);
  if (!target) return;
  fetch(file).then(function (r) { return r.text(); }).then(function (html) {
    target.innerHTML = html;
    if (id === 'site-header') fixHeaderLinksForSubfolder(target);
  }).catch(function () {});
}
function fixHeaderLinksForSubfolder(headerEl) {
  var logo = headerEl.querySelector('.brand-logo');
  if (logo && logo.getAttribute('src') && !logo.getAttribute('src').startsWith('/') && !logo.getAttribute('src').startsWith('http')) {
    logo.setAttribute('src', '/' + logo.getAttribute('src'));
  }
  headerEl.querySelectorAll('a[href]').forEach(function (link) {
    var href = link.getAttribute('href');
    if (!href || href.startsWith('http') || href.startsWith('/') || href.startsWith('#')) return;
    link.setAttribute('href', '/' + href);
  });
}
loadPartial('site-header', '/header.html');
loadPartial('site-footer', '/footer.html');

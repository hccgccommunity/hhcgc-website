          <option value="Nataraj Room">Nataraj Room</option>
          <option value="Ganesh Room">Ganesh Room</option>
        </select>
        <div id="calendar-embed-wrap"></div>
      </div>
    </div>
  </div>
</div>

<div id="site-footer"></div>

<script>
// ---- Sample data, standing in for a BigQuery-backed API call ----
// Real bookings are loaded from the API below (see loadBookings()).
const ALL_ROOM_NAMES = ['Surya Hall', 'Patanjali Hall', 'Nataraj Room', 'Ganesh Room'];

const API_BASE = 'PASTE_YOUR_CLOUD_FUNCTION_URL_HERE'; // e.g. https://us-central1-dharma-nidi-darshan.cloudfunctions.net/api
let BOOKINGS = [];

async function loadBookings() {
  const notice = document.getElementById('mock-notice');
  try {
    const res = await fetch(API_BASE + '/bookings');
    if (!res.ok) throw new Error('Server returned ' + res.status);
    BOOKINGS = await res.json();
    notice.style.display = 'none';
  } catch (err) {
    notice.textContent = 'Could not load bookings from the database (' + err.message + '). Check the database connection and try refreshing.';
    notice.style.display = 'block';
    BOOKINGS = [];
  }
  render();
}

let state = { search: '', room: '', status: '' };

function formatDate(iso) {
  const d = new Date(iso + 'T00:00:00');
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function isPastDue(b) {
  return b.payment_status === 'invoiced' && new Date(b.event_date) < new Date();
}

function statusBadge(b) {
  if (b.is_internal || b.payment_status === 'n/a') {
    return '<span class="badge badge-draft"><span class="badge-dot"></span>Internal · No charge</span>';
  }
  if (b.payment_status === 'paid') {
    const methodLabel = b.payment_method === 'zeffy' ? 'Zeffy · auto-matched' :
      b.payment_method === 'zelle' ? 'Zelle · confirmed' :
      b.payment_method === 'cash' ? 'Cash · confirmed' :
      b.payment_method === 'check' ? 'Check · confirmed' : 'Confirmed';
    return '<span class="badge badge-paid"><span class="badge-dot"></span>Paid</span><span class="method-tag">' + methodLabel + '</span>';
  }
  if (b.payment_status === 'cancelled') {
    return '<span class="badge badge-cancelled"><span class="badge-dot"></span>Cancelled</span>';
  }
  if (b.payment_status === 'invoiced') {
    const label = isPastDue(b) ? 'Past due — needs confirmation' : 'Awaiting payment';
    return '<span class="badge badge-needs-confirm"><span class="badge-dot"></span>' + label + '</span>';
  }
  return '<span class="badge badge-draft"><span class="badge-dot"></span>Draft</span>';
}

function isWholeFacility(b) {
  return b.rooms.length === ALL_ROOM_NAMES.length && ALL_ROOM_NAMES.every(function (r) { return b.rooms.includes(r); });
}

function matchesFilters(b) {
  const q = state.search.trim().toLowerCase();
  if (q && !(b.renter_name.toLowerCase().includes(q) || b.renter_email.toLowerCase().includes(q))) return false;
  if (state.room === '__whole_facility__' && !isWholeFacility(b)) return false;
  if (state.room && state.room !== '__whole_facility__' && !b.rooms.includes(state.room)) return false;
  if (state.status === 'needs-attention' && b.payment_status !== 'invoiced') return false;
  if (state.status === 'paid' && b.payment_status !== 'paid') return false;
  if (state.status === 'pending' && b.payment_status !== 'pending') return false;
  if (state.status === 'cancelled' && b.payment_status !== 'cancelled') return false;
  if (state.status === 'internal' && !(b.is_internal || b.payment_status === 'n/a')) return false;
  return true;
}

function render() {
  const tbody = document.getElementById('bookings-tbody');
  const emptyState = document.getElementById('empty-state');
  const filtered = BOOKINGS.filter(matchesFilters);

  document.getElementById('result-count').textContent =
    filtered.length + (filtered.length === 1 ? ' booking' : ' bookings');

  if (filtered.length === 0) {
    tbody.innerHTML = '';
    emptyState.style.display = 'block';
    return;
  }
  emptyState.style.display = 'none';

  tbody.innerHTML = filtered.map(function (b) {
    const needsAction = b.payment_status === 'invoiced';
    const roomCell = isWholeFacility(b)
      ? '<span class="room-pill whole-facility">&#9733; Whole Facility</span>'
      : '<span class="room-pill">' + escHtml(b.rooms.join(' + ')) + '</span>';
    const amountCell = '$' + b.final_total.toFixed(2) +
      (b.manual_adjustment_type ? '<span class="adjusted-tag" title="' + escHtml(b.manual_adjustment_reason || '') + '">Adjusted</span>' : '');
    return (
      '<tr>' +
        '<td><div class="renter-name">' + escHtml(b.renter_name) + (b.recurring_series_id ? ' <span class="discount-chip" style="margin-left:4px;" title="' + escHtml(b.recurrence_summary || '') + '">Recurring</span>' : '') + '</div><div class="renter-sub">' + escHtml(b.renter_email) + '</div></td>' +
        '<td>' + roomCell + '</td>' +
        '<td>' + formatDate(b.event_date) + '</td>' +
        '<td>' + b.hours + '</td>' +
        '<td class="amount">' + amountCell + '</td>' +
        '<td>' + statusBadge(b) + '</td>' +
        '<td style="position:relative;">' +
          (needsAction ? '<button class="btn-mark-paid" onclick="togglePopover(event, \'' + b.booking_id + '\')">Mark paid</button>' +
            '<div class="method-popover" id="popover-' + b.booking_id + '">' +
              '<button onclick="markPaid(\'' + b.booking_id + '\', \'zelle\')">Paid via Zelle</button>' +
              '<button onclick="markPaid(\'' + b.booking_id + '\', \'cash\')">Paid via Cash</button>' +
              '<button onclick="markPaid(\'' + b.booking_id + '\', \'check\')">Paid via Check</button>' +
            '</div>' : '') +
        '</td>' +
      '</tr>'
    );
  }).join('');
}

function escHtml(str) {
  return String(str || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

function togglePopover(evt, bookingId) {
  evt.stopPropagation();
  document.querySelectorAll('.method-popover.open').forEach(function (el) {
    if (el.id !== 'popover-' + bookingId) el.classList.remove('open');
  });
  const pop = document.getElementById('popover-' + bookingId);
  pop.classList.toggle('open');
}
document.addEventListener('click', function () {
  document.querySelectorAll('.method-popover.open').forEach(function (el) { el.classList.remove('open'); });
});

async function markPaid(bookingId, method) {
  document.getElementById('popover-' + bookingId).classList.remove('open');
  try {
    const res = await fetch(API_BASE + '/bookings/' + encodeURIComponent(bookingId) + '/mark-paid', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ paymentMethod: method })
    });
    if (!res.ok) {
      const data = await res.json().catch(function () { return {}; });
      alert('Could not mark as paid: ' + ((data.errors || [data.error]).join(' ') || 'unknown error'));
      return;
    }
    await loadBookings();
  } catch (err) {
    alert('Could not reach the booking system: ' + err.message);
  }
}

document.getElementById('search-input').addEventListener('input', function (e) {
  state.search = e.target.value;
  render();
});
document.getElementById('room-filter').addEventListener('change', function (e) {
  state.room = e.target.value;
  render();
});
document.getElementById('status-filter').addEventListener('change', function (e) {
  state.status = e.target.value;
  render();
});

// Real resource calendar IDs, pulled from the same embed hccgc.org/facility-calendar
// already uses — so this sidebar shows exactly the same live data as that public page.
const ROOM_CALENDAR_IDS = {
  'Surya Hall': 'c_188c0ce7torcmhnnlk4omolk4n9b6@resource.calendar.google.com',
  'Patanjali Hall': 'c_188433th1pkq6i1tlm4hmkguds17a@resource.calendar.google.com',
  'Nataraj Room': 'c_188428oa7oengjr3mrhsse0n4uu5e@resource.calendar.google.com',
  'Ganesh Room': 'c_1888mp0b3kdtij7qk891pqsv9jll2@resource.calendar.google.com'
};
const ROOM_COLORS = { 'Surya Hall': 'e67c73', 'Patanjali Hall': '3f51b5', 'Nataraj Room': '795548', 'Ganesh Room': '0b8043' }; // matches the public page, except Ganesh gets its own color instead of reusing Patanjali's

function renderCalendarEmbed() {
  const selected = document.getElementById('calendar-room-select').value;
  const wrap = document.getElementById('calendar-embed-wrap');
  const rooms = selected === 'all' ? Object.keys(ROOM_CALENDAR_IDS) : [selected];

  const params = new URLSearchParams();
  rooms.forEach(function (room) {
    params.append('src', ROOM_CALENDAR_IDS[room]);
    params.append('color', '%23' + (ROOM_COLORS[room] || '1'));
  });
  params.set('ctz', 'America/New_York');
  params.set('showTitle', '0');
  params.set('showPrint', '0');
  params.set('showTabs', '0');
  params.set('mode', 'WEEK');

  const url = 'https://calendar.google.com/calendar/embed?' + params.toString();
  wrap.innerHTML = '<iframe src="' + url + '" frameborder="0" scrolling="no"></iframe>' +
    '<div class="calendar-note">Requires the room calendar IDs above to be filled in, and each admin to have at least "See all event details" access to these resource calendars in Google Calendar.</div>';
}
document.getElementById('calendar-room-select').addEventListener('change', renderCalendarEmbed);
renderCalendarEmbed();

loadBookings();

// ---- Auth gate: same pattern as the portal shell ----
// TODO: uncomment and wire once you confirm the app-registry key for this
// module (e.g. "facility-bookings") and add it to admins' allowedApps in
// portalUsers via User Management.
/*

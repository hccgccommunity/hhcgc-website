            <div class="toggles-row">
              <label class="toggle-item">
                <input type="checkbox" id="weekdayCheck" />
                <div>
                  <span class="toggle-label">Weekday booking (Mon – Fri)</span>
                  <span class="toggle-discount">20% off</span>
                </div>
              </label>
              <label class="toggle-item">
                <input type="checkbox" id="nonprofitCheck" />
                <div>
                  <span class="toggle-label">Nonprofit organization</span>
                  <span class="toggle-discount">25% off</span>
                </div>
              </label>
              <div class="toggle-item" id="extendedHoursRow" style="cursor:default;">
                <div>
                  <span class="toggle-label">Extended booking (4+ hours)</span>

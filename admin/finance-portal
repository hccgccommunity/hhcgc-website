async function loadUnmatchedRentalPayments() {
  window.__matchingLoaded = true;
  const list = document.getElementById('matching-list');
  list.innerHTML = '<div class="empty-state">Loading…</div>';
  try {
    const res = await authedFetch(API_BASE + '/finance/unmatched-rental-payments');
    const payments = await res.json();
    if (!payments.length) { list.innerHTML = '<div class="empty-state">No unmatched rental payments with a plausible booking match right now.</div>'; return; }
    list.innerHTML = payments.map(function (p) {
      const candidatesHtml = p.candidates.map(function (c) {
        return '<div class="recon-candidate match" style="cursor:pointer;" onclick="confirmFinanceMatch(' + JSON.stringify(p.paymentId) + ', ' + JSON.stringify(c.bookingId) + ', ' + p.amount + ', ' + JSON.stringify(p.date) + ')">' +
          '<span>' + escHtml(c.renterName) + ' — ' + formatDate(c.eventDate) + ' (' + escHtml(c.bookingId) + ')</span>' +
          '<span class="amount">' + money(c.amount) + ' — click to confirm</span>' +
        '</div>';
      }).join('');
      return '<div class="recon-week-card">' +
        '<div class="recon-week-header"><span class="week-label">' + escHtml(p.donor) + ' — ' + formatDate(p.date) + '</span><span class="expected">' + money(p.amount) + '</span></div>' +
        candidatesHtml +
      '</div>';
    }).join('');
  } catch (err) {
    list.innerHTML = '<div class="empty-state">Could not load: ' + escHtml(err.message) + '</div>';
  }
}
async function confirmFinanceMatch(paymentId, bookingId, amount, date) {
  if (!confirm('Link this Zeffy payment to booking ' + bookingId + '? This highlights it in All Bookings — you still confirm Mark Paid there.')) return;
  try {
    const res = await authedFetch(API_BASE + '/finance/confirm-match', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ bookingId: bookingId, paymentId: paymentId, amount: amount, date: date })
    });
    const data = await res.json();
    if (!res.ok) { alert('Could not confirm: ' + ((data.errors || [data.error]).join(' ') || 'unknown error')); return; }
    await loadUnmatchedRentalPayments();
  } catch (err) {
    alert('Could not reach the server: ' + err.message);
  }
}


// Issue screenshots — unlike receipts, this folder is created and shared
// automatically the first time it's needed (drive.file scope allows the
// app to access anything it creates itself), so there's no manual Drive
// setup step required for this feature to work.
let cachedIssueScreenshotsFolderId = null;
async function getOrCreateIssueScreenshotsFolder(drive) {
  if (cachedIssueScreenshotsFolderId) return cachedIssueScreenshotsFolderId;
  const FOLDER_NAME = 'HCCGC Issue Report Screenshots';
  const existing = await drive.files.list({
    q: `name = '${FOLDER_NAME}' and mimeType = 'application/vnd.google-apps.folder' and trashed = false`,
    fields: 'files(id, name)'
  });
  if (existing.data.files && existing.data.files.length) {
    cachedIssueScreenshotsFolderId = existing.data.files[0].id;
    return cachedIssueScreenshotsFolderId;
  }
  const created = await drive.files.create({
    requestBody: { name: FOLDER_NAME, mimeType: 'application/vnd.google-apps.folder' },
    fields: 'id'
  });
  const folderId = created.data.id;
  await drive.permissions.create({
    fileId: folderId,
    requestBody: { type: 'domain', domain: 'hccgc.org', role: 'reader' }
  });
  cachedIssueScreenshotsFolderId = folderId;
  return folderId;
}
async function uploadScreenshotToDrive(base64Data, filename, mimeType) {
  const drive = await getDriveClientAsFacilityRental();
  const folderId = await getOrCreateIssueScreenshotsFolder(drive);
  return uploadFileToDrive(base64Data, filename, mimeType, folderId);
}

async function sendEmail({ to, cc, subject, htmlBody, attachments }) {
  const gmail = await getGmailClientAsFacilityRental();
  // Email headers are ASCII-only by spec — any non-ASCII subject (accented
  // names, curly quotes, currency symbols, etc.) has to be RFC 2047 encoded
  // or it renders as garbled mojibake in the recipient's inbox, the exact
  // bug a plain em-dash caused here once already.
  const encodedSubject = /^[\x00-\x7F]*$/.test(subject) ? subject : `=?UTF-8?B?${Buffer.from(subject, 'utf-8').toString('base64')}?=`;
  const headerLines = [
    `From: ${SENDER_DISPLAY_NAME} <${SENDER_DISPLAY_EMAIL}>`,
    `Reply-To: ${REPLY_TO_EMAIL}`,
    `To: ${to}`,
    cc ? `Cc: ${cc}` : null,
    `Subject: ${encodedSubject}`,
    'MIME-Version: 1.0'
  ].filter(line => line !== null);

  let raw;
  if (attachments && attachments.length) {
    const boundary = 'hccgc_boundary_' + Date.now();
    const parts = [
      `--${boundary}`,
      'Content-Type: text/html; charset=utf-8',
      '',
      htmlBody,
      ''
    ];
    attachments.forEach(att => {
      parts.push(
        `--${boundary}`,
        `Content-Type: ${att.mimeType}; name="${att.filename}"`,
        'Content-Transfer-Encoding: base64',
        `Content-Disposition: attachment; filename="${att.filename}"`,
        '',
        att.base64,
        ''
      );
    });
    parts.push(`--${boundary}--`);
    raw = [...headerLines, `Content-Type: multipart/mixed; boundary="${boundary}"`, '', ...parts].join('\r\n');
  } else {
    raw = [...headerLines, 'Content-Type: text/html; charset=utf-8', '', htmlBody].join('\r\n');
  }

  await gmail.users.messages.send({
    userId: 'me',
    requestBody: { raw: base64url(raw) }
  });
}

// Creates one plain (non-recurring) event per room for a single occurrence.
// Occurrences can have different times from each other, so each gets its own
// event rather than relying on a single RRULE-based series.
async function syncOccurrenceToCalendar({ rooms, roomsMap, occ, renterName, seriesLabel }) {
  const calendar = await getCalendarClient();
  const eventIds = [];
  const syncErrors = [];
  const startIso = new Date(`${occ.date}T${occ.startTime}:00`).toISOString();
  const endIso = new Date(`${occ.date}T${occ.endTime}:00`).toISOString();

  for (const roomName of rooms) {
    const calendarId = roomsMap[roomName] && roomsMap[roomName].calendar_id;
    if (!calendarId) { syncErrors.push(roomName + ': no calendar configured'); continue; }
    const event = {
      summary: roomName + ' — ' + renterName + (seriesLabel ? ' (' + seriesLabel + ')' : ''),
      description: 'HCCGC facility booking' + (seriesLabel ? ' — part of a ' + seriesLabel + ' series' : ''),
      start: { dateTime: startIso },
      end: { dateTime: endIso }
    };
    try {
      const { data } = await calendar.events.insert({ calendarId, resource: event });
      eventIds.push(data.id);
    } catch (err) {
      console.error('Calendar sync failed for ' + roomName + ' on ' + occ.date + ':', err.message);
      syncErrors.push(roomName + ' (' + occ.date + '): ' + err.message);
    }
  }
  return { eventIds, syncErrors };
}


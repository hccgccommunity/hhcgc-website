  <div id="footer-placeholder"></div>

  <script>
    // ── Load shared header & footer ──
    async function loadPartial(placeholderId, filePath) {
      const target = document.getElementById(placeholderId);
      if (!target) return;
      try {
        const response = await fetch(filePath);
        if (!response.ok) throw new Error("Unable to load " + filePath);
        target.innerHTML = await response.text();
      } catch (error) {
        console.error(error);
        target.innerHTML = "";
      }
    }

    async function initializePage() {
      await loadPartial("header-placeholder", "header.html");
      await loadPartial("footer-placeholder", "footer.html");
      const year = document.getElementById("year");
      if (year) year.textContent = new Date().getFullYear();
    }

    initializePage();

    // ── Availability Calendar — real booking data, week view, day-by-hour ──
    const AVAIL_ROOM_COLORS = { 'Surya Hall': '#d9720c', 'Patanjali Hall': '#6b3fa0', 'Nataraj Room': '#2e7d4f', 'Ganesh Room': '#2255a4', 'Kitchen': '#c2185b' };
    const AVAIL_DAY_START_HOUR = 7;  // 7 AM
    const AVAIL_DAY_END_HOUR = 21;   // 9 PM
    let availWeekOffset = 0; // 0 = current week, -1 = previous, +1 = next

    function renderAvailLegend() {
      const legend = document.getElementById('avail-cal-legend');
      legend.innerHTML = Object.keys(AVAIL_ROOM_COLORS).map(function (room) {
        return '<span class="avail-cal-legend-item"><span class="avail-cal-legend-dot" style="background:' + AVAIL_ROOM_COLORS[room] + ';"></span>' + room + '</span>';
      }).join('');
    }

    // Assigns each event a lane + total-lane-count so overlapping events
    // (same day, overlapping times — e.g. two different rooms booked at
    // once) render side by side as narrower columns instead of stacking
    // on top of each other. Greedy lane assignment, then each event's
    // width is sized to the max concurrency of anything it overlaps with.
    function layoutDayEvents(events) {
      const sorted = events.slice().sort(function (a, b) { return a.start - b.start; });
      const laneEnds = [];
      sorted.forEach(function (ev) {
        let placed = false;
        for (let i = 0; i < laneEnds.length; i++) {
          if (laneEnds[i] <= ev.start) { ev.lane = i; laneEnds[i] = ev.end; placed = true; break; }
        }
        if (!placed) { ev.lane = laneEnds.length; laneEnds.push(ev.end); }
      });
      sorted.forEach(function (ev) {
        let maxLane = ev.lane;
        sorted.forEach(function (other) {
          if (other === ev) return;
          if (other.start < ev.end && other.end > ev.start) maxLane = Math.max(maxLane, other.lane);
        });
        ev.totalLanes = maxLane + 1;
      });
      return sorted;
    }

    function getWeekDates(offset) {
      const today = new Date();
      const sunday = new Date(today.getFullYear(), today.getMonth(), today.getDate() - today.getDay() + (offset * 7));
      const dates = [];
      for (let i = 0; i < 7; i++) dates.push(new Date(sunday.getFullYear(), sunday.getMonth(), sunday.getDate() + i));
      return dates;
    }
    function toDateStr(d) { return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0'); }

    async function loadAvailabilityCalendar() {
      const weekDates = getWeekDates(availWeekOffset);
      const startDate = toDateStr(weekDates[0]);
      const endDate = toDateStr(weekDates[6]);
      document.getElementById('avail-cal-month-label').textContent =
        weekDates[0].toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) + ' – ' + weekDates[6].toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

      const gridEl = document.getElementById('avail-week-grid');
      gridEl.innerHTML = '<div style="grid-column:1/-1;padding:30px;text-align:center;color:var(--muted);">Loading…</div>';

      let bookings = [];
      let loadError = null;
      try {
        const res = await fetch(API_BASE + '/public/room-availability?startDate=' + startDate + '&endDate=' + endDate);
        if (res.ok) {
          bookings = await res.json();
        } else {
          const errData = await res.json().catch(function () { return {}; });
          loadError = (errData.errors || [errData.error || ('Server returned ' + res.status)]).join(' ');
        }
      } catch (err) { loadError = err.message; }

      if (loadError) {
        gridEl.innerHTML = '<div style="grid-column:1/-1;padding:30px;text-align:center;color:#b3382c;">Could not load availability: ' + loadError + '</div>';
        return;
      }

      const byDate = {};
      bookings.forEach(function (b) {
        if (!byDate[b.eventDate]) byDate[b.eventDate] = [];
        (b.rooms || []).forEach(function (room) {
          byDate[b.eventDate].push({ room: room, start: b.startTime, end: b.endTime });
        });
      });

      const totalHours = AVAIL_DAY_END_HOUR - AVAIL_DAY_START_HOUR;
      const todayStr = toDateStr(new Date());
      const rowHeightPx = 44; // matches --hour-px in CSS
      const bodyHeight = totalHours * rowHeightPx;

      // Header row: corner + 7 day labels
      let html = '<div class="avail-week-corner"></div>';
      weekDates.forEach(function (d) {
        const dStr = toDateStr(d);
        html += '<div class="avail-week-daylabel' + (dStr === todayStr ? ' is-today' : '') + '"><span class="dow">' + d.toLocaleDateString('en-US', { weekday: 'short' }) + '</span>' + d.getDate() + '</div>';
      });

      // Time-label column
      html += '<div class="avail-week-timecol" style="height:' + bodyHeight + 'px;">';
      for (let h = AVAIL_DAY_START_HOUR; h <= AVAIL_DAY_END_HOUR; h++) {
        const pct = ((h - AVAIL_DAY_START_HOUR) / totalHours) * 100;
        const label = h === 12 ? '12 PM' : h < 12 ? h + ' AM' : (h - 12) + ' PM';
        html += '<div class="avail-week-timelabel" style="top:' + pct + '%;">' + label + '</div>';
      }
      html += '</div>';

      // Day columns with absolutely-positioned chips
      weekDates.forEach(function (d) {
        const dStr = toDateStr(d);
        const dayBookingsRaw = (byDate[dStr] || []).map(function (bk) { return { room: bk.room, start: new Date(bk.start), end: new Date(bk.end) }; });
        const dayBookings = layoutDayEvents(dayBookingsRaw);
        let colHtml = '<div class="avail-week-daycol" style="height:' + bodyHeight + 'px;--hour-px:' + rowHeightPx + 'px;">';
        dayBookings.forEach(function (bk) {
          const start = bk.start;
          const end = bk.end;
          const startFrac = (start.getHours() + start.getMinutes() / 60 - AVAIL_DAY_START_HOUR) / totalHours;
          const endFrac = (end.getHours() + end.getMinutes() / 60 - AVAIL_DAY_START_HOUR) / totalHours;
          const clampedStart = Math.max(0, Math.min(1, startFrac));
          const clampedEnd = Math.max(0, Math.min(1, endFrac));
          if (clampedEnd <= clampedStart) return; // entirely outside the displayed window
          const topPx = clampedStart * bodyHeight;
          const heightPx = Math.max(16, (clampedEnd - clampedStart) * bodyHeight);
          const widthPct = 100 / bk.totalLanes;
          const leftPct = bk.lane * widthPct;
          const timeLabel = start.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }) + '–' + end.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
          colHtml += '<div class="avail-week-chip" style="top:' + topPx + 'px;height:' + heightPx + 'px;left:' + leftPct + '%;width:calc(' + widthPct + '% - 3px);right:auto;background:' + (AVAIL_ROOM_COLORS[bk.room] || '#8d6e63') + ';" title="' + bk.room + ' — ' + timeLabel + '">' +
            bk.room.replace(' Hall', '').replace(' Room', '') +
            (heightPx > 28 && bk.totalLanes === 1 ? '<span class="time">' + timeLabel + '</span>' : '') +
          '</div>';
        });
        colHtml += '</div>';
        html += colHtml;
      });

      gridEl.innerHTML = html;
    }

    document.getElementById('avail-cal-prev').addEventListener('click', function () {
      availWeekOffset--;
      loadAvailabilityCalendar();
    });
    document.getElementById('avail-cal-next').addEventListener('click', function () {
      availWeekOffset++;
      loadAvailabilityCalendar();
    });
    renderAvailLegend();

    // ── Cost Estimator ──
    const rates      = { surya: 45, patanjali: 40, nataraj: 30, ganesh: 15 };
    const roomNames  = { surya: 'Surya Hall', patanjali: 'Patanjali Hall', nataraj: 'Nataraj Room', ganesh: 'Ganesh Room' };
    const ALL_ROOMS  = ['surya', 'patanjali', 'nataraj', 'ganesh'];

    let selectedRooms = new Set(['surya']);
    let hours = 2;
    let days = 1;

    function syncEntireFacilityButton() {
      const allSelected = ALL_ROOMS.every(r => selectedRooms.has(r));
      document.getElementById('entireFacilityBtn').classList.toggle('active', allSelected);
    }

    // Individual room buttons — multi-select
    document.querySelectorAll('.room-btn[data-room]:not(#entireFacilityBtn)').forEach(btn => {
      btn.addEventListener('click', () => {
        const room = btn.dataset.room;
        if (selectedRooms.has(room)) {
          if (selectedRooms.size === 1) return; // keep at least one room selected
          selectedRooms.delete(room);
          btn.classList.remove('active');
        } else {
          selectedRooms.add(room);
          btn.classList.add('active');
        }
        syncEntireFacilityButton();
        calculate();
      });
    });

    // Entire Facility — selects/deselects all four at once
    document.getElementById('entireFacilityBtn').addEventListener('click', () => {
      const allSelected = ALL_ROOMS.every(r => selectedRooms.has(r));
      if (allSelected) {
        // Deselecting entire facility falls back to just Surya Hall, rather
        // than leaving nothing selected.
        selectedRooms = new Set(['surya']);
      } else {
        selectedRooms = new Set(ALL_ROOMS);
      }
      document.querySelectorAll('.room-btn[data-room]:not(#entireFacilityBtn)').forEach(b => {
        b.classList.toggle('active', selectedRooms.has(b.dataset.room));
      });
      syncEntireFacilityButton();
      calculate();
    });

    // Hours & Days steppers — both the +/- buttons and typing directly
    // into the field keep everything in sync either way.
    const hoursInput = document.getElementById('hoursInput');
    const daysInput = document.getElementById('daysInput');

    function setHours(v) {
      hours = Math.max(0.5, Math.round(v * 2) / 2); // snap to the nearest half-hour
      hoursInput.value = hours;
      calculate();
    }
    function setDays(v) {
      days = Math.max(1, Math.round(v));
      daysInput.value = days;
      calculate();
    }

    document.getElementById('stepDown').addEventListener('click', () => setHours(hours - 0.5));
    document.getElementById('stepUp').addEventListener('click', () => setHours(hours + 0.5));
    hoursInput.addEventListener('input', () => {
      const v = parseFloat(hoursInput.value);
      if (!isNaN(v) && v > 0) { hours = Math.round(v * 2) / 2; calculate(); }
    });
    hoursInput.addEventListener('blur', () => setHours(parseFloat(hoursInput.value) || hours));

    document.getElementById('stepDaysDown').addEventListener('click', () => setDays(days - 1));
    document.getElementById('stepDaysUp').addEventListener('click', () => setDays(days + 1));
    daysInput.addEventListener('input', () => {
      const v = parseInt(daysInput.value, 10);
      if (!isNaN(v) && v > 0) { days = v; calculate(); }
    });
    daysInput.addEventListener('blur', () => setDays(parseInt(daysInput.value, 10) || days));

    // Discount toggles
    ['weekdayCheck', 'nonprofitCheck'].forEach(id => {
      document.getElementById(id).addEventListener('change', calculate);
    });

    function calculate() {
      const isWeekday   = document.getElementById('weekdayCheck').checked;
      const isNonprofit = document.getElementById('nonprofitCheck').checked;
      const isExtended  = hours >= 4;

      const roomsList = ALL_ROOMS.filter(r => selectedRooms.has(r));
      const baseRate  = roomsList.reduce((sum, r) => sum + rates[r], 0);
      const baseTotal = baseRate * hours * days;

      let mult = 1;
      const pills = [];

      if (isWeekday)   { mult *= 0.80; pills.push('Weekday −20%'); }
      if (isExtended)  { mult *= 0.80; pills.push('4+ Hours −20%'); }
      if (isNonprofit) { mult *= 0.75; pills.push('Nonprofit −25%'); }

      const total   = baseTotal * mult;
      const savings = baseTotal - total;

      document.getElementById('totalAmount').textContent = '$' + total.toFixed(2);

      const isEntire = ALL_ROOMS.every(r => selectedRooms.has(r));
      const roomLabel = isEntire ? 'Entire Facility' : roomsList.map(r => roomNames[r]).join(' + ');
      const daysLabel = days > 1 ? `${days} days × ` : '';
      let text = `${roomLabel} · ${daysLabel}${hours} hr${hours !== 1 ? 's' : ''} · $${baseRate}/hr combined`;
      text += savings > 0.01
        ? ` · Base: $${baseTotal.toFixed(2)} · You save: $${savings.toFixed(2)}`
        : ` = $${baseTotal.toFixed(2)}`;
      document.getElementById('breakdown').textContent = text;

      document.getElementById('discountPills').innerHTML =
        pills.map(p => `<span class="disc-pill">${p}</span>`).join('');

      // Extended-hours indicator updates live, even though it's automatic
      // rather than a toggle the visitor controls directly.
      const extRow = document.getElementById('extendedHoursRow');
      const extTag = document.getElementById('extendedHoursTag');
      const extNote = document.getElementById('extendedHoursNote');
      extRow.classList.toggle('discount-applied', isExtended);
      extTag.textContent = isExtended ? '20% off — applied' : '20% off';
      extNote.textContent = isExtended
        ? 'Applied — your booking is 4 or more hours.'
        : 'Applies automatically once you select 4 or more hours below.';
    }

    calculate();

    // ── Facility Request Form ──
    const API_BASE = 'https://facility-rental-api-217911937447.us-central1.run.app';
    loadAvailabilityCalendar();

    document.getElementById('rf-hccg-rep').addEventListener('change', (e) => {
      document.getElementById('rf-hccg-rep-other-field').style.display = e.target.value === 'Other' ? 'flex' : 'none';
    });

    // ── Email-first lookup: auto-fill for a returning renter ──
    let knownRenter = null;
    document.getElementById('rf-is-nonprofit').addEventListener('change', function () {
      const isNonprofit = this.value === 'yes';
      document.getElementById('rf-website-field').style.display = isNonprofit ? 'flex' : 'none';
      const orgLabel = document.getElementById('rf-org-label');
      const orgInput = document.getElementById('rf-org');
      if (isNonprofit) {
        orgLabel.innerHTML = 'Organization name <span class="req-star">*</span>';
        orgInput.required = true;
      } else {
        orgLabel.textContent = 'Organization name (optional)';
        orgInput.required = false;
      }
    });
    const CONTACT_FIELD_IDS = ['rf-first-name', 'rf-last-name', 'rf-phone', 'rf-org', 'rf-website', 'rf-street', 'rf-suite', 'rf-city', 'rf-state', 'rf-zip'];

    function setContactFieldsLocked(locked) {
      CONTACT_FIELD_IDS.forEach((id) => {
        const el = document.getElementById(id);
        el.readOnly = locked;
        el.style.background = locked ? 'var(--surface-soft, #fff6ea)' : '#fff';
      });
    }

    async function checkEmailAndProceed() {
      const emailInput = document.getElementById('rf-email');
      const email = emailInput.value.trim();
      const statusEl = document.getElementById('rf-email-status');
      const banner = document.getElementById('rf-known-renter-banner');
      const continueBtn = document.getElementById('rf-continue-btn');

      if (!email || !email.includes('@')) {
        statusEl.style.color = '#b3382c';
        statusEl.textContent = 'Please enter a valid email address.';
        return;
      }

      statusEl.style.color = 'var(--muted)';
      statusEl.textContent = 'Checking…';
      continueBtn.disabled = true;

      try {
        const res = await fetch(API_BASE + '/public/renter-lookup?email=' + encodeURIComponent(email));
        const data = await res.json();
        statusEl.textContent = '';

        if (email.toLowerCase().endsWith('@hccgc.org')) {
          document.getElementById('rf-hccgc-access-gate').style.display = 'block';
          document.getElementById('rf-hccgc-gate').style.display = 'none';
          document.getElementById('rf-after-email').style.display = 'none';
          document.getElementById('rf-hccgc-fields').style.display = 'none';
          continueBtn.disabled = false;
          return;
        }
        document.getElementById('rf-after-email').style.display = 'block';

        if (data.found) {
          knownRenter = data.renter;
          banner.style.display = 'block';
          document.getElementById('rf-known-renter-name').textContent = data.renter.contact_name;
          const nameParts = (data.renter.contact_name || '').split(' ');
          document.getElementById('rf-first-name').value = nameParts[0] || '';
          document.getElementById('rf-last-name').value = nameParts.slice(1).join(' ') || '';
          document.getElementById('rf-phone').value = data.renter.phone || '';
          document.getElementById('rf-org').value = data.renter.organization_name || '';
          document.getElementById('rf-is-nonprofit').value = data.renter.is_nonprofit ? 'yes' : 'no';
          document.getElementById('rf-website').value = data.renter.website || '';
          document.getElementById('rf-is-nonprofit').dispatchEvent(new Event('change'));
          document.getElementById('rf-street').value = data.renter.address || '';
          document.getElementById('rf-suite').value = '';
          document.getElementById('rf-city').value = '';
          document.getElementById('rf-state').value = '';
          document.getElementById('rf-zip').value = '';
          setContactFieldsLocked(true);
          document.getElementById('rf-event-details').focus();
        } else {
          knownRenter = null;
          banner.style.display = 'none';
          setContactFieldsLocked(false);
          document.getElementById('rf-first-name').focus();
        }
      } catch (err) {
        statusEl.style.color = '#b3382c';
        statusEl.textContent = 'Could not check that email — you can still continue and fill in your info below.';
        document.getElementById('rf-after-email').style.display = 'block';
        setContactFieldsLocked(false);
      } finally {
        continueBtn.disabled = false;
      }
    }

    document.getElementById('rf-continue-btn').addEventListener('click', checkEmailAndProceed);

    let isHccgcEventPath = false;
    // Fields only meaningful for the standard renter path — their
    // `required` attribute has to move with them, or the browser's native
    // validation blocks submission on fields that are hidden and would
    // never get filled in on the HCCGC-event path.
    const STANDARD_REQUIRED_IDS = ['rf-first-name', 'rf-last-name', 'rf-phone', 'rf-street', 'rf-city', 'rf-state', 'rf-zip', 'rf-event-details'];
    const HCCGC_REQUIRED_IDS = ['rf-hccgc-event-name', 'rf-hccgc-organizer'];
    function setHccgcPath(isHccgc) {
      isHccgcEventPath = isHccgc;
      document.getElementById('rf-hccgc-gate').style.display = 'none';
      document.getElementById('rf-hccgc-fields').style.display = isHccgc ? 'block' : 'none';
      document.getElementById('rf-standard-only-section').style.display = isHccgc ? 'none' : 'block';
      document.getElementById('rf-standard-only-section-2').style.display = isHccgc ? 'none' : 'block';
      document.getElementById('rf-after-email').style.display = 'block';
      STANDARD_REQUIRED_IDS.forEach(function (id) { document.getElementById(id).required = !isHccgc; });
      HCCGC_REQUIRED_IDS.forEach(function (id) { document.getElementById(id).required = isHccgc; });
      if (isHccgc) document.getElementById('rf-hccgc-event-name').focus();
      else document.getElementById('rf-first-name').focus();
      updateLiveEstimate();
    }
    const HCCGC_ACCESS_CODE = '0301@2026';
    function submitHccgcAccessCode() {
      const input = document.getElementById('rf-hccgc-access-code');
      const resultBox = document.getElementById('rf-hccgc-access-result');
      if (input.value !== HCCGC_ACCESS_CODE) {
        resultBox.style.display = 'block';
        resultBox.className = 'request-result-box error';
        resultBox.textContent = 'Incorrect access code.';
        return;
      }
      resultBox.style.display = 'none';
      document.getElementById('rf-hccgc-access-gate').style.display = 'none';
      document.getElementById('rf-hccgc-gate').style.display = 'block';
    }
    document.getElementById('rf-hccgc-access-submit').addEventListener('click', submitHccgcAccessCode);
    document.getElementById('rf-hccgc-access-code').addEventListener('keydown', (e) => {
      if (e.key === 'Enter') { e.preventDefault(); submitHccgcAccessCode(); }
    });
    document.getElementById('rf-hccgc-yes-btn').addEventListener('click', function () { setHccgcPath(true); });
    document.getElementById('rf-hccgc-no-btn').addEventListener('click', function () { setHccgcPath(false); });
    document.getElementById('rf-email').addEventListener('keydown', (e) => {
      if (e.key === 'Enter') { e.preventDefault(); checkEmailAndProceed(); }
    });
    document.getElementById('rf-edit-contact-btn').addEventListener('click', () => {
      setContactFieldsLocked(false);
      document.getElementById('rf-first-name').focus();
    });

    function showRequestResult(message) {
      const box = document.getElementById('rf-result-box');
      box.style.display = 'block';
      box.className = 'request-result-box error';
      box.textContent = message;
    }

    // ── Room multi-select ──
    const roomPanel = document.getElementById('rf-room-panel');
    const roomBtn = document.getElementById('rf-room-btn');
    roomBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      roomPanel.style.display = roomPanel.style.display === 'none' ? 'block' : 'none';
    });
    document.addEventListener('click', (e) => {
      if (roomPanel.style.display !== 'none' && !roomPanel.contains(e.target) && e.target !== roomBtn) roomPanel.style.display = 'none';
    });
    function selectedRoomValues() {
      return Array.from(roomPanel.querySelectorAll('input:checked')).map(cb => cb.value);
    }
    function enforceKitchenConstraint() {
      const kitchenCb = document.getElementById('rf-kitchen-checkbox');
      const kitchenLabel = document.getElementById('rf-kitchen-label');
      const selected = selectedRoomValues();
      const eligible = selected.includes('Surya Hall') || selected.includes('Patanjali Hall') || selected.includes('Entire Facility');
      if (!eligible) {
        if (kitchenCb.checked) kitchenCb.checked = false; // no longer a valid combination — uncheck rather than leave it silently invalid
        kitchenCb.disabled = true;
        kitchenLabel.style.opacity = '0.5';
        kitchenLabel.style.cursor = 'not-allowed';
      } else {
        kitchenCb.disabled = false;
        kitchenLabel.style.opacity = '1';
        kitchenLabel.style.cursor = 'pointer';
      }
    }
    roomPanel.addEventListener('change', () => {
      enforceKitchenConstraint();
      const selected = selectedRoomValues();
      roomBtn.textContent = selected.length ? selected.join(', ') : 'Choose room(s)…';
    });
    enforceKitchenConstraint();

    // ── Repeatable date/time rows ──
    let dateRowCount = 0;
    function addDateRow() {
      dateRowCount++;
      const id = dateRowCount;
      const row = document.createElement('div');
      row.className = 'rf-date-row';
      row.dataset.rowId = id;
      row.innerHTML =
        '<div class="request-field"><label>Date</label><input type="date" class="rf-date-input" required></div>' +
        '<div class="request-field"><label>Start time</label><input type="time" class="rf-start-input" required></div>' +
        '<div class="request-field"><label>End time</label><input type="time" class="rf-end-input" required></div>' +
        '<div class="rf-remove-date-wrap"><button type="button" class="rf-remove-date" title="Remove this date">&times;</button></div>';
      row.querySelector('.rf-remove-date').addEventListener('click', () => {
        if (document.querySelectorAll('.rf-date-row').length === 1) return; // keep at least one row
        row.remove();
        updateLiveEstimate();
      });
      document.getElementById('rf-dates-list').appendChild(row);
    }
    document.getElementById('rf-add-date-btn').addEventListener('click', addDateRow);
    addDateRow(); // start with one row

    // ── Live estimate for the actual request being submitted — same
    // rates and discount rules as the standalone estimator above, but
    // applied per-occurrence (each date checked individually for the
    // weekday/extended-hours discounts) and summed across the whole
    // series, since a multi-date request can span a real mix of both. ──
    function updateLiveEstimate() {
      const box = document.getElementById('rf-live-estimate');
      if (isHccgcEventPath) { box.style.display = 'none'; return; }
      const roomValues = selectedRoomValues();
      const rows = Array.from(document.querySelectorAll('.rf-date-row'));
      const isNonprofit = document.getElementById('rf-is-nonprofit').value === 'yes';
      if (!roomValues.length || !rows.length) { box.style.display = 'none'; return; }

      const rateByName = { 'Surya Hall': 45, 'Patanjali Hall': 40, 'Nataraj Room': 30, 'Ganesh Room': 15, 'Kitchen': 0, 'Entire Facility': 130 };
      const normalizedRooms = roomValues.includes('Entire Facility') ? ['Surya Hall', 'Patanjali Hall', 'Nataraj Room', 'Ganesh Room'] : roomValues;
      const baseRate = normalizedRooms.reduce((sum, r) => sum + (rateByName[r] || 0), 0);

      let grandTotal = 0, grandBase = 0, validRows = 0;
      rows.forEach(function (row) {
        const dateVal = row.querySelector('.rf-date-input').value;
        const startVal = row.querySelector('.rf-start-input').value;
        const endVal = row.querySelector('.rf-end-input').value;
        if (!dateVal || !startVal || !endVal) return;
        const start = new Date(dateVal + 'T' + startVal + ':00');
        const end = new Date(dateVal + 'T' + endVal + ':00');
        const hours = Math.max(0, (end - start) / 3600000);
        if (hours <= 0) return;
        validRows++;
        const day = new Date(dateVal + 'T00:00:00').getDay();
        const isWeekday = day >= 1 && day <= 5;
        const isExtended = hours >= 4;
        const baseTotal = baseRate * hours;
        let mult = 1;
        if (isWeekday) mult *= 0.80;
        if (isExtended) mult *= 0.80;
        if (isNonprofit) mult *= 0.75;
        grandTotal += baseTotal * mult;
        grandBase += baseTotal;
      });

      if (!validRows) { box.style.display = 'none'; return; }
      box.style.display = 'block';
      document.getElementById('rf-live-estimate-amount').textContent = '$' + grandTotal.toFixed(2);
      const savings = grandBase - grandTotal;
      const roomLabel = roomValues.includes('Entire Facility') ? 'Entire Facility' : roomValues.join(' + ');
      document.getElementById('rf-live-estimate-breakdown').textContent = roomLabel + ' · ' + validRows + ' date' + (validRows !== 1 ? 's' : '') +
        (savings > 0.01 ? ' · Base: $' + grandBase.toFixed(2) + ' · You save: $' + savings.toFixed(2) : '');
    }
    document.getElementById('rf-dates-list').addEventListener('input', updateLiveEstimate);
    roomPanel.addEventListener('change', updateLiveEstimate);
    document.getElementById('rf-is-nonprofit').addEventListener('change', updateLiveEstimate);
    document.getElementById('rf-add-date-btn').addEventListener('click', updateLiveEstimate);

    document.getElementById('requestForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('rf-submit-btn');

      const rooms = selectedRoomValues();
      if (!rooms.length) { showRequestResult('Please select at least one room.'); return; }
      if (rooms.includes('Kitchen') && !rooms.includes('Surya Hall') && !rooms.includes('Patanjali Hall')) {
        showRequestResult('Kitchen can only be booked together with Surya Hall or Patanjali Hall.'); return;
      }

      const occurrences = Array.from(document.querySelectorAll('.rf-date-row')).map(row => ({
        date: row.querySelector('.rf-date-input').value,
        startTime: row.querySelector('.rf-start-input').value,
        endTime: row.querySelector('.rf-end-input').value
      }));
      if (occurrences.some(o => !o.date || !o.startTime || !o.endTime)) { showRequestResult('Please fill in every date row completely.'); return; }

      let payload;
      if (isHccgcEventPath) {
        if (!document.getElementById('rf-hccgc-event-name').value.trim()) { showRequestResult('Program/event name is required.'); return; }
        if (!document.getElementById('rf-hccgc-organizer').value.trim()) { showRequestResult('HCCGC representative name is required.'); return; }
        payload = {
          isHccgcEvent: true,
          email: document.getElementById('rf-email').value,
          eventName: document.getElementById('rf-hccgc-event-name').value,
          hccgcRepresentative: document.getElementById('rf-hccgc-organizer').value,
          eventDetails: document.getElementById('rf-hccgc-event-details').value,
          publishAsEvent: document.getElementById('rf-hccgc-publish').checked,
          rooms: rooms,
          occurrences: occurrences,
          notes: document.getElementById('rf-notes').value
        };
      } else {
        if (document.getElementById('rf-is-nonprofit').value === 'yes' && !document.getElementById('rf-org').value.trim()) {
          showRequestResult('Organization name is required for nonprofits.'); return;
        }
        const addressParts = [document.getElementById('rf-street').value, document.getElementById('rf-suite').value].filter(Boolean).join(', ');
        const fullAddress = addressParts + (addressParts ? ', ' : '') +
          document.getElementById('rf-city').value + ', ' + document.getElementById('rf-state').value + ' ' + document.getElementById('rf-zip').value;
        const repValue = document.getElementById('rf-hccg-rep').value;
        const hccgcRepresentative = repValue === 'Other' ? document.getElementById('rf-hccg-rep-other').value : repValue;
        payload = {
          isHccgcEvent: false,
          firstName: document.getElementById('rf-first-name').value,
          lastName: document.getElementById('rf-last-name').value,
          email: document.getElementById('rf-email').value,
          phone: document.getElementById('rf-phone').value,
          organizationName: document.getElementById('rf-org').value,
          isNonprofit: document.getElementById('rf-is-nonprofit').value === 'yes',
          website: document.getElementById('rf-website').value,
          billingAddress: fullAddress,
          eventDetails: document.getElementById('rf-event-details').value,
          rooms: rooms,
          occurrences: occurrences,
          hccgcRepresentative: hccgcRepresentative,
          references: document.getElementById('rf-references').value,
          notes: document.getElementById('rf-notes').value
        };
      }

      btn.disabled = true; btn.textContent = 'Submitting…';
      try {
        const res = await fetch(API_BASE + '/public/facility-request', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload)
        });
        const data = await res.json();
        if (!res.ok) {
          showRequestResult((data.errors || [data.error || 'Something went wrong. Please try again.']).join(' '));
          btn.disabled = false; btn.textContent = 'Submit request';
        } else {
          document.getElementById('requestForm').style.display = 'none';
          document.getElementById('rf-success-panel').style.display = 'block';
          if (!isHccgcEventPath && data.estimatedTotal !== undefined) {
            document.getElementById('rf-success-estimate').style.display = 'block';
            document.getElementById('rf-success-estimate-amount').textContent = '$' + Number(data.estimatedTotal).toFixed(2);
          }
        }
      } catch (err) {
        showRequestResult('Could not reach the server: ' + err.message);
        btn.disabled = false; btn.textContent = 'Submit request';
      }
    });

    // ── Address autocomplete ──
    // Uses OpenStreetMap's free Nominatim search — no API key required, so
    // this works out of the box. If a Google Maps API key gets added below,
    // that takes over instead (generally higher-quality US address results).
    const GOOGLE_MAPS_API_KEY = ''; // <-- add a Maps JavaScript API key (with Places enabled) here to switch to Google's autocomplete
    if (GOOGLE_MAPS_API_KEY) {
      const gmapsScript = document.createElement('script');
      gmapsScript.src = 'https://maps.googleapis.com/maps/api/js?key=' + GOOGLE_MAPS_API_KEY + '&libraries=places&callback=initRequestFormAutocomplete';
      gmapsScript.async = true;
      document.head.appendChild(gmapsScript);
    } else {
      setupFreeAddressAutocomplete();
    }
    window.initRequestFormAutocomplete = function () {
      const input = document.getElementById('rf-street');
      const autocomplete = new google.maps.places.Autocomplete(input, { types: ['address'], componentRestrictions: { country: 'us' } });
      autocomplete.addListener('place_changed', () => {
        const place = autocomplete.getPlace();
        if (!place.address_components) return;
        let streetNumber = '', route = '', city = '', state = '', zip = '';
        place.address_components.forEach((c) => {
          if (c.types.includes('street_number')) streetNumber = c.long_name;
          if (c.types.includes('route')) route = c.long_name;
          if (c.types.includes('locality')) city = c.long_name;
          if (c.types.includes('administrative_area_level_1')) state = c.short_name;
          if (c.types.includes('postal_code')) zip = c.long_name;
        });
        document.getElementById('rf-street').value = (streetNumber + ' ' + route).trim();
        document.getElementById('rf-city').value = city;
        document.getElementById('rf-state').value = state;
        document.getElementById('rf-zip').value = zip;
      });
    };

    function setupFreeAddressAutocomplete() {
      const input = document.getElementById('rf-street');
      const list = document.getElementById('rf-street-autocomplete');
      let debounceTimer = null;

      input.addEventListener('input', () => {
        const query = input.value.trim();
        clearTimeout(debounceTimer);
        if (query.length < 3) { list.style.display = 'none'; return; }
        debounceTimer = setTimeout(async () => {
          try {
            // viewbox biases results toward Greater Cincinnati (without
            // strictly excluding elsewhere) since most renters are local —
            // this alone fixes a lot of "my address doesn't show up" cases,
            // since unbiased results were getting crowded out by
            // better-known places elsewhere in the US with similar names.
            const viewbox = '-84.9,39.5,-83.9,38.9';
            const res = await fetch('https://nominatim.openstreetmap.org/search?format=json&addressdetails=1&countrycodes=us&limit=8&dedupe=1&accept-language=en&viewbox=' + viewbox + '&bounded=0&q=' + encodeURIComponent(query));
            const results = await res.json();
            if (!results.length) { list.style.display = 'none'; return; }
            list.innerHTML = results.map((r, i) => '<div data-i="' + i + '">' + r.display_name.replace(/</g, '&lt;') + '</div>').join('');
            list.style.display = 'block';
            list.querySelectorAll('div').forEach((div, i) => {
              div.addEventListener('click', () => {
                const addr = results[i].address || {};
                const streetNum = addr.house_number || '';
                const streetName = addr.road || '';
                input.value = (streetNum + ' ' + streetName).trim();
                document.getElementById('rf-city').value = addr.city || addr.town || addr.village || '';
                document.getElementById('rf-state').value = addr.state ? (US_STATE_ABBR[addr.state] || addr.state) : '';
                document.getElementById('rf-zip').value = addr.postcode || '';
                list.style.display = 'none';
              });
            });
          } catch (err) {
            list.style.display = 'none';
          }
        }, 400);
      });
      document.addEventListener('click', (e) => {
        if (!list.contains(e.target) && e.target !== input) list.style.display = 'none';
      });
    }
    const US_STATE_ABBR = { 'Ohio': 'OH', 'Kentucky': 'KY', 'Indiana': 'IN', 'Michigan': 'MI', 'Pennsylvania': 'PA', 'West Virginia': 'WV', 'Illinois': 'IL' };
  </script>


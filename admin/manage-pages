<script>
var allPages = [];
var currentStep = 1;
var TOTAL_STEPS = 6;
var STEP_NAMES = ['Basics', 'Event Details', 'Content', 'People', 'Schedule', 'Media & Registration'];
var isEditing = false;

window.addEventListener('hccgc-mp-ready', loadPages);

function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function fmtDate(d) {
  if (!d) return '';
  var p = d.split('-');
  if (p.length!==3) return d;
  return new Date(+p[0],+p[1]-1,+p[2]).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});
}
function showStatus(msg, type) {
  var b = document.getElementById('status-bar');
  b.textContent = msg; b.className = 'status-bar show ' + type;
  if (type!=='error') setTimeout(()=>b.classList.remove('show'), 3500);
}

// Convert Google Drive share URL to thumbnail URL (avoids CORS issues with uc?export=view)
function convertDriveUrl(url) {
  if (!url) return '';
  var m = url.match(/\/d\/([a-zA-Z0-9_-]+)/);
  if (m) return 'https://drive.google.com/thumbnail?id=' + m[1] + '&sz=w800';
  return url;
}

function loadPages() {
  var fb = window.__hccgcMP;
  fb.getDocs(fb.collection(fb.db, fb.PAGES_COLLECTION)).then(snap => {
    allPages = [];
    snap.forEach(d => { var data = d.data(); data.id = d.id; allPages.push(data); });
    allPages.sort((a,b) => (b.createdAt?.seconds||0) - (a.createdAt?.seconds||0));
    renderList();
  }).catch(err => {
    document.getElementById('pages-list').innerHTML = '<div class="empty-state">Could not load pages. ' + esc(err.message) + '</div>';
  });
}

function renderList() {
  var c = document.getElementById('pages-list');
  document.getElementById('pages-count').textContent = allPages.length + ' page' + (allPages.length!==1?'s':'');
  if (!allPages.length) { c.innerHTML = '<div class="empty-state">No pages yet. Click "New Page" to create your first one.</div>'; return; }
  c.innerHTML = allPages.map(p => {
    var isInit = p.type === 'initiative';
    var isLive = p.pageEnabled && p.slug;
    var dateStr = isInit ? (fmtDate(p.startDate) + (p.endDate ? ' – ' + fmtDate(p.endDate) : '')) : fmtDate(p.date);
    var urlInfo = isLive ? '<a href="/' + esc(p.slug) + '" target="_blank">hccgc.org/' + esc(p.slug) + ' ↗</a>' : '<span>Not published</span>';
    return '<div class="page-row">' +
      '<div class="page-row-dot' + (isLive?' live':'') + '"></div>' +
      '<div class="page-row-info">' +
        '<h4>' + esc(p.pageTitle||p.slug||'Untitled') + ' <span class="type-pill ' + (isInit?'initiative':'event') + '">' + (isInit?'Initiative':'Event') + '</span></h4>' +
        '<div class="meta">' + esc(dateStr||'No date') + ' &nbsp;·&nbsp; ' + urlInfo + '</div>' +
      '</div>' +
      '<div class="page-row-actions">' +
        '<button class="btn-row btn-edit-page" data-id="' + esc(p.id) + '">' +
          '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 113 3L12 15l-4 1 1-4 9.5-9.5z"/></svg> Edit' +
        '</button>' +
        '<button class="btn-row danger btn-delete-page" data-id="' + esc(p.id) + '">Delete</button>' +
      '</div>' +
    '</div>';
  }).join('');
}

document.getElementById('pages-list').addEventListener('click', evt => {
  var editBtn = evt.target.closest('.btn-edit-page');
  if (editBtn) { var p = allPages.find(x => x.id === editBtn.getAttribute('data-id')); if (p) openModal(p); return; }
  var delBtn = evt.target.closest('.btn-delete-page');
  if (delBtn) deletePage(delBtn.getAttribute('data-id'));
});

function deletePage(id) {
  if (!confirm('Delete this page? This cannot be undone.')) return;
  var fb = window.__hccgcMP;
  fb.deleteDoc(fb.doc(fb.db, fb.PAGES_COLLECTION, id)).then(() => {
    allPages = allPages.filter(p => p.id !== id);
    renderList();
    showStatus('Page deleted.', 'success');
  }).catch(err => showStatus('Error: ' + err.message, 'error'));
}

// Type toggle
document.getElementById('type-btn-event').addEventListener('click', () => setType('event'));
document.getElementById('type-btn-initiative').addEventListener('click', () => setType('initiative'));
function setType(type) {
  document.getElementById('page-type').value = type;
  document.getElementById('type-btn-event').classList.toggle('active', type==='event');
  document.getElementById('type-btn-initiative').classList.toggle('active', type==='initiative');
  var isInit = type === 'initiative';
  document.getElementById('step2-event-fields').style.display = isInit ? 'none' : 'block';
  document.getElementById('step2-initiative-fields').style.display = isInit ? 'block' : 'none';
  document.getElementById('step4-event').style.display = isInit ? 'none' : 'block';
  document.getElementById('step4-initiative').style.display = isInit ? 'block' : 'none';
  document.getElementById('step5-event').style.display = isInit ? 'none' : 'block';
  document.getElementById('step5-initiative').style.display = isInit ? 'block' : 'none';
  STEP_NAMES[3] = isInit ? 'Instructor' : 'Performers';
  STEP_NAMES[4] = isInit ? 'Curriculum' : 'Schedule';
  updateWizardUI();
}

// Slug preview
document.getElementById('page-slug').addEventListener('input', function() {
  var clean = this.value.toLowerCase().replace(/[^a-z0-9-]/g,'-').replace(/-+/g,'-').replace(/^-|-$/g,'');
  document.getElementById('slug-display').textContent = clean || 'your-slug';
  updateLiveLink(clean, document.getElementById('page-enabled').checked);
});
document.getElementById('page-enabled').addEventListener('change', function() {
  updateLiveLink(document.getElementById('page-slug').value.trim(), this.checked);
});
function updateLiveLink(slug, enabled) {
  var l = document.getElementById('live-link');
  if (slug && enabled) { l.href = '/' + slug; l.style.display = 'inline'; }
  else l.style.display = 'none';
}

// Sync to events checkbox
document.getElementById('sync-to-events').addEventListener('change', function() {
  document.getElementById('event-sync-fields').classList.toggle('show', this.checked);
});

// Image preview with Drive conversion
function setupImgPreview(inputId, wrapId, imgId) {
  document.getElementById(inputId).addEventListener('blur', function() {
    var url = convertDriveUrl(this.value.trim());
    var wrap = document.getElementById(wrapId);
    var img = document.getElementById(imgId);
    if (url) { img.src = url; wrap.style.display = 'block'; }
    else wrap.style.display = 'none';
  });
}
setupImgPreview('page-flyer-url', 'flyer-img-wrap', 'flyer-img');
setupImgPreview('page-instructor-photo', 'instructor-img-wrap', 'instructor-img');

// WIZARD UI
function updateWizardUI() {
  for (var i=1; i<=TOTAL_STEPS; i++) {
    document.getElementById('step-'+i).classList.toggle('active', i===currentStep);
  }
  document.getElementById('step-meta').textContent = 'Step ' + currentStep + ' of ' + TOTAL_STEPS + ' — ' + STEP_NAMES[currentStep-1];
  var bars = document.getElementById('step-bars');
  bars.innerHTML = '';
  for (var i=1; i<=TOTAL_STEPS; i++) {
    var d = document.createElement('div');
    d.className = 'step-bar' + (i<currentStep?' done':i===currentStep?' active':'');
    bars.appendChild(d);
  }
  document.getElementById('btn-back').style.display = currentStep > 1 ? 'inline-flex' : 'none';
  var isLast = currentStep === TOTAL_STEPS;
  document.getElementById('btn-next').style.display = isLast ? 'none' : 'inline-flex';
  document.getElementById('btn-save').style.display = isLast ? 'inline-flex' : 'none';
}

document.getElementById('btn-next').addEventListener('click', () => {
  if (!validateStep(currentStep)) return;
  currentStep = Math.min(currentStep+1, TOTAL_STEPS);
  updateWizardUI();
});
document.getElementById('btn-back').addEventListener('click', () => {
  currentStep = Math.max(currentStep-1, 1);
  updateWizardUI();
});

function validateStep(step) {
  var valid = true;
  if (step===1) {
    var title = document.getElementById('page-title').value.trim();
    var slug = document.getElementById('page-slug').value.trim();
    document.getElementById('err-title').classList.toggle('show', !title);
    document.getElementById('err-slug').classList.toggle('show', !slug || !/^[a-z0-9-]+$/.test(slug));
    if (!title || !slug || !/^[a-z0-9-]+$/.test(slug)) valid = false;
  }
  if (step===2 && document.getElementById('sync-to-events').checked) {
    var desc = document.getElementById('sync-description').value.trim();
    document.getElementById('err-sync-desc').classList.toggle('show', !desc);
    if (!desc) valid = false;
  }
  return valid;
}

// Open modal
document.getElementById('btn-new-page').addEventListener('click', () => openModal(null));

function openModal(page) {
  isEditing = !!page;
  document.getElementById('wizard-title').textContent = isEditing ? 'Edit Page' : 'New Page';
  document.getElementById('edit-page-id').value = page ? page.id : '';
  currentStep = 1;

  var type = page ? (page.type||'event') : 'event';
  setType(type);

  // Step 1
  document.getElementById('page-title').value = page ? (page.pageTitle||'') : '';
  document.getElementById('page-slug').value = page ? (page.slug||'') : '';
  document.getElementById('slug-display').textContent = (page&&page.slug) || 'your-slug';
  document.getElementById('page-tagline').value = page ? (page.tagline||'') : '';
  document.getElementById('page-hero-desc').value = page ? (page.heroDescription||'') : '';
  document.getElementById('page-enabled').checked = page ? !!page.pageEnabled : false;
  updateLiveLink(page?page.slug:'', page?!!page.pageEnabled:false);

  // Step 2
  document.getElementById('page-venue').value = page ? (page.venue||'') : '';
  document.getElementById('page-cost-display').value = page ? (page.costDisplay||'') : '';
  document.getElementById('page-date').value = page ? (page.date||'') : '';
  document.getElementById('page-from-time').value = page ? (page.fromTime||'') : '';
  document.getElementById('page-to-time').value = page ? (page.toTime||'') : '';
  document.getElementById('page-category').value = page ? (page.category||'') : '';
  document.getElementById('page-start-date').value = page ? (page.startDate||'') : '';
  document.getElementById('page-end-date').value = page ? (page.endDate||'') : '';
  document.getElementById('page-schedule-text').value = page ? (page.scheduleText||'') : '';
  document.getElementById('page-contact-name').value = page ? ((page.contact&&page.contact.name)||'') : '';
  document.getElementById('page-contact-phone').value = page ? ((page.contact&&page.contact.phone)||'') : '';
  document.getElementById('sync-to-events').checked = false;
  document.getElementById('event-sync-fields').classList.remove('show');
  document.getElementById('sync-description').value = '';

  // Step 3
  document.getElementById('page-about-title').value = page ? (page.aboutTitle||'') : '';
  document.getElementById('page-about-body').value = page ? (page.aboutBody||'') : '';
  document.getElementById('page-what-to-expect').value = page ? ((page.whatToExpect||[]).join('\n')) : '';
  document.getElementById('page-who-should-attend').value = page ? ((page.whoShouldAttend||[]).join('\n')) : '';

  // Step 4
  document.getElementById('page-performers').value = page ? ((page.performers||[]).map(p=>[p.name,p.role,p.location].filter(Boolean).join(' | ')).join('\n')) : '';
  document.getElementById('page-instructor-name').value = page ? ((page.instructor&&page.instructor.name)||'') : '';
  document.getElementById('page-instructor-role').value = page ? ((page.instructor&&page.instructor.role)||'') : '';
  document.getElementById('page-instructor-photo').value = page ? ((page.instructor&&page.instructor.driveUrl)||'') : '';
  document.getElementById('page-instructor-bio').value = page ? ((page.instructor&&page.instructor.bio)||'') : '';
  document.getElementById('instructor-img-wrap').style.display = 'none';

  // Step 5
  document.getElementById('page-schedule-items').value = page ? ((page.scheduleItems||[]).map(s=>[s.time,s.label,s.duration].filter(Boolean).join(' | ')).join('\n')) : '';
  document.getElementById('page-curriculum-title').value = page ? (page.curriculumTitle||'') : '';
  document.getElementById('page-curriculum').value = page ? ((page.curriculum||[]).map(w=>[w.weekLabel,w.title,w.description].filter(Boolean).join(' | ')).join('\n')) : '';

  // Step 6
  document.getElementById('page-zeffy-url').value = page ? (page.zeffyUrl||'') : '';
  document.getElementById('page-registration-note').value = page ? (page.registrationNote||'') : '';
  document.getElementById('page-flyer-url').value = page ? (page.driveUrl||'') : '';
  document.getElementById('page-meta-desc').value = page ? (page.metaDescription||'') : '';
  document.getElementById('flyer-img-wrap').style.display = 'none';

  ['err-title','err-slug','err-sync-desc'].forEach(id => document.getElementById(id).classList.remove('show'));
  updateWizardUI();
  document.getElementById('modal-overlay').classList.add('show');
}

function closeModal() { document.getElementById('modal-overlay').classList.remove('show'); }
document.getElementById('modal-close-btn').addEventListener('click', closeModal);
document.getElementById('btn-cancel').addEventListener('click', closeModal);

// SAVE
document.getElementById('btn-save').addEventListener('click', async function() {
  if (!validateStep(currentStep)) return;

  var btn = this;
  var orig = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '<div class="spinner"></div> Saving…';

  function parseLines(id) { return document.getElementById(id).value.split('\n').map(l=>l.trim()).filter(Boolean); }
  function parsePiped(id, keys) {
    return parseLines(id).map(line => {
      var parts = line.split('|').map(p=>p.trim());
      var obj = {}; keys.forEach((k,i) => obj[k]=parts[i]||'');
      return obj;
    });
  }

  var isInit = document.getElementById('page-type').value === 'initiative';
  var slug = document.getElementById('page-slug').value.trim().toLowerCase().replace(/[^a-z0-9-]/g,'-').replace(/-+/g,'-').replace(/^-|-$/g,'');
  var rawFlyer = document.getElementById('page-flyer-url').value.trim();
  var rawInstructorPhoto = document.getElementById('page-instructor-photo').value.trim();

  var pageData = {
    type: isInit ? 'initiative' : 'event',
    pageEnabled: document.getElementById('page-enabled').checked,
    slug: slug,
    pageTitle: document.getElementById('page-title').value.trim(),
    tagline: document.getElementById('page-tagline').value.trim(),
    heroDescription: document.getElementById('page-hero-desc').value.trim(),
    venue: document.getElementById('page-venue').value.trim(),
    costDisplay: document.getElementById('page-cost-display').value.trim(),
    contact: {
      name: document.getElementById('page-contact-name').value.trim(),
      phone: document.getElementById('page-contact-phone').value.trim()
    },
    aboutTitle: document.getElementById('page-about-title').value.trim(),
    aboutBody: document.getElementById('page-about-body').value.trim(),
    whatToExpect: parseLines('page-what-to-expect'),
    whoShouldAttend: parseLines('page-who-should-attend'),
    zeffyUrl: document.getElementById('page-zeffy-url').value.trim(),
    registrationNote: document.getElementById('page-registration-note').value.trim(),
    flyerImageUrl: convertDriveUrl(rawFlyer),
    driveUrl: rawFlyer,
    metaDescription: document.getElementById('page-meta-desc').value.trim()
  };

  if (!isInit) {
    pageData.date = document.getElementById('page-date').value;
    pageData.fromTime = document.getElementById('page-from-time').value.trim();
    pageData.toTime = document.getElementById('page-to-time').value.trim();
    pageData.category = document.getElementById('page-category').value;
    pageData.performers = parsePiped('page-performers', ['name','role','location']);
    pageData.scheduleItems = parsePiped('page-schedule-items', ['time','label','duration']);
  } else {
    pageData.startDate = document.getElementById('page-start-date').value;
    pageData.endDate = document.getElementById('page-end-date').value;
    pageData.scheduleText = document.getElementById('page-schedule-text').value.trim();
    pageData.instructor = {
      name: document.getElementById('page-instructor-name').value.trim(),
      role: document.getElementById('page-instructor-role').value.trim(),
      photoUrl: convertDriveUrl(rawInstructorPhoto),
      driveUrl: rawInstructorPhoto,
      bio: document.getElementById('page-instructor-bio').value.trim()
    };
    pageData.curriculumTitle = document.getElementById('page-curriculum-title').value.trim();
    pageData.curriculum = parsePiped('page-curriculum', ['weekLabel','title','description']);
  }

  var fb = window.__hccgcMP;
  if (!fb) {
    btn.disabled = false; btn.innerHTML = orig;
    showStatus('Not ready yet — please wait a moment and try again.', 'error');
    return;
  }
  try {
    var pageId = document.getElementById('edit-page-id').value;
    if (pageId) {
      await fb.setDoc(fb.doc(fb.db, fb.PAGES_COLLECTION, pageId), pageData, { merge: true });
    } else {
      pageData.createdAt = fb.serverTimestamp();
      var ref = await fb.addDoc(fb.collection(fb.db, fb.PAGES_COLLECTION), pageData);
      pageId = ref.id;
      document.getElementById('edit-page-id').value = pageId;
    }

    // Optionally sync to Manage Events
    if (document.getElementById('sync-to-events').checked) {
      var desc = document.getElementById('sync-description').value.trim();
      var eventRecord = {
        type: isInit ? 'initiative' : 'event',
        name: pageData.pageTitle,
        description: desc,
        date: isInit ? pageData.startDate : pageData.date,
        category: pageData.category || '',
        cost: pageData.costDisplay || '',
        rsvpUrl: pageData.zeffyUrl || '',
        createdByName: '',
        createdByEmail: '',
        createdAt: fb.serverTimestamp(),
        pageSlug: slug
      };
      if (!isInit) { eventRecord.fromTime = pageData.fromTime; eventRecord.toTime = pageData.toTime; }
      else { eventRecord.endDate = pageData.endDate; eventRecord.schedule = pageData.scheduleText; }
      await fb.addDoc(fb.collection(fb.db, fb.EVENTS_COLLECTION), eventRecord);
    }

    btn.disabled = false; btn.innerHTML = orig;
    closeModal();
    showStatus('Page saved!' + (pageData.pageEnabled && slug ? ' Live at hccgc.org/' + slug : ' Page is hidden.'), 'success');
    loadPages();
  } catch(err) {
    btn.disabled = false; btn.innerHTML = orig;
    showStatus('Error: ' + (err.message || 'unknown error'), 'error');
  }
});
</script>
</body>
</html>

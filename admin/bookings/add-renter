<style>
:root {
  --bg: #fff9f1; --surface: #ffffff; --surface-soft: #fff6ea; --border: rgba(121,62,17,0.14);
  --text: #2c1b10; --muted: #6a5141; --saffron: #b55a18; --saffron-dark: #8d3e0d; --maroon: #7f2e16;
  --radius: 22px; --shadow: 0 18px 45px rgba(93,43,14,0.10);
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: Arial, Helvetica, sans-serif; background: radial-gradient(circle at top left, rgba(217,138,30,0.12), transparent 22%), radial-gradient(circle at top right, rgba(127,46,22,0.05), transparent 20%), var(--bg); color: var(--text); min-height: 100vh; }
.container { width: min(calc(100% - 32px), 1000px); margin: 0 auto; }
.site-header { position: sticky; top: 0; z-index: 50; background: rgba(255,249,241,0.92); backdrop-filter: blur(10px); border-bottom: 1px solid var(--border); }
.nav { display: flex; align-items: center; justify-content: space-between; gap: 24px; min-height: 92px; padding: 12px 0; }
.site-header a.brand, .site-header a.brand:link, .site-header a.brand:visited { text-decoration: none; color: inherit; }
.brand { display: flex; align-items: center; gap: 16px; min-width: 0; }
.brand-logo-wrap { background: #fff; border: 1px solid var(--border); border-radius: 18px; padding: 8px; box-shadow: var(--shadow); flex-shrink: 0; }
.brand-logo { width: 88px; height: auto; border-radius: 12px; object-fit: contain; }
.brand-text h1 { margin: 0; font-size: 1.2rem; line-height: 1.15; color: var(--maroon); }
.site-header nav ul { list-style: none; display: flex; flex-wrap: wrap; gap: 18px; margin: 0; padding: 0; align-items: center; justify-content: flex-end; }
.site-header nav a, .site-header nav a:link, .site-header nav a:visited { font-weight: 700; color: var(--text); font-size: 0.96rem; text-decoration: none; }
.site-header nav a:hover { color: var(--saffron-dark); }
.menu-toggle { display: none; border: 0; background: transparent; padding: 6px 0; cursor: pointer; color: #2c1b10; align-self: flex-end; }
.menu-toggle .bar { display: block; width: 26px; height: 2px; margin: 5px 0; background: currentColor; }
@media (max-width: 768px) {
  .nav { flex-direction: column; align-items: stretch; gap: 8px; } .menu-toggle { display: inline-block; }
  .site-header nav { display: none; width: 100%; background: rgba(255,249,241,0.95); padding: 10px 0; }
  .site-header nav.is-open { display: block; } .site-header nav ul { flex-direction: column; gap: 14px; }
}
.page-hero { padding: 40px 0 28px; background: linear-gradient(135deg, var(--maroon) 0%, #4e1a09 100%); color: #fff; }
.page-hero .eyebrow { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(255,255,255,0.75); margin-bottom: 6px; }
.page-hero h1 { font-family: Georgia, "Times New Roman", serif; font-size: 1.9rem; color: #fff; margin-bottom: 6px; }
.page-hero p { color: #ffffff; opacity: 0.9; font-size: 0.92rem; max-width: 560px; }
.back-link { display: inline-flex; align-items: center; gap: 6px; font-size: 0.82rem; font-weight: 700; color: rgba(255,255,255,0.85); text-decoration: none; margin-bottom: 14px; }
.back-link:hover { color: #fff; text-decoration: underline; }
.module-nav { background: var(--surface); border-bottom: 1px solid var(--border); }
.module-nav ul { list-style: none; display: flex; gap: 4px; padding: 10px 0; flex-wrap: wrap; }
.module-nav a { display: inline-block; padding: 8px 16px; border-radius: 999px; font-size: 0.86rem; font-weight: 700; color: var(--muted); text-decoration: none; transition: background 0.15s, color 0.15s; }
.module-nav a.active { background: var(--surface-soft); color: var(--saffron-dark); }
.module-nav a:not(.active):hover { background: var(--surface-soft); }

.card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 28px; box-shadow: var(--shadow); margin: 24px 0; }
.card h2 { font-family: Georgia, "Times New Roman", serif; font-size: 1.2rem; color: var(--maroon); margin-bottom: 4px; }
.card .card-sub { font-size: 0.82rem; color: var(--muted); margin-bottom: 18px; }

.field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 14px; }
.field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px; }
.field label { font-size: 0.78rem; font-weight: 700; color: var(--muted); }
.field input[type="text"], .field input[type="email"], .field input[type="tel"], .field textarea {
  font-family: Arial, Helvetica, sans-serif; font-size: 0.9rem; padding: 9px 12px; border: 1.5px solid var(--border); border-radius: 10px; background: #fff; color: var(--text);
}
.field textarea { resize: vertical; min-height: 56px; }

.btn-primary {
  font-family: Arial, Helvetica, sans-serif; font-size: 0.9rem; font-weight: 700; color: #fff;
  background: linear-gradient(135deg, var(--saffron-dark), var(--maroon)); border: none; border-radius: 12px;
  padding: 12px 20px; cursor: pointer; margin-top: 4px;
}
.btn-primary:hover { opacity: 0.92; }

.result-box { margin-top: 16px; border-radius: 12px; padding: 12px 16px; font-size: 0.84rem; line-height: 1.5; }
.result-box.success { background: #e8f5ec; color: #2e7d4f; border: 1px solid rgba(46,125,79,0.25); }
.result-box.error { background: #fbe9e7; color: #b3382c; border: 1px solid rgba(179,56,44,0.25); }

.toolbar { display: flex; gap: 12px; margin-bottom: 16px; }
.toolbar input[type="text"] { flex: 1; font-family: Arial, Helvetica, sans-serif; font-size: 0.88rem; padding: 9px 14px; border: 1.5px solid var(--border); border-radius: 10px; }
table { width: 100%; border-collapse: collapse; font-size: 0.86rem; }
thead th { text-align: left; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted); background: var(--surface-soft); padding: 10px 12px; }
tbody td { padding: 10px 12px; border-bottom: 1px solid var(--border); }
tbody tr:last-child td { border-bottom: none; }
.empty-state { text-align: center; padding: 40px 20px; color: var(--muted); font-size: 0.88rem; }

.autocomplete-list {
  position: absolute; top: 100%; left: 0; right: 0; background: var(--surface); border: 1.5px solid var(--border);
  border-top: none; border-radius: 0 0 10px 10px; z-index: 20; max-height: 220px; overflow-y: auto; box-shadow: var(--shadow);
}
.autocomplete-list div { padding: 9px 12px; font-size: 0.86rem; cursor: pointer; }
.autocomplete-list div:hover { background: var(--surface-soft); }

.status-badge { display: inline-flex; align-items: center; gap: 5px; font-size: 0.72rem; font-weight: 700; padding: 3px 9px; border-radius: 999px; }
.status-badge.approved { background: #e8f5ec; color: #2e7d4f; }
.status-badge.pending { background: #fff3e0; color: #b5750a; }
.status-badge.rejected { background: #fbe9e7; color: #b3382c; }
.status-tabs { display: flex; gap: 6px; margin-bottom: 14px; }
.status-tabs button {
  font-family: Arial, Helvetica, sans-serif; font-size: 0.82rem; font-weight: 700; padding: 7px 14px;
  border-radius: 999px; border: 1.5px solid var(--border); background: #fff; color: var(--muted); cursor: pointer;
}
.status-tabs button.active { background: var(--surface-soft); color: var(--saffron-dark); border-color: var(--saffron-dark); }
.btn-small { font-family: Arial, Helvetica, sans-serif; font-size: 0.76rem; font-weight: 700; padding: 5px 10px; border-radius: 7px; cursor: pointer; margin-right: 4px; white-space: nowrap; }
.btn-approve { border: 1.5px solid #2e7d4f; background: #fff; color: #2e7d4f; }
.btn-approve:hover { background: #e8f5ec; }
.btn-reject { border: 1.5px solid var(--saffron-dark); background: #fff; color: var(--saffron-dark); }
.btn-reject:hover { background: var(--surface-soft); }
.btn-edit-renter { border: 1.5px solid var(--border); background: #fff; color: var(--text); }
.btn-edit-renter:hover { background: var(--surface-soft); }

.modal-overlay { position: fixed; inset: 0; background: rgba(44,27,16,0.5); z-index: 100; display: flex; align-items: flex-start; justify-content: center; padding: 60px 16px; overflow-y: auto; }
.modal-panel { background: var(--surface); border-radius: var(--radius); box-shadow: var(--shadow); width: 100%; max-width: 480px; }
.modal-header { display: flex; align-items: center; justify-content: space-between; padding: 22px 26px; border-bottom: 1px solid var(--border); }
.modal-header h2 { font-family: Georgia, "Times New Roman", serif; font-size: 1.15rem; color: var(--maroon); }
.modal-close { background: none; border: none; font-size: 1.4rem; color: var(--muted); cursor: pointer; line-height: 1; }
.modal-body { padding: 22px 26px; }
.modal-footer { display: flex; justify-content: flex-end; gap: 10px; padding: 18px 26px; border-top: 1px solid var(--border); }
.btn-secondary {
  font-family: Arial, Helvetica, sans-serif; font-size: 0.86rem; font-weight: 700; color: var(--text);
  background: #fff; border: 1.5px solid var(--border); border-radius: 10px; padding: 9px 14px; cursor: pointer;
}

#gate{padding:60px 16px;display:flex;justify-content:center;}
.gate-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:2.5rem 2rem;max-width:420px;width:100%;text-align:center;box-shadow:var(--shadow);}
.gate-card h3{font-family:Georgia,serif;font-size:1.3rem;color:var(--maroon);margin-bottom:.5rem;}
.gate-card p{color:var(--muted);font-size:.88rem;line-height:1.6;}
.gate-card a{color:var(--saffron-dark);}
</style>
</head>
<body>
<div id="site-header"></div>

<div id="gate">
  <div class="gate-card">
    <h3>Checking access&hellip;</h3>
    <p>Please sign in from the <a href="/admin/admin-portal">Admin Portal</a> first.</p>
  </div>
</div>

<div id="app">

<div class="page-hero">
  <div class="container">
    <a class="back-link" href="https://hccgc.org/admin/admin-portal">&larr; Back to apps</a>
    <div class="eyebrow">Facility Bookings</div>
    <h1>Add A Renter</h1>
    <p>Save a contact directly, or review and approve requests submitted through the public facility request form.</p>
  </div>
</div>

<div class="module-nav">
  <div class="container">
    <ul>
      <li><a href="dashboard">Dashboard</a></li>
      <li><a href="new-booking">New Booking</a></li>
      <li><a href="all-bookings">All Bookings</a></li>
      <li><a href="rooms-rates">Rooms &amp; Rates</a></li>
      <li><a href="add-renter" class="active">Add A Renter</a></li>
    </ul>
  </div>
</div>

<div class="container">
  <div class="card">
    <h2>New renter</h2>
    <div class="card-sub">This becomes selectable on the New Booking page immediately.</div>
    <div class="field-row">
      <div class="field"><label>Contact name</label><input type="text" id="f-name" placeholder="Jane Doe"></div>
      <div class="field"><label>Phone</label><input type="tel" id="f-phone" placeholder="555-555-5555"></div>
    </div>
    <div class="field-row">
      <div class="field"><label>Email</label><input type="email" id="f-email" placeholder="jane@example.com"></div>
      <div class="field"><label>Organization (optional)</label><input type="text" id="f-org" placeholder="e.g. a company or community group"></div>
    </div>
    <div class="field" style="position:relative;">
      <label>Street address</label>
      <input type="text" id="f-street" placeholder="Start typing an address…" autocomplete="off">
      <div class="autocomplete-list" id="street-autocomplete-list" style="display:none;"></div>
    </div>
    <div class="field-row">
      <div class="field"><label>Suite / Apartment # (optional)</label><input type="text" id="f-suite" placeholder="e.g. Suite 200"></div>
      <div class="field"><label>City</label><input type="text" id="f-city"></div>
    </div>
    <div class="field-row">
      <div class="field"><label>State</label><input type="text" id="f-state" placeholder="OH"></div>
      <div class="field"><label>ZIP</label><input type="text" id="f-zip"></div>
    </div>
    <div class="field"><label>Notes (optional)</label><textarea id="f-notes" placeholder="Anything worth remembering about this contact"></textarea></div>
    <div class="checkbox-row" style="display:flex;align-items:center;gap:8px;margin-bottom:14px;"><input type="checkbox" id="f-nonprofit"><label for="f-nonprofit">This renter is a nonprofit — applicable discount will be applied automatically on bookings</label></div>
    <button type="button" class="btn-primary" id="btn-add-renter">Save renter</button>
    <div class="result-box" id="result-box" style="display:none;"></div>
  </div>

  <div class="card">
    <h2>Renters</h2>
    <div class="status-tabs" id="status-tabs">
      <button data-status="pending" class="active">Pending review</button>
      <button data-status="approved">Approved</button>
      <button data-status="rejected">Rejected</button>
      <button data-status="">All</button>
    </div>
    <div class="toolbar">
      <input type="text" id="search-input" placeholder="Search by name, email, or organization…">
    </div>
    <table>
      <thead><tr><th>Contact</th><th>Email</th><th>Phone</th><th>Organization</th><th>Status</th><th></th></tr></thead>
      <tbody id="renters-tbody"></tbody>
    </table>
    <div class="empty-state" id="empty-state" style="display:none;">No renters here.</div>
  </div>
</div>

</div>

<div class="modal-overlay" id="edit-renter-modal-overlay" style="display:none;">
  <div class="modal-panel">
    <div class="modal-header">
      <h2>Edit renter</h2>
      <button class="modal-close" id="btn-close-edit-renter">&times;</button>
    </div>
    <div class="modal-body">
      <div class="field"><label>Contact name</label><input type="text" id="edit-f-name"></div>
      <div class="field-row">
        <div class="field"><label>Phone</label><input type="tel" id="edit-f-phone"></div>
        <div class="field"><label>Email</label><input type="email" id="edit-f-email"></div>
      </div>
      <div class="field"><label>Organization</label><input type="text" id="edit-f-org"></div>
      <div class="field"><label>Address</label><input type="text" id="edit-f-address"></div>
      <div class="field"><label>Notes</label><textarea id="edit-f-notes"></textarea></div>
      <div class="checkbox-row" style="display:flex;align-items:center;gap:8px;"><input type="checkbox" id="edit-f-nonprofit"><label for="edit-f-nonprofit">This renter is a nonprofit</label></div>
      <div class="result-box" id="edit-result-box" style="display:none;"></div>
    </div>
    <div class="modal-footer">
      <button type="button" class="btn-secondary" id="btn-cancel-edit-renter">Close</button>
      <button type="button" class="btn-primary" id="btn-save-edit-renter" style="margin-top:0;">Save changes</button>
    </div>
  </div>
</div>

<div id="site-footer"></div>

<script>
const API_BASE = 'https://facility-rental-api-217911937447.us-central1.run.app';

async function authedFetch(url, options) {
  options = options || {};
  var user = window.__hccgcFirebaseUser;
  if (!user) throw new Error('Not signed in.');
  var token = await user.getIdToken();
  options.headers = Object.assign({}, options.headers, { 'Authorization': 'Bearer ' + token });
  return fetch(url, options);
}

let RENTERS = [];
let statusFilter = 'pending';

function escHtml(str) { return String(str || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;'); }

async function loadRenters() {
  try {
    const res = await authedFetch(API_BASE + '/renters?all=true');
    if (!res.ok) throw new Error('Server returned ' + res.status);
    RENTERS = await res.json();
  } catch (err) {
    RENTERS = [];
  }
  renderRenters();
}

function renderRenters() {
  const q = document.getElementById('search-input').value.trim().toLowerCase();
  const filtered = RENTERS.filter(function (r) {
    if (statusFilter && (r.status || 'approved') !== statusFilter) return false;
    if (!q) return true;
    return (r.contact_name || '').toLowerCase().includes(q) ||
           (r.email || '').toLowerCase().includes(q) ||
           (r.organization_name || '').toLowerCase().includes(q);
  });
  const tbody = document.getElementById('renters-tbody');
  const emptyState = document.getElementById('empty-state');
  if (filtered.length === 0) {
    tbody.innerHTML = '';
    emptyState.style.display = 'block';
    return;
  }
  emptyState.style.display = 'none';
  tbody.innerHTML = filtered.map(function (r) {
    const status = r.status || 'approved';
    const actions = [];
    if (status === 'pending') {
      actions.push('<button type="button" class="btn-small btn-approve" onclick="approveRenterAction(\'' + r.renter_id + '\')">Approve</button>');
      actions.push('<button type="button" class="btn-small btn-reject" onclick="rejectRenterAction(\'' + r.renter_id + '\')">Reject</button>');
    } else if (status === 'approved') {
      actions.push('<button type="button" class="btn-small btn-reject" onclick="rejectRenterAction(\'' + r.renter_id + '\')">Reject</button>');
    } else if (status === 'rejected') {
      actions.push('<button type="button" class="btn-small btn-approve" onclick="approveRenterAction(\'' + r.renter_id + '\')">Approve</button>');
    }
    actions.push('<button type="button" class="btn-small btn-edit-renter" onclick="openEditRenterModal(\'' + r.renter_id + '\')">Edit</button>');
    return '<tr>' +
      '<td>' + escHtml(r.contact_name) + '</td>' +
      '<td>' + escHtml(r.email) + '</td>' +
      '<td>' + escHtml(r.phone) + '</td>' +
      '<td>' + escHtml(r.organization_name) + '</td>' +
      '<td><span class="status-badge ' + status + '">' + status.charAt(0).toUpperCase() + status.slice(1) + '</span></td>' +
      '<td style="white-space:nowrap;">' + actions.join('') + '</td>' +
    '</tr>';
  }).join('');
}
document.getElementById('search-input').addEventListener('input', renderRenters);
document.getElementById('status-tabs').addEventListener('click', function (e) {
  if (e.target.tagName !== 'BUTTON') return;
  statusFilter = e.target.dataset.status;
  document.querySelectorAll('#status-tabs button').forEach(function (b) { b.classList.toggle('active', b === e.target); });
  renderRenters();
});

async function approveRenterAction(renterId) {
  try {
    const res = await authedFetch(API_BASE + '/renters/' + encodeURIComponent(renterId) + '/approve', { method: 'POST' });
    const data = await res.json();
    if (!res.ok) { alert('Could not approve: ' + ((data.errors || [data.error]).join(' ') || 'unknown error')); return; }
    await loadRenters();
  } catch (err) {
    alert('Could not reach the server: ' + err.message);
  }
}
async function rejectRenterAction(renterId) {
  const reason = prompt('Reason for rejecting this renter? This will be emailed to them.');
  if (reason === null) return; // cancelled
  if (!reason.trim()) { alert('A reason is required.'); return; }
  try {
    const res = await authedFetch(API_BASE + '/renters/' + encodeURIComponent(renterId) + '/reject', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ reason })
    });
    const data = await res.json();
    if (!res.ok) { alert('Could not reject: ' + ((data.errors || [data.error]).join(' ') || 'unknown error')); return; }
    await loadRenters();
  } catch (err) {
    alert('Could not reach the server: ' + err.message);
  }
}

let editingRenterId = null;
function openEditRenterModal(renterId) {
  const r = RENTERS.find(function (x) { return x.renter_id === renterId; });
  if (!r) return;
  editingRenterId = renterId;
  document.getElementById('edit-f-name').value = r.contact_name || '';
  document.getElementById('edit-f-phone').value = r.phone || '';
  document.getElementById('edit-f-email').value = r.email || '';
  document.getElementById('edit-f-org').value = r.organization_name || '';
  document.getElementById('edit-f-address').value = r.address || '';
  document.getElementById('edit-f-notes').value = r.notes || '';
  document.getElementById('edit-f-nonprofit').checked = !!r.is_nonprofit;
  document.getElementById('edit-result-box').style.display = 'none';
  document.getElementById('edit-renter-modal-overlay').style.display = 'flex';
}
function closeEditRenterModal() { document.getElementById('edit-renter-modal-overlay').style.display = 'none'; }
document.getElementById('btn-close-edit-renter').addEventListener('click', closeEditRenterModal);
document.getElementById('btn-cancel-edit-renter').addEventListener('click', closeEditRenterModal);
document.getElementById('edit-renter-modal-overlay').addEventListener('click', function (e) { if (e.target === this) closeEditRenterModal(); });

document.getElementById('btn-save-edit-renter').addEventListener('click', async function () {
  const btn = this;
  const resultBox = document.getElementById('edit-result-box');
  const payload = {
    contactName: document.getElementById('edit-f-name').value,
    phone: document.getElementById('edit-f-phone').value,
    email: document.getElementById('edit-f-email').value,
    organizationName: document.getElementById('edit-f-org').value,
    address: document.getElementById('edit-f-address').value,
    notes: document.getElementById('edit-f-notes').value,
    isNonprofit: document.getElementById('edit-f-nonprofit').checked
  };
  btn.disabled = true; btn.textContent = 'Saving…';
  try {
    const res = await authedFetch(API_BASE + '/renters/' + encodeURIComponent(editingRenterId), {
      method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload)
    });
    const data = await res.json();
    resultBox.style.display = 'block';
    if (!res.ok) {
      resultBox.className = 'result-box error';
      resultBox.textContent = (data.errors || [data.error || 'Something went wrong.']).join(' ');
    } else {
      resultBox.className = 'result-box success';
      resultBox.textContent = 'Saved.';
      await loadRenters();
      setTimeout(closeEditRenterModal, 900);
    }
  } catch (err) {
    resultBox.style.display = 'block'; resultBox.className = 'result-box error';
    resultBox.textContent = 'Could not reach the server: ' + err.message;
  } finally {
    btn.disabled = false; btn.textContent = 'Save changes';
  }
});

function showResult(type, message) {
  const box = document.getElementById('result-box');
  box.style.display = 'block';
  box.className = 'result-box ' + type;
  box.textContent = message;
}

document.getElementById('btn-add-renter').addEventListener('click', async function () {
  const btn = this;
  const addressParts = [
    document.getElementById('f-street').value,
    document.getElementById('f-suite').value,
    document.getElementById('f-city').value && document.getElementById('f-state').value
      ? (document.getElementById('f-city').value + ', ' + document.getElementById('f-state').value + ' ' + document.getElementById('f-zip').value)
      : document.getElementById('f-city').value
  ].filter(Boolean).join(', ');
  const payload = {
    contactName: document.getElementById('f-name').value,
    phone: document.getElementById('f-phone').value,
    email: document.getElementById('f-email').value,
    organizationName: document.getElementById('f-org').value,
    address: addressParts,
    notes: document.getElementById('f-notes').value,
    isNonprofit: document.getElementById('f-nonprofit').checked
  };
  if (!payload.contactName) { showResult('error', 'Contact name is required.'); return; }

  btn.disabled = true; btn.textContent = 'Saving…';
  try {
    const res = await authedFetch(API_BASE + '/renters', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (!res.ok) {
      showResult('error', (data.errors || [data.error || 'Something went wrong.']).join(' '));
    } else {
      showResult('success', payload.contactName + ' saved — selectable on New Booking now.');
      ['f-name','f-phone','f-email','f-org','f-street','f-suite','f-city','f-state','f-zip','f-notes'].forEach(function (id) { document.getElementById(id).value = ''; });
      document.getElementById('f-nonprofit').checked = false;
      await loadRenters();
    }
  } catch (err) {
    showResult('error', 'Could not reach the server: ' + err.message);
  } finally {
    btn.disabled = false; btn.textContent = 'Save renter';
  }
});

// ---- Address autocomplete ----
// Uses Google Places Autocomplete if a Maps API key is configured below;
// otherwise the fields just work as plain manual entry, no error, no
// broken UI — autocomplete is a nice-to-have layered on top, not a
// requirement for the fields to function.
const GOOGLE_MAPS_API_KEY = ''; // <-- add a Maps JavaScript API key (with Places enabled) here to turn on autocomplete

if (GOOGLE_MAPS_API_KEY) {
  const script = document.createElement('script');
  script.src = 'https://maps.googleapis.com/maps/api/js?key=' + GOOGLE_MAPS_API_KEY + '&libraries=places&callback=initAddressAutocomplete';
  script.async = true;
  document.head.appendChild(script);
}
window.initAddressAutocomplete = function () {
  const input = document.getElementById('f-street');
  const autocomplete = new google.maps.places.Autocomplete(input, { types: ['address'], componentRestrictions: { country: 'us' } });
  autocomplete.addListener('place_changed', function () {
    const place = autocomplete.getPlace();
    if (!place.address_components) return;
    let streetNumber = '', route = '', city = '', state = '', zip = '';
    place.address_components.forEach(function (c) {
      if (c.types.includes('street_number')) streetNumber = c.long_name;
      if (c.types.includes('route')) route = c.long_name;
      if (c.types.includes('locality')) city = c.long_name;
      if (c.types.includes('administrative_area_level_1')) state = c.short_name;
      if (c.types.includes('postal_code')) zip = c.long_name;
    });
    document.getElementById('f-street').value = (streetNumber + ' ' + route).trim();
    document.getElementById('f-city').value = city;
    document.getElementById('f-state').value = state;
    document.getElementById('f-zip').value = zip;
  });
};

function loadPartial(id, file) {
  var target = document.getElementById(id);
  if (!target) return;
  fetch(file).then(function (r) { return r.text(); }).then(function (html) {
    target.innerHTML = html;
    if (id === 'site-header') fixHeaderLinksForSubfolder(target);
  }).catch(function () {});
}
function fixHeaderLinksForSubfolder(headerEl) {
  var logo = headerEl.querySelector('.brand-logo');
  if (logo && logo.getAttribute('src') && !logo.getAttribute('src').startsWith('/') && !logo.getAttribute('src').startsWith('http')) {
    logo.setAttribute('src', '/' + logo.getAttribute('src'));
  }
  headerEl.querySelectorAll('a[href]').forEach(function (link) {
    var href = link.getAttribute('href');
    if (!href || href.startsWith('http') || href.startsWith('/') || href.startsWith('#')) return;
    link.setAttribute('href', '/' + href);
  });
}
loadPartial('site-header', '/header.html');
loadPartial('site-footer', '/footer.html');
</script>


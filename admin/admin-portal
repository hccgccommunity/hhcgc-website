// POST /bookings/:id/unlink-payment — reverts a mistaken match back to
// whatever the booking's status was before (invoiced if an invoice had
// already gone out, pending otherwise).
async function unlinkPayment(req, res, bookingId, actor) {
  const [rows] = await bigquery.query({
    query: `SELECT invoice_sent_at, event_date, created_by FROM \`${DATASET}.bookings\` WHERE booking_id = @bookingId`,
    params: { bookingId }
  });
  if (!rows.length) return res.status(404).json({ errors: ['Booking not found.'] });
  const row = rows[0];
  const eventDateStr = (row.event_date && row.event_date.value) || row.event_date;
  const isPast = new Date(eventDateStr + 'T00:00:00') < new Date(new Date().toDateString());
  if (isPast && !isSuperAdmin(actor.email)) {
    return res.status(403).json({ errors: ['This booking has already happened — only tech-admin@hccgc.org can unlink a payment on a past booking.'] });
  }
  const revertStatus = row.invoice_sent_at ? 'invoiced' : 'pending';
  await bigquery.query({
    query: `UPDATE \`${DATASET}.bookings\` SET payment_status = @status, payment_method = NULL, paid_by = NULL,
            payment_match_source = NULL, payment_match_id = NULL, payment_match_details = NULL, payment_date = NULL, updated_at = CURRENT_TIMESTAMP()
            WHERE booking_id = @bookingId`,
    params: { status: revertStatus, bookingId }
  });
  await logAudit({ action: 'payment_unlinked', entityType: 'booking', entityId: bookingId, actorEmail: actor.email, details: {} });
  res.json({ bookingId, paymentStatus: revertStatus });
}


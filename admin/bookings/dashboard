<style>
:root {
  --bg: #fff9f1; --surface: #ffffff; --surface-soft: #fff6ea; --border: rgba(121,62,17,0.14);
  --text: #2c1b10; --muted: #6a5141; --saffron: #b55a18; --saffron-dark: #8d3e0d; --maroon: #7f2e16;
  --radius: 22px; --shadow: 0 18px 45px rgba(93,43,14,0.10);
  --green: #2e7d4f; --green-bg: #e8f5ec; --amber: #a15c00; --amber-bg: #fdf1de; --grey-bg: #f1ede8;
  --red: #b3382c; --red-bg: #fbe9e7;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: Arial, Helvetica, sans-serif; background: radial-gradient(circle at top left, rgba(217,138,30,0.12), transparent 22%), radial-gradient(circle at top right, rgba(127,46,22,0.05), transparent 20%), var(--bg); color: var(--text); min-height: 100vh; }
.container { width: min(calc(100% - 32px), 1200px); margin: 0 auto; }
.site-header { position: sticky; top: 0; z-index: 50; background: rgba(255, 249, 241, 0.92); backdrop-filter: blur(10px); border-bottom: 1px solid var(--border); }
.nav { display: flex; align-items: center; justify-content: space-between; gap: 24px; min-height: 92px; padding: 12px 0; }
.site-header a.brand, .site-header a.brand:link, .site-header a.brand:visited { text-decoration: none; color: inherit; }
.brand { display: flex; align-items: center; gap: 16px; min-width: 0; }
.brand-logo-wrap { background: #fff; border: 1px solid var(--border); border-radius: 18px; padding: 8px; box-shadow: var(--shadow); flex-shrink: 0; }
.brand-logo { width: 88px; height: auto; border-radius: 12px; object-fit: contain; }
.brand-text h1 { margin: 0; font-size: 1.2rem; line-height: 1.15; color: var(--maroon); }
.site-header nav ul { list-style: none; display: flex; flex-wrap: wrap; gap: 18px; margin: 0; padding: 0; align-items: center; justify-content: flex-end; }
.site-header nav a, .site-header nav a:link, .site-header nav a:visited { font-weight: 700; color: var(--text); font-size: 0.96rem; text-decoration: none; }
.site-header nav a:hover { color: var(--saffron-dark); }
.menu-toggle { display: none; border: 0; background: transparent; padding: 6px 0; cursor: pointer; color: #2c1b10; align-self: flex-end; }
.menu-toggle .bar { display: block; width: 26px; height: 2px; margin: 5px 0; background: currentColor; }
@media (max-width: 768px) {
  .nav { flex-direction: column; align-items: stretch; gap: 8px; } .menu-toggle { display: inline-block; }
  .site-header nav { display: none; width: 100%; background: rgba(255,249,241,0.95); padding: 10px 0; }
  .site-header nav.is-open { display: block; } .site-header nav ul { flex-direction: column; gap: 14px; }
}
.page-hero { padding: 28px 0 22px; background: linear-gradient(135deg, var(--maroon) 0%, #4e1a09 100%); color: #fff; }
.page-hero h1 { font-family: Georgia, "Times New Roman", serif; font-size: 1.9rem; color: #fff; margin-bottom: 6px; }
.page-hero p { color: #ffffff; opacity: 0.9; font-size: 0.92rem; max-width: 620px; }
.back-link { display: inline-flex; align-items: center; gap: 6px; font-size: 0.82rem; font-weight: 700; color: rgba(255,255,255,0.85); text-decoration: none; margin-bottom: 14px; }
.back-link:hover { color: #fff; text-decoration: underline; }
.eyebrow { font-size: 0.78rem; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; color: rgba(255,255,255,0.75); margin-bottom: 6px; }
.module-nav { background: var(--surface); border-bottom: 1px solid var(--border); }
.module-nav ul { list-style: none; display: flex; gap: 4px; padding: 10px 0; flex-wrap: wrap; }
.module-nav a { display: inline-block; padding: 8px 16px; border-radius: 999px; font-size: 0.86rem; font-weight: 700; color: var(--muted); text-decoration: none; }
.module-nav a.active { background: var(--surface-soft); color: var(--saffron-dark); }
.module-nav a:not(.active):hover { background: var(--surface-soft); }

.card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 22px; box-shadow: var(--shadow); }
.toolbar { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; margin-bottom: 20px; }
.toolbar select, .toolbar input[type="date"] { font-family: inherit; font-size: 0.88rem; padding: 9px 12px; border: 1.5px solid var(--border); border-radius: 10px; background: #fff; color: var(--text); }
.btn-secondary { font-family: inherit; font-size: 0.86rem; font-weight: 700; color: var(--text); background: #fff; border: 1.5px solid var(--border); border-radius: 10px; padding: 9px 14px; cursor: pointer; }

.stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 14px; margin-bottom: 20px; }
.stat-card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 18px; text-align: center; box-shadow: var(--shadow); }
.stat-card .value { font-size: 1.6rem; font-weight: 800; color: var(--maroon); }
.stat-card .label { font-size: 0.76rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.03em; margin-top: 4px; }

.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
@media (max-width: 900px) { .grid-2 { grid-template-columns: 1fr; } }
.section-title { font-family: Georgia, "Times New Roman", serif; color: var(--maroon); margin-bottom: 14px; font-size: 1.05rem; }

.bar-chart-row { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
.bar-chart-label { width: 140px; flex-shrink: 0; font-size: 0.84rem; font-weight: 700; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.bar-chart-track { flex: 1; background: var(--surface-soft); border-radius: 8px; height: 24px; position: relative; overflow: hidden; }
.bar-chart-fill { height: 100%; border-radius: 8px; background: linear-gradient(90deg, var(--saffron-dark), var(--saffron)); }
.bar-chart-value { width: 100px; flex-shrink: 0; text-align: right; font-weight: 700; font-size: 0.84rem; }

.contributor-row { display: flex; justify-content: space-between; align-items: center; padding: 9px 0; border-bottom: 1px solid var(--border); font-size: 0.86rem; }
.contributor-row:last-child { border-bottom: none; }
.contributor-row .rank { width: 22px; color: var(--muted); font-weight: 700; }
.contributor-row .name { flex: 1; }
.contributor-row .meta { color: var(--muted); font-size: 0.76rem; }
.contributor-row .amount { font-weight: 700; }
.empty-state { text-align: center; padding: 30px 20px; color: var(--muted); }

#gate{padding:60px 16px;display:flex;justify-content:center;}
.gate-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:2.5rem 2rem;max-width:420px;width:100%;text-align:center;box-shadow:var(--shadow);}
.gate-card h3{font-family:Georgia,serif;font-size:1.3rem;color:var(--maroon);margin-bottom:.5rem;}
.gate-card p{color:var(--muted);font-size:.88rem;line-height:1.6;}
.gate-card a{color:var(--saffron-dark);}
</style>
</head>
<body>
<div id="site-header"></div>

<div id="gate">
  <div class="gate-card">
    <h3>Checking access&hellip;</h3>
    <p>Please sign in from the <a href="/admin/admin-portal">Admin Portal</a> first.</p>
  </div>
</div>

<div id="app" style="display:none;">

<div class="page-hero">
  <div class="container">
    <a class="back-link" href="https://hccgc.org/admin/admin-portal">&larr; Back to apps</a>
    <div class="eyebrow">Facility Bookings</div>
    <h1>Dashboard</h1>
    <p>Booking activity — what's being rented, how much, and by whom. For cash position and accounting, see the Finance dashboard.</p>
  </div>
</div>

<div class="module-nav">
  <div class="container">
    <ul>
      <li><a href="dashboard" class="active">Dashboard</a></li>
      <li><a href="new-booking">New Booking</a></li>
      <li><a href="all-bookings">All Bookings</a></li>
      <li><a href="rooms-rates">Rooms &amp; Rates</a></li>
      <li><a href="add-renter">Add A Renter</a></li>
    </ul>
  </div>
</div>

<div class="container" style="padding:24px 0 60px;">
  <div class="card" style="margin-bottom:20px;">
    <h2 class="section-title">Revenue by month</h2>
    <p class="card-sub" style="margin:-8px 0 14px;">Always the trailing 12 months, this month, and the next 6 — paid and unpaid, not affected by the filters below.</p>
    <div id="revenue-by-month"></div>
  </div>

  <div class="toolbar">
    <select id="dash-range-preset">
      <option value="last3months" selected>Last 3 months</option>
      <option value="thismonth">This month</option>
      <option value="thisquarter">This quarter</option>
      <option value="lastmonth">Last month</option>
      <option value="lastquarter">Last quarter</option>
      <option value="thisyear">This year</option>
      <option value="custom">Custom</option>
    </select>
    <input type="date" id="dash-start-date" style="display:none;">
    <input type="date" id="dash-end-date" style="display:none;">
    <button type="button" class="btn-secondary" id="btn-refresh-dashboard">Refresh</button>
    <select id="dash-source-filter">
      <option value="facility-rental" selected>Facility Rental Revenue</option>
      <option value="fundraising">Fundraising Revenue</option>
      <option value="all">All (Facility Rental + Fundraising)</option>
    </select>
    <span style="font-size:0.78rem;color:var(--muted);">Individual donations aren't included in any of these views.</span>
  </div>

  <div class="stat-grid" id="stat-grid"></div>

  <div class="grid-2">
    <div class="card">
      <h2 class="section-title">Revenue by room</h2>
      <p class="card-sub" style="margin:-8px 0 14px;">Always facility rental, regardless of the filter above.</p>
      <div id="revenue-by-room"></div>
    </div>
    <div class="card">
      <h2 class="section-title" id="second-chart-title">Top renters</h2>
      <div id="second-chart"></div>
    </div>
  </div>
</div>

</div>

<div id="site-footer"></div>

<script>
const API_BASE = 'https://facility-rental-api-217911937447.us-central1.run.app';

async function authedFetch(url, options) {
  options = options || {};
  var user = window.__hccgcFirebaseUser;
  if (!user) throw new Error('Not signed in.');
  var token = await user.getIdToken();
  options.headers = Object.assign({}, options.headers, { 'Authorization': 'Bearer ' + token });
  return fetch(url, options);
}
function escHtml(str) { return String(str || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;'); }
function money(n) { return '$' + Math.round(Number(n)).toLocaleString('en-US'); }

function computePresetRange(preset) {
  var now = new Date();
  var fmt = function (d) { return d.toISOString().slice(0, 10); };
  var y = now.getFullYear(), m = now.getMonth();
  if (preset === 'thismonth') return { start: fmt(new Date(y, m, 1)), end: fmt(new Date(y, m + 1, 0)) };
  if (preset === 'lastmonth') return { start: fmt(new Date(y, m - 1, 1)), end: fmt(new Date(y, m, 0)) };
  if (preset === 'thisquarter') { var qs = Math.floor(m / 3) * 3; return { start: fmt(new Date(y, qs, 1)), end: fmt(new Date(y, qs + 3, 0)) }; }
  if (preset === 'lastquarter') { var qs2 = Math.floor(m / 3) * 3 - 3; return { start: fmt(new Date(y, qs2, 1)), end: fmt(new Date(y, qs2 + 3, 0)) }; }
  if (preset === 'thisyear') return { start: fmt(new Date(y, 0, 1)), end: fmt(new Date(y, 11, 31)) };
  return { start: fmt(new Date(y, m - 2, 1)), end: fmt(new Date(y, m + 1, 0)) };
}
(function initDates() {
  var range = computePresetRange('last3months');
  document.getElementById('dash-start-date').value = range.start;
  document.getElementById('dash-end-date').value = range.end;
})();
document.getElementById('dash-range-preset').addEventListener('change', function () {
  var preset = this.value;
  var inputs = [document.getElementById('dash-start-date'), document.getElementById('dash-end-date')];
  if (preset === 'custom') { inputs.forEach(function (el) { el.style.display = 'inline-block'; }); return; }
  inputs.forEach(function (el) { el.style.display = 'none'; });
  var range = computePresetRange(preset);
  document.getElementById('dash-start-date').value = range.start;
  document.getElementById('dash-end-date').value = range.end;
  loadDashboard();
});
document.getElementById('btn-refresh-dashboard').addEventListener('click', loadDashboard);

async function loadDashboard() {
  var start = document.getElementById('dash-start-date').value;
  var end = document.getElementById('dash-end-date').value;
  var source = document.getElementById('dash-source-filter').value;
  try {
    var res = await authedFetch(API_BASE + '/bookings-dashboard?startDate=' + start + '&endDate=' + end + '&source=' + source);
    var data = await res.json();
    if (!res.ok) throw new Error((data.errors || [data.error || ('Server returned ' + res.status)]).join(' '));
    renderStats(data, source);
    renderBarChart('revenue-by-room', data.revenueByRoom.map(function (r) { return { name: r.name + ' (' + r.count + ')', total: r.revenue }; }), 'No room activity in this range.');
    var secondTitle = document.getElementById('second-chart-title');
    if (source === 'fundraising') {
      secondTitle.textContent = 'Revenue by campaign';
      renderBarChart('second-chart', data.revenueByCampaign.map(function (r) { return { name: r.name + ' (' + r.count + ')', total: r.revenue }; }), 'No fundraising activity in this range.');
    } else {
      secondTitle.textContent = 'Top renters';
      renderContributors('second-chart', data.topRenters, 'No renters in this range.');
    }
  } catch (err) {
    document.getElementById('stat-grid').innerHTML = '<div class="empty-state">Could not load dashboard: ' + escHtml(err.message) + '</div>';
  }
}
document.getElementById('dash-source-filter').addEventListener('change', loadDashboard);
async function loadMonthlyTrend() {
  try {
    var res = await authedFetch(API_BASE + '/bookings-monthly-trend');
    var data = await res.json();
    if (!res.ok) throw new Error((data.errors || [data.error || ('Server returned ' + res.status)]).join(' '));
    renderBarChart('revenue-by-month', data.months.map(function (m) {
      var label = new Date(m.month + '-02').toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
      return { name: label, total: m.revenue };
    }), 'No booking activity in this window.');
  } catch (err) {
    document.getElementById('revenue-by-month').innerHTML = '<div class="empty-state">Could not load: ' + escHtml(err.message) + '</div>';
  }
}
function renderStats(data, source) {
  var revenueLabel = source === 'fundraising' ? 'Fundraising Revenue' : source === 'all' ? 'Total Revenue' : 'Facility Rental Revenue';
  var countLabel = source === 'fundraising' ? 'Fundraising Payments' : 'Bookings';
  var stats = [
    { label: revenueLabel, value: money(data.totalRevenue) },
    { label: countLabel, value: data.totalCount },
    { label: 'Hours Booked (facility rental)', value: data.totalHours },
    { label: 'Avg. Value', value: money(data.avgValue) },
    { label: 'Paid (facility rental)', value: data.paidCount },
    { label: 'Not Yet Paid (facility rental)', value: data.unpaidCount }
  ];
  document.getElementById('stat-grid').innerHTML = stats.map(function (s) {
    return '<div class="stat-card"><div class="value">' + s.value + '</div><div class="label">' + s.label + '</div></div>';
  }).join('');
}
function renderBarChart(containerId, items, emptyMessage) {
  var container = document.getElementById(containerId);
  if (!items.length) { container.innerHTML = '<div class="empty-state">' + emptyMessage + '</div>'; return; }
  var max = Math.max.apply(null, items.map(function (i) { return i.total; }));
  container.innerHTML = items.map(function (i) {
    var pct = max > 0 ? Math.max(2, (i.total / max) * 100) : 0;
    return '<div class="bar-chart-row">' +
      '<div class="bar-chart-label" title="' + escHtml(i.name) + '">' + escHtml(i.name) + '</div>' +
      '<div class="bar-chart-track"><div class="bar-chart-fill" style="width:' + pct + '%;"></div></div>' +
      '<div class="bar-chart-value">' + money(i.total) + '</div>' +
    '</div>';
  }).join('');
}
function renderContributors(containerId, items, emptyMessage) {
  var container = document.getElementById(containerId);
  if (!items.length) { container.innerHTML = '<div class="empty-state">' + emptyMessage + '</div>'; return; }
  container.innerHTML = items.map(function (item, i) {
    return '<div class="contributor-row">' +
      '<span class="rank">' + (i + 1) + '</span>' +
      '<span class="name">' + escHtml(item.name) + ' <span class="meta">(' + item.count + ')</span></span>' +
      '<span class="amount">' + money(item.revenue) + '</span>' +
    '</div>';
  }).join('');
}

function loadPartial(id, file) {
  var target = document.getElementById(id);
  if (!target) return;
  fetch(file).then(function (r) { return r.text(); }).then(function (html) {
    target.innerHTML = html;
    if (id === 'site-header') fixHeaderLinksForSubfolder(target);
  }).catch(function () {});
}
function fixHeaderLinksForSubfolder(headerEl) {
  var logo = headerEl.querySelector('.brand-logo');
  if (logo && logo.getAttribute('src') && !logo.getAttribute('src').startsWith('/') && !logo.getAttribute('src').startsWith('http')) {
    logo.setAttribute('src', '/' + logo.getAttribute('src'));
  }
  headerEl.querySelectorAll('a[href]').forEach(function (link) {
    var href = link.getAttribute('href');
    if (!href || href.startsWith('http') || href.startsWith('/') || href.startsWith('#')) return;
    link.setAttribute('href', '/' + href);
  });
}
loadPartial('site-header', '/header.html');
loadPartial('site-footer', '/footer.html');
</script>

<script type="module">
import { initializeApp } from 'https://www.gstatic.com/firebasejs/12.15.0/firebase-app.js';
import { getAuth, onAuthStateChanged } from 'https://www.gstatic.com/firebasejs/12.15.0/firebase-auth.js';
import { getFirestore, doc, getDoc } from 'https://www.gstatic.com/firebasejs/12.15.0/firebase-firestore.js';

var firebaseConfig = {
  apiKey: 'AIzaSyA6IzLjWTg7Rq04HsTH-iA3eDmSzKI7xME',
  authDomain: 'hccgc-a7a54.firebaseapp.com',
  projectId: 'hccgc-a7a54',
  storageBucket: 'hccgc-a7a54.firebasestorage.app',
  messagingSenderId: '75757201418',
  appId: '1:75757201418:web:c31e9361921242145717f3'
};

var ALLOWED_DOMAIN = 'hccgc.org';
var REQUIRED_APP_KEY = 'bookings-finance';
var PORTAL_URL = '/admin/admin-portal';

var fbApp = initializeApp(firebaseConfig);
var auth = getAuth(fbApp);
var db = getFirestore(fbApp);

function showGate(title, msg) {
  document.getElementById('gate').querySelector('h3').textContent = title;
  document.getElementById('gate').querySelector('p').innerHTML = msg;
  document.getElementById('gate').style.display = 'flex';
  document.getElementById('app').style.display = 'none';
}

onAuthStateChanged(auth, function(user) {
  if (!user) { showGate('Sign in required', 'Please sign in from the <a href="'+PORTAL_URL+'">Admin Portal</a> first.'); return; }
  var email = (user.email||'').toLowerCase();
  window.__hccgcCurrentUser = { email: email };
  window.__hccgcFirebaseUser = user;
  if (!email.endsWith('@'+ALLOWED_DOMAIN)) { showGate('Access denied', 'Please use an @'+ALLOWED_DOMAIN+' account.'); return; }
  getDoc(doc(db, 'portalUsers', email)).then(function(snap) {
    var data = snap.exists() ? snap.data() : {};
    if (!data.isAdmin && !(Array.isArray(data.allowedApps) && data.allowedApps.includes(REQUIRED_APP_KEY))) {
      showGate('Access not granted', "You don't have access to Facility Bookings. Ask an admin to grant it.");
      return;
    }
    document.getElementById('gate').style.display = 'none';
    document.getElementById('app').style.display = 'block';
    loadDashboard();
    loadMonthlyTrend();
  }).catch(function() { showGate('Error', 'Could not verify access. Please try again.'); });
});
</script>
</body>
</html>

async function selectExpenseLineItem(lineItemId) {
  currentReviewLineItemId = lineItemId;
  document.querySelectorAll('.exp-line-item').forEach(function (el) { el.classList.toggle('active', el.dataset.lineId === lineItemId); });
  const receiptBox = document.getElementById('exp-review-receipt');
  receiptBox.innerHTML = '<span style="color:var(--muted);font-size:0.86rem;">Loading receipt…</span>';
  try {
    const res = await authedFetch(API_BASE + '/finance/expense-receipt-url/' + encodeURIComponent(lineItemId));
    const data = await res.json();
    if (!data.url) { receiptBox.innerHTML = '<span style="color:var(--muted);font-size:0.86rem;">No receipt on file.</span>'; return; }
    // Drive's "open?id=" link is a viewer page, not a raw file stream — it
    // can't be embedded as an <img src>, so this always opens in a new tab
    // rather than trying (and failing) to show it inline.
    receiptBox.innerHTML = '<a href="' + data.url + '" target="_blank" rel="noopener" style="color:var(--saffron-dark);font-weight:700;font-size:1rem;">📄 Open receipt in Google Drive &rarr;</a>';
  } catch (err) {
    receiptBox.innerHTML = '<span style="color:var(--red);font-size:0.86rem;">Could not load receipt: ' + escHtml(err.message) + '</span>';
  }
}


// POST /bookings
// Body always carries an explicit `occurrences` array: [{ date, startTime, endTime }, ...].
// A one-off booking is just a one-item array — this keeps a single code path
// for both cases and lets each occurrence in a recurring series have its own
// time (needed now that daily/variable-time series are supported).
async function createBooking(req, res, actor) {
  const b = req.body || {};
  const isInternal = !!b.isInternal;
  const errors = [];
  if (!Array.isArray(b.rooms) || b.rooms.length === 0) errors.push('Select at least one room.');
  if (isInternal) {
    if (!b.renterName) errors.push('Program/event name is required.');
    if (!b.hccgcRepresentativeName) errors.push('HCCGC representative name is required for internal bookings.');
    if (!b.notes) errors.push('A description is required for internal bookings.');
  } else {
    if (!b.renterId) errors.push('Please select a renter from the directory.');
    if (!b.eventName) errors.push('Event name is required.');
  }
  // Internal bookings already capture this via "Program / event name" — no
  // separate field needed there, just reuse it so event_name is populated
  // consistently for every booking either way.
  const eventName = isInternal ? b.renterName : b.eventName;
  if (!isInternal && b.manualAdjustmentType && !b.manualAdjustmentReason) errors.push('A reason is required for a discretionary discount.');
  if (Array.isArray(b.rooms) && b.rooms.includes('Kitchen') && !b.rooms.includes('Surya Hall') && !b.rooms.includes('Patanjali Hall')) {
    errors.push('Kitchen can only be booked together with Surya Hall or Patanjali Hall.');
  }
  if (!Array.isArray(b.occurrences) || b.occurrences.length === 0) errors.push('At least one date/time is required.');
  else {
    const today = new Date(new Date().toDateString());
    b.occurrences.forEach((occ, i) => {
      if (!occ.date || !occ.startTime || !occ.endTime) errors.push(`Occurrence ${i + 1} is missing a date or time.`);
      else if (occurrenceHours(occ) <= 0) errors.push(`Occurrence ${i + 1}: end time must be after start time.`);
      else if (new Date(occ.date + 'T00:00:00') < today && !isSuperAdmin(actor.email)) {
        errors.push(`Occurrence ${i + 1} (${occ.date}) is in the past — only tech-admin@hccgc.org can create backdated bookings, for record-keeping purposes.`);
      }
    });
  }
  if (errors.length) return res.status(400).json({ errors });

  const roomsList = await getActiveRooms();
  const roomsMap = {};
  roomsList.forEach(r => { roomsMap[r.name] = r; });
  const unknownRooms = b.rooms.filter(r => !roomsMap[r]);
  if (unknownRooms.length) return res.status(400).json({ errors: [`Unknown or inactive room(s): ${unknownRooms.join(', ')}`] });

  // Conflict check — one query per occurrence, since each can have its own time.
  // Nothing gets created if ANY occurrence conflicts (all-or-nothing for the series).
  const conflictMessages = [];
  for (const occ of b.occurrences) {
    const [conflicts] = await bigquery.query({
      query: `SELECT booking_id, renter_name FROM \`${DATASET}.bookings\`
              WHERE event_date = @date AND payment_status != 'cancelled'
                AND start_time < @endTime AND end_time > @startTime
                AND EXISTS (SELECT 1 FROM UNNEST(rooms) rm WHERE rm IN UNNEST(@rooms))`,
      params: { date: occ.date, startTime: `${occ.date} ${occ.startTime}:00`, endTime: `${occ.date} ${occ.endTime}:00`, rooms: b.rooms },
      types: { rooms: ['STRING'] }
    });
    if (conflicts.length) conflictMessages.push(`${occ.date} ${occ.startTime}-${occ.endTime} conflicts with an existing booking (${conflicts[0].renter_name})`);
  }
  if (conflictMessages.length) return res.status(409).json({ errors: conflictMessages });

  const rules = await getDiscountRules();
  const isSeries = b.occurrences.length > 1;
  const seriesId = isSeries ? randomUUID() : null;
  const recurrenceSummary = isSeries ? `${b.occurrences.length} occurrences` : null;

  // Non-internal bookings must reference an existing renter — the contact's
  // name/email/phone/address/organization come from the renters table
  // itself, not from anything the client sent, so a stale or tampered
  // client value can never diverge from the actual directory record.
  let renterId = null;
  let renterFields = { renterName: b.renterName, renterEmail: b.renterEmail, renterPhone: b.renterPhone, renterAddress: b.renterAddress, organizationName: b.organizationName };
  if (!isInternal) {
    const [renterRows] = await bigquery.query({
      query: `SELECT renter_id, contact_name, email, phone, address, organization_name FROM \`${DATASET}.renters\` WHERE renter_id = @renterId`,
      params: { renterId: b.renterId }
    });
    if (!renterRows.length) return res.status(400).json({ errors: ['Selected renter was not found — they may have been removed. Please pick again.'] });
    renterId = renterRows[0].renter_id;
    renterFields = {
      renterName: renterRows[0].contact_name, renterEmail: renterRows[0].email, renterPhone: renterRows[0].phone,
      renterAddress: renterRows[0].address, organizationName: renterRows[0].organization_name
    };
  }

  const displayName = isInternal ? b.renterName : renterFields.renterName;
  const createdBookingIds = [];
  const allSyncErrors = [];
  let totalFinal = 0;

  for (const occ of b.occurrences) {
    const hours = occurrenceHours(occ);
    let baseTotal = 0, mult = 1, subtotal = 0, finalTotal = 0;
    if (!isInternal) {
      const priced = computeOccurrencePricing(b.rooms, roomsMap, hours, occ.date, !!b.isNonprofit, rules);
      baseTotal = priced.baseTotal; mult = priced.mult; subtotal = priced.subtotal;
      finalTotal = applyManualAdjustment(subtotal, b.manualAdjustmentType, b.manualAdjustmentValue);
    }
    totalFinal += finalTotal;

    const { eventIds, syncErrors } = await syncOccurrenceToCalendar({
      rooms: b.rooms, roomsMap, occ, renterName: displayName, seriesLabel: isSeries ? recurrenceSummary : null
    });
    allSyncErrors.push(...syncErrors);

    const bookingId = 'HCC-' + randomUUID().slice(0, 8);
    createdBookingIds.push(bookingId);

    await bigquery.query({
      query: `INSERT INTO \`${DATASET}.bookings\`
        (booking_id, rooms, renter_id, renter_name, renter_email, renter_phone, renter_address, organization_name, hccgc_representative_name,
         event_date, start_time, end_time, hours, is_nonprofit, is_internal,
         base_total, standard_discount_multiplier, subtotal_after_standard_discount,
         manual_adjustment_type, manual_adjustment_value, manual_adjustment_reason, manual_adjustment_by,
         final_total, payment_status, payment_method, calendar_event_ids, recurring_series_id, recurrence_summary,
         event_name, notes, created_by, created_at)
        VALUES (@bookingId, @rooms, @renterId, @renterName, @renterEmail, @renterPhone, @renterAddress, @organizationName, @hccgcRepName,
         @eventDate, @startTime, @endTime, @hours, @isNonprofit, @isInternal,
         @baseTotal, @mult, @subtotal, @adjType, @adjValue, @adjReason, @adjBy,
         @finalTotal, @paymentStatus, NULL, @eventIds, @seriesId, @recurrenceSummary,
         @eventName, @notes, @enteredBy, CURRENT_TIMESTAMP())`,
      params: {
        bookingId, rooms: b.rooms, renterId, renterName: displayName, renterEmail: renterFields.renterEmail || null,
        renterPhone: renterFields.renterPhone || null, renterAddress: renterFields.renterAddress || null, organizationName: renterFields.organizationName || null,
        hccgcRepName: b.hccgcRepresentativeName || null,
        eventDate: occ.date, startTime: `${occ.date} ${occ.startTime}:00`, endTime: `${occ.date} ${occ.endTime}:00`,
        hours, isNonprofit: !isInternal && !!b.isNonprofit, isInternal,
        baseTotal, mult, subtotal,
        adjType: (!isInternal && b.manualAdjustmentType) || null, adjValue: (!isInternal && b.manualAdjustmentValue) || null,
        adjReason: (!isInternal && b.manualAdjustmentReason) || null, adjBy: (!isInternal && b.manualAdjustmentType) ? actor.email : null,
        finalTotal, paymentStatus: isInternal ? 'n/a' : 'pending',
        eventIds, seriesId, recurrenceSummary, eventName: eventName || null, notes: b.notes || null, enteredBy: actor.email
      },
      types: {
        rooms: ['STRING'], eventIds: ['STRING'], eventName: 'STRING',
        renterId: 'STRING', renterEmail: 'STRING', renterPhone: 'STRING', renterAddress: 'STRING',
        organizationName: 'STRING', hccgcRepName: 'STRING', adjType: 'STRING', adjReason: 'STRING',
        adjValue: 'NUMERIC', adjBy: 'STRING', seriesId: 'STRING', recurrenceSummary: 'STRING', notes: 'STRING',
        hours: 'NUMERIC', baseTotal: 'NUMERIC', mult: 'NUMERIC', subtotal: 'NUMERIC', finalTotal: 'NUMERIC'
      }
    });
  }

  let eventListingCreated = false;
  let eventListingError;
  if (isInternal && b.publishAsEvent) {
    try {
      await createEventListing({
        name: b.renterName,
        description: b.notes,
        firstOccurrence: b.occurrences[0],
        createdByName: b.hccgcRepresentativeName,
        createdByEmail: actor.email
      });
      eventListingCreated = true;
    } catch (err) {
      console.error('Manage Events listing failed:', err.message);
      eventListingError = err.message;
    }
  }

  await logAudit({
    action: isInternal ? 'internal_booking_created' : 'booking_created',
    entityType: 'booking',
    entityId: createdBookingIds[0],
    actorEmail: actor.email,
    details: { bookingIds: createdBookingIds, rooms: b.rooms, renterName: displayName, occurrenceCount: b.occurrences.length, totalAcrossAllOccurrences: Math.round(totalFinal * 100) / 100 }
  });

  res.json({
    bookingIds: createdBookingIds,
    occurrenceCount: b.occurrences.length,
    totalAcrossAllOccurrences: Math.round(totalFinal * 100) / 100,
    isInternal,
    eventListingCreated: eventListingCreated || undefined,
    eventListingError,
    calendarSyncErrors: allSyncErrors.length ? allSyncErrors : undefined
  });
}

// POST /admin/fix-calendar-swap — one-time cleanup for the Surya Hall / Ganesh
// Room calendar ID mix-up. Contamination could only ever affect single-room
// "Surya Hall" bookings — that was the one calendar with write access before
// the swap was caught, and calendar sync for a booking is all-or-nothing, so
// multi-room bookings involving Surya couldn't have partially synced.
async function fixCalendarSwap(req, res, actor) {
  const roomsList = await getActiveRooms();
  const roomsMap = {};
  roomsList.forEach(r => { roomsMap[r.name] = r; });
  const suryaCalId = roomsMap['Surya Hall'] && roomsMap['Surya Hall'].calendar_id;
  const ganeshCalId = roomsMap['Ganesh Room'] && roomsMap['Ganesh Room'].calendar_id;
  if (!suryaCalId || !ganeshCalId) return res.status(400).json({ error: 'Surya Hall or Ganesh Room calendar_id missing from the rooms table.' });

  const [rows] = await bigquery.query(
    `SELECT booking_id, calendar_event_ids FROM \`${DATASET}.bookings\`
     WHERE ARRAY_LENGTH(rooms) = 1 AND rooms[OFFSET(0)] = 'Surya Hall'
       AND calendar_event_ids IS NOT NULL AND ARRAY_LENGTH(calendar_event_ids) > 0`
  );

  const calendar = await getCalendarClient();
  let checked = 0, alreadyCorrect = 0, fixed = 0, unclear = 0;
  const details = [];

  for (const row of rows) {
    checked++;
    const eventId = row.calendar_event_ids[0];
    let onSurya = false, onGanesh = false;
    try { await calendar.events.get({ calendarId: suryaCalId, eventId }); onSurya = true; } catch (e) { /* not here, keep checking */ }
    if (!onSurya) {
      try { await calendar.events.get({ calendarId: ganeshCalId, eventId }); onGanesh = true; } catch (e) { /* not here either */ }
    }

    if (onSurya) { alreadyCorrect++; continue; }

    if (onGanesh) {
      try {
        await calendar.events.delete({ calendarId: ganeshCalId, eventId });
        await bigquery.query({
          query: `UPDATE \`${DATASET}.bookings\` SET calendar_event_ids = NULL WHERE booking_id = @bookingId`,
          params: { bookingId: row.booking_id }
        });
        fixed++;
        details.push({ bookingId: row.booking_id, eventId, action: 'removed from Ganesh Room calendar, cleared for resync' });
      } catch (err) {
        details.push({ bookingId: row.booking_id, eventId, error: err.message });
      }
    } else {
      unclear++;
      details.push({ bookingId: row.booking_id, eventId, note: 'not found on Surya or Ganesh calendar — check manually' });
    }
  }

  await logAudit({
    action: 'calendar_swap_cleanup', entityType: 'bulk', entityId: 'surya-ganesh-fix',
    actorEmail: actor.email, details: { checked, alreadyCorrect, fixed, unclear }
  });

  res.json({ checked, alreadyCorrect, fixed, unclear, details: details.slice(0, 40) });
}

// POST /admin/reset-calendar-sync — deletes every calendar event this system
// has ever created (using the exact event IDs already stored in BigQuery, so
// nothing unrelated on these calendars gets touched) and clears sync state on
// every booking. Booking data itself is untouched. Run /admin/backfill-calendar
// afterward to recreate everything fresh with the current (correct) mapping.
const SWAP_PARTNER = { 'Surya Hall': 'Ganesh Room', 'Ganesh Room': 'Surya Hall', 'Patanjali Hall': 'Nataraj Room', 'Nataraj Room': 'Patanjali Hall' };
async function resetCalendarSync(req, res, actor) {
  const roomsList = await getActiveRooms();
  const roomsMap = {};
  roomsList.forEach(r => { roomsMap[r.name] = r; });

  const [rows] = await bigquery.query(
    `SELECT booking_id, rooms, calendar_event_ids FROM \`${DATASET}.bookings\`
     WHERE calendar_event_ids IS NOT NULL AND ARRAY_LENGTH(calendar_event_ids) > 0`
  );

  const calendar = await getCalendarClient();
  let bookingsProcessed = 0, eventsDeleted = 0, eventsNotFound = 0;

  for (const row of rows) {
    bookingsProcessed++;
    for (let i = 0; i < row.rooms.length; i++) {
      const roomName = row.rooms[i];
      const eventId = row.calendar_event_ids[i];
      if (!eventId) continue;
      const primaryCalId = roomsMap[roomName] && roomsMap[roomName].calendar_id;
      const partnerRoom = SWAP_PARTNER[roomName];
      const partnerCalId = partnerRoom && roomsMap[partnerRoom] && roomsMap[partnerRoom].calendar_id;

      let deleted = false;
      for (const calId of [primaryCalId, partnerCalId].filter(Boolean)) {
        try {
          await calendar.events.delete({ calendarId: calId, eventId });
          deleted = true;
          break;
        } catch (err) { /* not on this calendar, try next */ }
      }
      if (deleted) eventsDeleted++; else eventsNotFound++;
    }
  }

  await bigquery.query(`UPDATE \`${DATASET}.bookings\` SET calendar_event_ids = NULL WHERE calendar_event_ids IS NOT NULL AND ARRAY_LENGTH(calendar_event_ids) > 0`);

  await logAudit({
    action: 'calendar_full_reset', entityType: 'bulk', entityId: 'calendar-reset',
    actorEmail: actor.email, details: { bookingsProcessed, eventsDeleted, eventsNotFound }
  });

  res.json({ bookingsProcessed, eventsDeleted, eventsNotFound, note: 'Run /admin/backfill-calendar next to recreate everything.' });
}

// POST /admin/backfill-calendar — one-time (or repeatable) sync for any
// booking that doesn't yet have calendar events, e.g. historical rows
// imported directly via SQL, which never went through createBooking and so
// never triggered calendar sync. Safe to re-run: only touches bookings
// where calendar_event_ids is currently empty/NULL.
async function backfillCalendarSync(req, res, actor) {
  const roomsList = await getActiveRooms();
  const roomsMap = {};
  roomsList.forEach(r => { roomsMap[r.name] = r; });

  const [rows] = await bigquery.query(
    `SELECT booking_id, rooms, renter_name, start_time, end_time
     FROM \`${DATASET}.bookings\`
     WHERE (calendar_event_ids IS NULL OR ARRAY_LENGTH(calendar_event_ids) = 0)
       AND payment_status != 'cancelled'
     ORDER BY event_date`
  );

  let synced = 0;
  const errors = [];
  for (const row of rows) {
    const startTime = row.start_time && row.start_time.value ? row.start_time.value : row.start_time;
    const endTime = row.end_time && row.end_time.value ? row.end_time.value : row.end_time;
    const occ = {
      date: String(startTime).slice(0, 10),
      startTime: String(startTime).slice(11, 16),
      endTime: String(endTime).slice(11, 16)
    };
    const { eventIds, syncErrors } = await syncOccurrenceToCalendar({
      rooms: row.rooms, roomsMap, occ, renterName: row.renter_name, seriesLabel: null
    });
    if (syncErrors.length) {
      errors.push({ bookingId: row.booking_id, errors: syncErrors });
      continue;
    }
    await bigquery.query({
      query: `UPDATE \`${DATASET}.bookings\` SET calendar_event_ids = @eventIds WHERE booking_id = @bookingId`,
      params: { eventIds, bookingId: row.booking_id },
      types: { eventIds: ['STRING'] }
    });
    synced++;
  }

  await logAudit({
    action: 'calendar_backfill_run', entityType: 'bulk', entityId: 'calendar-backfill',
    actorEmail: actor.email, details: { totalCandidates: rows.length, synced, failed: errors.length }
  });

  res.json({ totalCandidates: rows.length, synced, failed: errors.length, errors: errors.slice(0, 20) });
}

// POST /bookings/:id/cancel
// Cancellation policy: 14+ days' notice before the booking = no fee, full
// refund. 7-13 days' notice = 50% cancellation fee. Under 7 days: this
// specific tier was never explicitly specified — a 100% fee (no refund) is
// applied here as the natural extension of the stated policy, but that's an
// assumption, not something confirmed. Flag it if that's not right.
// Shared by both single-booking and whole-series cancellation — computes the
// fee for one occurrence based on its own date, removes its calendar event,
// and marks it cancelled. Returns null if the booking doesn't exist, or
// { alreadyCancelled: true } if it's already cancelled.
async function cancelOneBookingRow(bookingId, actor, roomsMap, calendar) {
  const [rows] = await bigquery.query({
    query: `SELECT event_date, rooms, calendar_event_ids, final_total, payment_status FROM \`${DATASET}.bookings\` WHERE booking_id = @bookingId`,
    params: { bookingId }
  });
  if (!rows.length) return null;
  const row = rows[0];
  if (row.payment_status === 'cancelled') return { alreadyCancelled: true };

  const eventDateStr = (row.event_date && row.event_date.value) || row.event_date;
  const isPast = new Date(eventDateStr + 'T00:00:00') < new Date(new Date().toDateString());
  if (isPast && !isSuperAdmin(actor.email)) return { locked: true };

  const today = new Date(); today.setHours(0, 0, 0, 0);
  const eventD = new Date(eventDateStr + 'T00:00:00');
  const daysUntil = Math.ceil((eventD - today) / 86400000);

  const finalTotal = Number(row.final_total) || 0;
  let feeRate;
  if (daysUntil >= 14) feeRate = 0;
  else if (daysUntil >= 7) feeRate = 0.5;
  else feeRate = 1.0;
  const fee = Math.round(finalTotal * feeRate * 100) / 100;
  const refund = Math.round((finalTotal - fee) * 100) / 100;

  if (Array.isArray(row.rooms) && Array.isArray(row.calendar_event_ids)) {
    for (let i = 0; i < row.rooms.length; i++) {
      const calId = roomsMap[row.rooms[i]] && roomsMap[row.rooms[i]].calendar_id;
      const eventId = row.calendar_event_ids[i];
      if (!calId || !eventId) continue;
      try { await calendar.events.delete({ calendarId: calId, eventId }); } catch (err) { /* already gone, fine */ }
    }
  }

  await bigquery.query({
    query: `UPDATE \`${DATASET}.bookings\`
            SET payment_status = 'cancelled', cancellation_fee = @fee, refund_amount = @refund,
                cancelled_at = CURRENT_TIMESTAMP(), cancelled_by = @actorEmail,
                calendar_event_ids = NULL, updated_at = CURRENT_TIMESTAMP()
            WHERE booking_id = @bookingId`,
    params: { fee, refund, actorEmail: actor.email, bookingId },
    types: { fee: 'NUMERIC', refund: 'NUMERIC' }
  });

  return { daysUntil, feeRate, fee, refund };
}

// ---- Invoice / receipt generation ----
function money(n) { return '$' + Number(n).toFixed(0); }
const ROOM_SHORT_NAMES = { 'Surya Hall': 'Surya', 'Patanjali Hall': 'Patanjali', 'Nataraj Room': 'Nataraj', 'Ganesh Room': 'Ganesh', 'Kitchen': 'Kitchen', 'Lunch Room': 'Lunch Room' };
const ALL_FOUR_ROOMS = ['Surya Hall', 'Patanjali Hall', 'Nataraj Room', 'Ganesh Room'];

function roomsDisplay(rooms) {
  if (Array.isArray(rooms) && ALL_FOUR_ROOMS.every(r => rooms.includes(r))) return 'Full Facility';
  return (Array.isArray(rooms) ? rooms : [rooms]).map(r => ROOM_SHORT_NAMES[r] || r).join(' + ');
}
function formatTime12h(hhmm) {
  const [h, m] = hhmm.split(':').map(Number);
  const period = h >= 12 ? 'PM' : 'AM';
  const h12 = h % 12 === 0 ? 12 : h % 12;
  return m === 0 ? `${h12}${period}` : `${h12}:${String(m).padStart(2, '0')}${period}`;
}
function timeRangeDisplay(startTime, endTime) {
  const start = (startTime || '').slice(11, 16), end = (endTime || '').slice(11, 16);
  if (start === '00:00' && end === '23:59') return 'Full Day';
  const startH = Number(start.slice(0, 2)), endH = Number(end.slice(0, 2));
  if (startH <= 8 && (endH >= 21 || endH === 0)) return 'Full Day';
  return `${formatTime12h(start)}-${formatTime12h(end)}`;
}

function numberToWords(num) {
  const ones = ['', 'one', 'two', 'three', 'four', 'five', 'six', 'seven', 'eight', 'nine', 'ten',
    'eleven', 'twelve', 'thirteen', 'fourteen', 'fifteen', 'sixteen', 'seventeen', 'eighteen', 'nineteen'];
  const tens = ['', '', 'twenty', 'thirty', 'forty', 'fifty', 'sixty', 'seventy', 'eighty', 'ninety'];
  function convertHundreds(n) {
    let str = '';
    if (n >= 100) { str += ones[Math.floor(n / 100)] + ' hundred'; n %= 100; if (n > 0) str += ' and '; }
    if (n >= 20) { str += tens[Math.floor(n / 10)]; if (n % 10 > 0) str += '-' + ones[n % 10]; }
    else if (n > 0) { str += ones[n]; }
    return str;
  }
  if (num === 0) return 'zero';
  const parts = [];
  const millions = Math.floor(num / 1e6), thousands = Math.floor((num % 1e6) / 1e3), remainder = num % 1000;
  if (millions) parts.push(convertHundreds(millions) + ' million');
  if (thousands) parts.push(convertHundreds(thousands) + ' thousand');
  if (remainder) parts.push(convertHundreds(remainder));
  return parts.join(' ');
}
function amountInWords(amount) {
  const dollars = Math.floor(amount);
  const words = numberToWords(dollars);
  return words.charAt(0).toUpperCase() + words.slice(1) + ' dollar' + (dollars === 1 ? '' : 's');
}

// Counts each series (or standalone booking) once, regardless of how many
// occurrence rows share it — otherwise a 10-occurrence series receipt would
// jump the counter by 10 instead of 1.
async function getNextInvoiceNumber() {
  const year = new Date().getFullYear();
  const [rows] = await bigquery.query({
    query: `SELECT COUNT(DISTINCT COALESCE(recurring_series_id, booking_id)) AS cnt FROM \`${DATASET}.bookings\`
            WHERE receipt_sent_at IS NOT NULL AND EXTRACT(YEAR FROM receipt_sent_at) = @year`,
    params: { year }
  });
  const seq = (Number(rows[0].cnt) || 0) + 1;
  return `INV-${year}-${String(seq).padStart(3, '0')}`;
}


// POST /finance/expense-submissions/:submissionId/approve — every line item
// needs a category assigned first. Sends the payout request to the actual
// approver with line-item detail, total, and the Zelle ID needed to pay it.
async function approveExpenseSubmission(req, res, submissionId, actor) {
  const requestedIds = Array.isArray(req.body && req.body.lineItemIds) ? req.body.lineItemIds : null;

  const [allRows] = await bigquery.query({
    query: `SELECT * FROM \`${DATASET}.expense_line_items\` WHERE submission_id = @submissionId AND status = 'submitted'`,
    params: { submissionId }
  });
  if (!allRows.length) return res.status(404).json({ errors: ['No pending items found for this submission.'] });

  // No explicit selection sent -> defaults to "everything still pending",
  // same as the old behavior, so nothing breaks for a caller that doesn't
  // send lineItemIds.
  const rows = requestedIds ? allRows.filter(r => requestedIds.includes(r.line_item_id)) : allRows;
  if (!rows.length) return res.status(400).json({ errors: ['No matching pending items were selected.'] });

  const uncategorized = rows.filter(r => !r.category_id);
  if (uncategorized.length) return res.status(400).json({ errors: [`Assign a category to every selected expense first (${uncategorized.length} missing).`] });

  const ids = rows.map(r => r.line_item_id);
  await bigquery.query({
    query: `UPDATE \`${DATASET}.expense_line_items\` SET status = 'approved', approved_by = @actorEmail, approved_at = CURRENT_TIMESTAMP()
            WHERE line_item_id IN UNNEST(@ids) AND status = 'submitted'`,
    params: { actorEmail: actor.email, ids },
    types: { ids: ['STRING'] }
  });
  await logAudit({ action: 'expense_submission_approved', entityType: 'expense_submission', entityId: submissionId, actorEmail: actor.email, details: { count: rows.length, lineItemIds: ids } });

  const unwrap = v => (v && typeof v === 'object' && 'value' in v) ? v.value : v;
  const total = rows.reduce((s, r) => s + Number(r.amount), 0);
  const first = rows[0];
  const rowsHtml = rows.map(r => `<tr><td style="padding:4px 10px 4px 0;">${escapeHtml(r.expense_for)}</td><td style="padding:4px 10px 4px 0;">${escapeHtml(unwrap(r.expense_date))}</td><td>${money(Number(r.amount))}</td></tr>`).join('');

  try {
    await sendEmail({
      to: EXPENSE_APPROVER_EMAIL, cc: FINANCE_INBOX, subject: `Expense approved — ${escapeHtml(first.submitter_first_name)} ${escapeHtml(first.submitter_last_name)} (${money(total)})`,
      htmlBody: `
        <div style="font-family: Arial, Helvetica, sans-serif; max-width: 560px;">
          <h2 style="color:#7f2e16;">Expense reimbursement approved — ready to pay</h2>
          <p><strong>${escapeHtml(first.submitter_first_name)} ${escapeHtml(first.submitter_last_name)}</strong> (${escapeHtml(first.submitter_email)})</p>
          <table style="border-collapse: collapse; font-size: 0.9rem; margin: 12px 0;">
            <thead><tr><th style="text-align:left; padding:4px 10px 4px 0;">For</th><th style="text-align:left; padding:4px 10px 4px 0;">Date</th><th style="text-align:left;">Amount</th></tr></thead>
            <tbody>${rowsHtml}</tbody>
          </table>
          <p style="font-size:1.1rem; font-weight:bold; color:#7f2e16;">Total: ${money(total)}</p>
          <div style="background:#fff6ea; border-radius:8px; padding:10px 14px; margin: 12px 0;">Zelle ID: <strong>${escapeHtml(first.zelle_id)}</strong></div>
        </div>`
    });
  } catch (err) {
    console.error('Expense approval email failed:', err.message);
  }

  res.json({ submissionId, approvedCount: rows.length, total: Math.round(total * 100) / 100 });
}

// POST /finance/expense-submissions/:submissionId/reject
async function rejectExpenseSubmission(req, res, submissionId, actor) {
  const reason = ((req.body && req.body.reason) || '').trim();
  if (!reason) return res.status(400).json({ errors: ['A reason is required.'] });
  const requestedIds = Array.isArray(req.body && req.body.lineItemIds) ? req.body.lineItemIds : null;

  const [allRows] = await bigquery.query({ query: `SELECT line_item_id, submitter_email FROM \`${DATASET}.expense_line_items\` WHERE submission_id = @submissionId AND status = 'submitted'`, params: { submissionId } });
  if (!allRows.length) return res.status(404).json({ errors: ['No pending items found for this submission.'] });

  const rows = requestedIds ? allRows.filter(r => requestedIds.includes(r.line_item_id)) : allRows;
  if (!rows.length) return res.status(400).json({ errors: ['No matching pending items were selected.'] });
  const ids = rows.map(r => r.line_item_id);

  await bigquery.query({
    query: `UPDATE \`${DATASET}.expense_line_items\` SET status = 'rejected', rejection_reason = @reason WHERE line_item_id IN UNNEST(@ids) AND status = 'submitted'`,
    params: { reason, ids },
    types: { ids: ['STRING'] }
  });
  await logAudit({ action: 'expense_submission_rejected', entityType: 'expense_submission', entityId: submissionId, actorEmail: actor.email, details: { reason, lineItemIds: ids } });

  try {
    await sendEmail({
      to: rows[0].submitter_email, cc: FINANCE_INBOX, subject: `Update on your expense submission`,
      htmlBody: `
        <div style="font-family: Arial, Helvetica, sans-serif; max-width: 560px; margin: 0 auto; color: #2c1b10; background: #fff9f1;">
          <div style="text-align:center; padding: 28px 20px 10px;"><img src="data:image/png;base64,${LOGO_BASE64}" width="90" height="90" alt="HCCGC" style="display:inline-block;"></div>
          <div style="padding: 10px 32px 32px;">
            <p>Namaste,</p><p>Your recent expense submission wasn't approved.</p>
            <div style="background:#fff6ea; border-radius:8px; padding:12px 16px; margin: 14px 0; font-size:0.92rem;">${escapeHtml(reason)}</div>
            <p>Questions? Reach out to <a href="mailto:finance@hccgc.org" style="color:#b55a18;">finance@hccgc.org</a>.</p>
            <p style="margin-top:20px;">Warm Regards,<br>Team HCCGC</p>
          </div>
        </div>`
    });
  } catch (err) {
    console.error('Expense rejection email failed:', err.message);
  }
  res.json({ submissionId, status: 'rejected' });
}

// POST /finance/expense-line-items/:id/mark-paid — once actually paid via
// Zelle, try to suggest which bank transaction it corresponds to (same
// "suggest, never auto-link" philosophy as the rest of this module).
async function markExpensePaid(req, res, lineItemId, actor) {
  const [rows] = await bigquery.query({ query: `SELECT * FROM \`${DATASET}.expense_line_items\` WHERE line_item_id = @lineItemId`, params: { lineItemId } });
  if (!rows.length) return res.status(404).json({ errors: ['Expense not found.'] });
  if (rows[0].status !== 'approved') return res.status(400).json({ errors: ['Only approved expenses can be marked paid.'] });

  await bigquery.query({
    query: `UPDATE \`${DATASET}.expense_line_items\` SET status = 'paid', paid_at = CURRENT_TIMESTAMP() WHERE line_item_id = @lineItemId`,
    params: { lineItemId }
  });
  await logAudit({ action: 'expense_marked_paid', entityType: 'expense_line_item', entityId: lineItemId, actorEmail: actor.email, details: {} });

  const amount = Number(rows[0].amount);
  const [bankRows] = await bigquery.query({
    query: `SELECT date, description, amount FROM \`${PAYMENTS_DATASET}.bank_transactions\`
            WHERE LOWER(description) LIKE '%zelle%' AND ABS(amount + @amount) < 1
            ORDER BY date DESC LIMIT 10`,
    params: { amount }
  });
  const unwrap = v => (v && typeof v === 'object' && 'value' in v) ? v.value : v;
  const candidates = bankRows.map(r => ({ date: unwrap(r.date), description: r.description, amount: Number(r.amount) }));
  res.json({ lineItemId, status: 'paid', candidates });
}


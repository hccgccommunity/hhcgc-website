              <div class="detail-item">
                <span class="detail-label">Rooms Available</span>
                <span class="detail-value">4 Spaces — Various Sizes</span>
              </div>
              <div class="detail-item">
                <span class="detail-label">Visit Hours</span>
                <span class="detail-value">Mon &amp; Tue, 5 – 6 PM</span>
              </div>
              <div class="detail-item">
                <span class="detail-label">Weekday Discount</span>
                <span class="detail-value">20% Off (Mon – Fri)</span>
              </div>
              <div class="detail-item">
                <span class="detail-label">Extended Booking</span>
                <span class="detail-value">Extra 20% Off (4+ Hours)</span>
              </div>
              <div class="detail-item">
                <span class="detail-label">Nonprofit Rate</span>
                <span class="detail-value">Additional 25% Off</span>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- OUR SPACES -->
    <section class="section" id="rooms">
      <div class="container">
        <div class="section-head content-width">
          <span class="section-kicker">Our Spaces</span>
          <h2>Four Rooms, Endless Possibilities</h2>
          <p class="section-copy">From spacious halls for large community events to cozy rooms for focused gatherings — every space is designed with comfort and cultural purpose in mind.</p>
        </div>

        <div class="pill-row">
          <div class="pill-card">
            <img class="room-img" src="https://hccgc.org/big-room.jpeg" alt="Surya Hall" onerror="this.style.display='none'" />
            <h3>Surya Hall</h3>
            <p>Spacious and versatile hall for large gatherings, workshops, classes, and community events.</p>
            <div class="rate-badge">$45 / hour</div>
          </div>
          <div class="pill-card">
            <img class="room-img" src="https://hccgc.org/shakha-room.jpeg" alt="Patanjali Hall" onerror="this.style.display='none'" />
            <h3>Patanjali Hall</h3>
            <p>Comfortable hall for workshops, cultural programs, and structured group activities.</p>
            <div class="rate-badge">$40 / hour</div>
          </div>
          <div class="pill-card">
            <img class="room-img" src="https://hccgc.org/room-2.jpeg" alt="Nataraj Room" onerror="this.style.display='none'" />
            <h3>Nataraj Room</h3>
            <p>Open studio space for dance, rehearsals, yoga, and movement-based activities.</p>
            <div class="rate-badge">$30 / hour</div>
          </div>
          <div class="pill-card">
            <img class="room-img" src="https://hccgc.org/office-room.jpeg" alt="Ganesh Room" onerror="this.style.display='none'" />
            <h3>Ganesh Room</h3>
            <p>Welcoming space ideal for meetings, small gatherings, and focused group sessions.</p>
            <div class="rate-badge">$15 / hour</div>
          </div>
        </div>


      </div>
    </section>

    <!-- PRICING / COST ESTIMATOR + FLOOR PLAN (side by side) -->
    <section class="section" id="estimator">
      <div class="container">
        <div style="display:flex;gap:24px;flex-wrap:wrap;align-items:stretch;">
        <!-- FLOOR PLAN -->
        <div style="flex:1;min-width:320px;border-radius:24px;background:rgba(255,255,255,0.74);border:1px solid var(--border);box-shadow:0 12px 30px rgba(93,43,14,.08);padding:28px 32px;display:flex;flex-direction:column;justify-content:center;">
          <div style="margin-bottom:16px;text-align:center;">
            <span class="section-kicker">Floor Plan</span>
            <h3 style="margin:8px 0 4px;color:var(--maroon);font-family:Georgia,'Times New Roman',serif;font-size:clamp(1.4rem,2.4vw,2rem);">Facility Layout</h3>
            <p style="margin:0;color:var(--muted);font-size:0.95rem;">Rooms drawn approximately to scale based on actual dimensions.</p>
          </div>
          <!--
            Scale: 8px = 1ft
            Building: 49ft wide × 70ft tall → 392 × 560px  (x=50, y=30)
            Patanjali Hall:  47ft × 18ft → w=376 h=144  (x=50  y=30)
            Surya Hall:      30ft × 40ft → w=240 h=320  (x=50  y=174)
            Nataraj Room:    19ft × 34ft → w=152 h=272  (x=290 y=174)
            Ganesh Room:     13ft × 18ft → w=104 h=144  (x=338 y=446, right-aligned)
            Welcome Lobby:   30ft × 12ft → w=240 h=96   (x=50  y=494, below Surya)
            ViewBox: 0 0 492 630  (50 left margin + 392 + 50 right margin, 30 top + 560 + 40 bottom)
          -->
          <svg width="100%" viewBox="0 0 492 630" role="img" xmlns="http://www.w3.org/2000/svg" style="font-family:Arial,Helvetica,sans-serif;">
            <title>HCCGC Facility Floor Plan</title>
            <desc>To-scale floor plan at 8px per foot. Patanjali Hall top, Surya Hall bottom-left, Nataraj Room right-upper, Ganesh Room right-lower, Welcome Lobby bottom-left.</desc>

            <!-- Outer building shell -->
            <rect x="50" y="30" width="392" height="560" rx="3" fill="none" stroke="#7f2e16" stroke-width="2" opacity="0.18"/>

            <!-- PATANJALI HALL — extended to align with Nataraj right edge -->
            <rect x="50" y="30" width="392" height="144" rx="3" fill="#E1F5EE" stroke="#0F6E56" stroke-width="1.5"/>
            <text x="246" y="95" text-anchor="middle" font-size="15" font-weight="700" fill="#085041">Patanjali Hall</text>
            <text x="246" y="114" text-anchor="middle" font-size="11" fill="#0F6E56">850 sqft · 18 × 47 ft · $40/hr</text>

            <!-- SURYA HALL — 30ft wide × 40ft tall -->
            <rect x="50" y="174" width="240" height="320" rx="3" fill="#FAEEDA" stroke="#854F0B" stroke-width="1.5"/>
            <text x="170" y="322" text-anchor="middle" font-size="15" font-weight="700" fill="#633806">Surya Hall</text>
            <text x="170" y="342" text-anchor="middle" font-size="11" fill="#854F0B">1200 sqft · 30 × 40 ft · $45/hr</text>

            <!-- NATARAJ ROOM — 19ft wide × 34ft tall -->
            <rect x="290" y="174" width="152" height="272" rx="3" fill="#EEEDFE" stroke="#534AB7" stroke-width="1.5"/>
            <text x="366" y="303" text-anchor="middle" font-size="15" font-weight="700" fill="#3C3489">Nataraj Room</text>
            <text x="366" y="322" text-anchor="middle" font-size="11" fill="#534AB7">600 sqft · 19 × 34 ft · $30/hr</text>

            <!-- GANESH ROOM — 13ft wide × 18ft tall (right-aligned within right column) -->
            <rect x="338" y="446" width="104" height="144" rx="3" fill="#FAECE7" stroke="#993C1D" stroke-width="1.5"/>
            <text x="390" y="511" text-anchor="middle" font-size="14" font-weight="700" fill="#712B13">Ganesh Room</text>
            <text x="390" y="528" text-anchor="middle" font-size="10" fill="#993C1D">250 sqft · 13 × 18 ft</text>
            <text x="390" y="543" text-anchor="middle" font-size="10" fill="#993C1D">$15/hr</text>

            <!-- WELCOME LOBBY — 30ft wide × 12ft tall (below Surya Hall) -->
            <rect x="50" y="494" width="240" height="96" rx="3" fill="rgba(217,164,65,0.10)" stroke="#d9a441" stroke-width="1" stroke-dasharray="5 3"/>
            <text x="170" y="535" text-anchor="middle" font-size="13" font-weight="700" fill="#8d3e0d">Welcome &amp; Check-In</text>
            <text x="170" y="553" text-anchor="middle" font-size="10" fill="#6a5141">Guest Arrival · Lobby</text>

            <!-- Small corridor strip between Nataraj bottom and Ganesh left -->
            <!-- Nataraj ends at y=446, Ganesh starts at x=338. Space x=290..338, y=446..590 is a gap/corridor -->
            <rect x="290" y="446" width="48" height="144" rx="2" fill="rgba(217,164,65,0.06)" stroke="#d9a441" stroke-width="0.75" stroke-dasharray="3 3"/>
            <text x="314" y="519" text-anchor="middle" font-size="8" fill="#6a5141" transform="rotate(-90,314,519)">corridor</text>

            <!-- Caption -->
            <text x="246" y="610" text-anchor="middle" font-size="9" fill="#6a5141" opacity="0.5">Approximately to scale · 8 px = 1 ft</text>
          </svg>


<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Khel Sandhya | Hindu Community Center of Greater Cincinnati</title>
  <meta name="description" content="Khel Sandhya is HCCGC’s community indoor games evening featuring carrom, table tennis, chess, and friendly community connection." />
  <style>
    :root{--bg:#fff9f1;--card:#fff;--soft:#fff3e4;--text:#2c1b10;--muted:#6a5141;--orange:#c65a12;--dark:#8d3e0d;--maroon:#7f2e16;--border:rgba(121,62,17,.16);--shadow:0 18px 45px rgba(93,43,14,.10)}
    *{box-sizing:border-box} body{margin:0;font-family:Arial,Helvetica,sans-serif;color:var(--text);background:radial-gradient(circle at top left,rgba(217,138,30,.14),transparent 24%),linear-gradient(180deg,#fff9f1,#fff7ec 55%,#fffaf4);line-height:1.65}
    a{text-decoration:none;color:inherit}.container{width:min(calc(100% - 32px),1220px);margin:auto}.hero{padding:70px 0 35px}.hero-card{display:grid;grid-template-columns:1.1fr .9fr;gap:34px;align-items:center;background:linear-gradient(135deg,rgba(255,255,255,.96),rgba(255,246,234,.92));border:1px solid var(--border);border-radius:34px;box-shadow:var(--shadow);padding:clamp(26px,4vw,46px);position:relative;overflow:hidden}.hero-card:before{content:"ॐ";position:absolute;right:34px;top:16px;font-size:7rem;color:rgba(198,90,18,.06);font-family:Georgia,serif}.kicker{display:inline-block;padding:8px 14px;border-radius:999px;background:rgba(198,90,18,.12);color:var(--dark);font-size:.78rem;font-weight:800;text-transform:uppercase;letter-spacing:.08em;margin-bottom:12px}.hero h1{margin:0;color:var(--maroon);font-family:Georgia,serif;font-size:clamp(2.8rem,6vw,5rem);line-height:1.02}.hero p{color:var(--muted);font-size:1.15rem;margin:14px 0 0;max-width:680px}.buttons{display:flex;flex-wrap:wrap;gap:12px;margin-top:26px}.btn{display:inline-flex;align-items:center;justify-content:center;min-height:46px;padding:12px 18px;border-radius:999px;font-weight:800}.primary{background:linear-gradient(135deg,var(--orange),var(--dark));color:#fff}.secondary{background:#fff;color:var(--dark);border:1px solid var(--border)}.panel{display:grid;gap:14px}.quick,.content,.side,.info,.embed{background:rgba(255,255,255,.9);border:1px solid var(--border);border-radius:24px;box-shadow:0 10px 28px rgba(93,43,14,.08)}.quick{padding:18px}.quick h3,.side h3,.form-head h2{margin:0 0 8px;color:var(--maroon);font-family:Georgia,serif}.quick p{margin:0;color:var(--muted);font-size:.98rem}.games{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}.game{background:var(--soft);border:1px solid var(--border);border-radius:18px;padding:14px;font-weight:800;color:var(--dark)}.game span{font-size:1.5rem;margin-right:8px}
    .game img{width:34px;height:34px;object-fit:cover;border-radius:8px;margin-right:8px;box-shadow:0 4px 10px rgba(93,43,14,.12)}
    .carrom-game{align-items:center}.section{padding:42px 0}.head{text-align:center;margin-bottom:24px}.head h2{font-family:Georgia,serif;color:var(--maroon);font-size:clamp(2rem,3.4vw,3rem);line-height:1.2;margin:8px 0 10px}.head p{color:var(--muted);max-width:820px;margin:auto;font-size:1.05rem}.grid{display:grid;grid-template-columns:1.05fr .95fr;gap:24px}.content{padding:clamp(24px,3vw,34px)}.content p{margin:0 0 16px;color:var(--muted);font-size:1.04rem}.highlight{padding:16px 18px;border-left:5px solid var(--orange);background:var(--soft);border-radius:16px;margin-top:18px;color:var(--maroon);font-weight:800}.stack{display:grid;gap:18px}.side{padding:22px}.side ul{list-style:none;margin:0;padding:0;display:grid;gap:12px}.side li{display:grid;grid-template-columns:28px 1fr;gap:10px;color:var(--muted)}.side li:before{content:"✓";display:inline-flex;align-items:center;justify-content:center;width:24px;height:24px;border-radius:50%;background:rgba(198,90,18,.12);color:var(--dark);font-weight:900}.info-row{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:24px}.info{text-align:center;padding:20px}.info .icon{font-size:2rem}.info h3{margin:6px 0 4px;color:var(--maroon)}.info p{margin:0;color:var(--muted);font-size:.95rem}.embed{max-width:1040px;margin:auto;overflow:hidden;background:transparent;border:0;box-shadow:none;border-radius:0}.form-head{text-align:center;padding:26px 28px;background:linear-gradient(135deg,rgba(198,90,18,.10),rgba(255,246,234,.9));border:1px solid var(--border);border-radius:30px;margin-bottom:16px}.form-head p{margin:0 auto;color:var(--muted);max-width:720px}.zeffy{min-height:650px;width:100%;background:transparent}.fallback{position:relative;height:650px;width:100%;background:transparent;overflow:hidden}.fallback iframe{position:absolute;inset:0;width:100%;height:100%;border:0;background:transparent;display:block}@media(max-width:980px){.hero-card,.grid,.info-row,.games{grid-template-columns:1fr}}@media(max-width:640px){.container{width:min(calc(100% - 24px),1220px)}.hero{padding-top:42px}.hero-card{border-radius:24px;padding:22px}.buttons .btn{width:100%}.section{padding:34px 0}}
  </style>
</head>
<body>
  <div id="header-placeholder"></div>
  <main>
    <section class="hero">
      <div class="container">
        <div class="hero-card">
          <div>
            <span class="kicker">HCCGC Community Initiative</span>
            <h1>Khel Sandhya</h1>
            <p>A warm community evening of indoor games, friendly competition, and meaningful connection.</p>
            <div class="buttons">
              <a class="btn primary" href="#rsvp">RSVP / Register</a>
              <a class="btn secondary" href="#about">Learn More</a>
            </div>
          </div>
          <div class="panel">
            <div class="quick">
              <h3>Come for the games. Stay for the community.</h3>
              <p>Enjoy structured play, meet fellow community members, and be part of a welcoming HCCGC gathering.</p>
            </div>
            <div class="games">
              <div class="game"><span>🏓</span>Table Tennis</div>
              <div class="game carrom-game"><img src="carrom-icon.jpg" alt="Carrom board icon">Carrom</div>
              <div class="game"><span>♟</span>Chess</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="about" class="section">
      <div class="container">
        <div class="head">
          <span class="kicker">About the initiative</span>
          <h2>What is Khel Sandhya?</h2>
          <p>Khel Sandhya is HCCGC’s signature community evening dedicated to bringing people together through simple, engaging indoor games.</p>
        </div>
        <div class="grid">
          <article class="content">
            <p>Designed for participants across age groups, Khel Sandhya offers a welcoming space to unwind, connect, and enjoy friendly competition.</p>
            <p>From classic games like carrom, table tennis, and chess, to moments of laughter and camaraderie, Khel Sandhya is less about winning and more about building a sense of belonging within our community.</p>
            <p>Each session is thoughtfully organized with structured formats such as knockout tournaments, ensuring fair play, minimal wait times, and an engaging experience for all participants. Whether you are a seasoned player or just looking to have a good time, there is something for everyone.</p>
            <div class="highlight">Beyond the games, Khel Sandhya reflects HCCGC’s larger vision — creating a space where our community can come together, connect, and feel at home.</div>
          </article>
          <div class="stack">
            <article class="side">
              <h3>What to Expect</h3>
              <ul>
                <li>Organized gameplay with simple formats</li>
                <li>Opportunities to participate or simply watch and socialize</li>
                <li>A friendly, respectful, and family-friendly environment</li>
                <li>Well-managed schedules designed to maximize playtime</li>
                <li>A chance to meet and connect with fellow community members</li>
              </ul>
            </article>
            <article class="side">
              <h3>Who Can Join</h3>
              <ul>
                <li>Open to participants 12 years and above</li>
                <li>Suitable for all skill levels — beginners to experienced players</li>
                <li>Games may vary by session based on community interest</li>
              </ul>
            </article>
          </div>
        </div>
        <div class="info-row">
          <div class="info"><div class="icon">🤝</div><h3>Community First</h3><p>A relaxed space to build connections and enjoy time together.</p></div>
          <div class="info"><div class="icon">🏆</div><h3>Friendly Play</h3><p>Structured formats that keep the evening engaging and fair.</p></div>
          <div class="info"><div class="icon">🏠</div><h3>HCCGC Spirit</h3><p>A space our community can call its own.</p></div>
        </div>
      </div>
    </section>

    <section id="rsvp" class="section">
      <div class="container">
        <div class="embed">
          <div class="form-head">
            <h2>Join the Next Khel Sandhya</h2>
            <p>Please complete the RSVP form below. Details and available games may vary by session.</p>
          </div>
          <div class="zeffy" data-zeffy-embed data-form-url="/embed/ticketing/khel-sandhya-ravps-for--58"></div>
          <div class="fallback" data-zeffy-embed-fallback style="display:none;">
            <iframe title="Khel Sandhya RSVP form powered by Zeffy" src="https://www.zeffy.com/embed/ticketing/khel-sandhya-ravps-for--58" allowpaymentrequest allowTransparency="true"></iframe>
          </div>
        </div>
        <script src="https://www.zeffy.com/embed/v2/zeffy-embed.js" onerror="document.querySelectorAll('[data-zeffy-embed-fallback]').forEach(function(el){el.style.display='block';});"></script>
      </div>
    </section>
  </main>
  <div id="footer-placeholder"></div>

  <script>
    async function loadPartial(placeholderId, filePath) {
      const target = document.getElementById(placeholderId);
      if (!target) return;
      try {
        const response = await fetch(filePath);
        if (!response.ok) throw new Error("Unable to load " + filePath);
        target.innerHTML = await response.text();
      } catch (error) {
        console.error(error);
        target.innerHTML = "";
      }
    }
    async function initializePage() {
      await loadPartial("header-placeholder", "header.html");
      await loadPartial("footer-placeholder", "footer.html");
      const year = document.getElementById("year");
      if (year) year.textContent = new Date().getFullYear();
    }
    initializePage();
  </script>
</body>
</html>

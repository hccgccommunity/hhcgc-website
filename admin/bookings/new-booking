<style>
:root {
  --bg: #fff9f1; --surface: #ffffff; --surface-soft: #fff6ea; --border: rgba(121,62,17,0.14);
  --text: #2c1b10; --muted: #6a5141; --saffron: #b55a18; --saffron-dark: #8d3e0d; --maroon: #7f2e16;
  --radius: 22px; --shadow: 0 18px 45px rgba(93,43,14,0.10);
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: Arial, Helvetica, sans-serif; background: radial-gradient(circle at top left, rgba(217,138,30,0.12), transparent 22%), radial-gradient(circle at top right, rgba(127,46,22,0.05), transparent 20%), var(--bg); color: var(--text); min-height: 100vh; }
.container { width: min(calc(100% - 32px), 1280px); margin: 0 auto; }
.site-header { position: sticky; top: 0; z-index: 50; background: rgba(255,249,241,0.92); backdrop-filter: blur(10px); border-bottom: 1px solid var(--border); }
.nav { display: flex; align-items: center; justify-content: space-between; gap: 24px; min-height: 92px; padding: 12px 0; }
.site-header a.brand, .site-header a.brand:link, .site-header a.brand:visited { text-decoration: none; color: inherit; }
.brand { display: flex; align-items: center; gap: 16px; min-width: 0; }
.brand-logo-wrap { background: #fff; border: 1px solid var(--border); border-radius: 18px; padding: 8px; box-shadow: var(--shadow); flex-shrink: 0; }
.brand-logo { width: 88px; height: auto; border-radius: 12px; object-fit: contain; }
.brand-text h1 { margin: 0; font-size: 1.2rem; line-height: 1.15; color: var(--maroon); }
.site-header nav ul { list-style: none; display: flex; flex-wrap: wrap; gap: 18px; margin: 0; padding: 0; align-items: center; justify-content: flex-end; }
.site-header nav a, .site-header nav a:link, .site-header nav a:visited { font-weight: 700; color: var(--text); font-size: 0.96rem; text-decoration: none; }
.site-header nav a:hover { color: var(--saffron-dark); }
.menu-toggle { display: none; border: 0; background: transparent; padding: 6px 0; cursor: pointer; color: #2c1b10; align-self: flex-end; }
.menu-toggle .bar { display: block; width: 26px; height: 2px; margin: 5px 0; background: currentColor; }
@media (max-width: 768px) {
  .nav { flex-direction: column; align-items: stretch; gap: 8px; } .menu-toggle { display: inline-block; }
  .site-header nav { display: none; width: 100%; background: rgba(255,249,241,0.95); padding: 10px 0; }
  .site-header nav.is-open { display: block; } .site-header nav ul { flex-direction: column; gap: 14px; }
}
.page-hero { padding: 28px 0 22px; background: linear-gradient(135deg, var(--maroon) 0%, #4e1a09 100%); color: #fff; }
.page-hero .eyebrow { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(255,255,255,0.75); margin-bottom: 6px; }
.page-hero h1 { font-family: Georgia, "Times New Roman", serif; font-size: 1.9rem; color: #fff; margin-bottom: 6px; }
.page-hero p { color: #ffffff; opacity: 0.9; font-size: 0.92rem; max-width: 560px; }
.module-nav { background: var(--surface); border-bottom: 1px solid var(--border); }
.module-nav ul { list-style: none; display: flex; gap: 4px; padding: 10px 0; flex-wrap: wrap; }
.module-nav a { display: inline-block; padding: 8px 16px; border-radius: 999px; font-size: 0.86rem; font-weight: 700; color: var(--muted); text-decoration: none; transition: background 0.15s, color 0.15s; }
.module-nav a.active { background: var(--surface-soft); color: var(--saffron-dark); }
.module-nav a:not(.active):hover { background: var(--surface-soft); }

.layout { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); gap: 24px; padding: 28px 0 60px; align-items: stretch; }
.form-col { display: flex; flex-direction: column; gap: 20px; }
.form-col .full-span { }
.card { min-width: 0; }
.calendar-col { display: flex; height: 100%; }
.calendar-card { display: flex; flex-direction: column; width: 100%; }

.avail-cal-header { display: flex; align-items: center; justify-content: space-between; padding: 8px 0 12px; flex-wrap: wrap; gap: 8px; border-bottom: 1px solid var(--border); margin-bottom: 8px; }
.avail-cal-nav { display: flex; align-items: center; gap: 8px; }
.avail-cal-nav button { font-family: inherit; font-size: 1rem; font-weight: 700; color: var(--saffron-dark); background: var(--surface-soft); border: 1px solid var(--border); border-radius: 8px; width: 28px; height: 28px; cursor: pointer; }
.avail-cal-nav button:hover { background: #fff; }
.avail-cal-month-label { font-size: 0.9rem; font-weight: 700; color: var(--maroon); min-width: 120px; text-align: center; }
.avail-view-toggle { display: flex; border: 1.5px solid var(--border); border-radius: 8px; overflow: hidden; }
.avail-view-btn { font-family: inherit; font-size: 0.72rem; font-weight: 700; padding: 5px 10px; border: none; background: #fff; color: var(--muted); cursor: pointer; }
.avail-view-btn.active { background: var(--saffron-dark); color: #fff; }
.avail-cal-legend { display: flex; gap: 8px; flex-wrap: wrap; font-size: 0.7rem; color: var(--muted); }
.avail-cal-legend-item { display: flex; align-items: center; gap: 4px; }
.avail-cal-legend-dot { width: 9px; height: 9px; border-radius: 3px; display: inline-block; flex-shrink: 0; }
.avail-week-scroll { overflow-x: auto; overflow-y: hidden; flex: 1 1 auto; min-height: 0; }
.avail-week-grid { display: grid; grid-template-columns: 42px repeat(7, minmax(64px, 1fr)); min-width: 500px; }
.avail-week-daylabel { text-align: center; font-size: 0.66rem; font-weight: 700; color: var(--text); padding: 6px 2px; border-bottom: 1px solid var(--border); border-left: 1px solid var(--border); }
.avail-week-daylabel .dow { display: block; font-size: 0.6rem; color: var(--muted); text-transform: uppercase; font-weight: 700; }
.avail-week-daylabel.is-today { color: var(--saffron-dark); }
.avail-week-corner { border-bottom: 1px solid var(--border); }
.avail-week-timecol { position: relative; }
.avail-week-timelabel { position: absolute; right: 6px; font-size: 0.55rem; color: var(--muted); transform: translateY(-50%); white-space: nowrap; }
.avail-week-daycol { border-left: 1px solid var(--border); position: relative; background-image: repeating-linear-gradient(to bottom, var(--border) 0, var(--border) 1px, transparent 1px, transparent var(--hour-px, 34px)); }
.avail-week-chip { position: absolute; border-radius: 4px; padding: 1px 4px; color: #fff; font-size: 0.6rem; font-weight: 700; line-height: 1.25; overflow: hidden; box-sizing: border-box; cursor: default; }
.avail-week-chip .detail { display: block; font-weight: 400; opacity: 0.92; font-size: 0.56rem; }
.avail-month-grid { display: grid; grid-template-columns: repeat(7, 1fr); flex: 1 1 auto; min-height: 0; overflow-y: auto; }
.avail-month-weekday { text-align: center; font-size: 0.64rem; font-weight: 700; color: var(--muted); text-transform: uppercase; padding: 6px 2px; border-bottom: 1px solid var(--border); }
.avail-month-day { min-height: 56px; border-right: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 3px; font-size: 0.62rem; }
.avail-month-day:nth-child(7n) { border-right: none; }
.avail-month-day.empty { background: var(--surface-soft); }
.avail-month-day-num { font-weight: 700; color: var(--text); margin-bottom: 2px; }
.avail-month-day.is-today .avail-month-day-num { color: var(--saffron-dark); }
.avail-month-chip { display: block; border-radius: 3px; padding: 0 3px; margin-bottom: 1px; color: #fff; font-size: 0.56rem; line-height: 1.35; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.avail-month-more { font-size: 0.56rem; color: var(--muted); }
@media (max-width: 1000px) {
  .layout { grid-template-columns: 1fr; }
  .form-col { grid-template-columns: 1fr; }
}
.card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 26px; box-shadow: var(--shadow); }
.cost-summary-card { background: linear-gradient(165deg, var(--surface-soft), var(--surface)); border-color: rgba(213,138,45,0.3); }
.card + .card { margin-top: 20px; }
.card h2 { font-family: Georgia, "Times New Roman", serif; font-size: 1.15rem; color: var(--maroon); margin-bottom: 4px; }
.card .card-sub { font-size: 0.8rem; color: var(--muted); margin-bottom: 16px; }

.field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 14px; }
.field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px; }
.field label { font-size: 0.78rem; font-weight: 700; color: var(--muted); }
.field input[type="text"], .field input[type="email"], .field input[type="tel"], .field input[type="date"], .field input[type="time"], .field input[type="number"], .field select, .field textarea {
  font-family: Arial, Helvetica, sans-serif; font-size: 0.88rem; padding: 9px 12px; border: 1.5px solid var(--border); border-radius: 10px; background: #fff; color: var(--text);
  width: 100%; box-sizing: border-box; min-width: 0;
}
.field textarea { resize: vertical; min-height: 56px; }

.room-picker { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); gap: 10px; margin-bottom: 8px; }
.room-check { display: flex; align-items: center; gap: 8px; padding: 10px 12px; border: 1.5px solid var(--border); border-radius: 10px; cursor: pointer; font-size: 0.86rem; transition: border-color 0.15s, background 0.15s; }
.room-check:has(input:checked) { border-color: var(--saffron-dark); background: var(--surface-soft); font-weight: 700; }
.room-check input { width: 16px; height: 16px; accent-color: var(--saffron-dark); }
.room-check .rate { margin-left: auto; font-size: 0.74rem; color: var(--muted); }

.internal-toggle-strip { display: flex; flex-wrap: wrap; align-items: center; gap: 6px 24px; padding: 12px 18px; border: 1px dashed var(--border); border-radius: 14px; background: var(--surface); margin-bottom: 4px; }
.internal-toggle-strip .checkbox-row { font-size: 0.86rem; }
.internal-toggle-strip .muted-inline { color: var(--muted); font-weight: 400; }
.internal-toggle-strip .collapsible.open { padding-top: 0; }
.btn-whole-facility {
  font-family: Arial, Helvetica, sans-serif; font-size: 0.76rem; font-weight: 700; color: var(--saffron-dark);
  background: var(--surface-soft); border: 1.5px solid var(--border); border-radius: 999px; padding: 6px 14px; cursor: pointer;
}
.btn-whole-facility:hover { background: #fbe9cf; }

.checkbox-row { display: flex; align-items: center; gap: 8px; margin-bottom: 14px; font-size: 0.86rem; }
.section-divider { border-top: 1px solid var(--border); margin: 6px 0 16px; }
.checkbox-row input { width: 16px; height: 16px; }

.summary-line { display: flex; justify-content: space-between; font-size: 0.86rem; padding: 7px 0; border-bottom: 1px solid var(--border); }
.summary-line:last-of-type { border-bottom: none; }
.summary-line .label { color: var(--muted); }
.summary-line.total { font-weight: 700; font-size: 1.05rem; color: var(--maroon); padding-top: 12px; }
.discount-chip { display: inline-block; font-size: 0.68rem; font-weight: 700; color: var(--saffron-dark); background: var(--surface-soft); border-radius: 999px; padding: 2px 8px; margin: 2px 4px 0 0; }
.no-discount { font-size: 0.78rem; color: var(--muted); font-style: italic; }

.adjustment-toggle { display: flex; align-items: center; gap: 8px; margin: 16px 0 10px; font-size: 0.86rem; font-weight: 700; color: var(--text); cursor: pointer; }
.collapsible { display: none; padding-top: 8px; }
.collapsible.open { display: block; }

.btn-primary {
  font-family: Arial, Helvetica, sans-serif; font-size: 0.9rem; font-weight: 700; color: #fff;
  background: linear-gradient(135deg, var(--saffron-dark), var(--maroon)); border: none; border-radius: 12px;
  padding: 12px 20px; cursor: pointer; width: 100%; margin-top: 14px;
}
.btn-primary:hover { opacity: 0.92; }
.btn-secondary {
  font-family: Arial, Helvetica, sans-serif; font-size: 0.78rem; font-weight: 700; color: var(--saffron-dark);
  background: var(--surface-soft); border: 1.5px solid var(--border); border-radius: 8px; padding: 6px 12px; cursor: pointer;
}

.result-box { margin-top: 16px; border-radius: 12px; padding: 12px 16px; font-size: 0.84rem; line-height: 1.5; }
.modal-overlay { position: fixed; inset: 0; background: rgba(44,27,16,0.5); z-index: 100; display: flex; align-items: flex-start; justify-content: center; padding: 60px 16px; overflow-y: auto; }
.modal-panel { background: var(--surface); border-radius: var(--radius); box-shadow: var(--shadow); width: 100%; max-width: 480px; }
.modal-header { display: flex; align-items: center; justify-content: space-between; padding: 22px 26px; border-bottom: 1px solid var(--border); }
.modal-header h2 { font-family: Georgia, "Times New Roman", serif; font-size: 1.15rem; color: var(--maroon); }
.modal-close { background: none; border: none; font-size: 1.4rem; color: var(--muted); cursor: pointer; line-height: 1; }
.modal-body { padding: 22px 26px; }
.modal-footer { display: flex; justify-content: flex-end; gap: 10px; padding: 18px 26px; border-top: 1px solid var(--border); }
.result-box.success { background: #e8f5ec; color: #2e7d4f; border: 1px solid rgba(46,125,79,0.25); }
.result-box.error { background: #fbe9e7; color: #b3382c; border: 1px solid rgba(179,56,44,0.25); }
.conflict-note { background: #fdf1de; color: #a15c00; border: 1px solid rgba(161,92,0,0.2); border-radius: 12px; padding: 12px 16px; font-size: 0.8rem; margin-top: 16px; }

.occ-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; margin-top: 10px; }
.occ-table th { text-align: left; font-size: 0.68rem; text-transform: uppercase; color: var(--muted); padding: 6px 6px; }
.occ-table td { padding: 4px 6px; }
.occ-table input[type="date"], .occ-table input[type="time"] { font-family: Arial, Helvetica, sans-serif; font-size: 0.8rem; padding: 6px 8px; border: 1.5px solid var(--border); border-radius: 8px; width: 100%; }
.occ-remove { background: none; border: none; color: #b3382c; cursor: pointer; font-size: 0.9rem; padding: 4px 6px; }


#gate{padding:60px 16px;display:flex;justify-content:center;}
.gate-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:2.5rem 2rem;max-width:420px;width:100%;text-align:center;box-shadow:var(--shadow);}
.gate-card h3{font-family:Georgia,serif;font-size:1.3rem;color:var(--maroon);margin-bottom:.5rem;}
.gate-card p{color:var(--muted);font-size:.88rem;line-height:1.6;}
.gate-card a{color:var(--saffron-dark);}
.back-link { display: inline-flex; align-items: center; gap: 6px; font-size: 0.82rem; font-weight: 700; color: rgba(255,255,255,0.85); text-decoration: none; margin-bottom: 14px; }
.back-link:hover { color: #fff; text-decoration: underline; }
.nav-badge { display: inline-block; background: #b3382c; color: #fff; font-size: 0.68rem; font-weight: 700; padding: 1px 6px; border-radius: 999px; margin-left: 4px; vertical-align: middle; }
</style>
</head>
<body>
<div id="site-header"></div>

<div id="gate">
  <div class="gate-card">
    <h3>Checking access&hellip;</h3>
    <p>Please sign in from the <a href="/admin/admin-portal">Admin Portal</a> first.</p>
  </div>
</div>

<div id="app">
<datalist id="common-times">
  <option value="06:00"><option value="06:30"><option value="07:00"><option value="07:30">
  <option value="08:00"><option value="08:30"><option value="09:00"><option value="09:30">
  <option value="10:00"><option value="10:30"><option value="11:00"><option value="11:30">
  <option value="12:00"><option value="12:30"><option value="13:00"><option value="13:30">
  <option value="14:00"><option value="14:30"><option value="15:00"><option value="15:30">
  <option value="16:00"><option value="16:30"><option value="17:00"><option value="17:30">
  <option value="18:00"><option value="18:30"><option value="19:00"><option value="19:30">
  <option value="20:00"><option value="20:30"><option value="21:00"><option value="21:30">
  <option value="22:00">
</datalist>

<div class="page-hero">
  <div class="container">
    <a class="back-link" href="https://hccgc.org/admin/admin-portal">&larr; Back to apps</a>
    <h1>Facility Bookings</h1>
    <p>Pick a room, a date, and a renter — cost and availability update as you go.</p>
  </div>
</div>

<div class="module-nav">
  <div class="container">
    <ul>
      <li><a href="dashboard">Dashboard</a></li>
      <li><a href="new-booking" class="active">New Booking</a></li>
      <li><a href="all-bookings" id="nav-all-bookings">All Bookings</a></li>
      <li><a href="rooms-rates">Rooms &amp; Rates</a></li>
      <li><a href="add-renter" id="nav-add-renter">Add A Renter</a></li>
    </ul>
  </div>
</div>

<div class="container">
  <div class="layout">
    <div class="calendar-col">
      <div class="card calendar-card">
        <h2>Room availability</h2>
        <div class="card-sub">Live from actual bookings — same source of truth as the public availability calendar.</div>
        <div class="avail-cal-header">
          <div class="avail-cal-nav">
            <button type="button" id="avail-cal-prev" aria-label="Previous">&larr;</button>
            <div class="avail-cal-month-label" id="avail-cal-week-label"></div>
            <button type="button" id="avail-cal-next" aria-label="Next">&rarr;</button>
          </div>
          <div class="avail-view-toggle">
            <button type="button" class="avail-view-btn active" id="avail-view-week-btn">Week</button>
            <button type="button" class="avail-view-btn" id="avail-view-month-btn">Month</button>
          </div>
          <div class="avail-cal-legend" id="avail-cal-legend"></div>
        </div>
        <div class="avail-week-scroll" id="avail-week-container">
          <div class="avail-week-grid" id="avail-week-grid"></div>
        </div>
        <div class="avail-month-grid" id="avail-month-grid" style="display:none;"></div>
      </div>
    </div>

    <div class="form-col">
      <div class="internal-toggle-strip full-span">
        <div class="checkbox-row" style="margin-bottom:0;"><input type="checkbox" id="f-internal-enabled"><label for="f-internal-enabled">This is an HCCGC program/initiative <span class="muted-inline">— no charge, no customer</span></label></div>
        <div class="collapsible" id="publish-event-field">
          <div class="checkbox-row" style="margin-bottom:0;">
            <input type="checkbox" id="f-publish-event" checked>
            <label for="f-publish-event">Also list this on the public Upcoming Events page</label>
          </div>
        </div>
      </div>

      <div class="card" id="renter-details-card">
        <h2 id="renter-details-title">Renter</h2>
        <div class="card-sub" id="renter-details-sub">Who's booking, and what for.</div>
        <div class="field" id="f-renter-select-field">
          <label>Select a contact</label>
          <select id="f-renter-select" required>
            <option value="">Choose a renter…</option>
          </select>
          <div class="card-sub" style="margin-bottom:0;margin-top:6px;">Don't see who you're looking for? <a href="add-renter" style="color:var(--saffron-dark);font-weight:700;">Add them on the Add A Renter page</a> first.</div>
        </div>
        <div class="field" id="f-event-name-field"><label>Event name</label><input type="text" id="f-event-name" placeholder="e.g. Weekly Shakha, Birthday Celebration"></div>
        <div class="field" id="f-name-field" style="display:none;"><label id="f-name-label">Program / event name</label><input type="text" id="f-name" placeholder="e.g. Weekly Bhajan Sandhya"></div>
        <div class="field" id="f-hccg-rep-field" style="display:none;"><label>HCCGC representative name</label><input type="text" id="f-hccg-rep" placeholder="Who at HCCGC is organizing this?"></div>
        <div class="field"><label id="f-notes-label">Notes (optional)</label><textarea id="f-notes" placeholder="Anything worth remembering about this booking"></textarea></div>
      </div>

      <div class="card" id="rooms-card">
        <h2>Rooms</h2>
        <div class="card-sub">Select all four for whole-facility. Kitchen requires Surya Hall or Patanjali Hall.</div>
        <button type="button" class="btn-whole-facility" id="btn-whole-facility">Select all rooms (whole facility)</button>
        <div class="room-picker" id="room-picker" style="margin-top:12px;"></div>
        <div class="checkbox-row" id="nonprofit-row" style="display:none;"><span style="color:var(--green);font-weight:700;">&#10003; Nonprofit discount applied</span> <span class="card-sub" style="margin:0;">(based on this renter's saved status — change it in Add A Renter)</span></div>

        <div class="section-divider"></div>

        <div class="adjustment-toggle" id="adjustment-toggle">
          <input type="checkbox" id="f-adjustment-enabled" style="width:16px;height:16px;">
          Apply a one-time discretionary discount
        </div>
        <div class="collapsible" id="adjustment-fields">
          <div class="field-row">
            <div class="field">
              <label>Type</label>
              <select id="f-adj-type"><option value="percent">Percent off</option><option value="flat">Flat dollar amount off</option></select>
            </div>
            <div class="field"><label>Value</label><input type="number" id="f-adj-value" placeholder="e.g. 10" min="0" step="0.01"></div>
          </div>
          <div class="field"><label>Reason (required — shows up in the audit report)</label><input type="text" id="f-adj-reason" placeholder="e.g. Board-approved discount for founding member"></div>
          <div class="card-sub" style="margin-bottom:0;">For a recurring booking, this same discount applies to every occurrence.</div>
        </div>
      </div>

      <div class="card">
        <h2>Date &amp; time</h2>
        <div class="card-sub">First occurrence. If this repeats, add the pattern below and adjust any date's time as needed.</div>
        <div class="field"><label>Date</label><input type="date" id="f-date"></div>
        <div class="field-row">
          <div class="field"><label>Start time</label><input type="time" id="f-start" value="14:00" list="common-times"></div>
          <div class="field"><label>End time</label><input type="time" id="f-end" value="16:00" list="common-times"></div>
        </div>


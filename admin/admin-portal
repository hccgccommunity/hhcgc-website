// POST /bookings/:id/approve-request — an admin approving a public booking
// request. Applies to the whole series if this occurrence is part of one.
// Moves 'requested' -> 'pending' and syncs the calendar now (not before —
// no point holding a slot for a request that might get rejected). From
// here it's a completely normal booking: Send Invoice, Mark Paid, etc.
async function approveBookingRequest(req, res, bookingId, actor) {
  const [rows] = await bigquery.query({ query: `SELECT * FROM \`${DATASET}.bookings\` WHERE booking_id = @bookingId`, params: { bookingId } });
  if (!rows.length) return res.status(404).json({ errors: ['Booking not found.'] });
  const first = rows[0];
  if (first.payment_status !== 'requested') return res.status(400).json({ errors: ['This booking is not awaiting approval.'] });

  const seriesId = first.recurring_series_id;
  const [occurrences] = seriesId
    ? await bigquery.query({ query: `SELECT * FROM \`${DATASET}.bookings\` WHERE recurring_series_id = @seriesId AND payment_status = 'requested'`, params: { seriesId } })
    : [[first]];

  const roomsList = await getActiveRooms();
  const roomsMap = {};
  roomsList.forEach(r => { roomsMap[r.name] = r; });
  const calendar = await getCalendarClient();
  const unwrap = v => (v && typeof v === 'object' && 'value' in v) ? v.value : v;

  for (const occRow of occurrences) {
    const eventDate = unwrap(occRow.event_date);
    const startTime = unwrap(occRow.start_time);
    const endTime = unwrap(occRow.end_time);
    const occ = { date: eventDate, startTime: String(startTime).slice(11, 16), endTime: String(endTime).slice(11, 16) };
    const { eventIds } = await syncOccurrenceToCalendar({ rooms: occRow.rooms, roomsMap, occ, renterName: occRow.renter_name, seriesLabel: unwrap(occRow.recurrence_summary) });
    await bigquery.query({
      query: `UPDATE \`${DATASET}.bookings\` SET payment_status = 'pending', calendar_event_ids = @eventIds, updated_at = CURRENT_TIMESTAMP() WHERE booking_id = @bookingId`,
      params: { eventIds, bookingId: occRow.booking_id },
      types: { eventIds: ['STRING'] }
    });
  }

  await logAudit({ action: 'booking_request_approved', entityType: 'booking', entityId: bookingId, actorEmail: actor.email, details: { occurrenceCount: occurrences.length } });
  res.json({ bookingId, occurrencesApproved: occurrences.length, status: 'pending' });
}

// POST /bookings/:id/reject-request — requires a reason, applies to the
// whole series, emails the renter with that reason.
async function rejectBookingRequest(req, res, bookingId, actor) {
  const reason = ((req.body && req.body.reason) || '').trim();
  if (!reason) return res.status(400).json({ errors: ['A reason is required when rejecting a booking request.'] });

  const [rows] = await bigquery.query({ query: `SELECT * FROM \`${DATASET}.bookings\` WHERE booking_id = @bookingId`, params: { bookingId } });
  if (!rows.length) return res.status(404).json({ errors: ['Booking not found.'] });
  const first = rows[0];
  if (first.payment_status !== 'requested') return res.status(400).json({ errors: ['This booking is not awaiting approval.'] });

  const seriesId = first.recurring_series_id;
  const whereClause = seriesId ? `recurring_series_id = @key AND payment_status = 'requested'` : `booking_id = @key`;
  await bigquery.query({
    query: `UPDATE \`${DATASET}.bookings\` SET payment_status = 'rejected', rejection_reason = @reason, updated_at = CURRENT_TIMESTAMP() WHERE ${whereClause}`,
    params: { reason, key: seriesId || bookingId }
  });

  await logAudit({ action: 'booking_request_rejected', entityType: 'booking', entityId: bookingId, actorEmail: actor.email, details: { reason } });

  if (first.renter_email) {
    try {
      await sendEmail({
        to: first.renter_email, cc: CC_EMAIL, subject: `Update on your HCCGC facility request`,
        htmlBody: `
          <div style="font-family: Arial, Helvetica, sans-serif; max-width: 560px; margin: 0 auto; color: #2c1b10; background: #fff9f1;">
            <div style="text-align:center; padding: 28px 20px 10px;">
              <img src="data:image/png;base64,${LOGO_BASE64}" width="90" height="90" alt="HCCGC" style="display:inline-block;">
            </div>
            <div style="padding: 10px 32px 32px;">
              <p>Namaste,</p>
              <p>Thank you for your interest in the Hindu Community Center of Greater Cincinnati. Unfortunately, we're not able to move forward with your request at this time.</p>
              <div style="background:#fff6ea; border-radius:8px; padding:12px 16px; margin: 14px 0; font-size:0.92rem;">${escapeHtml(reason)}</div>
              <p>If you have any questions, feel free to reach out to us at <a href="mailto:facility-rental@hccgc.org" style="color:#b55a18;">facility-rental@hccgc.org</a>.</p>
              <p style="margin-top:20px;">Warm Regards,<br>Team HCCGC</p>
            </div>
          </div>`
      });
    } catch (err) {
      console.error('Booking rejection email failed:', err.message);
    }
  }

  res.json({ bookingId, status: 'rejected' });
}


// PATCH /finance/categories/:id — rename or activate/deactivate. Default
// (seeded) categories can be deactivated but not deleted outright, so
// historical categorizations referencing them stay meaningful.
async function updateFinanceCategory(req, res, categoryId, actor) {
  const b = req.body || {};
  const [rows] = await bigquery.query({ query: `SELECT category_id FROM \`${DATASET}.transaction_categories\` WHERE category_id = @categoryId`, params: { categoryId } });
  if (!rows.length) return res.status(404).json({ errors: ['Category not found.'] });
  const sets = [];
  const params = { categoryId };
  if (b.name !== undefined) { sets.push('name = @name'); params.name = b.name; }
  if (b.active !== undefined) { sets.push('active = @active'); params.active = !!b.active; }
  if (!sets.length) return res.status(400).json({ errors: ['Nothing to update.'] });
  await bigquery.query({ query: `UPDATE \`${DATASET}.transaction_categories\` SET ${sets.join(', ')} WHERE category_id = @categoryId`, params });
  await logAudit({ action: 'finance_category_updated', entityType: 'category', entityId: categoryId, actorEmail: actor.email, details: b });
  res.json({ categoryId, ok: true });
}


<style>
:root {
  --bg: #fff9f1;
  --surface: #ffffff;
  --surface-soft: #fff6ea;
  --border: rgba(121,62,17,0.14);
  --text: #2c1b10;
  --muted: #6a5141;
  --saffron: #b55a18;
  --saffron-dark: #8d3e0d;
  --maroon: #7f2e16;
  --radius: 22px;
  --shadow: 0 18px 45px rgba(93,43,14,0.10);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: Arial, Helvetica, sans-serif;
  background:
    radial-gradient(circle at top left, rgba(217,138,30,0.12), transparent 22%),
    radial-gradient(circle at top right, rgba(127,46,22,0.05), transparent 20%),
    var(--bg);
  color: var(--text);
  min-height: 100vh;
}

.container { width: min(calc(100% - 32px), 1220px); margin: 0 auto; }

.page-hero {
  background: linear-gradient(135deg, var(--maroon) 0%, #4e1a09 100%);
  color: #fff;
  padding: 48px 0 42px;
  text-align: center;
}
.page-hero h2 {
  font-family: Georgia, "Times New Roman", serif;
  font-size: 2rem;
  margin-bottom: 10px;
  font-weight: 700;
}
.page-hero p {
  font-size: 0.95rem;
  opacity: 0.85;
  max-width: 520px;
  margin: 0 auto;
  line-height: 1.65;
}
.hero-badge {
  display: inline-block;
  background: rgba(255,255,255,0.15);
  border: 1px solid rgba(255,255,255,0.28);
  border-radius: 20px;
  padding: 4px 14px;
  font-size: 0.72rem;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  margin-bottom: 14px;
  font-weight: 700;
}

#gate { padding: 60px 16px; display: flex; justify-content: center; }
.gate-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 2.5rem 2rem;
  max-width: 420px;
  width: 100%;
  text-align: center;
  box-shadow: var(--shadow);
}
.gate-card h3 {
  font-family: Georgia, "Times New Roman", serif;
  font-size: 1.4rem;
  color: var(--maroon);
  margin-bottom: 0.5rem;
}
.gate-card > p { color: var(--muted); font-size: 0.88rem; line-height: 1.65; margin-bottom: 1.75rem; }

.btn-google {
  display: flex; align-items: center; justify-content: center; gap: 10px;
  width: 100%; padding: 0.72rem 1rem; background: #fff;
  border: 1.5px solid var(--border); border-radius: 10px;
  font-size: 0.95rem; font-weight: 600; color: #3c4043;
  cursor: pointer; transition: background 0.15s, box-shadow 0.15s;
  font-family: Arial, Helvetica, sans-serif;
}
.btn-google:hover { background: #f8f9fa; box-shadow: 0 1px 8px rgba(0,0,0,0.13); }
.btn-google:disabled { opacity: 0.6; cursor: not-allowed; }

.gate-note { margin-top: 1.2rem; font-size: 0.78rem; color: var(--muted); line-height: 1.5; }
.gate-note a { color: var(--saffron-dark); text-decoration: none; }
.gate-note a:hover { text-decoration: underline; }

#signin-error {
  display: none;
  color: #c0392b;
  background: #fdecea;
  border: 1px solid #f5c6cb;
  border-radius: 8px;
  padding: 10px 14px;
  font-size: 0.82rem;
  margin-top: 1rem;
  text-align: left;
}

#app { display: none; }

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  flex-wrap: wrap;
  margin: 2rem 0 1.5rem;
}
.toolbar-left h3 {
  font-family: Georgia, "Times New Roman", serif;
  font-size: 1.5rem;
  color: var(--maroon);
}
.toolbar-left p { font-size: 0.86rem; color: var(--muted); margin-top: 4px; }

/* VIEW TOGGLE */
.view-toggle {
  display: flex; gap: 0; border: 1.5px solid var(--border); border-radius: 10px; overflow: hidden;
}
.view-btn {
  padding: 0.45rem 0.9rem; border: none; background: #fff; color: var(--muted);
  font-size: 0.82rem; font-weight: 700; cursor: pointer; font-family: Arial, Helvetica, sans-serif;
  display: inline-flex; align-items: center; gap: 6px; transition: all 0.12s;
}
.view-btn:first-child { border-right: 1.5px solid var(--border); }
.view-btn.active { background: var(--maroon); color: #fff; }
.view-btn:not(.active):hover { background: var(--surface-soft); color: var(--saffron-dark); }

/* CALENDAR */
.calendar-wrap { background: #fff; border: 1px solid var(--border); border-radius: 16px; overflow: hidden; margin-bottom: 2rem; }
.cal-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 1rem 1.4rem; border-bottom: 1px solid var(--border); background: var(--surface-soft);
}
.cal-header h3 { font-family: Georgia, serif; font-size: 1.1rem; color: var(--maroon); }
.cal-nav { display: flex; gap: 6px; }
.cal-nav-btn {
  width: 32px; height: 32px; border-radius: 8px; border: 1px solid var(--border);
  background: #fff; cursor: pointer; display: flex; align-items: center; justify-content: center;
  font-size: 1rem; color: var(--muted);
}
.cal-nav-btn:hover { border-color: var(--saffron); color: var(--saffron-dark); }
.cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); }
.cal-day-label {
  text-align: center; padding: 8px 4px; font-size: 0.72rem; font-weight: 700;
  color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em;
  border-bottom: 1px solid var(--border);
}
.cal-cell {
  min-height: 80px; padding: 6px; border-right: 1px solid var(--border);
  border-bottom: 1px solid var(--border); vertical-align: top; position: relative;
  cursor: default;
}
.cal-cell:nth-child(7n) { border-right: none; }
.cal-cell.other-month { background: #fafafa; }
.cal-cell.today { background: rgba(181,90,24,0.05); }
.cal-date {
  font-size: 0.78rem; font-weight: 700; color: var(--muted); margin-bottom: 4px;
  width: 22px; height: 22px; display: flex; align-items: center; justify-content: center;
  border-radius: 50%;
}
.cal-cell.today .cal-date { background: var(--maroon); color: #fff; }
.cal-event-dot {
  font-size: 0.68rem; line-height: 1.3; padding: 2px 5px; border-radius: 4px;
  margin-bottom: 2px; cursor: pointer; white-space: nowrap; overflow: hidden;
  text-overflow: ellipsis; font-weight: 600;
}
.cal-event-dot.type-event { background: rgba(127,46,22,0.12); color: var(--maroon); }
.cal-event-dot.type-initiative { background: rgba(181,90,24,0.12); color: var(--saffron-dark); }
.cal-more { font-size: 0.68rem; color: var(--muted); padding: 1px 4px; cursor: pointer; }
.cal-more:hover { color: var(--saffron-dark); }

/* DAY DETAIL PANEL */
.day-detail {
  display: none; padding: 1rem 1.4rem; border-top: 1px solid var(--border); background: var(--surface-soft);
}
.day-detail.show { display: block; }
.day-detail h4 { font-family: Georgia, serif; font-size: 1rem; color: var(--maroon); margin-bottom: 10px; }
.day-event-row {
  display: flex; align-items: center; gap: 12px; padding: 8px 0;
  border-bottom: 1px dashed var(--border);
}
.day-event-row:last-child { border-bottom: none; }
.day-event-name { font-size: 0.86rem; font-weight: 700; color: var(--text); flex: 1; }
.day-event-time { font-size: 0.78rem; color: var(--muted); }
.day-event-actions { display: flex; gap: 6px; }


.user-chip {
  display: flex; align-items: center; gap: 10px;
  background: #fff; border: 1px solid var(--border);
  border-radius: 999px; padding: 6px 14px 6px 6px;
}
.user-avatar {
  width: 30px; height: 30px; border-radius: 50%;
  background: var(--maroon); color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.72rem; font-weight: 700; flex-shrink: 0;
  overflow: hidden;
}
.user-avatar img { width: 100%; height: 100%; object-fit: cover; }
.user-name { font-size: 0.82rem; font-weight: 700; }
.btn-signout {
  background: none; border: none; font-size: 0.72rem; color: var(--muted);
  cursor: pointer; padding: 2px 4px; font-family: Arial, Helvetica, sans-serif;
}
.btn-signout:hover { color: var(--maroon); }

.btn-add {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 0.7rem 1.4rem; background: var(--maroon); color: #fff;
  border: none; border-radius: 999px; font-size: 0.9rem; font-weight: 700;
  cursor: pointer; font-family: Arial, Helvetica, sans-serif;
  transition: background 0.15s, transform 0.1s;
}
.btn-add:hover { background: #5a1e0a; }
.btn-add:active { transform: scale(0.98); }

.status-bar {
  display: none; align-items: center; gap: 10px;
  padding: 0.75rem 1.1rem; border-radius: 12px;
  font-size: 0.86rem; font-weight: 600; margin-bottom: 1.25rem;
}
.status-bar.show { display: flex; }
.status-bar.success { background: #e8f5e9; color: #2e7d32; border: 1px solid #c8e6c9; }
.status-bar.error { background: #fdecea; color: #c0392b; border: 1px solid #f5c6cb; }
.status-bar.info { background: var(--surface-soft); color: var(--saffron-dark); border: 1px solid var(--border); }

.events-list { display: flex; flex-direction: column; gap: 14px; margin-bottom: 1.5rem; }

.event-row {
  background: #fff; border: 1px solid var(--border); border-radius: 16px;
  padding: 1.25rem 1.5rem; display: grid; grid-template-columns: 1fr auto;
  gap: 16px; align-items: start; box-shadow: 0 4px 16px rgba(93,43,14,0.05);
}
.event-row.is-past { opacity: 0.6; background: var(--surface-soft); }

.past-badge {
  display: inline-block; background: rgba(108,108,108,0.12); color: #6a5141;
  border: 1px solid var(--border); padding: 3px 10px; border-radius: 999px;
  font-size: 0.7rem; font-weight: 800; text-transform: uppercase;
  letter-spacing: 0.04em; margin-left: 8px;
}

.event-row-main h4 {
  font-family: Georgia, "Times New Roman", serif;
  color: var(--maroon); font-size: 1.15rem; margin-bottom: 6px;
}
.event-row-meta {
  display: flex; flex-wrap: wrap; gap: 12px; font-size: 0.82rem;
  color: var(--saffron-dark); font-weight: 700; margin-bottom: 8px;
}
.event-row-desc { font-size: 0.88rem; color: var(--muted); line-height: 1.55; margin-bottom: 6px; }
.event-row-link { font-size: 0.8rem; color: var(--muted); word-break: break-all; }
.event-row-link a { color: var(--saffron-dark); }
.event-row-created {
  font-size: 0.74rem; color: var(--muted); opacity: 0.8; margin-top: 6px;
  border-top: 1px dashed var(--border); padding-top: 6px;
}

.event-row-actions { display: flex; flex-direction: column; gap: 8px; flex-shrink: 0; }

.btn-icon {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 0.45rem 0.8rem; border: 1px solid var(--border); border-radius: 8px;
  background: #fff; font-size: 0.78rem; font-weight: 600; color: var(--muted);
  cursor: pointer; font-family: Arial, Helvetica, sans-serif;
  transition: all 0.12s; white-space: nowrap;
}
.btn-icon:hover { border-color: var(--saffron); color: var(--saffron-dark); }
.btn-icon.danger:hover { border-color: #c0392b; color: #c0392b; }

.empty-state {
  text-align: center; padding: 50px 20px; color: var(--muted);
  background: #fff; border: 1px dashed var(--border); border-radius: 16px;
}

.section-divider {
  display: flex; align-items: center; gap: 10px; margin: 2rem 0 1rem;
  cursor: pointer; user-select: none;
}
.section-divider .line { flex: 1; height: 1px; background: var(--border); }
.section-divider span.label {
  font-size: 0.8rem; font-weight: 700; color: var(--muted);
  text-transform: uppercase; letter-spacing: 0.06em; white-space: nowrap;
}
.section-divider .chevron { transition: transform 0.15s; color: var(--muted); }
.section-divider.collapsed .chevron { transform: rotate(-90deg); }
.past-events-list { display: flex; flex-direction: column; gap: 14px; }
.past-events-list.collapsed { display: none; }

.modal-overlay {
  display: none; position: fixed; inset: 0; background: rgba(44,27,16,0.45);
  z-index: 200; align-items: center; justify-content: center; padding: 20px;
}
.modal-overlay.show { display: flex; }
.modal-card {
  background: #fff; border-radius: 18px; max-width: 540px; width: 100%;
  max-height: 90vh; overflow-y: auto; box-shadow: var(--shadow);
}
.modal-header {
  padding: 1.4rem 1.6rem; border-bottom: 1px solid var(--border);
  display: flex; align-items: center; justify-content: space-between;
}
.modal-header h3 {
  font-family: Georgia, "Times New Roman", serif;
  color: var(--maroon); font-size: 1.2rem;
}
.modal-close {
  background: none; border: none; cursor: pointer;
  color: var(--muted); font-size: 1.3rem; line-height: 1; padding: 4px;
}
.modal-close:hover { color: var(--maroon); }
.modal-tab {
  padding: 0.75rem 1.1rem; font-size: 0.86rem; font-weight: 700;
  color: var(--muted); cursor: pointer; border: none; background: none;
  border-bottom: 2.5px solid transparent; margin-bottom: -1px;
  font-family: Arial, Helvetica, sans-serif; transition: color 0.12s;
}
.modal-tab.active { color: var(--maroon); border-bottom-color: var(--maroon); }
.modal-tab:hover { color: var(--saffron-dark); }
.modal-panel { display: none; }
.modal-panel.active { display: block; }

.modal-body { padding: 1.5rem 1.6rem; }

.form-group { margin-bottom: 1.1rem; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }

label { display: block; font-size: 0.82rem; font-weight: 700; color: var(--text); margin-bottom: 0.4rem; }

input[type="text"], input[type="date"], input[type="time"], select, textarea {
  width: 100%; padding: 0.6rem 0.85rem;
  border: 1.5px solid var(--border); border-radius: 10px;
  font-size: 0.9rem; font-family: Arial, Helvetica, sans-serif;
  background: #fff; color: var(--text);
  transition: border-color 0.15s, box-shadow 0.15s;
}
input:focus, textarea:focus, select:focus {
  outline: none; border-color: var(--saffron);
  box-shadow: 0 0 0 3px rgba(181,90,24,0.14);
}
textarea { resize: vertical; }

.type-toggle {
  display: flex;
  gap: 8px;
  margin-top: 4px;
}
.type-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  padding: 0.65rem 0.8rem;
  border: 1.5px solid var(--border);
  border-radius: 10px;
  background: #fff;
  color: var(--muted);
  font-size: 0.86rem;
  font-weight: 700;
  cursor: pointer;
  font-family: Arial, Helvetica, sans-serif;
  transition: all 0.12s;
  text-align: center;
}
.type-btn:hover { border-color: var(--saffron); color: var(--saffron-dark); }
.type-btn.active { background: var(--maroon); border-color: var(--maroon); color: #fff; }
.type-btn.active svg { filter: brightness(10); }

.initiative-badge {
  display: inline-block;
  background: rgba(127,46,22,0.1);
  color: var(--maroon);
  border: 1px solid rgba(127,46,22,0.2);
  padding: 3px 10px;
  border-radius: 999px;
  font-size: 0.7rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  margin-left: 8px;
}

.field-error { font-size: 0.76rem; color: #c0392b; margin-top: 4px; display: none; }
.field-error.show { display: block; }

.modal-footer {
  padding: 1.2rem 1.6rem 1.5rem; display: flex; justify-content: flex-end;
  gap: 10px; border-top: 1px solid var(--border);
}

.btn-secondary {
  padding: 0.65rem 1.3rem; border-radius: 10px; border: 1.5px solid var(--border);
  background: #fff; color: var(--muted); font-weight: 700; font-size: 0.88rem;
  cursor: pointer; font-family: Arial, Helvetica, sans-serif;
}
.btn-secondary:hover { border-color: var(--saffron); color: var(--saffron-dark); }

.btn-save {
  padding: 0.65rem 1.5rem; border-radius: 10px; border: none;
  background: var(--maroon); color: #fff; font-weight: 700; font-size: 0.88rem;
  cursor: pointer; font-family: Arial, Helvetica, sans-serif;
  display: inline-flex; align-items: center; gap: 8px;
}
.btn-save:hover { background: #5a1e0a; }
.btn-save:disabled { background: #b8907e; cursor: not-allowed; }

.spinner {
  width: 14px; height: 14px; border: 2px solid rgba(255,255,255,0.4);
  border-top-color: #fff; border-radius: 50%; animation: spin 0.7s linear infinite;
  display: inline-block; flex-shrink: 0;
}
@keyframes spin { to { transform: rotate(360deg); } }

@media (max-width: 640px) {
  .event-row { grid-template-columns: 1fr; }
  .event-row-actions { flex-direction: row; }
  .form-row { grid-template-columns: 1fr; }
  .toolbar { flex-direction: column; align-items: stretch; }
}

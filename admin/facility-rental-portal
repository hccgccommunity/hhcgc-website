function render() {
  const tbody = document.getElementById('bookings-tbody');
  const emptyState = document.getElementById('ab-empty-state');
  const filteredBookings = BOOKINGS.filter(matchesFilters);
  const allItems = sortDisplayItems(groupIntoDisplayItems(filteredBookings));

  const totalPages = Math.max(1, Math.ceil(allItems.length / state.pageSize));
  if (state.page > totalPages) state.page = totalPages;
  if (state.page < 1) state.page = 1;
  const pageStart = (state.page - 1) * state.pageSize;
  const items = allItems.slice(pageStart, pageStart + state.pageSize);

  document.getElementById('result-count').textContent =
    filteredBookings.length + (filteredBookings.length === 1 ? ' booking' : ' bookings') +
    (allItems.length !== filteredBookings.length ? ' (' + allItems.length + ' rows, grouped)' : '');

  renderTableHead();
  renderPaginationBar(totalPages);

  if (items.length === 0) {
    tbody.innerHTML = '';
    emptyState.style.display = 'block';
    return;
  }
  emptyState.style.display = 'none';

  tbody.innerHTML = items.map(function (item) {
    if (item.type === 'single') return renderBookingRow(item.booking, false);
    const summary = renderSeriesSummaryRow(item);
    if (!expandedSeries.has(item.seriesId)) return summary;
    return summary + item.occurrences.map(function (occ) { return renderBookingRow(occ, true, item.payment_status === 'mixed'); }).join('');
  }).join('');
}

function renderPaginationBar(totalPages) {
  const bar = document.getElementById('pagination-bar');
  if (totalPages <= 1) { bar.innerHTML = ''; return; }
  bar.innerHTML =
    '<button ' + (state.page <= 1 ? 'disabled' : '') + ' onclick="goToPage(' + (state.page - 1) + ')">&lsaquo; Prev</button>' +
    '<span class="page-indicator">Page ' + state.page + ' of ' + totalPages + '</span>' +
    '<button ' + (state.page >= totalPages ? 'disabled' : '') + ' onclick="goToPage(' + (state.page + 1) + ')">Next &rsaquo;</button>';
}
function goToPage(p) {
  state.page = p;
  render();
  document.querySelector('.table-wrap').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

// ---- Generic per-row actions menu (kebab button + dropdown) — replaces
// the old stack of individual buttons, which got unwieldy once a row could
// have 5-6 possible actions at once. ----
let ROW_ACTIONS_REGISTRY = {};
function renderActionsKebab(rowId, actions) {
  ROW_ACTIONS_REGISTRY[rowId] = actions;
  if (!actions.length) return '<span style="font-size:0.7rem;color:var(--muted);">&mdash;</span>';
  return '<button class="btn-kebab" onclick="toggleActionsMenu(event, \'' + rowId + '\')">&#8942;</button>' +
    '<div class="actions-menu" id="actions-menu-' + rowId + '"></div>';
}
function toggleActionsMenu(evt, rowId) {
  evt.stopPropagation();
  document.querySelectorAll('.actions-menu.open').forEach(function (el) {
    if (el.id !== 'actions-menu-' + rowId) el.classList.remove('open');
  });
  const menu = document.getElementById('actions-menu-' + rowId);
  const willOpen = !menu.classList.contains('open');
  if (willOpen) {
    const actions = ROW_ACTIONS_REGISTRY[rowId] || [];
    menu.innerHTML = actions.map(function (a, i) {
      return '<button class="' + (a.danger ? 'danger' : '') + '" onclick="runRowAction(\'' + rowId + '\', ' + i + ')">' + a.label + '</button>';
    }).join('');
    // Reparent to <body> directly — a position:fixed element only escapes
    // an ancestor's stacking context if NO ancestor between it and body
    // has a transform/filter/perspective/will-change set. Moving it to be
    // a direct child of body sidesteps that entirely, guaranteeing it
    // renders above any modal overlay regardless of which ancestor was
    // trapping it before.
    document.body.appendChild(menu);
    const rect = evt.target.getBoundingClientRect();
    menu.style.left = Math.max(8, rect.right - 190) + 'px';
    // Render first (off-screen positioning doesn't matter yet) so we can
    // measure its real height, then decide whether it fits below the
    // button or needs to open upward instead — otherwise a menu opened
    // near the bottom of the page renders partly hidden under the footer.
    menu.style.top = '-9999px';
    menu.classList.add('open');
    const menuHeight = menu.getBoundingClientRect().height;
    const spaceBelow = window.innerHeight - rect.bottom;
    if (spaceBelow < menuHeight + 20) {
      menu.style.top = Math.max(8, rect.top - menuHeight - 6) + 'px';
    } else {
      menu.style.top = (rect.bottom + 6) + 'px';
    }
  } else {
    menu.classList.remove('open');
  }
}
function runRowAction(rowId, index) {
  const menu = document.getElementById('actions-menu-' + rowId);
  if (menu) menu.classList.remove('open');
  const actions = ROW_ACTIONS_REGISTRY[rowId] || [];
  if (actions[index]) actions[index].fn();
}
document.addEventListener('click', function () {
  document.querySelectorAll('.actions-menu.open').forEach(function (el) { el.classList.remove('open'); });
});

async function viewDocument(bookingId, kind) {
  try {
    const res = await authedFetch(API_BASE + '/bookings/' + encodeURIComponent(bookingId) + '/' + kind + '-preview');
    if (!res.ok) {
      const data = await res.json().catch(function () { return {}; });
      alert('Could not load ' + kind + ': ' + ((data.errors || [data.error]).join(' ') || 'unknown error'));
      return;
    }
    const html = await res.text();
    const blob = new Blob([html], { type: 'text/html' });
    const url = URL.createObjectURL(blob);
    window.open(url, '_blank');
    setTimeout(function () { URL.revokeObjectURL(url); }, 30000);
  } catch (err) {
    alert('Could not reach the booking system: ' + err.message);
  }
}
async function downloadDocument(bookingId, kind) {
  try {
    const res = await authedFetch(API_BASE + '/bookings/' + encodeURIComponent(bookingId) + '/' + kind + '-preview');
    if (!res.ok) {
      const data = await res.json().catch(function () { return {}; });
      alert('Could not generate ' + kind + ': ' + ((data.errors || [data.error]).join(' ') || 'unknown error'));
      return;
    }
    const html = await res.text();
    const blob = new Blob([html], { type: 'text/html' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = kind + '-' + bookingId + '.html';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  } catch (err) {
    alert('Could not reach the booking system: ' + err.message);
  }
}


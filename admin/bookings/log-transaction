
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Log Transaction — HCCGC Admin Portal</title>
<link rel="icon" type="image/x-icon" href="/favicon.ico">
<script async src="https://www.googletagmanager.com/gtag/js?id=G-F5ZHQ4CDR9"></script>
<script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-F5ZHQ4CDR9');</script>
<style>
:root {
  --bg: #fff9f1; --surface: #ffffff; --surface-soft: #fff6ea; --border: rgba(121,62,17,0.14);
  --text: #2c1b10; --muted: #6a5141; --saffron: #b55a18; --saffron-dark: #8d3e0d; --maroon: #7f2e16;
  --radius: 22px; --shadow: 0 18px 45px rgba(93,43,14,0.10);
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: Arial, Helvetica, sans-serif; background: radial-gradient(circle at top left, rgba(217,138,30,0.12), transparent 22%), radial-gradient(circle at top right, rgba(127,46,22,0.05), transparent 20%), var(--bg); color: var(--text); min-height: 100vh; }
.container { width: min(calc(100% - 32px), 900px); margin: 0 auto; }
.site-header { position: sticky; top: 0; z-index: 50; background: rgba(255,249,241,0.92); backdrop-filter: blur(10px); border-bottom: 1px solid var(--border); }
.nav { display: flex; align-items: center; justify-content: space-between; gap: 24px; min-height: 92px; padding: 12px 0; }
.site-header a.brand, .site-header a.brand:link, .site-header a.brand:visited { text-decoration: none; color: inherit; }
.brand { display: flex; align-items: center; gap: 16px; min-width: 0; }
.brand-logo-wrap { background: #fff; border: 1px solid var(--border); border-radius: 18px; padding: 8px; box-shadow: var(--shadow); flex-shrink: 0; }
.brand-logo { width: 88px; height: auto; border-radius: 12px; object-fit: contain; }
.brand-text h1 { margin: 0; font-size: 1.2rem; line-height: 1.15; color: var(--maroon); }
.site-header nav ul { list-style: none; display: flex; flex-wrap: wrap; gap: 18px; margin: 0; padding: 0; align-items: center; justify-content: flex-end; }
.site-header nav a, .site-header nav a:link, .site-header nav a:visited { font-weight: 700; color: var(--text); font-size: 0.96rem; text-decoration: none; }
.site-header nav a:hover { color: var(--saffron-dark); }
.menu-toggle { display: none; border: 0; background: transparent; padding: 6px 0; cursor: pointer; color: #2c1b10; align-self: flex-end; }
.menu-toggle .bar { display: block; width: 26px; height: 2px; margin: 5px 0; background: currentColor; }
@media (max-width: 768px) {
  .nav { flex-direction: column; align-items: stretch; gap: 8px; } .menu-toggle { display: inline-block; }
  .site-header nav { display: none; width: 100%; background: rgba(255,249,241,0.95); padding: 10px 0; }
  .site-header nav.is-open { display: block; } .site-header nav ul { flex-direction: column; gap: 14px; }
}
.page-hero { padding: 40px 0 28px; background: linear-gradient(135deg, var(--maroon) 0%, #4e1a09 100%); color: #fff; }
.page-hero .eyebrow { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.08em; color: rgba(255,255,255,0.75); margin-bottom: 6px; }
.page-hero h1 { font-family: Georgia, "Times New Roman", serif; font-size: 1.9rem; color: #fff; margin-bottom: 6px; }
.page-hero p { color: #ffffff; opacity: 0.9; font-size: 0.92rem; max-width: 560px; }
.module-nav { background: var(--surface); border-bottom: 1px solid var(--border); }
.module-nav ul { list-style: none; display: flex; gap: 4px; padding: 10px 0; flex-wrap: wrap; }
.module-nav a { display: inline-block; padding: 8px 16px; border-radius: 999px; font-size: 0.86rem; font-weight: 700; color: var(--muted); text-decoration: none; transition: background 0.15s, color 0.15s; }
.module-nav a.active { background: var(--surface-soft); color: var(--saffron-dark); }
.module-nav a:not(.active):hover { background: var(--surface-soft); }

.card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 28px; box-shadow: var(--shadow); margin: 24px 0; }
.card h2 { font-family: Georgia, "Times New Roman", serif; font-size: 1.2rem; color: var(--maroon); margin-bottom: 4px; }
.card .card-sub { font-size: 0.82rem; color: var(--muted); margin-bottom: 18px; }

.reminder-note { background: #fdf1de; color: #a15c00; border: 1px solid rgba(161,92,0,0.2); border-radius: 12px; padding: 12px 16px; font-size: 0.84rem; margin-bottom: 20px; }
.reminder-note a { color: #a15c00; font-weight: 700; }

.field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 14px; }
.field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px; }
.field label { font-size: 0.78rem; font-weight: 700; color: var(--muted); }
.field input[type="text"], .field input[type="date"], .field input[type="number"], .field select, .field textarea {
  font-family: Arial, Helvetica, sans-serif; font-size: 0.9rem; padding: 10px 12px; border: 1.5px solid var(--border); border-radius: 10px; background: #fff; color: var(--text);
}
.field textarea { resize: vertical; min-height: 60px; }
.type-toggle { display: flex; gap: 8px; margin-bottom: 14px; }
.type-toggle button {
  flex: 1; padding: 10px; border-radius: 10px; border: 1.5px solid var(--border); background: #fff;
  font-family: Arial, Helvetica, sans-serif; font-size: 0.86rem; font-weight: 700; color: var(--muted); cursor: pointer;
}
.type-toggle button.active.income { border-color: #2e7d4f; color: #2e7d4f; background: #e8f5ec; }
.type-toggle button.active.expense { border-color: #b3382c; color: #b3382c; background: #fbe9e7; }

.btn-primary {
  font-family: Arial, Helvetica, sans-serif; font-size: 0.92rem; font-weight: 700; color: #fff;
  background: linear-gradient(135deg, var(--saffron-dark), var(--maroon)); border: none; border-radius: 12px;
  padding: 13px 20px; cursor: pointer; width: 100%; margin-top: 4px;
}
.btn-primary:hover { opacity: 0.92; }

.result-box { margin-top: 16px; border-radius: 12px; padding: 12px 16px; font-size: 0.86rem; line-height: 1.5; }
.result-box.success { background: #e8f5ec; color: #2e7d4f; border: 1px solid rgba(46,125,79,0.25); }
.result-box.error { background: #fbe9e7; color: #b3382c; border: 1px solid rgba(179,56,44,0.25); }
#gate{padding:60px 16px;display:flex;justify-content:center;}
.gate-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:2.5rem 2rem;max-width:420px;width:100%;text-align:center;box-shadow:var(--shadow);}
.gate-card h3{font-family:Georgia,serif;font-size:1.3rem;color:var(--maroon);margin-bottom:.5rem;}
.gate-card p{color:var(--muted);font-size:.88rem;line-height:1.6;}
.gate-card a{color:var(--saffron-dark);}
.back-link { display: inline-flex; align-items: center; gap: 6px; font-size: 0.82rem; font-weight: 700; color: rgba(255,255,255,0.85); text-decoration: none; margin-bottom: 14px; }
.back-link:hover { color: #fff; text-decoration: underline; }
</style>
</head>
<body>
<div id="site-header"></div>

<div id="gate">
  <div class="gate-card">
    <h3>Checking access&hellip;</h3>
    <p>Please sign in from the <a href="/admin/admin-portal">Admin Portal</a> first.</p>
  </div>
</div>

<div id="app">

<div class="page-hero">
  <div class="container">
    <a class="back-link" href="https://hccgc.org/admin/admin-portal">&larr; Back to apps</a>
    <div class="eyebrow">Facility Bookings</div>
    <h1>Log Transaction</h1>
    <p>For income and expenses that aren't tied to a facility booking — donations, Zelle transfers, cash, other initiatives.</p>
  </div>
</div>

<div class="module-nav">
  <div class="container">
    <ul>
      <li><a href="new-booking">New Booking</a></li>
      <li><a href="all-bookings">All Bookings</a></li>
      <li><a href="rooms-rates">Rooms &amp; Rates</a></li>
      <li><a href="log-transaction" class="active">Log Transaction</a></li>
      <li><a href="add-renter">Add A Renter</a></li>
    </ul>
  </div>
</div>

<div class="container">
  <div class="card">
    <div class="reminder-note">
      If this is actually paying off a facility booking, don't log it here — go to <a href="all-bookings">All Bookings</a> and mark that booking paid instead. Logging it in both places double-counts the revenue.
    </div>

    <h2>Transaction details</h2>
    <div class="card-sub">Choose income or expense, then fill in the rest.</div>

    <div class="type-toggle">
      <button type="button" id="btn-type-income" class="active income">Income</button>
      <button type="button" id="btn-type-expense" class="expense">Expense</button>
    </div>

    <div class="field-row">
      <div class="field"><label>Date</label><input type="date" id="f-date"></div>
      <div class="field"><label>Amount</label><input type="number" id="f-amount" placeholder="100.00" step="0.01" min="0"></div>
    </div>

    <div class="field-row">
      <div class="field">
        <label>Initiative</label>
        <select id="f-initiative">
          <option value="Donations">Donations</option>
          <option value="Sangeet Sandhya">Sangeet Sandhya</option>
          <option value="Dharma 101">Dharma 101</option>
          <option value="General Operations">General Operations</option>
        </select>
      </div>
      <div class="field">
        <label>Source</label>
        <select id="f-source">
          <option value="zelle">Zelle</option>
          <option value="cash">Cash</option>
          <option value="check">Check</option>
          <option value="bank">Bank (direct)</option>
          <option value="manual">Other / manual</option>
        </select>
      </div>
    </div>

    <div class="field"><label>Description</label><textarea id="f-description" placeholder="What is this? e.g. Zelle donation from the Menon family for Diwali celebration"></textarea></div>
    <div class="field"><label>Entered by</label><div id="f-entered-by-display" style="padding:9px 12px;background:var(--surface-soft);border-radius:10px;font-size:0.86rem;color:var(--muted);">Signed in as &mdash;</div></div>

    <button type="button" class="btn-primary" id="btn-generate">Log transaction</button>

    <div class="result-box" id="result-box" style="display:none;"></div>
  </div>
</div>

</div>

<div id="site-footer"></div>

<script>
const API_BASE = 'PASTE_YOUR_CLOUD_FUNCTION_URL_HERE'; // e.g. https://us-central1-dharma-nidi-darshan.cloudfunctions.net/api

async function authedFetch(url, options) {
  options = options || {};
  var user = window.__hccgcFirebaseUser;
  if (!user) throw new Error('Not signed in.');
  var token = await user.getIdToken();
  options.headers = Object.assign({}, options.headers, { 'Authorization': 'Bearer ' + token });
  return fetch(url, options);
}


let currentType = 'income';
document.getElementById('btn-type-income').addEventListener('click', function () {
  currentType = 'income';
  this.classList.add('active');
  document.getElementById('btn-type-expense').classList.remove('active');
});
document.getElementById('btn-type-expense').addEventListener('click', function () {
  currentType = 'expense';
  this.classList.add('active');
  document.getElementById('btn-type-income').classList.remove('active');
});

async function loadInitiatives() {
  try {
    const res = await authedFetch(API_BASE + '/initiatives');
    if (!res.ok) throw new Error('Server returned ' + res.status);
    const rows = await res.json();
    const select = document.getElementById('f-initiative');
    select.innerHTML = rows.map(function (r) { return '<option value="' + r.name + '">' + r.name + '</option>'; }).join('');
  } catch (err) {
    showResult('error', 'Could not load initiatives from the database (' + err.message + '). Showing defaults — check before saving.');
  }
}
// loadInitiatives() is intentionally NOT called here — moved into the auth
// gate's success handler below, since it needs a valid sign-in token first.

function showResult(type, message) {
  const box = document.getElementById('result-box');
  box.style.display = 'block';
  box.className = 'result-box ' + type;
  box.textContent = message;
}

document.getElementById('btn-generate').addEventListener('click', async function () {
  const btn = this;
  const payload = {
    date: document.getElementById('f-date').value,
    amount: parseFloat(document.getElementById('f-amount').value),
    type: currentType,
    initiativeName: document.getElementById('f-initiative').value,
    source: document.getElementById('f-source').value,
    description: document.getElementById('f-description').value
  };
  if (!payload.date || !payload.amount) { showResult('error', 'Date and amount are required.'); return; }

  btn.disabled = true; btn.textContent = 'Saving…';
  try {
    const res = await authedFetch(API_BASE + '/transactions', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (!res.ok) {
      showResult('error', (data.errors || [data.error || 'Something went wrong.']).join(' '));
    } else {
      showResult('success', 'Transaction logged.');
      document.getElementById('f-amount').value = '';
      document.getElementById('f-description').value = '';
    }
  } catch (err) {
    showResult('error', 'Could not reach the server: ' + err.message);
  } finally {
    btn.disabled = false; btn.textContent = 'Log transaction';
  }
});

function loadPartial(id, file) {
  var target = document.getElementById(id);
  if (!target) return;
  fetch(file).then(function (r) { return r.text(); }).then(function (html) {
    target.innerHTML = html;
    if (id === 'site-header') fixHeaderLinksForSubfolder(target);
  }).catch(function () {});
}
function fixHeaderLinksForSubfolder(headerEl) {
  var logo = headerEl.querySelector('.brand-logo');
  if (logo && logo.getAttribute('src') && !logo.getAttribute('src').startsWith('/') && !logo.getAttribute('src').startsWith('http')) {
    logo.setAttribute('src', '/' + logo.getAttribute('src'));
  }
  headerEl.querySelectorAll('a[href]').forEach(function (link) {
    var href = link.getAttribute('href');
    if (!href || href.startsWith('http') || href.startsWith('/') || href.startsWith('#')) return;
    link.setAttribute('href', '/' + href);
  });
}
loadPartial('site-header', '/header.html');
loadPartial('site-footer', '/footer.html');
</script>

<script type="module">
import { initializeApp } from 'https://www.gstatic.com/firebasejs/12.15.0/firebase-app.js';
import { getAuth, onAuthStateChanged } from 'https://www.gstatic.com/firebasejs/12.15.0/firebase-auth.js';
import { getFirestore, doc, getDoc } from 'https://www.gstatic.com/firebasejs/12.15.0/firebase-firestore.js';

var firebaseConfig = {
  apiKey: 'AIzaSyA6IzLjWTg7Rq04HsTH-iA3eDmSzKI7xME',
  authDomain: 'hccgc-a7a54.firebaseapp.com',
  projectId: 'hccgc-a7a54',
  storageBucket: 'hccgc-a7a54.firebasestorage.app',
  messagingSenderId: '75757201418',
  appId: '1:75757201418:web:c31e9361921242145717f3'
};

var ALLOWED_DOMAIN = 'hccgc.org';
var REQUIRED_APP_KEY = 'bookings-finance';
var PORTAL_URL = '/admin/admin-portal';

var fbApp = initializeApp(firebaseConfig);
var auth = getAuth(fbApp);
var db = getFirestore(fbApp);

function showGate(title, msg) {
  document.getElementById('gate').querySelector('h3').textContent = title;
  document.getElementById('gate').querySelector('p').innerHTML = msg;
  document.getElementById('gate').style.display = 'flex';
  document.getElementById('app').style.display = 'none';
}

onAuthStateChanged(auth, function(user) {
  if (!user) { showGate('Sign in required', 'Please sign in from the <a href="'+PORTAL_URL+'">Admin Portal</a> first.'); return; }
  var email = (user.email||'').toLowerCase();
  window.__hccgcCurrentUser = { email: email };
  window.__hccgcFirebaseUser = user;
  if (!email.endsWith('@'+ALLOWED_DOMAIN)) { showGate('Access denied', 'Please use an @'+ALLOWED_DOMAIN+' account.'); return; }
  getDoc(doc(db, 'portalUsers', email)).then(function(snap) {
    var data = snap.exists() ? snap.data() : {};
    if (!data.isAdmin && !(Array.isArray(data.allowedApps) && data.allowedApps.includes(REQUIRED_APP_KEY))) {
      showGate('Access not granted', "You don't have access to Facility Bookings. Ask an admin to grant it.");
      return;
    }
    document.getElementById('gate').style.display = 'none';
    document.getElementById('app').style.display = 'block';
    var entryDisplay = document.getElementById('f-entered-by-display');
    if (entryDisplay) entryDisplay.textContent = 'Signed in as ' + email;
    loadInitiatives();
  }).catch(function() { showGate('Error', 'Could not verify access. Please try again.'); });
});
</script>
</body>
</html>

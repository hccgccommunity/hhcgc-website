// GET /finance/expense-receipt-url/:lineItemId — a short-lived signed URL
// for viewing one receipt, generated on demand rather than making anything
// in the bucket publicly readable.
// GET /finance/expense-receipt-image/:lineItemId — streams the receipt's
// actual bytes through this API (authenticated the same way as everything
// else here) rather than exposing a Drive link. Keeps receipts off any
// public/shared Drive URL — the file itself never needs to be shared
// beyond the impersonated mailbox that already owns it.
async function streamReceiptImage(req, res, lineItemId) {
  const [rows] = await bigquery.query({ query: `SELECT receipt_url FROM \`${DATASET}.expense_line_items\` WHERE line_item_id = @lineItemId`, params: { lineItemId } });
  if (!rows.length || !rows[0].receipt_url) return res.status(404).json({ errors: ['Receipt not found.'] });
  const url = rows[0].receipt_url;

  const driveMatch = url.match(/[?&]id=([^&]+)/);
  if (!driveMatch) {
    // Historical import — an external (non-Drive) link we don't control
    // and can't proxy. Nothing to stream; the frontend falls back to a
    // plain link for these.
    return res.status(200).json({ externalUrl: url });
  }
  const fileId = driveMatch[1];

  try {
    const drive = await getDriveClientAsFacilityRental();
    const meta = await drive.files.get({ fileId, fields: 'mimeType, name' });
    const fileRes = await drive.files.get({ fileId, alt: 'media' }, { responseType: 'stream' });
    res.setHeader('Content-Type', meta.data.mimeType || 'application/octet-stream');
    res.setHeader('Cache-Control', 'private, max-age=300');
    fileRes.data.pipe(res);
  } catch (err) {
    res.status(500).json({ errors: ['Could not load the receipt: ' + err.message] });
  }
}


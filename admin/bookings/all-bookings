<script>
// ---- Sample data, standing in for a BigQuery-backed API call ----
// Real bookings are loaded from the API below (see loadBookings()).
const ALL_ROOM_NAMES = ['Surya Hall', 'Patanjali Hall', 'Nataraj Room', 'Ganesh Room'];

const API_BASE = 'https://api-1009110816870.us-central1.run.app';

async function authedFetch(url, options) {
  options = options || {};
  var user = window.__hccgcFirebaseUser;
  if (!user) throw new Error('Not signed in.');
  var token = await user.getIdToken();
  options.headers = Object.assign({}, options.headers, { 'Authorization': 'Bearer ' + token });
  return fetch(url, options);
}

let BOOKINGS = [];

async function loadBookings() {
  const notice = document.getElementById('mock-notice');
  try {
    const res = await authedFetch(API_BASE + '/bookings');
    if (!res.ok) throw new Error('Server returned ' + res.status);
    BOOKINGS = await res.json();
    notice.style.display = 'none';
  } catch (err) {
    notice.textContent = 'Could not load bookings from the database (' + err.message + '). Check the database connection and try refreshing.';
    notice.style.display = 'block';
    BOOKINGS = [];
  }
  render();
}

let state = { search: '', room: '', status: '', sortKey: 'updated_display', sortDir: 'desc' };

function formatDate(iso) {
  const d = new Date(iso + 'T00:00:00');
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}
function formatDateTime(iso) {
  if (!iso) return '—';
  const d = new Date(iso);
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) + ', ' + d.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
}

function isPastDue(b) {
  return (b.payment_status === 'invoiced' || b.payment_status === 'pending') && new Date(b.event_date) < new Date();
}

function statusBadge(b) {
  if (b.is_internal || b.payment_status === 'n/a') {
    return '<span class="badge badge-draft"><span class="badge-dot"></span>Internal · No charge</span>';
  }
  if (b.payment_status === 'paid') {
    const methodLabel = b.payment_method === 'zeffy' ? 'Zeffy · auto-matched' :
      b.payment_method === 'zelle' ? 'Zelle · confirmed' :
      b.payment_method === 'cash' ? 'Cash · confirmed' :
      b.payment_method === 'check' ? 'Check · confirmed' : 'Confirmed';
    return '<span class="badge badge-paid"><span class="badge-dot"></span>Paid</span><span class="method-tag">' + methodLabel + '</span>';
  }
  if (b.payment_status === 'cancelled') {
    const feeTag = (b.cancellation_fee !== null && b.cancellation_fee !== undefined)
      ? '<span class="method-tag">Fee: $' + Number(b.cancellation_fee).toFixed(2) + ' · Refund: $' + Number(b.refund_amount).toFixed(2) + '</span>' : '';
    return '<span class="badge badge-cancelled"><span class="badge-dot"></span>Cancelled</span>' + feeTag;
  }
  // "pending" and "invoiced" both mean "not yet paid" — pending is simply the
  // default status a new booking starts in, since nothing in this system
  // currently has a separate "invoice sent" step.
  const label = isPastDue(b) ? 'Past due — needs confirmation' : 'Awaiting payment';
  return '<span class="badge badge-needs-confirm"><span class="badge-dot"></span>' + label + '</span>';
}

function isWholeFacility(b) {
  return ALL_ROOM_NAMES.every(function (r) { return b.rooms.includes(r); });
}

function matchesFilters(b) {
  const q = state.search.trim().toLowerCase();
  if (q && !(b.renter_name.toLowerCase().includes(q) || (b.renter_email || '').toLowerCase().includes(q))) return false;
  if (state.room === '__whole_facility__' && !isWholeFacility(b)) return false;
  if (state.room && state.room !== '__whole_facility__' && !b.rooms.includes(state.room)) return false;
  if (state.status === 'needs-attention' && !(b.payment_status === 'invoiced' || b.payment_status === 'pending')) return false;
  if (state.status === 'paid' && b.payment_status !== 'paid') return false;
  if (state.status === 'pending' && b.payment_status !== 'pending') return false;
  if (state.status === 'cancelled' && b.payment_status !== 'cancelled') return false;
  if (state.status === 'internal' && !(b.is_internal || b.payment_status === 'n/a')) return false;
  return true;
}

function sortBookings(list) {
  const key = state.sortKey, dir = state.sortDir === 'asc' ? 1 : -1;
  return list.slice().sort(function (a, b) {
    let av = a[key], bv = b[key];
    if (key === 'renter_name') { av = (av || '').toLowerCase(); bv = (bv || '').toLowerCase(); }
    if (av === null || av === undefined) av = '';
    if (bv === null || bv === undefined) bv = '';
    if (av < bv) return -1 * dir;
    if (av > bv) return 1 * dir;
    return 0;
  });
}

function render() {
  const tbody = document.getElementById('bookings-tbody');
  const emptyState = document.getElementById('empty-state');
  const filtered = sortBookings(BOOKINGS.filter(matchesFilters));

  document.getElementById('result-count').textContent =
    filtered.length + (filtered.length === 1 ? ' booking' : ' bookings');

  document.querySelectorAll('thead th.sortable').forEach(function (th) {
    th.classList.toggle('active', th.dataset.sort === state.sortKey);
    th.querySelector('.sort-arrow').textContent = th.dataset.sort === state.sortKey ? (state.sortDir === 'asc' ? '↑' : '↓') : '⇅';
  });

  if (filtered.length === 0) {
    tbody.innerHTML = '';
    emptyState.style.display = 'block';
    return;
  }
  emptyState.style.display = 'none';

  tbody.innerHTML = filtered.map(function (b) {
    // Both "pending" (the default status a new booking starts in) and
    // "invoiced" mean "not yet paid" — the old version only checked for
    // "invoiced", which nothing in the system ever actually sets, so Mark
    // Paid never appeared for real bookings. This is the fix for that.
    const needsAction = (b.payment_status === 'pending' || b.payment_status === 'invoiced');
    const canEdit = b.payment_status !== 'cancelled';
    const roomCell = isWholeFacility(b)
      ? '<span class="room-pill whole-facility">&#9733; Whole Facility</span>'
      : '<span class="room-pill">' + escHtml(b.rooms.join(' + ')) + '</span>';
    const amountCell = '$' + Number(b.final_total).toFixed(2) +
      (b.manual_adjustment_type ? '<span class="adjusted-tag" title="' + escHtml(b.manual_adjustment_reason || '') + '">Adjusted</span>' : '');
    return (
      '<tr>' +
        '<td><div class="renter-name">' + escHtml(b.renter_name) + (b.recurring_series_id ? ' <span class="discount-chip" style="margin-left:4px;" title="' + escHtml(b.recurrence_summary || '') + '">Recurring</span>' : '') + '</div><div class="renter-sub">' + escHtml(b.renter_email) + '</div></td>' +
        '<td>' + roomCell + '</td>' +
        '<td>' + formatDate(b.event_date) + '</td>' +
        '<td>' + b.hours + '</td>' +
        '<td class="amount">' + amountCell + '</td>' +
        '<td>' + statusBadge(b) + '</td>' +
        '<td class="notes-cell" title="' + escHtml(b.notes || '') + '">' + escHtml(b.notes || '—') + '</td>' +
        '<td class="updated-cell">' + formatDateTime(b.updated_display) + '</td>' +
        '<td style="position:relative;">' +
          '<div class="row-actions">' +
          (needsAction ? '<button class="btn-mark-paid" onclick="togglePopover(event, \'' + b.booking_id + '\')">Mark paid</button>' : '') +
          (canEdit ? '<button class="btn-edit" onclick="openEditModal(\'' + b.booking_id + '\')">Edit</button>' : '') +
          (canEdit ? '<button class="btn-cancel-booking" onclick="cancelBookingFlow(\'' + b.booking_id + '\')">Cancel</button>' : '') +
          '</div>' +
          (needsAction ? '<div class="method-popover" id="popover-' + b.booking_id + '">' +
              '<button onclick="markPaid(\'' + b.booking_id + '\', \'zelle\')">Paid via Zelle</button>' +
              '<button onclick="markPaid(\'' + b.booking_id + '\', \'cash\')">Paid via Cash</button>' +
              '<button onclick="markPaid(\'' + b.booking_id + '\', \'check\')">Paid via Check</button>' +
            '</div>' : '') +
        '</td>' +
      '</tr>'
    );
  }).join('');
}

document.querySelectorAll('thead th.sortable').forEach(function (th) {
  th.addEventListener('click', function () {
    const key = th.dataset.sort;
    if (state.sortKey === key) {
      state.sortDir = state.sortDir === 'asc' ? 'desc' : 'asc';
    } else {
      state.sortKey = key;
      state.sortDir = 'asc';
    }
    render();
  });
});

function escHtml(str) {
  return String(str || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

function togglePopover(evt, bookingId) {
  evt.stopPropagation();
  document.querySelectorAll('.method-popover.open').forEach(function (el) {
    if (el.id !== 'popover-' + bookingId) el.classList.remove('open');
  });
  const pop = document.getElementById('popover-' + bookingId);
  pop.classList.toggle('open');
}
document.addEventListener('click', function () {
  document.querySelectorAll('.method-popover.open').forEach(function (el) { el.classList.remove('open'); });
});

async function markPaid(bookingId, method) {
  document.getElementById('popover-' + bookingId).classList.remove('open');
  try {
    const res = await authedFetch(API_BASE + '/bookings/' + encodeURIComponent(bookingId) + '/mark-paid', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ paymentMethod: method })
    });
    if (!res.ok) {
      const data = await res.json().catch(function () { return {}; });
      alert('Could not mark as paid: ' + ((data.errors || [data.error]).join(' ') || 'unknown error'));
      return;
    }
    await loadBookings();
  } catch (err) {
    alert('Could not reach the booking system: ' + err.message);
  }
}

// ---- Cancellation ----
// Client-side preview only, using the same policy the backend enforces
// authoritatively: 14+ days' notice = no fee. 7-13 days = 50% fee. Under 7
// days = 100% fee (this last tier was never explicitly specified — it's the
// natural extension of the stated policy, flagged as an assumption).
function computeCancellationPreview(b) {
  const today = new Date(); today.setHours(0, 0, 0, 0);
  const eventD = new Date(b.event_date + 'T00:00:00');
  const daysUntil = Math.ceil((eventD - today) / 86400000);
  let feeRate = daysUntil >= 14 ? 0 : daysUntil >= 7 ? 0.5 : 1.0;
  const fee = Math.round(Number(b.final_total) * feeRate * 100) / 100;
  const refund = Math.round((Number(b.final_total) - fee) * 100) / 100;
  return { daysUntil, feeRate, fee, refund };
}

async function cancelBookingFlow(bookingId) {
  const b = BOOKINGS.find(function (x) { return x.booking_id === bookingId; });
  if (!b) return;
  const preview = computeCancellationPreview(b);
  const msg = b.is_internal
    ? 'Cancel this internal booking? This frees up the room and removes it from the calendar.'
    : ('Cancel this booking (' + preview.daysUntil + ' days before the event)?\n\n' +
       'Cancellation fee: $' + preview.fee.toFixed(2) + '\n' +
       'Refund: $' + preview.refund.toFixed(2) + '\n\n' +
       'This cannot be undone.');
  if (!confirm(msg)) return;

  try {
    const res = await authedFetch(API_BASE + '/bookings/' + encodeURIComponent(bookingId) + '/cancel', { method: 'POST' });
    const data = await res.json();
    if (!res.ok) {
      alert('Could not cancel: ' + ((data.errors || [data.error]).join(' ') || 'unknown error'));
      return;
    }
    await loadBookings();
  } catch (err) {
    alert('Could not reach the booking system: ' + err.message);
  }
}

// ---- Edit ----
const EDIT_ROOMS = [
  { name: 'Surya Hall', rate: 45 }, { name: 'Patanjali Hall', rate: 40 },
  { name: 'Nataraj Room', rate: 30 }, { name: 'Ganesh Room', rate: 15 }, { name: 'Kitchen', rate: 0 }
];
let EDIT_RENTERS = [];
let editingBookingId = null;

async function loadEditRenters() {
  try {
    const res = await authedFetch(API_BASE + '/renters');
    if (res.ok) EDIT_RENTERS = await res.json();
  } catch (err) { EDIT_RENTERS = []; }
}

function buildEditRoomPicker() {
  const wrap = document.getElementById('edit-room-picker');
  wrap.innerHTML = EDIT_ROOMS.map(function (r) {
    const rateText = r.rate > 0 ? ('$' + r.rate + '/hr') : 'Free';
    return '<label class="modal-room-check"><input type="checkbox" class="edit-room-cb" value="' + r.name + '"> ' + r.name + '<span class="rate">' + rateText + '</span></label>';
  }).join('');
  wrap.querySelectorAll('.edit-room-cb').forEach(function (cb) {
    cb.addEventListener('change', enforceEditKitchenRule);
  });
}
function enforceEditKitchenRule() {
  const kitchenCb = document.querySelector('.edit-room-cb[value="Kitchen"]');
  if (!kitchenCb) return;
  const surya = document.querySelector('.edit-room-cb[value="Surya Hall"]').checked;
  const patanjali = document.querySelector('.edit-room-cb[value="Patanjali Hall"]').checked;
  const eligible = surya || patanjali;
  kitchenCb.disabled = !eligible;
  if (!eligible) kitchenCb.checked = false;
}

async function openEditModal(bookingId) {
  const b = BOOKINGS.find(function (x) { return x.booking_id === bookingId; });
  if (!b) return;
  editingBookingId = bookingId;

  buildEditRoomPicker();
  await loadEditRenters();
  const select = document.getElementById('edit-renter-select');
  select.innerHTML = '<option value="">Choose a renter…</option>' + EDIT_RENTERS.map(function (r) {
    const label = r.contact_name + (r.email ? (' — ' + r.email) : '');
    return '<option value="' + r.renter_id + '">' + label.replace(/</g, '&lt;') + '</option>';
  }).join('');

  document.getElementById('edit-renter-select-field').style.display = b.is_internal ? 'none' : 'flex';
  document.getElementById('edit-name-field').style.display = b.is_internal ? 'flex' : 'none';
  document.getElementById('edit-hccg-rep-field').style.display = b.is_internal ? 'flex' : 'none';
  document.getElementById('edit-nonprofit-row').style.display = b.is_internal ? 'none' : 'flex';

  if (b.is_internal) {
    document.getElementById('edit-name').value = b.renter_name || '';
    document.getElementById('edit-hccg-rep').value = b.hccgc_representative_name || '';
  } else {
    select.value = b.renter_id || '';
    document.getElementById('edit-nonprofit').checked = !!b.is_nonprofit;
  }
  document.getElementById('edit-date').value = b.event_date;
  document.getElementById('edit-start').value = (b.start_time || '').slice(11, 16);
  document.getElementById('edit-end').value = (b.end_time || '').slice(11, 16);
  document.getElementById('edit-notes').value = b.notes || '';
  document.querySelectorAll('.edit-room-cb').forEach(function (cb) { cb.checked = b.rooms.includes(cb.value); });
  enforceEditKitchenRule();

  document.getElementById('edit-modal-title').textContent = b.is_internal ? 'Edit internal booking' : 'Edit booking';
  document.getElementById('edit-result-box').style.display = 'none';
  document.getElementById('edit-modal-overlay').style.display = 'flex';
}

function closeEditModal() {
  document.getElementById('edit-modal-overlay').style.display = 'none';
  editingBookingId = null;
}
document.getElementById('btn-close-edit').addEventListener('click', closeEditModal);
document.getElementById('btn-cancel-edit-modal').addEventListener('click', closeEditModal);
document.getElementById('edit-modal-overlay').addEventListener('click', function (e) {
  if (e.target === this) closeEditModal();
});

document.getElementById('btn-save-edit').addEventListener('click', async function () {
  const btn = this;
  const b = BOOKINGS.find(function (x) { return x.booking_id === editingBookingId; });
  if (!b) return;
  const rooms = Array.from(document.querySelectorAll('.edit-room-cb:checked')).map(function (cb) { return cb.value; });
  const resultBox = document.getElementById('edit-result-box');

  const payload = {
    rooms: rooms,
    eventDate: document.getElementById('edit-date').value,
    startTime: document.getElementById('edit-start').value,
    endTime: document.getElementById('edit-end').value,
    notes: document.getElementById('edit-notes').value,
    renterId: b.is_internal ? null : document.getElementById('edit-renter-select').value,
    renterName: b.is_internal ? document.getElementById('edit-name').value : null,
    hccgcRepresentativeName: b.is_internal ? document.getElementById('edit-hccg-rep').value : null,
    isNonprofit: b.is_internal ? false : document.getElementById('edit-nonprofit').checked
  };

  btn.disabled = true; btn.textContent = 'Saving…';
  try {
    const res = await authedFetch(API_BASE + '/bookings/' + encodeURIComponent(editingBookingId), {
      method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (!res.ok) {
      resultBox.style.display = 'block'; resultBox.className = 'result-box error';
      resultBox.textContent = (data.errors || [data.error || 'Something went wrong.']).join(' ');
    } else {
      resultBox.style.display = 'block'; resultBox.className = 'result-box success';
      resultBox.textContent = 'Saved — new total $' + Number(data.finalTotal).toFixed(2) + '.';
      await loadBookings();
      setTimeout(closeEditModal, 900);
    }
  } catch (err) {
    resultBox.style.display = 'block'; resultBox.className = 'result-box error';
    resultBox.textContent = 'Could not reach the booking system: ' + err.message;
  } finally {
    btn.disabled = false; btn.textContent = 'Save changes';
  }
});

document.getElementById('search-input').addEventListener('input', function (e) {
  state.search = e.target.value;
  render();
});
document.getElementById('room-filter').addEventListener('change', function (e) {
  state.room = e.target.value;
  render();
});
document.getElementById('status-filter').addEventListener('change', function (e) {
  state.status = e.target.value;
  render();
});
// loadBookings() is intentionally NOT called here — moved into the auth
// gate's success handler below, since it needs a valid sign-in token first.

function loadPartial(id, file) {
  var target = document.getElementById(id);
  if (!target) return;
  fetch(file).then(function (r) { return r.text(); }).then(function (html) {
    target.innerHTML = html;
    if (id === 'site-header') fixHeaderLinksForSubfolder(target);
  }).catch(function () {});
}
function fixHeaderLinksForSubfolder(headerEl) {
  var logo = headerEl.querySelector('.brand-logo');
  if (logo && logo.getAttribute('src') && !logo.getAttribute('src').startsWith('/') && !logo.getAttribute('src').startsWith('http')) {
    logo.setAttribute('src', '/' + logo.getAttribute('src'));
  }
  headerEl.querySelectorAll('a[href]').forEach(function (link) {
    var href = link.getAttribute('href');
    if (!href || href.startsWith('http') || href.startsWith('/') || href.startsWith('#')) return;
    link.setAttribute('href', '/' + href);
  });
}
loadPartial('site-header', '/header.html');
loadPartial('site-footer', '/footer.html');


<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Submit Expenses — Hindu Community Center of Greater Cincinnati</title>
<link rel="icon" type="image/x-icon" href="/favicon.ico">
<style>
:root {
  --bg: #fff9f1; --surface: #ffffff; --surface-soft: #fff6ea; --border: rgba(121,62,17,0.14);
  --text: #2c1b10; --muted: #6a5141; --saffron: #b55a18; --saffron-dark: #8d3e0d; --maroon: #7f2e16;
  --radius: 22px; --shadow: 0 18px 45px rgba(93,43,14,0.10);
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: Arial, Helvetica, sans-serif; background: radial-gradient(circle at top left, rgba(217,138,30,0.12), transparent 22%), var(--bg); color: var(--text); min-height: 100vh; }
.container { width: min(calc(100% - 32px), 720px); margin: 0 auto; }
.page-hero { padding: 44px 0 30px; background: linear-gradient(135deg, var(--maroon) 0%, #4e1a09 100%); color: #fff; text-align: center; }
.page-hero img { width: 64px; height: 64px; margin-bottom: 14px; }
.page-hero h1 { font-family: Georgia, "Times New Roman", serif; font-size: 1.8rem; color: #fff; margin-bottom: 8px; }
.page-hero p { color: #ffffff; opacity: 0.9; font-size: 0.94rem; max-width: 480px; margin: 0 auto; }
.card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 32px; box-shadow: var(--shadow); margin: 28px 0 60px; }
.field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px; }
.field label { font-size: 0.82rem; font-weight: 700; color: var(--muted); }
.field label .req { color: var(--saffron-dark); }
.field input, .field select, .field textarea {
  font-family: Arial, Helvetica, sans-serif; font-size: 0.92rem; padding: 10px 14px; border: 1.5px solid var(--border);
  border-radius: 10px; background: #fff; color: var(--text); width: 100%;
}
.field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.section-title { font-family: Georgia, "Times New Roman", serif; font-size: 1.1rem; color: var(--maroon); margin: 24px 0 8px; }
.section-title:first-child { margin-top: 0; }
.expense-card { border: 1.5px solid var(--border); border-radius: 16px; padding: 18px; margin-bottom: 14px; background: var(--surface-soft); }
.expense-card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
.expense-card-header span { font-weight: 700; font-size: 0.88rem; color: var(--saffron-dark); }
.btn-remove-expense { border: none; background: none; color: var(--maroon); font-weight: 700; font-size: 0.8rem; cursor: pointer; }
.btn-add-expense {
  font-family: inherit; font-size: 0.88rem; font-weight: 700; padding: 10px 16px; border-radius: 10px;
  border: 1.5px solid var(--saffron-dark); background: #fff; color: var(--saffron-dark); cursor: pointer; width: 100%; margin-bottom: 20px;
}
.file-upload-label {
  display: flex; align-items: center; justify-content: center; gap: 8px; padding: 14px; border: 2px dashed var(--border);
  border-radius: 10px; cursor: pointer; font-size: 0.86rem; color: var(--muted); background: #fff;
}
.file-upload-label.has-file { border-color: var(--saffron-dark); color: var(--saffron-dark); font-weight: 700; }
.btn-primary {
  font-family: inherit; font-size: 0.95rem; font-weight: 700; color: #fff;
  background: linear-gradient(135deg, var(--saffron-dark), var(--maroon)); border: none; border-radius: 12px;
  padding: 13px 22px; cursor: pointer; width: 100%; margin-top: 8px;
}
.btn-primary:disabled { opacity: 0.6; cursor: default; }
.result-box { margin-top: 16px; border-radius: 12px; padding: 14px 16px; font-size: 0.88rem; line-height: 1.55; }
.result-box.error { background: #fbe9e7; color: #b3382c; border: 1px solid rgba(179,56,44,0.25); }
.success-panel { text-align: center; padding: 30px 10px; }
.success-panel .icon { font-size: 2.4rem; margin-bottom: 10px; }
.success-panel h2 { font-family: Georgia, "Times New Roman", serif; color: var(--maroon); margin-bottom: 10px; }
.success-panel p { color: var(--muted); font-size: 0.92rem; line-height: 1.6; }
.total-bar { display: flex; justify-content: space-between; padding: 14px 18px; background: var(--surface-soft); border-radius: 12px; font-weight: 700; margin-bottom: 16px; }
footer { text-align: center; padding: 20px; font-size: 0.78rem; color: var(--muted); }
footer a { color: var(--saffron-dark); }
</style>
</head>
<body>

<div id="header-placeholder"></div>

<div class="page-hero">
  <div class="container">
    <h1>Submit Expenses for Reimbursement</h1>
    <p>Add as many expenses as you need — one submission, no need to fill this out separately for each one.</p>
  </div>
</div>

<div class="container">
  <div class="card" id="form-card">
    <form id="expenseForm">
      <div class="section-title">Your info</div>
      <div class="field-row">
        <div class="field"><label>First name <span class="req">*</span></label><input type="text" id="ef-first-name" required></div>
        <div class="field"><label>Last name <span class="req">*</span></label><input type="text" id="ef-last-name" required></div>
      </div>
      <div class="field"><label>Email <span class="req">*</span></label><input type="email" id="ef-email" required></div>
      <div class="field"><label>Your Zelle ID <span class="req">*</span></label><input type="text" id="ef-zelle-id" placeholder="Phone number or email used for Zelle" required></div>

      <div class="section-title">Expenses</div>
      <div class="total-bar"><span>Total</span><span id="ef-total">$0.00</span></div>
      <div id="expenses-list"></div>
      <button type="button" class="btn-add-expense" id="btn-add-expense">+ Add another expense</button>

      <button type="submit" class="btn-primary" id="ef-submit-btn">Submit expenses</button>
      <div class="result-box" id="ef-result-box" style="display:none;"></div>
    </form>

    <div class="success-panel" id="ef-success-panel" style="display:none;">
      <div class="icon">&#127881;</div>
      <h2>Submitted!</h2>
      <p>Your expenses are in for review. You'll hear back once they're approved and on their way to being paid.</p>
    </div>
  </div>
</div>

<div id="footer-placeholder"></div>

<script>
async function loadPartial(placeholderId, filePath) {
  const target = document.getElementById(placeholderId);
  if (!target) return;
  try {
    const response = await fetch(filePath);
    if (!response.ok) throw new Error("Unable to load " + filePath);
    target.innerHTML = await response.text();
  } catch (error) {
    console.error(error);
    target.innerHTML = "";
  }
}
loadPartial("header-placeholder", "header.html");
loadPartial("footer-placeholder", "footer.html");

const API_BASE = 'https://facility-rental-api-217911937447.us-central1.run.app';
let expenseCount = 0;

function addExpenseCard() {
  expenseCount++;
  const id = expenseCount;
  const card = document.createElement('div');
  card.className = 'expense-card';
  card.dataset.rowId = id;
  card.innerHTML =
    '<div class="expense-card-header"><span>Expense</span><button type="button" class="btn-remove-expense">Remove</button></div>' +
    '<div class="field"><label>What was this for? <span class="req">*</span></label><input type="text" class="ex-for" placeholder="e.g. Office supplies, event decorations" required></div>' +
    '<div class="field-row">' +
      '<div class="field"><label>Date <span class="req">*</span></label><input type="date" class="ex-date" required></div>' +
      '<div class="field"><label>Amount <span class="req">*</span></label><input type="number" step="0.01" min="0.01" class="ex-amount" required></div>' +
    '</div>' +
    '<div class="field"><label>Receipt <span class="req">*</span></label>' +
      '<label class="file-upload-label" id="upload-label-' + id + '">📎 Choose a file (photo or PDF)<input type="file" class="ex-receipt" accept="image/*,application/pdf" style="display:none;"></label>' +
    '</div>';
  card.querySelector('.btn-remove-expense').addEventListener('click', function () {
    if (document.querySelectorAll('.expense-card').length === 1) return;
    card.remove();
    updateTotal();
  });
  card.querySelector('.ex-amount').addEventListener('input', updateTotal);
  card.querySelector('.ex-receipt').addEventListener('change', function (e) {
    const label = document.getElementById('upload-label-' + id);
    if (e.target.files.length) {
      label.classList.add('has-file');
      label.firstChild.textContent = '✓ ' + e.target.files[0].name;
    }
  });
  document.getElementById('expenses-list').appendChild(card);
}
function updateTotal() {
  let total = 0;
  document.querySelectorAll('.ex-amount').forEach(function (input) { total += Number(input.value) || 0; });
  document.getElementById('ef-total').textContent = '$' + total.toFixed(2);
}
document.getElementById('btn-add-expense').addEventListener('click', addExpenseCard);
addExpenseCard();

function fileToBase64(file) {
  return new Promise(function (resolve, reject) {
    const reader = new FileReader();
    reader.onload = function () { resolve(reader.result.split(',')[1]); };
    reader.onerror = reject;
    reader.readAsDataURL(file);
  });
}

function showResult(message) {
  const box = document.getElementById('ef-result-box');
  box.style.display = 'block';
  box.className = 'result-box error';
  box.textContent = message;
}

document.getElementById('expenseForm').addEventListener('submit', async function (e) {
  e.preventDefault();
  const btn = document.getElementById('ef-submit-btn');

  const firstName = document.getElementById('ef-first-name').value.trim();
  const lastName = document.getElementById('ef-last-name').value.trim();
  const email = document.getElementById('ef-email').value.trim();
  const zelleId = document.getElementById('ef-zelle-id').value.trim();
  if (!firstName || !lastName) { showResult('First and last name are both required.'); return; }
  if (!email || !email.includes('@')) { showResult('A valid email is required.'); return; }
  if (!zelleId) { showResult('Your Zelle ID is required.'); return; }

  const cards = document.querySelectorAll('.expense-card');
  for (let i = 0; i < cards.length; i++) {
    const card = cards[i];
    const label = 'Expense ' + (i + 1);
    if (!card.querySelector('.ex-for').value.trim()) { showResult(label + ': please describe what this was for.'); return; }
    if (!card.querySelector('.ex-date').value) { showResult(label + ': a date is required.'); return; }
    const amount = Number(card.querySelector('.ex-amount').value);
    if (!amount || amount <= 0) { showResult(label + ': a valid amount is required.'); return; }
    if (!card.querySelector('.ex-receipt').files.length) { showResult(label + ': a receipt is required.'); return; }
  }

  btn.disabled = true; btn.textContent = 'Uploading…';
  try {
    const expenses = [];
    for (const card of cards) {
      const file = card.querySelector('.ex-receipt').files[0];
      const base64 = await fileToBase64(file);
      expenses.push({
        expenseFor: card.querySelector('.ex-for').value,
        expenseDate: card.querySelector('.ex-date').value,
        amount: Number(card.querySelector('.ex-amount').value),
        receiptBase64: base64,
        receiptFilename: file.name,
        receiptMimeType: file.type
      });
    }

    const payload = {
      firstName: document.getElementById('ef-first-name').value,
      lastName: document.getElementById('ef-last-name').value,
      email: document.getElementById('ef-email').value,
      zelleId: document.getElementById('ef-zelle-id').value,
      expenses: expenses
    };

    const res = await fetch(API_BASE + '/public/expense-submission', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (!res.ok) {
      showResult((data.errors || [data.error || 'Something went wrong. Please try again.']).join(' '));
      btn.disabled = false; btn.textContent = 'Submit expenses';
    } else {
      document.getElementById('expenseForm').style.display = 'none';
      document.getElementById('ef-success-panel').style.display = 'block';
    }
  } catch (err) {
    showResult('Could not reach the server: ' + err.message);
    btn.disabled = false; btn.textContent = 'Submit expenses';
  }
});
</script>
</body>
</html>

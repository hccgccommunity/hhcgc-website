async function findPaymentMatches(req, res, bookingId) {
  const occurrences = await getOccurrencesForDocument(bookingId);
  if (!occurrences) return res.status(404).json({ errors: ['Booking not found.'] });
  const first = occurrences[0];
  const total = Math.round(occurrences.reduce((sum, o) => sum + Number(o.final_total), 0) * 100) / 100;

  const candidates = [];

  const [zeffyRows] = await bigquery.query({
    query: `SELECT payment_id, payment_date, gross_amount, net_amount, donor_name, donor_email, TO_JSON_STRING(raw_json) AS raw_str
            FROM \`${PAYMENTS_DATASET}.fact_payments\`
            WHERE campaign_id = @campaignId
            ORDER BY payment_date DESC
            LIMIT 300`,
    params: { campaignId: ZEFFY_CAMPAIGN_ID }
  });
  zeffyRows.forEach(row => {
    const rawStr = row.raw_str || '';
    const referenceMatch = rawStr.includes(first.booking_id);
    const grossAmt = Number(row.gross_amount) / 100, netAmt = Number(row.net_amount) / 100;
    const amountMatch = Math.abs(grossAmt - total) < 0.01 || Math.abs(netAmt - total) < 0.01;
    if (referenceMatch || amountMatch) {
      candidates.push({
        source: 'zeffy', id: row.payment_id,
        date: (row.payment_date && row.payment_date.value) || row.payment_date,
        amount: grossAmt,
        label: `${row.donor_name || row.donor_email || 'Unknown donor'} \u2014 $${grossAmt.toFixed(2)}`,
        confidence: referenceMatch ? 'high' : 'possible',
        reason: referenceMatch ? 'Invoice number found in payment details' : 'Amount matches'
      });
    }
  });

  const renterFirstName = (first.renter_name || '').toLowerCase().split(' ')[0];
  const [zelleRows] = await bigquery.query({
    query: `SELECT date, description, amount FROM \`${PAYMENTS_DATASET}.bank_transactions\`
            WHERE LOWER(description) LIKE '%zelle%'
            ORDER BY date DESC
            LIMIT 300`
  });
  zelleRows.forEach(row => {
    const desc = (row.description || '').toLowerCase();
    const amt = Number(row.amount);
    const amountMatch = Math.abs(amt - total) < 0.01;
    const nameMatch = renterFirstName.length > 2 && desc.includes(renterFirstName);
    if (amountMatch || nameMatch) {
      const dateVal = (row.date && row.date.value) || row.date;
      candidates.push({
        source: 'zelle', id: `${dateVal}|${row.description}|${amt}`,
        date: dateVal, amount: amt,
        label: `${row.description} \u2014 $${amt.toFixed(2)}`,
        confidence: (amountMatch && nameMatch) ? 'high' : 'possible',
        reason: [amountMatch ? 'Amount matches' : null, nameMatch ? 'Renter name appears in description' : null].filter(Boolean).join(', ')
      });
    }
  });

  candidates.sort((a, b) => (a.confidence === 'high' ? 0 : 1) - (b.confidence === 'high' ? 0 : 1));
  res.json({ bookingId, invoiceTotal: total, candidates: candidates.slice(0, 15) });
}


        <div class="estimator-card" style="flex:1;min-width:320px;">
          <div class="section-head content-width">
            <span class="section-kicker">Pricing</span>
            <h2>Rental Cost Estimator</h2>
            <p class="section-copy">Tap your room, set the hours, and toggle any discounts — your estimate updates instantly.</p>
          </div>

          <!-- Room selector — multi-select tap targets, plus Entire Facility -->
          <div class="select-group">
            <label>Select Room(s)</label>
            <div class="room-selector">
              <button class="room-btn active" data-room="surya">
                Surya Hall
                <span class="room-btn-rate">$45 / hr</span>
              </button>
              <button class="room-btn" data-room="patanjali">
                Patanjali Hall
                <span class="room-btn-rate">$40 / hr</span>
              </button>
              <button class="room-btn" data-room="nataraj">
                Nataraj Room
                <span class="room-btn-rate">$30 / hr</span>
              </button>
              <button class="room-btn" data-room="ganesh">
                Ganesh Room
                <span class="room-btn-rate">$15 / hr</span>
              </button>

<body>
<div id="site-header"></div>

<div id="gate">
  <div class="gate-card">
    <h3>Checking access&hellip;</h3>
    <p>Please sign in from the <a href="/admin/admin-portal">Admin Portal</a> first.</p>
  </div>
</div>

<div id="app">

<div class="page-hero">
  <div class="container">
    <a class="back-link" href="https://hccgc.org/admin/admin-portal">&larr; Back to apps</a>
    <div class="eyebrow">Facility Bookings</div>
    <h1>Rooms &amp; Rates</h1>
    <p>Add rooms, change rates, and tune discount rules — every change generates the exact query to run.</p>
  </div>
</div>

<div class="module-nav">
  <div class="container">
    <ul>
      <li><a href="new-booking">New Booking</a></li>
      <li><a href="all-bookings">All Bookings</a></li>
      <li><a href="rooms-rates" class="active">Rooms &amp; Rates</a></li>
      <li><a href="add-renter">Add A Renter</a></li>
    </ul>
  </div>
</div>

<div class="container">
  <div class="card">
    <h2>Rooms</h2>
    <div class="card-sub">Edit a rate directly in the table, then click Save changes to generate the update query.</div>
    <table>
      <thead><tr><th>Room</th><th>Rate / hour</th><th>Status</th><th></th></tr></thead>
      <tbody id="rooms-tbody"></tbody>
    </table>

    <div class="add-room-row">
      <div class="field"><label>New room name</label><input type="text" id="new-room-name" placeholder="e.g. Community Hall"></div>
      <div class="field"><label>Rate / hour</label><input type="number" id="new-room-rate" placeholder="25"></div>
      <div class="field"><label>Calendar email</label><input type="text" id="new-room-calendar" placeholder="room@resource.calendar.google.com"></div>
      <button type="button" class="btn-small" id="btn-add-room">Add room</button>
    </div>

    <div class="result-box" id="rooms-result" style="display:none;"></div>
  </div>

  <div class="card">
    <h2>Discount rules</h2>
    <div class="card-sub">These apply automatically to every booking — see New Booking for how they stack.</div>
    <div class="rules-grid">
      <div class="rule-field">
        <label>Weekday multiplier</label>
        <input type="number" id="r-weekday" value="0.80" step="0.01">
        <span class="rule-hint">0.80 = 20% off Mon–Fri bookings</span>
      </div>
      <div class="rule-field">
        <label>Nonprofit multiplier</label>
        <input type="number" id="r-nonprofit" value="0.75" step="0.01">
        <span class="rule-hint">0.75 = 25% off for nonprofit renters</span>
      </div>
      <div class="rule-field">
        <label>Extended-hours multiplier</label>
        <input type="number" id="r-extended-mult" value="0.80" step="0.01">
        <span class="rule-hint">applies once hours meet the threshold below</span>
      </div>
      <div class="rule-field">
        <label>Extended-hours threshold</label>
        <input type="number" id="r-extended-threshold" value="4" step="0.5">
        <span class="rule-hint">in hours</span>
      </div>
    </div>
    <div class="card-sub" style="margin-top:12px;margin-bottom:0;">There's no automatic whole-facility/bundle discount — that's applied case by case as a discretionary adjustment on the booking itself, in New Booking.</div>
    <button type="button" class="btn-primary" id="btn-generate-rules">Save discount rules</button>
    <div class="result-box" id="rules-result" style="display:none;"></div>
  </div>
</div>

</div>

<div id="site-footer"></div>

<script>
const API_BASE = 'https://facility-rental-api-217911937447.us-central1.run.app';

async function authedFetch(url, options) {
  options = options || {};
  var user = window.__hccgcFirebaseUser;
  if (!user) throw new Error('Not signed in.');
  var token = await user.getIdToken();
  options.headers = Object.assign({}, options.headers, { 'Authorization': 'Bearer ' + token });
  return fetch(url, options);
}

let ROOMS = [];

async function loadRooms() {
  try {
    const res = await authedFetch(API_BASE + '/rooms');
    if (!res.ok) throw new Error('Server returned ' + res.status);
    const data = await res.json();
    ROOMS = data.map(function (r) { return { name: r.name, rate: Number(r.rate_per_hour), active: true }; });
  } catch (err) {
    showRoomsResult('error', 'Could not load rooms from the database (' + err.message + ').');
    ROOMS = [];
  }
  renderRooms();
}

async function loadDiscountRules() {
  try {
    const res = await authedFetch(API_BASE + '/discount-rules');
    if (!res.ok) throw new Error('Server returned ' + res.status);
    const r = await res.json();
    document.getElementById('r-weekday').value = r.weekday_multiplier;
    document.getElementById('r-nonprofit').value = r.nonprofit_multiplier;
    document.getElementById('r-extended-mult').value = r.extended_hours_multiplier;
    document.getElementById('r-extended-threshold').value = r.extended_hours_threshold;
  } catch (err) {
    showRulesResult('error', 'Could not load current discount rules (' + err.message + '). Showing defaults — check before saving.');
  }
}

function renderRooms() {
  const tbody = document.getElementById('rooms-tbody');
  tbody.innerHTML = ROOMS.map(function (r, i) {
    return (
      '<tr>' +
        '<td>' + escHtml(r.name) + '</td>' +
        '<td><div class="rate-input-wrap">$<input type="number" step="1" value="' + r.rate + '" data-idx="' + i + '" class="rate-field"> /hr</div></td>' +
        '<td><span class="status-pill ' + (r.active ? 'status-active' : 'status-inactive') + '">' + (r.active ? 'Active' : 'Retired') + '</span></td>' +
        '<td>' + (r.active ? '<button type="button" class="btn-small" data-save="' + i + '">Save rate</button> <button type="button" class="btn-small danger" data-retire="' + i + '">Retire</button>' : '') + '</td>' +
      '</tr>'
    );
  }).join('');

  document.querySelectorAll('.rate-field').forEach(function (input) {
    input.addEventListener('change', function () {
      const idx = parseInt(this.dataset.idx, 10);
      ROOMS[idx].rate = parseFloat(this.value) || ROOMS[idx].rate;
    });
  });
  document.querySelectorAll('[data-save]').forEach(function (btn) {
    btn.addEventListener('click', async function () {
      const idx = parseInt(this.dataset.save, 10);
      const room = ROOMS[idx];
      btn.disabled = true; btn.textContent = 'Saving…';
      try {
        const res = await authedFetch(API_BASE + '/rooms/' + encodeURIComponent(room.name), {
          method: 'PATCH', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ ratePerHour: room.rate })
        });
        if (!res.ok) throw new Error('Server returned ' + res.status);
        showRoomsResult('success', room.name + ' rate updated to $' + room.rate + '/hr.');
      } catch (err) {
        showRoomsResult('error', 'Could not save: ' + err.message);
      } finally {
        btn.disabled = false; btn.textContent = 'Save rate';
      }
    });
  });
  document.querySelectorAll('[data-retire]').forEach(function (btn) {
    btn.addEventListener('click', async function () {
      const idx = parseInt(this.dataset.retire, 10);
      const room = ROOMS[idx];
      if (!confirm('Retire ' + room.name + '? It stays visible on past bookings but can\'t be selected for new ones.')) return;
      try {
        const res = await authedFetch(API_BASE + '/rooms/' + encodeURIComponent(room.name), {
          method: 'PATCH', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ active: false })
        });
        if (!res.ok) throw new Error('Server returned ' + res.status);
        room.active = false;
        renderRooms();
        showRoomsResult('success', room.name + ' retired.');
      } catch (err) {
        showRoomsResult('error', 'Could not retire: ' + err.message);
      }
    });
  });
}

function showRoomsResult(type, message) {
  const box = document.getElementById('rooms-result');
  box.style.display = 'block';
  box.className = 'result-box ' + type;
  box.textContent = message;
}
function showRulesResult(type, message) {
  const box = document.getElementById('rules-result');
  box.style.display = 'block';
  box.className = 'result-box ' + type;
  box.textContent = message;
}

// loadRooms() / loadDiscountRules() intentionally NOT called here — moved
// into the auth gate's success handler below, since they need a valid
// sign-in token first.

function escHtml(str) { return String(str || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;'); }

document.getElementById('btn-add-room').addEventListener('click', async function () {
  const name = document.getElementById('new-room-name').value.trim();
  const rate = parseFloat(document.getElementById('new-room-rate').value);
  const calendar = document.getElementById('new-room-calendar').value.trim();
  if (!name || !rate) { showRoomsResult('error', 'Enter a room name and rate first.'); return; }
  try {
    const res = await authedFetch(API_BASE + '/rooms', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name: name, ratePerHour: rate, calendarId: calendar })
    });
    if (!res.ok) throw new Error('Server returned ' + res.status);
    document.getElementById('new-room-name').value = '';
    document.getElementById('new-room-rate').value = '';
    document.getElementById('new-room-calendar').value = '';
    showRoomsResult('success', name + ' added.');
    await loadRooms();
  } catch (err) {
    showRoomsResult('error', 'Could not add room: ' + err.message);
  }
});

document.getElementById('btn-generate-rules').addEventListener('click', async function () {
  const btn = this;
  const payload = {
    weekdayMultiplier: parseFloat(document.getElementById('r-weekday').value),
    nonprofitMultiplier: parseFloat(document.getElementById('r-nonprofit').value),
    extendedHoursMultiplier: parseFloat(document.getElementById('r-extended-mult').value),
    extendedHoursThreshold: parseFloat(document.getElementById('r-extended-threshold').value)
  };
  btn.disabled = true; btn.textContent = 'Saving…';
  try {
    const res = await authedFetch(API_BASE + '/discount-rules', {
      method: 'PATCH', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    if (!res.ok) throw new Error('Server returned ' + res.status);
    showRulesResult('success', 'Discount rules saved.');
  } catch (err) {
    showRulesResult('error', 'Could not save: ' + err.message);
  } finally {
    btn.disabled = false; btn.textContent = 'Save discount rules';
  }
});

function loadPartial(id, file) {
  var target = document.getElementById(id);
  if (!target) return;
  fetch(file).then(function (r) { return r.text(); }).then(function (html) {
    target.innerHTML = html;
    if (id === 'site-header') fixHeaderLinksForSubfolder(target);
  }).catch(function () {});
}
function fixHeaderLinksForSubfolder(headerEl) {
  var logo = headerEl.querySelector('.brand-logo');
  if (logo && logo.getAttribute('src') && !logo.getAttribute('src').startsWith('/') && !logo.getAttribute('src').startsWith('http')) {
    logo.setAttribute('src', '/' + logo.getAttribute('src'));
  }
  headerEl.querySelectorAll('a[href]').forEach(function (link) {
    var href = link.getAttribute('href');
    if (!href || href.startsWith('http') || href.startsWith('/') || href.startsWith('#')) return;
    link.setAttribute('href', '/' + href);
  });
}
loadPartial('site-header', '/header.html');
loadPartial('site-footer', '/footer.html');
</script>

<script type="module">
import { initializeApp } from 'https://www.gstatic.com/firebasejs/12.15.0/firebase-app.js';
import { getAuth, onAuthStateChanged } from 'https://www.gstatic.com/firebasejs/12.15.0/firebase-auth.js';
import { getFirestore, doc, getDoc } from 'https://www.gstatic.com/firebasejs/12.15.0/firebase-firestore.js';

var firebaseConfig = {
  apiKey: 'AIzaSyA6IzLjWTg7Rq04HsTH-iA3eDmSzKI7xME',
  authDomain: 'hccgc-a7a54.firebaseapp.com',
  projectId: 'hccgc-a7a54',
  storageBucket: 'hccgc-a7a54.firebasestorage.app',
  messagingSenderId: '75757201418',
  appId: '1:75757201418:web:c31e9361921242145717f3'
};

var ALLOWED_DOMAIN = 'hccgc.org';
var REQUIRED_APP_KEY = 'bookings-finance';
var PORTAL_URL = '/admin/admin-portal';

var fbApp = initializeApp(firebaseConfig);
var auth = getAuth(fbApp);
var db = getFirestore(fbApp);

function showGate(title, msg) {
  document.getElementById('gate').querySelector('h3').textContent = title;
  document.getElementById('gate').querySelector('p').innerHTML = msg;
  document.getElementById('gate').style.display = 'flex';
  document.getElementById('app').style.display = 'none';
}

onAuthStateChanged(auth, function(user) {
  if (!user) { showGate('Sign in required', 'Please sign in from the <a href="'+PORTAL_URL+'">Admin Portal</a> first.'); return; }
  var email = (user.email||'').toLowerCase();
  window.__hccgcCurrentUser = { email: email };
  window.__hccgcFirebaseUser = user;
  if (!email.endsWith('@'+ALLOWED_DOMAIN)) { showGate('Access denied', 'Please use an @'+ALLOWED_DOMAIN+' account.'); return; }
  getDoc(doc(db, 'portalUsers', email)).then(function(snap) {
    var data = snap.exists() ? snap.data() : {};
    if (!data.isAdmin && !(Array.isArray(data.allowedApps) && data.allowedApps.includes(REQUIRED_APP_KEY))) {
      showGate('Access not granted', "You don't have access to Facility Bookings. Ask an admin to grant it.");
      return;
    }
    document.getElementById('gate').style.display = 'none';
    document.getElementById('app').style.display = 'block';
    var entryDisplay = document.getElementById('f-entered-by-display');
    if (entryDisplay) entryDisplay.textContent = 'Signed in as ' + email;
    loadRooms();
    loadDiscountRules();
  }).catch(function() { showGate('Error', 'Could not verify access. Please try again.'); });
});
</script>

function money(n) { return '$' + Math.round(Number(n)).toLocaleString('en-US'); }

function computePresetRange(preset) {
  var now = new Date();
  var fmt = function (d) { return d.toISOString().slice(0, 10); };
  var y = now.getFullYear(), m = now.getMonth();
  if (preset === 'thismonth') return { start: fmt(new Date(y, m, 1)), end: fmt(new Date(y, m + 1, 0)) };
  if (preset === 'lastmonth') return { start: fmt(new Date(y, m - 1, 1)), end: fmt(new Date(y, m, 0)) };
  if (preset === 'thisquarter') { var qs = Math.floor(m / 3) * 3; return { start: fmt(new Date(y, qs, 1)), end: fmt(new Date(y, qs + 3, 0)) }; }
  if (preset === 'lastquarter') { var qs2 = Math.floor(m / 3) * 3 - 3; return { start: fmt(new Date(y, qs2, 1)), end: fmt(new Date(y, qs2 + 3, 0)) }; }
  if (preset === 'thisyear') return { start: fmt(new Date(y, 0, 1)), end: fmt(new Date(y, 11, 31)) };
  return { start: fmt(new Date(y, m - 2, 1)), end: fmt(new Date(y, m + 1, 0)) };
}
(function initDates() {
  var range = computePresetRange('last3months');
  document.getElementById('dash-start-date').value = range.start;
  document.getElementById('dash-end-date').value = range.end;
})();
document.getElementById('dash-range-preset').addEventListener('change', function () {
  var preset = this.value;
  var inputs = [document.getElementById('dash-start-date'), document.getElementById('dash-end-date')];
  if (preset === 'custom') { inputs.forEach(function (el) { el.style.display = 'inline-block'; }); return; }
  inputs.forEach(function (el) { el.style.display = 'none'; });
  var range = computePresetRange(preset);
  document.getElementById('dash-start-date').value = range.start;
  document.getElementById('dash-end-date').value = range.end;
  loadDashboard();
});
document.getElementById('btn-refresh-dashboard').addEventListener('click', loadDashboard);

async function loadDashboard() {
  var start = document.getElementById('dash-start-date').value;
  var end = document.getElementById('dash-end-date').value;
  var source = document.getElementById('dash-source-filter').value;
  try {
    var res = await authedFetch(API_BASE + '/bookings-dashboard?startDate=' + start + '&endDate=' + end + '&source=' + source);
    var data = await res.json();
    if (!res.ok) throw new Error((data.errors || [data.error || ('Server returned ' + res.status)]).join(' '));
    renderStats(data, source);
    renderBarChart('revenue-by-room', data.revenueByRoom.map(function (r) { return { name: r.name + ' (' + r.count + ')', total: r.revenue }; }), 'No room activity in this range.');
    var secondTitle = document.getElementById('second-chart-title');
    if (source === 'fundraising') {
      secondTitle.textContent = 'Revenue by campaign';
      renderBarChart('second-chart', data.revenueByCampaign.map(function (r) { return { name: r.name + ' (' + r.count + ')', total: r.revenue }; }), 'No fundraising activity in this range.');
    } else {
      secondTitle.textContent = 'Top renters';
      renderContributors('second-chart', data.topRenters, 'No renters in this range.');
    }
  } catch (err) {
    document.getElementById('stat-grid').innerHTML = '<div class="empty-state">Could not load dashboard: ' + escHtml(err.message) + '</div>';
  }
}
document.getElementById('dash-source-filter').addEventListener('change', loadDashboard);
async function loadMonthlyTrend() {
  try {
    var res = await authedFetch(API_BASE + '/bookings-monthly-trend');
    var data = await res.json();
    if (!res.ok) throw new Error((data.errors || [data.error || ('Server returned ' + res.status)]).join(' '));
    renderVerticalTrendChart('revenue-by-month', data.months, 'No booking activity in this window.');
  } catch (err) {
    document.getElementById('revenue-by-month').innerHTML = '<div class="empty-state">Could not load: ' + escHtml(err.message) + '</div>';
  }
}
function niceMax(value) {
  if (value % 100 === 0) return value + 100;
  return Math.ceil(value / 100) * 100;
}
function renderVerticalTrendChart(containerId, months, emptyMessage) {
  var container = document.getElementById(containerId);
  if (!months.length) { container.innerHTML = '<div class="empty-state">' + emptyMessage + '</div>'; return; }
  var rawMax = Math.max.apply(null, months.map(function (m) { return m.revenue; })) || 1;
  var axisMax = niceMax(rawMax);
  var chartHeight = 150;
  var gridlineCount = 4;
  var yAxisHtml = '<div class="trend-yaxis" style="height:' + chartHeight + 'px;">' +
    Array.from({ length: gridlineCount + 1 }, function (_, i) {
      var val = axisMax * (gridlineCount - i) / gridlineCount;
      return '<div class="trend-yaxis-label">' + money(val) + '</div>';
    }).join('') +
  '</div>';
  var bars = months.map(function (m) {
    var h = Math.max(2, (m.revenue / axisMax) * chartHeight);
    var label = new Date(m.month + '-02').toLocaleDateString('en-US', { month: 'short', year: '2-digit' });
    return '<div class="trend-month">' +
      '<div class="trend-bars" style="height:' + chartHeight + 'px;"><div class="trend-bar" style="height:' + h + 'px;" title="' + label + ': ' + money(m.revenue) + '"></div></div>' +
      '<div class="trend-month-label">' + label + '</div>' +
    '</div>';
  }).join('');
  container.innerHTML = '<div class="trend-chart-wrap">' + yAxisHtml + '<div class="trend-chart">' + bars + '</div></div>';
}
function renderStats(data, source) {
  var revenueLabel = source === 'fundraising' ? 'Fundraising Revenue' : source === 'all' ? 'Total Revenue (Facility + Fundraising)' : 'Facility Rental Revenue';
  var countLabel = source === 'fundraising' ? 'Fundraising Payments' : 'Bookings';
  var stats = [
    { label: revenueLabel, value: money(data.totalRevenue) },
    { label: countLabel, value: data.totalCount },
    { label: 'Avg. Value', value: money(data.avgValue) }
  ];
  // Hours/paid/unpaid are facility-rental-only concepts (a Zeffy
  // fundraising payment has no "hours" or "paid status") — shown only
  // when facility rental is actually part of what's selected, so picking
  // "Fundraising Revenue" doesn't show what looks like leftover facility
  // rental data mixed into the fundraising-only view.
  if (source !== 'fundraising') {
    stats.push({ label: 'Hours Booked (facility rental)', value: data.totalHours });
    stats.push({ label: 'Paid (facility rental)', value: data.paidCount });
    stats.push({ label: 'Not Yet Paid (facility rental)', value: data.unpaidCount });
  }
  document.getElementById('stat-grid').innerHTML = stats.map(function (s) {
    return '<div class="stat-card"><div class="value">' + s.value + '</div><div class="label">' + s.label + '</div></div>';
  }).join('');
}
function renderBarChart(containerId, items, emptyMessage) {
  var container = document.getElementById(containerId);
  if (!items.length) { container.innerHTML = '<div class="empty-state">' + emptyMessage + '</div>'; return; }
  var max = Math.max.apply(null, items.map(function (i) { return i.total; }));
  container.innerHTML = items.map(function (i) {
    var pct = max > 0 ? Math.max(2, (i.total / max) * 100) : 0;
    return '<div class="bar-chart-row">' +
      '<div class="bar-chart-label" title="' + escHtml(i.name) + '">' + escHtml(i.name) + '</div>' +
      '<div class="bar-chart-track"><div class="bar-chart-fill" style="width:' + pct + '%;"></div></div>' +
      '<div class="bar-chart-value">' + money(i.total) + '</div>' +
    '</div>';
  }).join('');
}
function renderContributors(containerId, items, emptyMessage) {
  var container = document.getElementById(containerId);
  if (!items.length) { container.innerHTML = '<div class="empty-state">' + emptyMessage + '</div>'; return; }
  container.innerHTML = items.map(function (item, i) {
    return '<div class="contributor-row">' +
      '<span class="rank">' + (i + 1) + '</span>' +
      '<span class="name">' + escHtml(item.name) + ' <span class="meta">(' + item.count + ')</span></span>' +
      '<span class="amount">' + money(item.revenue) + '</span>' +
    '</div>';
  }).join('');
}



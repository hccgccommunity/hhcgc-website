  const paymentDateStr = new Date(String(paymentDateVal).slice(0, 10) + 'T00:00:00').toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
  const methodDisplay = first.payment_match_source === 'zeffy' ? 'Zeffy' :
    first.payment_match_source === 'zelle' ? 'Zelle' :
    first.payment_method === 'zelle' ? 'Zelle' :
    first.payment_method === 'cash' ? 'Cash' :
    first.payment_method === 'check' ? 'Check' : 'payment received';

  const rows = occurrences.map(o => {
    const dateStr = new Date(o.event_date + 'T00:00:00').toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
    return `<tr>
      <td style="padding:8px 10px; border-bottom:1px solid #eee2d3;">${dateStr}</td>
      <td style="padding:8px 10px; border-bottom:1px solid #eee2d3;">${formatTime12h((o.start_time || '').slice(11, 16))}</td>
      <td style="padding:8px 10px; border-bottom:1px solid #eee2d3;">${o.hours}</td>
      <td style="padding:8px 10px; border-bottom:1px solid #eee2d3;">${escapeHtml(roomsDisplay(o.rooms))}</td>
      <td style="padding:8px 10px; border-bottom:1px solid #eee2d3;">${money(o.final_total)}</td>
    </tr>`;
  }).join('');

  return `
  <div style="font-family: Arial, Helvetica, sans-serif; max-width: 580px; margin: 0 auto; color: #2c1b10; background: #fff9f1;">
    <div style="text-align:center; padding: 28px 20px 10px;">
      <img src="data:image/png;base64,${LOGO_BASE64}" width="90" height="90" alt="HCCGC" style="display:inline-block;">
    </div>
    <div style="padding: 10px 32px 32px;">
      <p><strong>Invoice Number:</strong> ${invoiceNumber}<br><strong>Date:</strong> ${todayStr}</p>
      <p><strong>To:</strong><br>${escapeHtml(first.renter_name)}</p>
      <p>Thank you for choosing the Hindu Community Center of Greater Cincinnati for your event. We appreciate your support and hope your experience at our facility was enjoyable.</p>
      <table style="width:100%; border-collapse: collapse; margin: 14px 0; font-size: 0.86rem;">
        <thead><tr>
          <th style="text-align:left; padding:8px 10px; border-bottom:2px solid #7f2e16; color:#7f2e16;">Date</th>
          <th style="text-align:left; padding:8px 10px; border-bottom:2px solid #7f2e16; color:#7f2e16;">Time</th>
          <th style="text-align:left; padding:8px 10px; border-bottom:2px solid #7f2e16; color:#7f2e16;"># Hours</th>
          <th style="text-align:left; padding:8px 10px; border-bottom:2px solid #7f2e16; color:#7f2e16;">Room(s) Booked</th>
          <th style="text-align:left; padding:8px 10px; border-bottom:2px solid #7f2e16; color:#7f2e16;">Amount</th>
        </tr></thead>
        <tbody>${rows}</tbody>
      </table>
      <p>Payment of <strong>${money(total)} (${amountInWords(total)})</strong> was received on ${paymentDateStr} via ${methodDisplay}.</p>
      <p>We look forward to welcoming you back in the future. Please visit our website at <a href="https://hccgc.org" style="color:#b55a18;">hccgc.org</a> to learn more about our community programs, cultural events, and initiatives.</p>
      <p>This is an automated message — please don't reply directly to this email. For questions, reach out to us at <a href="mailto:${CC_EMAIL}" style="color:#b55a18;">${CC_EMAIL}</a>.</p>
      <p style="margin-top:20px;">Team HCCGC</p>
      <div style="margin-top:24px; padding-top:16px; border-top:1px solid #eee2d3; font-size:0.8rem; color:#6a5141; line-height:1.5;">
        7500 Industrial Row Dr.<br>Mason, OH 45040<br>info@hccgc.org<br>www.hccgc.org
      </div>
    </div>
  </div>`;
}
function escapeHtml(str) { return String(str || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }

async function getOccurrencesForDocument(bookingId) {
  const [rows] = await bigquery.query({ query: `SELECT * FROM \`${DATASET}.bookings\` WHERE booking_id = @bookingId`, params: { bookingId } });
  if (!rows.length) return null;
  const unwrap = v => (v && typeof v === 'object' && 'value' in v) ? v.value : v;
  const clean = r => ({
    ...r, event_date: unwrap(r.event_date), start_time: unwrap(r.start_time), end_time: unwrap(r.end_time),
    final_total: Number(r.final_total), invoice_sent_at: unwrap(r.invoice_sent_at), updated_at: unwrap(r.updated_at),
    payment_date: unwrap(r.payment_date)
  });
  const first = clean(rows[0]);
  if (!first.recurring_series_id) return [first];
  const [seriesRows] = await bigquery.query({
    query: `SELECT * FROM \`${DATASET}.bookings\` WHERE recurring_series_id = @seriesId AND payment_status != 'cancelled' ORDER BY event_date`,
    params: { seriesId: first.recurring_series_id }
  });
  return seriesRows.map(clean);
}

// POST /bookings/:id/send-invoice
async function sendBookingInvoice(req, res, bookingId, actor) {
  const occurrences = await getOccurrencesForDocument(bookingId);
  if (!occurrences) return res.status(404).json({ errors: ['Booking not found.'] });
  const first = occurrences[0];
  if (!first.renter_email) return res.status(400).json({ errors: ['This renter has no email on file.'] });

  // Can't resend an already-sent invoice unless the booking's changed since —
  // otherwise it's too easy to spam the renter with duplicate invoices.
  if (first.invoice_sent_at && (!first.updated_at || new Date(first.updated_at) <= new Date(first.invoice_sent_at))) {
    return res.status(400).json({ errors: ['An invoice was already sent for this booking, and nothing has changed since. Edit the booking first if you need to resend.'] });
  }

  const total = occurrences.reduce((sum, o) => sum + Number(o.final_total), 0);
  const html = buildInvoiceHtml(occurrences);
  try {
    await sendEmail({ to: first.renter_email, cc: CC_EMAIL, subject: `Invoice for your HCCGC booking - ${money(total)} due`, htmlBody: html });
  } catch (err) {
    return res.status(500).json({ errors: ['Could not send the email: ' + err.message] });
  }

  const seriesId = first.recurring_series_id;
  const whereClause = seriesId ? `recurring_series_id = @key` : `booking_id = @key`;
  await bigquery.query({
    query: `UPDATE \`${DATASET}.bookings\` SET invoice_sent_at = CURRENT_TIMESTAMP(),
            payment_status = IF(payment_status = 'pending', 'invoiced', payment_status)
            WHERE ${whereClause}`,
    params: { key: seriesId || bookingId }
  });

  await logAudit({ action: 'invoice_sent', entityType: 'booking', entityId: bookingId, actorEmail: actor.email, details: { to: first.renter_email, occurrenceCount: occurrences.length } });
  res.json({ bookingId, sentTo: first.renter_email });
}

// POST /bookings/:id/send-receipt
async function sendBookingReceipt(req, res, bookingId, actor) {
  const occurrences = await getOccurrencesForDocument(bookingId);
  if (!occurrences) return res.status(404).json({ errors: ['Booking not found.'] });
  const first = occurrences[0];
  if (first.payment_status !== 'paid') return res.status(400).json({ errors: ['This booking is not marked paid yet.'] });
  if (!first.renter_email) return res.status(400).json({ errors: ['This renter has no email on file.'] });

  const html = await buildReceiptHtml(occurrences);
  try {
    await sendEmail({
      to: first.renter_email, cc: CC_EMAIL, subject: `Receipt for your HCCGC booking`, htmlBody: html,
      attachments: [{ filename: 'HCCGC-Event-Day-Checkout-Instructions.pdf', mimeType: 'application/pdf', base64: CHECKOUT_PDF_BASE64 }]
    });
  } catch (err) {
    return res.status(500).json({ errors: ['Could not send the email: ' + err.message] });
  }

  const seriesId = first.recurring_series_id;
  const whereClause = seriesId ? `recurring_series_id = @key` : `booking_id = @key`;
  await bigquery.query({
    query: `UPDATE \`${DATASET}.bookings\` SET receipt_sent_at = CURRENT_TIMESTAMP() WHERE ${whereClause}`,
    params: { key: seriesId || bookingId }
  });

  await logAudit({ action: 'receipt_sent', entityType: 'booking', entityId: bookingId, actorEmail: actor.email, details: { to: first.renter_email, occurrenceCount: occurrences.length } });
  res.json({ bookingId, sentTo: first.renter_email });
}

// GET /bookings/:id/invoice-preview and /receipt-preview — same generated
// document as the emailed version, returned as raw HTML for download.
// Doesn't send anything or touch invoice_sent_at/receipt_sent_at — purely
// read-only, so it's safe to use even on locked/historical bookings.
async function previewBookingDocument(req, res, bookingId, kind) {
  const occurrences = await getOccurrencesForDocument(bookingId);
  if (!occurrences) return res.status(404).json({ errors: ['Booking not found.'] });
  if (kind === 'receipt' && occurrences[0].payment_status !== 'paid') {
    return res.status(400).json({ errors: ['This booking is not marked paid yet.'] });
  }
  const html = kind === 'receipt' ? await buildReceiptHtml(occurrences) : buildInvoiceHtml(occurrences);
  res.set('Content-Type', 'text/html; charset=utf-8');
  res.send(html);
}

async function cancelBooking(req, res, bookingId, actor) {
  const roomsList = await getActiveRooms();
  const roomsMap = {};
  roomsList.forEach(r => { roomsMap[r.name] = r; });
  const calendar = await getCalendarClient();
  const result = await cancelOneBookingRow(bookingId, actor, roomsMap, calendar);
  if (!result) return res.status(404).json({ errors: ['Booking not found.'] });
  if (result.alreadyCancelled) return res.status(400).json({ errors: ['This booking is already cancelled.'] });
  if (result.locked) return res.status(403).json({ errors: ['This booking has already happened — only tech-admin@hccgc.org can cancel a past booking.'] });

  await logAudit({
    action: 'booking_cancelled', entityType: 'booking', entityId: bookingId, actorEmail: actor.email,
    details: { daysUntilBooking: result.daysUntil, feeRatePct: result.feeRate * 100, cancellationFee: result.fee, refundAmount: result.refund }
  });

  res.json({ bookingId, daysUntilBooking: result.daysUntil, cancellationFee: result.fee, refundAmount: result.refund });
}

// POST /bookings/series/:seriesId/cancel — cancels every non-cancelled
// occurrence in a recurring series at once. Each occurrence's fee is still
// computed individually based on its own date (a series spanning months
// shouldn't get one blanket fee), then summed for the response.
async function cancelBookingSeries(req, res, seriesId, actor) {
  const [rows] = await bigquery.query({
    query: `SELECT booking_id FROM \`${DATASET}.bookings\` WHERE recurring_series_id = @seriesId AND payment_status != 'cancelled'`,
    params: { seriesId }
  });
  if (!rows.length) return res.status(404).json({ errors: ['No cancellable occurrences found for this series.'] });

  const roomsList = await getActiveRooms();
  const roomsMap = {};
  roomsList.forEach(r => { roomsMap[r.name] = r; });
  const calendar = await getCalendarClient();

  let totalFee = 0, totalRefund = 0, cancelledCount = 0, lockedCount = 0;
  for (const row of rows) {
    const result = await cancelOneBookingRow(row.booking_id, actor, roomsMap, calendar);
    if (result && result.locked) { lockedCount++; continue; }
    if (result && !result.alreadyCancelled) {
      totalFee += result.fee; totalRefund += result.refund; cancelledCount++;
    }
  }

  await logAudit({
    action: 'booking_series_cancelled', entityType: 'booking_series', entityId: seriesId, actorEmail: actor.email,
    details: { occurrencesCancelled: cancelledCount, lockedCount, totalFee: Math.round(totalFee * 100) / 100, totalRefund: Math.round(totalRefund * 100) / 100 }
  });

  res.json({ seriesId, occurrencesCancelled: cancelledCount, lockedCount, totalFee: Math.round(totalFee * 100) / 100, totalRefund: Math.round(totalRefund * 100) / 100 });
}

// POST /bookings/series/:seriesId/mark-paid — marks every not-yet-paid
// occurrence in a series paid in one action, since a renter pays for the
// whole series at once, not occurrence by occurrence.
async function markSeriesPaid(req, res, seriesId, actor) {
  const method = (req.body || {}).paymentMethod;
  if (!['zelle', 'cash', 'check', 'zeffy'].includes(method)) {
    return res.status(400).json({ errors: ['paymentMethod must be zelle, cash, check, or zeffy.'] });
  }
  const [rows] = await bigquery.query({
    query: `SELECT booking_id FROM \`${DATASET}.bookings\` WHERE recurring_series_id = @seriesId AND payment_status IN ('pending','invoiced')`,
    params: { seriesId }
  });
  if (!rows.length) return res.status(400).json({ errors: ['No unpaid occurrences found for this series.'] });

  await bigquery.query({
    query: `UPDATE \`${DATASET}.bookings\` SET payment_status = 'paid', payment_method = @method, paid_by = @actorEmail, payment_date = CURRENT_DATE(), updated_at = CURRENT_TIMESTAMP()
            WHERE recurring_series_id = @seriesId AND payment_status IN ('pending','invoiced')`,
    params: { method, seriesId, actorEmail: actor.email }
  });

  await logAudit({ action: 'booking_series_marked_paid', entityType: 'booking_series', entityId: seriesId, actorEmail: actor.email, details: { paymentMethod: method, occurrencesMarked: rows.length } });
  res.json({ seriesId, paymentStatus: 'paid', paymentMethod: method, occurrencesMarked: rows.length });
}

// PATCH /bookings/series/:seriesId — edits a whole recurring series at once.
// Renter/rooms/notes/nonprofit status apply uniformly to every occurrence
// (matches how the series was created — one set of rooms and one renter for
// the whole thing). The `occurrences` array carries each occurrence's own
// date/time; an occurrence flagged `remove: true` gets cancelled individually
// (with its own cancellation fee) rather than deleted outright.
async function updateBookingSeries(req, res, seriesId, actor) {
  const b = req.body || {};
  const [existingRows] = await bigquery.query({
    query: `SELECT * FROM \`${DATASET}.bookings\` WHERE recurring_series_id = @seriesId AND payment_status != 'cancelled'`,
    params: { seriesId }
  });
  if (!existingRows.length) return res.status(404).json({ errors: ['No editable occurrences found for this series.'] });
  const isInternal = !!existingRows[0].is_internal;

  const errors = [];
  const rooms = Array.isArray(b.rooms) && b.rooms.length ? b.rooms : null;
  if (!rooms) errors.push('Select at least one room.');
  if (rooms && rooms.includes('Kitchen') && !rooms.includes('Surya Hall') && !rooms.includes('Patanjali Hall')) {
    errors.push('Kitchen can only be booked together with Surya Hall or Patanjali Hall.');
  }
  if (!isInternal && !b.renterId) errors.push('Select a renter.');
  if (!isInternal && !b.eventName) errors.push('Event name is required.');
  if (!Array.isArray(b.occurrences) || !b.occurrences.length) errors.push('At least one occurrence is required.');
  if (errors.length) return res.status(400).json({ errors });

  const roomsList = await getActiveRooms();
  const roomsMap = {};
  roomsList.forEach(r => { roomsMap[r.name] = r; });
  const unknownRooms = rooms.filter(r => !roomsMap[r]);
  if (unknownRooms.length) return res.status(400).json({ errors: [`Unknown or inactive room(s): ${unknownRooms.join(', ')}`] });

  let renterId = null;
  let renterFields = { renterName: b.renterName, renterEmail: null, renterPhone: null, renterAddress: null, organizationName: null };
  if (!isInternal) {
    const [renterRows] = await bigquery.query({
      query: `SELECT renter_id, contact_name, email, phone, address, organization_name FROM \`${DATASET}.renters\` WHERE renter_id = @renterId`,
      params: { renterId: b.renterId }
    });
    if (!renterRows.length) return res.status(400).json({ errors: ['Selected renter was not found — they may have been removed. Please pick again.'] });
    renterId = renterRows[0].renter_id;
    renterFields = {
      renterName: renterRows[0].contact_name, renterEmail: renterRows[0].email, renterPhone: renterRows[0].phone,
      renterAddress: renterRows[0].address, organizationName: renterRows[0].organization_name
    };
  }
  const displayName = isInternal ? (b.renterName || existingRows[0].renter_name) : renterFields.renterName;
  const eventName = isInternal ? displayName : b.eventName;
  const rules = await getDiscountRules();
  const calendar = await getCalendarClient();
  const seriesBookingIds = existingRows.map(r => r.booking_id);

  let updatedCount = 0, removedCount = 0;
  const occurrenceErrors = [];
  let totalFinal = 0;

  for (const occInput of b.occurrences) {
    const existing = existingRows.find(r => r.booking_id === occInput.bookingId);
    if (!existing) { occurrenceErrors.push(`Unknown occurrence ${occInput.bookingId}.`); continue; }

    const existingDateStr = (existing.event_date && existing.event_date.value) || existing.event_date;
    const isPast = new Date(existingDateStr + 'T00:00:00') < new Date(new Date().toDateString());
    if (isPast && !isSuperAdmin(actor.email)) {
      occurrenceErrors.push(`${existing.booking_id} (${existingDateStr}): already happened — only tech-admin@hccgc.org can edit past occurrences.`);
      continue;
    }

    if (occInput.remove) {
      const result = await cancelOneBookingRow(existing.booking_id, actor, roomsMap, calendar);
      if (result && !result.alreadyCancelled) removedCount++;
      continue;
    }

    if (!occInput.eventDate || !occInput.startTime || !occInput.endTime) {
      occurrenceErrors.push(`${existing.booking_id}: date/time missing.`); continue;
    }
    const start = new Date(`${occInput.eventDate}T${occInput.startTime}:00`);
    const end = new Date(`${occInput.eventDate}T${occInput.endTime}:00`);
    const hours = Math.round(((end - start) / 3600000) * 100) / 100;
    if (hours <= 0) { occurrenceErrors.push(`${existing.booking_id}: end time must be after start time.`); continue; }

    const [conflicts] = await bigquery.query({
      query: `SELECT booking_id, renter_name FROM \`${DATASET}.bookings\`
              WHERE event_date = @date AND payment_status != 'cancelled' AND booking_id NOT IN UNNEST(@seriesIds)
                AND start_time < @endTime AND end_time > @startTime
                AND EXISTS (SELECT 1 FROM UNNEST(rooms) rm WHERE rm IN UNNEST(@rooms))`,
      params: { date: occInput.eventDate, startTime: `${occInput.eventDate} ${occInput.startTime}:00`, endTime: `${occInput.eventDate} ${occInput.endTime}:00`, rooms, seriesIds: seriesBookingIds },
      types: { rooms: ['STRING'], seriesIds: ['STRING'] }
    });
    if (conflicts.length) { occurrenceErrors.push(`${occInput.eventDate}: conflicts with an existing booking (${conflicts[0].renter_name}).`); continue; }

    let baseTotal = 0, mult = 1, subtotal = 0, finalTotal = 0;
    if (!isInternal) {
      const priced = computeOccurrencePricing(rooms, roomsMap, hours, occInput.eventDate, !!b.isNonprofit, rules);
      baseTotal = priced.baseTotal; mult = priced.mult; subtotal = priced.subtotal;
      finalTotal = applyManualAdjustment(subtotal, b.manualAdjustmentType, b.manualAdjustmentValue);
    }
    totalFinal += finalTotal;

    const oldRooms = existing.rooms || [];
    const oldEventIds = existing.calendar_event_ids || [];
    if (oldRooms.length && oldEventIds.length) {
      for (let i = 0; i < oldRooms.length; i++) {
        const calId = roomsMap[oldRooms[i]] && roomsMap[oldRooms[i]].calendar_id;
        const eventId = oldEventIds[i];
        if (!calId || !eventId) continue;
        try { await calendar.events.delete({ calendarId: calId, eventId }); } catch (err) { /* already gone, fine */ }
      }
    }
    const occ = { date: occInput.eventDate, startTime: occInput.startTime, endTime: occInput.endTime };
    const { eventIds } = await syncOccurrenceToCalendar({ rooms, roomsMap, occ, renterName: displayName, seriesLabel: existingRows[0].recurrence_summary });

    await bigquery.query({
      query: `UPDATE \`${DATASET}.bookings\`
              SET rooms = @rooms, renter_id = @renterId, renter_name = @renterName, renter_email = @renterEmail,
                  renter_phone = @renterPhone, renter_address = @renterAddress, organization_name = @organizationName,
                  hccgc_representative_name = @hccgcRepName,
                  event_date = @eventDate, start_time = @startTime, end_time = @endTime, hours = @hours,
                  is_nonprofit = @isNonprofit, base_total = @baseTotal, standard_discount_multiplier = @mult,
                  subtotal_after_standard_discount = @subtotal, manual_adjustment_type = @adjType,
                  manual_adjustment_value = @adjValue, manual_adjustment_reason = @adjReason,
                  manual_adjustment_by = @adjBy, final_total = @finalTotal, calendar_event_ids = @eventIds,
                  event_name = @eventName, notes = @notes, updated_at = CURRENT_TIMESTAMP()
              WHERE booking_id = @bookingId`,
      params: {
        rooms, renterId, renterName: displayName, renterEmail: renterFields.renterEmail || null,
        renterPhone: renterFields.renterPhone || null, renterAddress: renterFields.renterAddress || null,
        organizationName: renterFields.organizationName || null, hccgcRepName: isInternal ? (b.hccgcRepresentativeName || existingRows[0].hccgc_representative_name) : null,
        eventDate: occInput.eventDate, startTime: `${occInput.eventDate} ${occInput.startTime}:00`, endTime: `${occInput.eventDate} ${occInput.endTime}:00`, hours,
        isNonprofit: !isInternal && !!b.isNonprofit, baseTotal, mult, subtotal,
        adjType: (!isInternal && b.manualAdjustmentType) || null, adjValue: (!isInternal && b.manualAdjustmentValue) || null,
        adjReason: (!isInternal && b.manualAdjustmentReason) || null, adjBy: (!isInternal && b.manualAdjustmentType) ? actor.email : null,
        finalTotal, eventIds, eventName: eventName || null, notes: b.notes || null, bookingId: existing.booking_id
      },
      types: {
        rooms: ['STRING'], eventIds: ['STRING'], renterId: 'STRING', renterEmail: 'STRING', renterPhone: 'STRING',
        renterAddress: 'STRING', organizationName: 'STRING', hccgcRepName: 'STRING', adjType: 'STRING',
        adjReason: 'STRING', adjValue: 'NUMERIC', adjBy: 'STRING', eventName: 'STRING', notes: 'STRING',
        hours: 'NUMERIC', baseTotal: 'NUMERIC', mult: 'NUMERIC', subtotal: 'NUMERIC', finalTotal: 'NUMERIC'
      }
    });
    updatedCount++;
  }

  await logAudit({
    action: 'booking_series_updated', entityType: 'booking_series', entityId: seriesId, actorEmail: actor.email,
    details: { updatedCount, removedCount, occurrenceErrors }
  });

  res.json({ seriesId, updatedCount, removedCount, totalFinal: Math.round(totalFinal * 100) / 100, occurrenceErrors: occurrenceErrors.length ? occurrenceErrors : undefined });
}

// PATCH /bookings/:id — edits rooms/date/time/renter/notes/adjustment and
// fully re-syncs pricing + calendar events to match. Scoped to one occurrence
// at a time (same granularity the table already shows) — editing an entire
// recurring series in one action isn't supported here.
async function updateBooking(req, res, bookingId, actor) {
  const b = req.body || {};
  const [existingRows] = await bigquery.query({ query: `SELECT * FROM \`${DATASET}.bookings\` WHERE booking_id = @bookingId`, params: { bookingId } });
  if (!existingRows.length) return res.status(404).json({ errors: ['Booking not found.'] });
  const existing = existingRows[0];
  if (existing.payment_status === 'cancelled') return res.status(400).json({ errors: ['Cancelled bookings cannot be edited — create a new booking instead.'] });

  const existingDateStr = (existing.event_date && existing.event_date.value) || existing.event_date;
  const isPast = new Date(existingDateStr + 'T00:00:00') < new Date(new Date().toDateString());
  if (isPast && !isSuperAdmin(actor.email)) {
    return res.status(403).json({ errors: ['This booking has already happened — only tech-admin@hccgc.org can edit past bookings.'] });
  }

  const isInternal = !!existing.is_internal;
  const errors = [];
  const rooms = Array.isArray(b.rooms) && b.rooms.length ? b.rooms : null;
  if (!rooms) errors.push('Select at least one room.');
  if (!b.eventDate || !b.startTime || !b.endTime) errors.push('Date and time are required.');
  if (rooms && rooms.includes('Kitchen') && !rooms.includes('Surya Hall') && !rooms.includes('Patanjali Hall')) {
    errors.push('Kitchen can only be booked together with Surya Hall or Patanjali Hall.');
  }
  if (!isInternal && !b.renterId) errors.push('Select a renter.');
  if (!isInternal && !b.eventName) errors.push('Event name is required.');
  if (errors.length) return res.status(400).json({ errors });

  const roomsList = await getActiveRooms();
  const roomsMap = {};
  roomsList.forEach(r => { roomsMap[r.name] = r; });
  const unknownRooms = rooms.filter(r => !roomsMap[r]);
  if (unknownRooms.length) return res.status(400).json({ errors: [`Unknown or inactive room(s): ${unknownRooms.join(', ')}`] });

  const start = new Date(`${b.eventDate}T${b.startTime}:00`);
  const end = new Date(`${b.eventDate}T${b.endTime}:00`);
  const hours = Math.round(((end - start) / 3600000) * 100) / 100;
  if (hours <= 0) return res.status(400).json({ errors: ['End time must be after start time.'] });

  const [conflicts] = await bigquery.query({
    query: `SELECT booking_id, renter_name FROM \`${DATASET}.bookings\`
            WHERE event_date = @date AND payment_status != 'cancelled' AND booking_id != @bookingId
              AND start_time < @endTime AND end_time > @startTime
              AND EXISTS (SELECT 1 FROM UNNEST(rooms) rm WHERE rm IN UNNEST(@rooms))`,
    params: { date: b.eventDate, startTime: `${b.eventDate} ${b.startTime}:00`, endTime: `${b.eventDate} ${b.endTime}:00`, rooms, bookingId },
    types: { rooms: ['STRING'] }
  });
  if (conflicts.length) return res.status(409).json({ errors: [`Conflicts with an existing booking (${conflicts[0].renter_name}) for one of these rooms at this time.`] });

  let renterId = null;
  let renterFields = { renterName: b.renterName, renterEmail: null, renterPhone: null, renterAddress: null, organizationName: null };
  if (!isInternal) {
    const [renterRows] = await bigquery.query({
      query: `SELECT renter_id, contact_name, email, phone, address, organization_name FROM \`${DATASET}.renters\` WHERE renter_id = @renterId`,
      params: { renterId: b.renterId }
    });
    if (!renterRows.length) return res.status(400).json({ errors: ['Selected renter was not found — they may have been removed. Please pick again.'] });
    renterId = renterRows[0].renter_id;
    renterFields = {
      renterName: renterRows[0].contact_name, renterEmail: renterRows[0].email, renterPhone: renterRows[0].phone,
      renterAddress: renterRows[0].address, organizationName: renterRows[0].organization_name
    };
  }
  const displayName = isInternal ? (b.renterName || existing.renter_name) : renterFields.renterName;
  const eventName = isInternal ? displayName : b.eventName;

  const rules = await getDiscountRules();
  let baseTotal = 0, mult = 1, subtotal = 0, finalTotal = 0;
  if (!isInternal) {
    const priced = computeOccurrencePricing(rooms, roomsMap, hours, b.eventDate, !!b.isNonprofit, rules);
    baseTotal = priced.baseTotal; mult = priced.mult; subtotal = priced.subtotal;
    finalTotal = applyManualAdjustment(subtotal, b.manualAdjustmentType, b.manualAdjustmentValue);
  }

  const oldRooms = existing.rooms || [];
  const oldEventIds = existing.calendar_event_ids || [];
  if (oldRooms.length && oldEventIds.length) {
    const calendar = await getCalendarClient();
    for (let i = 0; i < oldRooms.length; i++) {
      const calId = roomsMap[oldRooms[i]] && roomsMap[oldRooms[i]].calendar_id;
      const eventId = oldEventIds[i];
      if (!calId || !eventId) continue;
      try { await calendar.events.delete({ calendarId: calId, eventId }); } catch (err) { /* already gone, fine */ }
    }
  }
  const occ = { date: b.eventDate, startTime: b.startTime, endTime: b.endTime };
  const { eventIds, syncErrors } = await syncOccurrenceToCalendar({ rooms, roomsMap, occ, renterName: displayName, seriesLabel: null });

  await bigquery.query({
    query: `UPDATE \`${DATASET}.bookings\`
            SET rooms = @rooms, renter_id = @renterId, renter_name = @renterName, renter_email = @renterEmail,
                renter_phone = @renterPhone, renter_address = @renterAddress, organization_name = @organizationName,
                hccgc_representative_name = @hccgcRepName,
                event_date = @eventDate, start_time = @startTime, end_time = @endTime, hours = @hours,
                is_nonprofit = @isNonprofit, base_total = @baseTotal, standard_discount_multiplier = @mult,
                subtotal_after_standard_discount = @subtotal, manual_adjustment_type = @adjType,
                manual_adjustment_value = @adjValue, manual_adjustment_reason = @adjReason,
                manual_adjustment_by = @adjBy, final_total = @finalTotal, calendar_event_ids = @eventIds,
                event_name = @eventName, notes = @notes, updated_at = CURRENT_TIMESTAMP()
            WHERE booking_id = @bookingId`,
    params: {
      rooms, renterId, renterName: displayName, renterEmail: renterFields.renterEmail || null,
      renterPhone: renterFields.renterPhone || null, renterAddress: renterFields.renterAddress || null,
      organizationName: renterFields.organizationName || null, hccgcRepName: isInternal ? (b.hccgcRepresentativeName || existing.hccgc_representative_name) : null,
      eventDate: b.eventDate, startTime: `${b.eventDate} ${b.startTime}:00`, endTime: `${b.eventDate} ${b.endTime}:00`, hours,
      isNonprofit: !isInternal && !!b.isNonprofit, baseTotal, mult, subtotal,
      adjType: (!isInternal && b.manualAdjustmentType) || null, adjValue: (!isInternal && b.manualAdjustmentValue) || null,
      adjReason: (!isInternal && b.manualAdjustmentReason) || null, adjBy: (!isInternal && b.manualAdjustmentType) ? actor.email : null,
      finalTotal, eventIds, eventName: eventName || null, notes: b.notes || null, bookingId
    },
    types: {
      rooms: ['STRING'], eventIds: ['STRING'], renterId: 'STRING', renterEmail: 'STRING', renterPhone: 'STRING',
      renterAddress: 'STRING', organizationName: 'STRING', hccgcRepName: 'STRING', adjType: 'STRING',
      adjReason: 'STRING', adjValue: 'NUMERIC', adjBy: 'STRING', eventName: 'STRING', notes: 'STRING',
      hours: 'NUMERIC', baseTotal: 'NUMERIC', mult: 'NUMERIC', subtotal: 'NUMERIC', finalTotal: 'NUMERIC'
    }
  });

  await logAudit({
    action: 'booking_updated', entityType: 'booking', entityId: bookingId, actorEmail: actor.email,
    details: { rooms, eventDate: b.eventDate, startTime: b.startTime, endTime: b.endTime, finalTotal }
  });

  res.json({ bookingId, finalTotal, calendarSyncErrors: syncErrors.length ? syncErrors : undefined });
}

// POST /bookings/:id/mark-paid
const ZEFFY_CAMPAIGN_ID = '3f88c4c1-de75-4c2b-8933-9cfaf277d616';
const PAYMENTS_DATASET = 'zeffy_finance'; // separate dataset from admin_portal_backend, same project

// GET /bookings/:id/payment-matches — searches Zeffy and Zelle for payments
// that might correspond to this booking's invoice. Zeffy has a strong
// signal (the renter is asked to enter this exact booking ID as their
// "Invoice Number" custom question, which lands somewhere in raw_json).
// Zelle has no structured reference at all, so that side is inherently
// fuzzier — amount plus a name appearing in the free-text description.
// ============================================================
// Finance module — categorization, statements, reconciliation
// ============================================================
const RENTAL_CAMPAIGN_ID = ZEFFY_CAMPAIGN_ID; // already defined above
const DONATION_CAMPAIGN_ID = '01198867-7ec4-4e22-9517-f843dfc03941';

// Bank transactions have no natural unique ID — build a stable composite key
// from the fields that actually distinguish one row from another.
function bankTransactionKey(row) {
  const dateStr = (row.date && row.date.value) || row.date;
  const ingestStr = (row.ingestion_timestamp && row.ingestion_timestamp.value) || row.ingestion_timestamp || '';
  return crypto.createHash('md5').update(`${dateStr}|${row.description}|${row.amount}|${ingestStr}`).digest('hex');
}


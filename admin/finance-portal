const PIE_COLORS = [
  '#b55a18', '#2e7d4f', '#2255a4', '#a4283a', '#7d5ba6',
  '#c98a1f', '#1f8a8a', '#c23b7a', '#4a7d1f', '#8d3e0d',
  '#3a5fa0', '#a4632e', '#5a8f6e', '#7f2e16'
];
function renderPieChart(containerId, items, emptyMessage) {
  const container = document.getElementById(containerId);
  if (!items || !items.length) { container.innerHTML = '<div class="empty-state" style="padding:20px;">' + emptyMessage + '</div>'; return; }
  const total = items.reduce(function (s, i) { return s + Math.max(0, i.total); }, 0);
  if (total <= 0) { container.innerHTML = '<div class="empty-state" style="padding:20px;">' + emptyMessage + '</div>'; return; }

  const cx = 90, cy = 90, r = 80;
  let angleStart = -90; // start at 12 o'clock
  const slices = items.map(function (item, i) {
    const value = Math.max(0, item.total);
    const pct = value / total;
    const angleSweep = pct * 360;
    const angleEnd = angleStart + angleSweep;
    const largeArc = angleSweep > 180 ? 1 : 0;
    const toRad = function (deg) { return (deg * Math.PI) / 180; };
    const x1 = cx + r * Math.cos(toRad(angleStart)), y1 = cy + r * Math.sin(toRad(angleStart));
    const x2 = cx + r * Math.cos(toRad(angleEnd)), y2 = cy + r * Math.sin(toRad(angleEnd));
    const path = pct >= 0.9999
      ? '<circle cx="' + cx + '" cy="' + cy + '" r="' + r + '" fill="' + PIE_COLORS[i % PIE_COLORS.length] + '"></circle>'
      : '<path d="M' + cx + ',' + cy + ' L' + x1.toFixed(2) + ',' + y1.toFixed(2) + ' A' + r + ',' + r + ' 0 ' + largeArc + ' 1 ' + x2.toFixed(2) + ',' + y2.toFixed(2) + ' Z" fill="' + PIE_COLORS[i % PIE_COLORS.length] + '"><title>' + escHtml(item.name) + ': ' + money(value) + ' (' + (pct * 100).toFixed(1) + '%)</title></path>';
    angleStart = angleEnd;
    return path;
  }).join('');

  const legend = items.map(function (item, i) {
    const pct = total > 0 ? (Math.max(0, item.total) / total) * 100 : 0;
    return '<div class="pie-legend-row">' +
      '<span class="pie-legend-dot" style="background:' + PIE_COLORS[i % PIE_COLORS.length] + ';"></span>' +
      '<span class="pie-legend-name">' + escHtml(item.name) + '</span>' +
      '<span class="pie-legend-value">' + moneyRound(item.total) + ' (' + pct.toFixed(1) + '%)</span>' +
    '</div>';
  }).join('');

  container.innerHTML = '<div class="pie-chart-wrap">' +
    '<svg viewBox="0 0 180 180" width="180" height="180">' + slices + '</svg>' +
    '<div class="pie-legend">' + legend + '</div>' +
  '</div>';
}

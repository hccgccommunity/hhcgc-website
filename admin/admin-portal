// POST /public/facility-request — UNAUTHENTICATED. Replaces the old Google
// Form. Handles both a brand-new renter (creates a 'pending' renter record)
// and a known one (looked up by email server-side — never trusts a
// client-supplied renter ID). Either way, creates the actual booking row(s)
// with payment_status = 'requested': no calendar sync yet, nothing visible
// as a real booking until an admin reviews and approves it. A new renter's
// request naturally waits on the renter itself being approved first, since
// the review queue only surfaces requests from approved renters.
async function submitFacilityRequest(req, res) {
  const b = req.body || {};
  const errors = [];
  if (!b.email) errors.push('Email is required.');
  if (!Array.isArray(b.rooms) || !b.rooms.length) errors.push('Please select at least one room.');
  if (!Array.isArray(b.occurrences) || !b.occurrences.length) errors.push('At least one date is required.');
  if (Array.isArray(b.occurrences)) {
    b.occurrences.forEach((occ, i) => {
      if (!occ.date || !occ.startTime || !occ.endTime) errors.push(`Date row ${i + 1}: date and time are all required.`);
    });
  }
  if (!b.eventDetails) errors.push('Please tell us about your event.');

  const email = (b.email || '').trim().toLowerCase();
  let existingRenter = null;
  if (email) {
    const [rows] = await bigquery.query({
      query: `SELECT renter_id, contact_name, email, phone, address, organization_name
              FROM \`${DATASET}.renters\` WHERE LOWER(email) = @email AND status IN ('approved', 'pending') LIMIT 1`,
      params: { email }
    });
    if (rows.length) existingRenter = rows[0];
  }
  // Always required, matched renter or not — the frontend pre-fills these
  // for a matched renter, but someone can still correct something before
  // submitting, and that correction should genuinely apply to this request.
  if (!b.firstName) errors.push('First name is required.');
  if (!b.lastName) errors.push('Last name is required.');
  if (!b.phone) errors.push('Phone number is required.');
  if (!b.billingAddress) errors.push('Billing address is required.');
  if (errors.length) return res.status(400).json({ errors });

  let renterId, contactName, renterEmail, renterPhone, renterAddress, renterOrg;
  const isNewRenter = !existingRenter;

  contactName = `${b.firstName} ${b.lastName}`.trim();
  renterEmail = b.email;
  renterPhone = b.phone;
  renterAddress = b.billingAddress;
  renterOrg = b.organizationName;

  if (existingRenter) {
    // Link to the existing approved/pending renter (so New Booking's
    // dropdown etc. still resolve correctly) — but this particular request
    // uses whatever was actually submitted, in case something was edited.

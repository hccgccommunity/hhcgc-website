<style>
:root {
  --bg:#fff9f1;--surface:#fff;--surface-soft:#fff6ea;--border:rgba(121,62,17,0.14);
  --text:#2c1b10;--muted:#6a5141;--saffron:#b55a18;--saffron-dark:#8d3e0d;
  --maroon:#7f2e16;--radius:22px;--shadow:0 18px 45px rgba(93,43,14,0.10);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{font-family:Arial,Helvetica,sans-serif;background:radial-gradient(circle at top left,rgba(217,138,30,0.12),transparent 22%),radial-gradient(circle at top right,rgba(127,46,22,0.05),transparent 20%),var(--bg);color:var(--text);min-height:100vh;}
.container{width:min(calc(100% - 32px),1100px);margin:0 auto;}
.site-header{position:sticky;top:0;z-index:50;background:rgba(255,249,241,0.92);backdrop-filter:blur(10px);border-bottom:1px solid var(--border);}
.nav{display:flex;align-items:center;justify-content:space-between;gap:24px;min-height:92px;padding:12px 0;}
.brand{display:flex;align-items:center;gap:16px;min-width:0;}
.brand-logo-wrap{background:#7f2e16;border-radius:18px;padding:8px;flex-shrink:0;}
.brand-logo{width:88px;height:auto;border-radius:12px;object-fit:contain;}
.brand-text h1{margin:0;font-size:1.2rem;line-height:1.15;color:var(--maroon);font-family:Georgia,serif;}
.site-header a.brand,.site-header a.brand:link,.site-header a.brand:visited{text-decoration:none;color:inherit;}
.site-header nav ul{list-style:none;display:flex;flex-wrap:wrap;gap:18px;margin:0;padding:0;align-items:center;justify-content:flex-end;}
.site-header nav a,.site-header nav a:link,.site-header nav a:visited{font-weight:700;color:var(--text);font-size:0.96rem;text-decoration:none;}
.site-header nav a:hover{color:var(--saffron-dark);}
.menu-toggle{display:none;border:0;background:transparent;padding:6px 0;cursor:pointer;color:#2c1b10;align-self:flex-end;}
.menu-toggle .bar{display:block;width:26px;height:2px;margin:5px 0;background:currentColor;}
@media(max-width:768px){.nav{flex-direction:column;align-items:stretch;gap:8px;}.menu-toggle{display:inline-block;}.site-header nav{display:none;width:100%;background:rgba(255,249,241,0.95);padding:10px 0;}.site-header nav.is-open{display:block;}.site-header nav ul{flex-direction:column;gap:14px;}}
#gate{padding:60px 16px;display:flex;justify-content:center;}
.gate-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:2.5rem 2rem;max-width:420px;width:100%;text-align:center;box-shadow:var(--shadow);}
.gate-card h3{font-family:Georgia,serif;font-size:1.3rem;color:var(--maroon);margin-bottom:.5rem;}
.gate-card p{color:var(--muted);font-size:.88rem;line-height:1.6;}
.gate-card a{color:var(--saffron-dark);}
#app{display:none;}
.page-header{padding:36px 0 20px;}
.page-header h1{font-family:Georgia,serif;font-size:1.8rem;color:var(--maroon);margin-bottom:6px;}
.page-header p{color:var(--muted);font-size:.9rem;}
.back-link{font-size:.82rem;color:var(--saffron-dark);text-decoration:none;display:inline-block;margin-bottom:10px;}
.back-link:hover{text-decoration:underline;}
.status-bar{display:none;align-items:center;gap:10px;padding:.75rem 1.1rem;border-radius:12px;font-size:.86rem;font-weight:600;margin:0 0 1.25rem;}
.status-bar.show{display:flex;}
.status-bar.success{background:#e8f5e9;color:#2e7d32;border:1px solid #c8e6c9;}
.status-bar.error{background:#fdecea;color:#c0392b;border:1px solid #f5c6cb;}
.toolbar{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:1.5rem;flex-wrap:wrap;}
.btn-new{display:inline-flex;align-items:center;gap:8px;padding:.7rem 1.4rem;background:var(--maroon);color:#fff;border:none;border-radius:999px;font-size:.9rem;font-weight:700;cursor:pointer;font-family:Arial,Helvetica,sans-serif;}
.btn-new:hover{background:#5a1e0a;}
.pages-list{display:flex;flex-direction:column;gap:14px;padding-bottom:60px;}
.page-row{background:#fff;border:1px solid var(--border);border-radius:16px;padding:1.2rem 1.5rem;display:flex;align-items:center;gap:16px;flex-wrap:wrap;}
.page-row-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;background:#e0e0e0;}
.page-row-dot.live{background:#4caf50;}
.page-row-info{flex:1;min-width:200px;}
.page-row-info h4{font-family:Georgia,serif;font-size:1rem;color:var(--maroon);margin-bottom:3px;}
.page-row-info .meta{font-size:.78rem;color:var(--muted);}
.page-row-info .meta a{color:var(--saffron-dark);text-decoration:none;}
.page-row-info .meta a:hover{text-decoration:underline;}
.type-pill{font-size:.68rem;font-weight:800;text-transform:uppercase;letter-spacing:.04em;padding:2px 9px;border-radius:999px;}
.type-pill.event{background:rgba(127,46,22,.1);color:var(--maroon);}
.type-pill.initiative{background:rgba(181,90,24,.12);color:var(--saffron-dark);}
.page-row-actions{display:flex;gap:8px;}
.btn-row{display:inline-flex;align-items:center;gap:6px;padding:.45rem .9rem;border:1px solid var(--border);border-radius:8px;background:#fff;font-size:.8rem;font-weight:600;color:var(--muted);cursor:pointer;font-family:Arial,Helvetica,sans-serif;white-space:nowrap;}
.btn-row:hover{border-color:var(--saffron);color:var(--saffron-dark);}
.btn-row.danger:hover{border-color:#c0392b;color:#c0392b;}
.empty-state{text-align:center;padding:50px 20px;color:var(--muted);background:#fff;border:1px dashed var(--border);border-radius:16px;}
/* MODAL */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(44,27,16,.45);z-index:200;align-items:flex-start;justify-content:center;padding:16px;overflow-y:auto;}
.modal-overlay.show{display:flex;}
.modal-card{background:#fff;border-radius:18px;max-width:640px;width:100%;box-shadow:var(--shadow);margin:auto;}
.wizard-header{padding:1.4rem 1.6rem 0;}
.wizard-header-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
.wizard-header-top h3{font-family:Georgia,serif;color:var(--maroon);font-size:1.1rem;}
.modal-close{background:none;border:none;cursor:pointer;color:var(--muted);font-size:1.3rem;}
.modal-close:hover{color:var(--maroon);}
.step-bars{display:flex;gap:5px;margin-bottom:6px;}
.step-bar{height:4px;border-radius:2px;flex:1;background:var(--border);transition:background .2s;}
.step-bar.active{background:var(--maroon);}
.step-bar.done{background:var(--saffron);}
.step-meta{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--saffron-dark);padding:0 1.6rem;margin-bottom:10px;}
.wizard-step{display:none;padding:0 1.6rem 1.2rem;}
.wizard-step.active{display:block;}
.form-group{margin-bottom:1.1rem;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
label{display:block;font-size:.82rem;font-weight:700;color:var(--text);margin-bottom:.4rem;}
label .hint{font-weight:400;color:var(--muted);}
input[type=text],input[type=date],input[type=time],input[type=url],textarea,select{width:100%;padding:.6rem .85rem;border:1.5px solid var(--border);border-radius:10px;font-size:.9rem;font-family:Arial,Helvetica,sans-serif;background:#fff;color:var(--text);}
input:focus,textarea:focus,select:focus{outline:none;border-color:var(--saffron);box-shadow:0 0 0 3px rgba(181,90,24,.14);}
textarea{resize:vertical;}
.field-hint{font-size:.76rem;color:var(--muted);margin-top:4px;line-height:1.5;}
.field-error{font-size:.76rem;color:#c0392b;margin-top:4px;display:none;}
.field-error.show{display:block;}
.slug-preview{font-size:.78rem;color:var(--muted);margin-top:4px;}
.slug-preview span{font-weight:700;color:var(--saffron-dark);}
.toggle-row{display:flex;align-items:center;gap:10px;padding:12px 14px;background:var(--surface-soft);border:1px solid var(--border);border-radius:10px;margin-bottom:1.1rem;cursor:pointer;}
.toggle-row label{margin:0;cursor:pointer;font-size:.88rem;font-weight:600;}
.toggle-row input[type=checkbox]{width:auto;cursor:pointer;}
.type-toggle{display:flex;gap:8px;margin-top:4px;}
.type-btn{flex:1;display:flex;align-items:center;justify-content:center;gap:7px;padding:.65rem .8rem;border:1.5px solid var(--border);border-radius:10px;background:#fff;color:var(--muted);font-size:.86rem;font-weight:700;cursor:pointer;font-family:Arial,Helvetica,sans-serif;transition:all .12s;}
.type-btn.active{background:var(--maroon);border-color:var(--maroon);color:#fff;}
.type-btn:hover:not(.active){border-color:var(--saffron);color:var(--saffron-dark);}
.sec-label{font-size:.72rem;font-weight:800;text-transform:uppercase;letter-spacing:.07em;color:var(--saffron-dark);margin:1.2rem 0 .6rem;padding-bottom:6px;border-bottom:1px dashed var(--border);display:block;}
.drive-help{background:#e8f5e9;border:1px solid #c8e6c9;border-radius:10px;padding:10px 14px;font-size:.77rem;color:#2e7d32;margin-top:6px;line-height:1.6;}
.drive-help strong{display:block;margin-bottom:3px;}
.img-preview{margin-top:8px;display:none;}
.img-preview img{max-width:100%;border-radius:8px;border:1px solid var(--border);max-height:140px;object-fit:contain;}
.event-sync-box{background:var(--surface-soft);border:1px solid var(--border);border-radius:12px;padding:1rem 1.2rem;margin-top:.8rem;}
.event-sync-box h4{font-size:.82rem;font-weight:700;margin-bottom:.6rem;color:var(--text);}
.event-sync-fields{display:none;}
.event-sync-fields.show{display:block;}
.wizard-footer{padding:1.2rem 1.6rem 1.5rem;display:flex;justify-content:space-between;align-items:center;border-top:1px solid var(--border);gap:10px;flex-wrap:wrap;}
.wizard-footer-left{display:flex;gap:8px;}
.wizard-footer-right{display:flex;align-items:center;gap:10px;}
.live-link{font-size:.78rem;color:var(--saffron-dark);text-decoration:none;}
.live-link:hover{text-decoration:underline;}
.btn-secondary{padding:.6rem 1.2rem;border-radius:10px;border:1.5px solid var(--border);background:#fff;color:var(--muted);font-weight:700;font-size:.86rem;cursor:pointer;font-family:Arial,Helvetica,sans-serif;}
.btn-secondary:hover{border-color:var(--saffron);color:var(--saffron-dark);}
.btn-next{padding:.6rem 1.4rem;border-radius:10px;border:none;background:var(--saffron-dark);color:#fff;font-weight:700;font-size:.86rem;cursor:pointer;font-family:Arial,Helvetica,sans-serif;display:inline-flex;align-items:center;gap:6px;}
.btn-next:hover{background:#6a2e09;}
.btn-save{padding:.6rem 1.4rem;border-radius:10px;border:none;background:var(--maroon);color:#fff;font-weight:700;font-size:.86rem;cursor:pointer;font-family:Arial,Helvetica,sans-serif;display:inline-flex;align-items:center;gap:8px;}
.btn-save:hover{background:#5a1e0a;}
.btn-save:disabled,.btn-next:disabled{opacity:.6;cursor:not-allowed;}
.spinner{width:14px;height:14px;border:2px solid rgba(255,255,255,.4);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite;display:inline-block;}
@keyframes spin{to{transform:rotate(360deg);}}
@media(max-width:600px){.form-row{grid-template-columns:1fr;}.page-row{flex-direction:column;align-items:stretch;}.wizard-footer{flex-direction:column;}.wizard-footer-left,.wizard-footer-right{width:100%;justify-content:flex-end;}}
</style>
</head>
<body>
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TPBF5VKB" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

<div id="site-header"></div>

<div id="gate">
  <div class="gate-card">
    <h3>Checking access&hellip;</h3>
    <p>Please sign in from the <a href="/admin/admin-portal">Admin Portal</a> first.</p>
  </div>
</div>

<div id="app">
  <div class="container">
    <div class="page-header">
      <a class="back-link" href="/admin/admin-portal">&larr; Back to apps</a>
      <h1>Manage Pages</h1>
      <p>Create and publish public event and initiative pages. Changes go live instantly — no deploy needed.</p>
    </div>
    <div class="status-bar" id="status-bar"></div>
    <div class="toolbar">
      <div id="pages-count" style="font-size:.86rem;color:var(--muted);"></div>
      <button class="btn-new" id="btn-new-page">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        New Page
      </button>
    </div>
    <div class="pages-list" id="pages-list">
      <div class="empty-state">Loading&hellip;</div>
    </div>
  </div>
</div>

<!-- WIZARD MODAL -->
<div class="modal-overlay" id="modal-overlay">
  <div class="modal-card">
    <div class="wizard-header">
      <div class="wizard-header-top">
        <h3 id="wizard-title">New Page</h3>
        <button class="modal-close" id="modal-close-btn">&times;</button>
      </div>
      <div class="step-bars" id="step-bars"></div>
    </div>
    <div class="step-meta" id="step-meta"></div>

    <input type="hidden" id="edit-page-id">

    <!-- STEP 1: Basics -->
    <div class="wizard-step active" id="step-1">
      <div class="form-group">
        <label>Page Type *</label>
        <div class="type-toggle">
          <button type="button" class="type-btn active" id="type-btn-event" data-type="event">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Event <span style="font-weight:400;font-size:.75rem;">(one-time)</span>
          </button>
          <button type="button" class="type-btn" id="type-btn-initiative" data-type="initiative">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 3a2.828 2.828 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5L17 3z"/></svg>
            Initiative <span style="font-weight:400;font-size:.75rem;">(recurring)</span>
          </button>
        </div>
        <input type="hidden" id="page-type" value="event">
      </div>
      <div class="form-group">
        <label for="page-title">Page Title *</label>
        <input type="text" id="page-title" placeholder="e.g. Parisa Sparsha – An Evening of Classical Music">
        <div class="field-error" id="err-title">Please enter a page title.</div>
      </div>
      <div class="form-group">
        <label for="page-slug">URL Slug *</label>
        <input type="text" id="page-slug" placeholder="e.g. parisa-sparsha">
        <div class="slug-preview">hccgc.org/<span id="slug-display">your-slug</span></div>
        <div class="field-error" id="err-slug">Please enter a valid slug (lowercase, hyphens, numbers only).</div>
      </div>
      <div class="form-group">
        <label for="page-tagline">Tagline</label>
        <input type="text" id="page-tagline" placeholder="e.g. A composer's insight into a composer's mind">
      </div>
      <div class="form-group">
        <label for="page-hero-desc">Hero Description</label>
        <textarea id="page-hero-desc" rows="2" placeholder="Short paragraph shown in the hero banner"></textarea>
      </div>
      <div class="toggle-row">
        <input type="checkbox" id="page-enabled">
        <label for="page-enabled">Page is live and publicly visible</label>
      </div>
    </div>

    <!-- STEP 2: Event Details -->
    <div class="wizard-step" id="step-2">
      <div class="form-row">
        <div class="form-group">
          <label for="page-venue">Venue</label>
          <input type="text" id="page-venue" placeholder="HCCGC (default if blank)">
        </div>
        <div class="form-group">
          <label for="page-cost-display">Cost</label>
          <input type="text" id="page-cost-display" placeholder="e.g. $15 early / $20 at door">
        </div>
      </div>
      <!-- Event-only date/time -->
      <div id="step2-event-fields">
        <div class="form-row">
          <div class="form-group">
            <label for="page-date">Date</label>
            <input type="date" id="page-date">
          </div>
          <div class="form-group">
            <label for="page-from-time">Start Time</label>
            <input type="text" id="page-from-time" placeholder="e.g. 6:30 PM">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="page-to-time">End Time</label>
            <input type="text" id="page-to-time" placeholder="e.g. 9:00 PM">
          </div>
          <div class="form-group">
            <label for="page-category">Category</label>
            <select id="page-category">
              <option value="">None</option>
              <option value="Cultural">Cultural</option>
              <option value="Spiritual">Spiritual</option>
              <option value="Kids">Kids</option>
              <option value="Wellness">Wellness</option>
              <option value="Community">Community</option>
              <option value="Education">Education</option>
            </select>
          </div>
        </div>
      </div>
      <!-- Initiative-only date fields -->
      <div id="step2-initiative-fields" style="display:none;">
        <div class="form-row">
          <div class="form-group">
            <label for="page-start-date">Start Date</label>
            <input type="date" id="page-start-date">
          </div>
          <div class="form-group">
            <label for="page-end-date">End Date</label>
            <input type="date" id="page-end-date">
          </div>
        </div>
        <div class="form-group">
          <label for="page-schedule-text">Weekly Schedule</label>
          <input type="text" id="page-schedule-text" placeholder="e.g. Tuesdays 6–7 PM, Thursdays 7–8 PM">
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="page-contact-name">Contact Name</label>
          <input type="text" id="page-contact-name" placeholder="e.g. Ajay Bhosale">
        </div>
        <div class="form-group">
          <label for="page-contact-phone">Contact Phone</label>
          <input type="text" id="page-contact-phone" placeholder="e.g. (513) 680-9379">
        </div>
      </div>

      <!-- Sync to Manage Events -->
      <div class="event-sync-box">
        <h4>Also add to Upcoming Events page?</h4>
        <div class="toggle-row" style="margin-bottom:.6rem;">
          <input type="checkbox" id="sync-to-events">
          <label for="sync-to-events">Yes — create an entry in Manage Events</label>
        </div>
        <div class="event-sync-fields" id="event-sync-fields">
          <p style="font-size:.78rem;color:var(--muted);margin-bottom:.8rem;">The fields above will be used. Add a short description for the upcoming events listing:</p>
          <div class="form-group" style="margin-bottom:.5rem;">
            <label for="sync-description">Short Description *</label>
            <textarea id="sync-description" rows="2" placeholder="One or two sentences describing this event/initiative for the upcoming events page"></textarea>
            <div class="field-error" id="err-sync-desc">Please enter a short description.</div>
          </div>
        </div>
      </div>
    </div>

    <!-- STEP 3: Content -->
    <div class="wizard-step" id="step-3">
      <div class="form-group">
        <label for="page-about-title">About Section Title</label>
        <input type="text" id="page-about-title" placeholder="e.g. A Celebration of Timeless Melodies">
      </div>
      <div class="form-group">
        <label for="page-about-body">About Section Body</label>
        <textarea id="page-about-body" rows="5" placeholder="Full description. Use a new line for each paragraph."></textarea>
      </div>
      <div class="form-group">
        <label for="page-what-to-expect">What to Expect <span class="hint">(one item per line)</span></label>
        <textarea id="page-what-to-expect" rows="3" placeholder="Live violin, vocals, harmonium&#10;Narration in Marathi&#10;Intimate mahfil-style setting"></textarea>
      </div>
      <div class="form-group">
        <label for="page-who-should-attend">Who Should Attend <span class="hint">(one item per line)</span></label>
        <textarea id="page-who-should-attend" rows="3" placeholder="Lovers of Marathi and Hindi film music&#10;Families of all ages"></textarea>
      </div>
    </div>

    <!-- STEP 4: People -->
    <div class="wizard-step" id="step-4">
      <div id="step4-event">
        <div class="form-group">
          <label for="page-performers">Performers <span class="hint">(one per line: Name | Role | Location)</span></label>
          <textarea id="page-performers" rows="5" placeholder="Sachin Ingale | Vocalist · Violinist · Composer | Pune, India&#10;Ruchir Ingale | Vocalist | Pune, India"></textarea>
          <div class="field-hint">Separate Name, Role, and Location with |</div>
        </div>
      </div>

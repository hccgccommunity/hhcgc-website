function showGate(title, msg) {
  const g = document.getElementById('gate');
  g.querySelector('h3').textContent = title;
  g.querySelector('p').innerHTML = msg;
  g.style.display = 'flex';
  document.getElementById('app').style.display = 'none';
}

onAuthStateChanged(auth, async user => {
  if (!user) { showGate('Sign in required', 'Please sign in from the <a href="/admin/admin-portal">Admin Portal</a> first.'); return; }
  const email = (user.email || '').toLowerCase();
  if (!email.endsWith('@' + ALLOWED_DOMAIN)) { showGate('Access denied', 'Please use an @' + ALLOWED_DOMAIN + ' account.'); return; }
  try {
    const snap = await getDoc(doc(db, USERS_COLLECTION, email));
    const data = snap.exists() ? snap.data() : {};
    if (!data.isAdmin && !(Array.isArray(data.allowedApps) && data.allowedApps.includes(REQUIRED_APP_KEY))) {
      showGate('Access not granted', "You don't have access to Manage Pages. Ask an admin to grant it from User Management.");
      return;
    }
  } catch(e) { showGate('Error', 'Could not verify your access. Please try again.'); return; }
  document.getElementById('gate').style.display = 'none';
  document.getElementById('app').style.display = 'block';
  window.dispatchEvent(new CustomEvent('hccgc-mp-ready'));
});

.module-nav { background: var(--surface); border-bottom: 1px solid var(--border); }
.module-nav ul { list-style: none; display: flex; gap: 4px; padding: 10px 0; flex-wrap: wrap; }
.module-nav a { display: inline-block; padding: 8px 16px; border-radius: 999px; font-size: 0.86rem; font-weight: 700; color: var(--muted); text-decoration: none; transition: background 0.15s, color 0.15s; }
.module-nav a.active { background: var(--surface-soft); color: var(--saffron-dark); }
.module-nav a.disabled { color: rgba(106,81,65,0.4); cursor: default; }
.module-nav a:not(.disabled):not(.active):hover { background: var(--surface-soft); }

.card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 28px; box-shadow: var(--shadow); margin: 24px 0; }
.card h2 { font-family: Georgia, "Times New Roman", serif; font-size: 1.2rem; color: var(--maroon); margin-bottom: 4px; }
.card .card-sub { font-size: 0.82rem; color: var(--muted); margin-bottom: 18px; }

table { width: 100%; border-collapse: collapse; font-size: 0.88rem; }
thead th { text-align: left; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--muted); background: var(--surface-soft); padding: 10px 12px; }
tbody td { padding: 10px 12px; border-bottom: 1px solid var(--border); vertical-align: middle; }
tbody tr:last-child td { border-bottom: none; }
tbody input[type="text"], tbody input[type="number"] {
  font-family: Arial, Helvetica, sans-serif; font-size: 0.86rem; padding: 6px 10px; border: 1.5px solid var(--border); border-radius: 8px; width: 100%;
}
.rate-input-wrap { display: flex; align-items: center; gap: 4px; }
.rate-input-wrap input { width: 80px; }
.status-pill { font-size: 0.72rem; font-weight: 700; padding: 3px 10px; border-radius: 999px; }
.status-active { background: #e8f5ec; color: #2e7d4f; }
.status-inactive { background: #f1ede8; color: var(--muted); }
.btn-small { font-family: Arial, Helvetica, sans-serif; font-size: 0.78rem; font-weight: 700; padding: 6px 12px; border-radius: 8px; border: 1.5px solid var(--saffron-dark); background: #fff; color: var(--saffron-dark); cursor: pointer; }
.btn-small:hover { background: var(--surface-soft); }
.btn-small.danger { border-color: #b3382c; color: #b3382c; }

.rules-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
.rule-field { display: flex; flex-direction: column; gap: 6px; }
.rule-field label { font-size: 0.78rem; font-weight: 700; color: var(--muted); }
.rule-field .rule-hint { font-size: 0.74rem; color: var(--muted); font-style: italic; }
.rule-field input { font-family: Arial, Helvetica, sans-serif; font-size: 0.9rem; padding: 9px 12px; border: 1.5px solid var(--border); border-radius: 10px; }

.btn-primary {
  font-family: Arial, Helvetica, sans-serif; font-size: 0.88rem; font-weight: 700; color: #fff;
  background: linear-gradient(135deg, var(--saffron-dark), var(--maroon)); border: none; border-radius: 12px;
  padding: 11px 20px; cursor: pointer; margin-top: 18px;
}
.btn-primary:hover { opacity: 0.92; }

.result-box { margin-top: 16px; border-radius: 12px; padding: 12px 16px; font-size: 0.86rem; line-height: 1.5; }
.result-box.success { background: #e8f5ec; color: #2e7d4f; border: 1px solid rgba(46,125,79,0.25); }
.result-box.error { background: #fbe9e7; color: #b3382c; border: 1px solid rgba(179,56,44,0.25); }
.add-room-row { display: grid; grid-template-columns: 2fr 1fr 2fr 1fr; gap: 10px; margin-top: 16px; align-items: end; }
.add-room-row .field { display: flex; flex-direction: column; gap: 6px; }
.add-room-row .field label { font-size: 0.76rem; font-weight: 700; color: var(--muted); }
.add-room-row input { font-family: Arial, Helvetica, sans-serif; font-size: 0.86rem; padding: 9px 12px; border: 1.5px solid var(--border); border-radius: 10px; }
#gate{padding:60px 16px;display:flex;justify-content:center;}
.gate-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:2.5rem 2rem;max-width:420px;width:100%;text-align:center;box-shadow:var(--shadow);}
.gate-card h3{font-family:Georgia,serif;font-size:1.3rem;color:var(--maroon);margin-bottom:.5rem;}
.gate-card p{color:var(--muted);font-size:.88rem;line-height:1.6;}
.gate-card a{color:var(--saffron-dark);}
.back-link { display: inline-flex; align-items: center; gap: 6px; font-size: 0.82rem; font-weight: 700; color: rgba(255,255,255,0.85); text-decoration: none; margin-bottom: 14px; }
.back-link:hover { color: #fff; text-decoration: underline; }

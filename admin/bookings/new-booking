          <select id="f-renter-select" required>
            <option value="">Choose a renter…</option>
          </select>
          <div class="card-sub" style="margin-bottom:0;margin-top:6px;">Don't see who you're looking for? <a href="add-renter" style="color:var(--saffron-dark);font-weight:700;">Add them on the Add A Renter page</a> first.</div>
        </div>
        <div class="field" id="f-name-field" style="display:none;"><label id="f-name-label">Program / event name</label><input type="text" id="f-name" placeholder="e.g. Weekly Bhajan Sandhya"></div>
        <div class="field" id="f-hccg-rep-field" style="display:none;"><label>HCCGC representative name</label><input type="text" id="f-hccg-rep" placeholder="Who at HCCGC is organizing this?"></div>
        <div class="field"><label id="f-notes-label">Notes (optional)</label><textarea id="f-notes" placeholder="Anything worth remembering about this booking"></textarea></div>
      </div>

      <div class="card" id="rooms-card">

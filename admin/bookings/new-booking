<script>
// ---- Mirrors zeffy_finance.rooms and zeffy_finance.discount_rules ----
// TODO: once the backend endpoint exists, fetch these live instead of
// hardcoding. Note: there is no bundle/whole-facility multiplier here on
// purpose — that discount is always applied manually via the discretionary
// adjustment above, never automatically.
const ROOMS = [
  { name: 'Surya Hall', rate: 45 },
  { name: 'Patanjali Hall', rate: 40 },
  { name: 'Nataraj Room', rate: 30 },
  { name: 'Ganesh Room', rate: 15 },
  { name: 'Kitchen', rate: 0 }
];
const RULES = {
  weekdayMultiplier: 0.80,
  nonprofitMultiplier: 0.75,
  extendedHoursMultiplier: 0.80,
  extendedHoursThreshold: 4
};

const roomPicker = document.getElementById('room-picker');
ROOMS.forEach(function (r) {
  const label = document.createElement('label');
  label.className = 'room-check';
  const rateText = r.rate > 0 ? ('$' + r.rate + '/hr') : 'Free';
  label.innerHTML = '<input type="checkbox" class="room-cb" value="' + r.name + '"> ' + r.name + '<span class="rate">' + rateText + '</span>';
  roomPicker.appendChild(label);
});
document.getElementById('btn-whole-facility').addEventListener('click', function () {
  document.querySelectorAll('.room-cb').forEach(function (cb) { cb.checked = true; });
  enforceKitchenRule();
  recalc();
});
function selectedRooms() {
  return Array.from(document.querySelectorAll('.room-cb:checked')).map(function (cb) { return cb.value; });
}
// Kitchen only makes sense alongside Surya Hall or Patanjali Hall — disable
// it otherwise, and uncheck it automatically if the last qualifying room
// gets unchecked while Kitchen is still selected.
function enforceKitchenRule() {
  const kitchenCb = document.querySelector('.room-cb[value="Kitchen"]');
  const suryaChecked = document.querySelector('.room-cb[value="Surya Hall"]').checked;
  const patanjaliChecked = document.querySelector('.room-cb[value="Patanjali Hall"]').checked;
  const eligible = suryaChecked || patanjaliChecked;
  kitchenCb.disabled = !eligible;
  kitchenCb.closest('.room-check').style.opacity = eligible ? '1' : '0.5';
  if (!eligible) kitchenCb.checked = false;
}
roomPicker.addEventListener('change', enforceKitchenRule);
enforceKitchenRule();

// ---- Occurrence list: the source of truth for what actually gets booked ----
let occurrences = []; // [{ date, startTime, endTime }]

function hoursBetween(startTime, endTime) {
  if (!startTime || !endTime) return 0;
  const s = startTime.split(':').map(Number);
  const e = endTime.split(':').map(Number);
  const diff = (e[0] * 60 + e[1]) - (s[0] * 60 + s[1]);
  return diff > 0 ? Math.round((diff / 60) * 100) / 100 : 0;
}
function isWeekday(dateStr) {
  if (!dateStr) return false;
  const day = new Date(dateStr + 'T00:00:00').getDay();
  return day >= 1 && day <= 5;
}
function addDays(dateStr, n) {
  const d = new Date(dateStr + 'T00:00:00');
  d.setDate(d.getDate() + n);
  return d.toISOString().slice(0, 10);
}
function addMonths(dateStr, n) {
  const d = new Date(dateStr + 'T00:00:00');
  d.setMonth(d.getMonth() + n);
  return d.toISOString().slice(0, 10);
}

function regenerateOccurrences() {
  const firstDate = document.getElementById('f-date').value;
  const startTime = document.getElementById('f-start').value;
  const endTime = document.getElementById('f-end').value;
  if (!firstDate || !startTime || !endTime) { occurrences = []; renderOccTable(); return; }

  if (!document.getElementById('f-recurring-enabled').checked) {
    occurrences = [{ date: firstDate, startTime: startTime, endTime: endTime }];
    renderOccTable();
    return;
  }

  const frequency = document.getElementById('f-recur-frequency').value;
  const endType = document.getElementById('f-recur-end-type').value;
  const count = endType === 'count' ? parseInt(document.getElementById('f-recur-count').value, 10) : null;
  const until = endType === 'until' ? document.getElementById('f-recur-until').value : null;

  const dates = [firstDate];
  let cur = firstDate;
  let guard = 0;
  while (guard++ < 366) {
    if (count && dates.length >= count) break;
    cur = frequency === 'daily' ? addDays(cur, 1)
        : frequency === 'weekly' ? addDays(cur, 7)
        : frequency === 'biweekly' ? addDays(cur, 14)
        : addMonths(cur, 1);
    if (until && cur > until) break;
    if (!count && !until) break;
    dates.push(cur);
  }
  occurrences = dates.map(function (d) { return { date: d, startTime: startTime, endTime: endTime }; });
  renderOccTable();
}

function renderOccTable() {
  const table = document.getElementById('occ-table');
  const tbody = document.getElementById('occ-tbody');
  const invoiceModeField = document.getElementById('invoice-mode-field');
  const isRecurring = document.getElementById('f-recurring-enabled').checked;
  if (!isRecurring || occurrences.length <= 1) { table.style.display = 'none'; invoiceModeField.style.display = 'none'; recalc(); return; }

  table.style.display = 'table';
  invoiceModeField.style.display = 'block';
  tbody.innerHTML = occurrences.map(function (occ, i) {
    return '<tr>' +
      '<td><input type="date" value="' + occ.date + '" data-i="' + i + '" data-f="date"' + (window.__hccgcCurrentUser && window.__hccgcCurrentUser.email !== 'tech-admin@hccgc.org' ? ' min="' + new Date().toISOString().slice(0, 10) + '"' : '') + '></td>' +
      '<td><input type="time" value="' + occ.startTime + '" data-i="' + i + '" data-f="startTime" list="common-times"></td>' +
      '<td><input type="time" value="' + occ.endTime + '" data-i="' + i + '" data-f="endTime" list="common-times"></td>' +
      '<td><button type="button" class="occ-remove" data-remove="' + i + '" title="Remove this date">&times;</button></td>' +
    '</tr>';
  }).join('');

  tbody.querySelectorAll('input').forEach(function (input) {
    input.addEventListener('change', function () {
      occurrences[parseInt(this.dataset.i, 10)][this.dataset.f] = this.value;
      recalc();
    });
  });
  tbody.querySelectorAll('[data-remove]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      occurrences.splice(parseInt(this.dataset.remove, 10), 1);
      renderOccTable();
    });
  });
  recalc();
}

document.getElementById('f-recurring-enabled').addEventListener('change', function () {
  document.getElementById('recurring-fields').classList.toggle('open', this.checked);
  regenerateOccurrences();
});
document.getElementById('f-recur-end-type').addEventListener('change', function () {
  const isCount = this.value === 'count';
  document.getElementById('recur-count-field').style.display = isCount ? 'flex' : 'none';
  document.getElementById('recur-until-field').style.display = isCount ? 'none' : 'flex';
});
document.getElementById('btn-regenerate-occurrences').addEventListener('click', regenerateOccurrences);
['f-date','f-start','f-end'].forEach(function (id) {
  document.getElementById(id).addEventListener('change', regenerateOccurrences);
});

document.getElementById('f-internal-enabled').addEventListener('change', function () {
  const isInternal = this.checked;
  document.getElementById('renter-details-title').textContent = isInternal ? 'Program' : 'Renter';
  document.getElementById('renter-details-sub').textContent = isInternal ? 'What is this reserving the space for?' : "Who's booking, and what for.";
  document.getElementById('f-renter-select-field').style.display = isInternal ? 'none' : 'flex';
  document.getElementById('f-event-name-field').style.display = isInternal ? 'none' : 'flex';
  document.getElementById('f-name-field').style.display = isInternal ? 'flex' : 'none';
  document.getElementById('f-hccg-rep-field').style.display = isInternal ? 'flex' : 'none';
  document.getElementById('publish-event-field').classList.toggle('open', isInternal);
  document.getElementById('nonprofit-row').style.display = isInternal ? 'none' : 'flex';
  document.getElementById('adjustment-toggle').style.display = isInternal ? 'none' : 'flex';
  document.getElementById('f-notes-label').textContent = isInternal ? 'Description' : 'Notes (optional)';
  document.getElementById('f-notes').placeholder = isInternal ? 'What is this program/event about?' : 'Anything worth remembering about this booking';
  if (isInternal) {
    document.getElementById('f-renter-select').value = '';
    document.getElementById('nonprofit-row').style.display = 'none';
    document.getElementById('f-adjustment-enabled').checked = false;
    document.getElementById('adjustment-fields').classList.remove('open');
  } else {
    document.getElementById('f-name').value = '';
    document.getElementById('f-hccg-rep').value = '';
  }
  recalc();
});

document.getElementById('adjustment-toggle').addEventListener('click', function (e) {
  if (e.target.id !== 'f-adjustment-enabled') document.getElementById('f-adjustment-enabled').click();
});
document.getElementById('f-adjustment-enabled').addEventListener('change', function () {
  document.getElementById('adjustment-fields').classList.toggle('open', this.checked);
  recalc();
});
['f-renter-select','f-adj-type','f-adj-value'].forEach(function (id) {
  document.getElementById(id).addEventListener('input', recalc);
  document.getElementById(id).addEventListener('change', recalc);
});
roomPicker.addEventListener('change', recalc);

function recalc() {
  if (document.getElementById('f-internal-enabled').checked) {
    document.getElementById('s-base').textContent = '$0.00';
    document.getElementById('s-discount-tags').innerHTML = '<span class="no-discount">N/A — internal HCCGC use</span>';
    document.getElementById('s-subtotal').textContent = '$0.00';
    document.getElementById('s-adjustment-line').style.display = 'none';
    document.getElementById('s-final').textContent = '$0.00';
    document.getElementById('s-total-label').textContent = 'Total';
    document.getElementById('cost-summary-sub').textContent = 'No charge for internal HCCGC programs — this just reserves the room and syncs the calendar.';
    return;
  }

  const rooms = selectedRooms();
  const rateSum = rooms.reduce(function (sum, name) {
    const r = ROOMS.find(function (x) { return x.name === name; });
    return sum + (r ? r.rate : 0);
  }, 0);
  const selectedRenter = RENTERS.find(function (r) { return r.renter_id === document.getElementById('f-renter-select').value; });
  const isNonprofit = !document.getElementById('f-internal-enabled').checked && !!(selectedRenter && selectedRenter.is_nonprofit);
  document.getElementById('nonprofit-row').style.display = isNonprofit ? 'flex' : 'none';
  const occList = occurrences.length ? occurrences : [{
    date: document.getElementById('f-date').value,
    startTime: document.getElementById('f-start').value,
    endTime: document.getElementById('f-end').value
  }];

  let base = 0, subtotal = 0;
  const tagsSet = {};
  occList.forEach(function (occ) {
    const hours = hoursBetween(occ.startTime, occ.endTime);
    const occBase = Math.round(rateSum * hours * 100) / 100;
    let mult = 1;
    if (isWeekday(occ.date)) { mult *= RULES.weekdayMultiplier; tagsSet['Weekday'] = true; }
    if (hours >= RULES.extendedHoursThreshold) { mult *= RULES.extendedHoursMultiplier; tagsSet['Extended hours'] = true; }
    if (isNonprofit) { mult *= RULES.nonprofitMultiplier; tagsSet['Nonprofit'] = true; }
    base += occBase;
    subtotal += Math.round(occBase * mult * 100) / 100;
  });
  base = Math.round(base * 100) / 100;
  subtotal = Math.round(subtotal * 100) / 100;

  const adjEnabled = document.getElementById('f-adjustment-enabled').checked;
  const adjType = document.getElementById('f-adj-type').value;
  const adjValue = parseFloat(document.getElementById('f-adj-value').value) || 0;
  let final = subtotal;
  let adjustmentAmount = 0;
  if (adjEnabled && adjValue > 0) {
    if (adjType === 'percent') { adjustmentAmount = Math.round(subtotal * (adjValue / 100) * 100) / 100; }
    else { adjustmentAmount = adjValue * occList.length; }
    final = Math.round((subtotal - adjustmentAmount) * 100) / 100;
  }

  document.getElementById('s-base').textContent = '$' + base.toFixed(2);
  const tags = Object.keys(tagsSet);
  document.getElementById('s-discount-tags').innerHTML = tags.length
    ? tags.map(function (t) { return '<span class="discount-chip">' + t + '</span>'; }).join('')
    : '<span class="no-discount">None</span>';
  document.getElementById('s-subtotal').textContent = '$' + subtotal.toFixed(2);
  document.getElementById('s-adjustment-line').style.display = (adjEnabled && adjValue > 0) ? 'flex' : 'none';
  document.getElementById('s-adjustment').textContent = '-$' + adjustmentAmount.toFixed(2);
  document.getElementById('s-final').textContent = '$' + final.toFixed(2);
  document.getElementById('s-total-label').textContent = occList.length > 1 ? ('Total (' + occList.length + ' occurrences)') : 'Total';
  document.getElementById('cost-summary-sub').textContent = occList.length > 1
    ? 'Combined total across all ' + occList.length + ' occurrences below.'
    : 'Recalculates live as you fill in the form.';
}

// ---- Calendar sidebar ----
// Same underlying source of truth as the public availability calendar
// (the bookings table itself) — just the authenticated, full-detail
// endpoint instead of the stripped-down public one, since this is
// internal-only. Previously this embedded the actual Google Calendar
// resource calendars directly, which depended on the viewer having "See
// all event details" access to those specific calendars in Google
// Calendar — a permission that isn't guaranteed for everyone using this
// page, which is why it could appear blank. Querying the same data this
// portal already writes to sidesteps that entirely.
const AVAIL_ROOM_COLORS = { 'Surya Hall': '#d9720c', 'Patanjali Hall': '#6b3fa0', 'Nataraj Room': '#2e7d4f', 'Ganesh Room': '#2255a4', 'Kitchen': '#c2185b' };
// The visible window runs 9 AM today through 8 AM the next day, not
// midnight-to-midnight — a booking that runs into the evening (e.g. 9pm-1am)
// stays entirely within its own day's column instead of splitting across
// the midnight boundary into a different column. Hours before 9 AM are
// still real bookings, just displayed in the lower portion of the SAME
// calendar day's column, treated as hour+24 for positioning purposes.
const AVAIL_DAY_START_HOUR = 9;
const AVAIL_DAY_END_HOUR = 33; // 9 + 24 = wraps to 8 AM the next day
let availWeekOffset = 0;
let availMonthOffset = 0;
let availViewMode = 'week';

// getHours()/getMinutes() return the BROWSER's own local time, not
// necessarily Eastern — for an admin viewing this from outside the
// Eastern timezone, that would silently misposition every chip
// vertically in the calendar, not just mislabel it. This extracts the
// actual Eastern hour/minute regardless of where the viewer is.
function getEasternHourMinute(date) {
  const parts = new Intl.DateTimeFormat('en-US', {
    timeZone: 'America/New_York', hourCycle: 'h23', hour: '2-digit', minute: '2-digit'
  }).formatToParts(date).reduce(function (acc, p) { if (p.type !== 'literal') acc[p.type] = Number(p.value); return acc; }, {});
  return { hour: parts.hour, minute: parts.minute };
}

function formatTimeRangeEastern(startIso, endIso) {
  var opts = { hour: 'numeric', minute: '2-digit', timeZone: 'America/New_York' };
  return new Date(startIso).toLocaleTimeString('en-US', opts) + '\u2013' + new Date(endIso).toLocaleTimeString('en-US', opts);
}

function layoutDayEvents(events) {
  const sorted = events.slice().sort(function (a, b) { return a.start - b.start; });
  const laneEnds = [];
  sorted.forEach(function (ev) {
    let placed = false;
    for (let i = 0; i < laneEnds.length; i++) {
      if (laneEnds[i] <= ev.start) { ev.lane = i; laneEnds[i] = ev.end; placed = true; break; }
    }
    if (!placed) { ev.lane = laneEnds.length; laneEnds.push(ev.end); }
  });
  sorted.forEach(function (ev) {
    let maxLane = ev.lane;
    sorted.forEach(function (other) {
      if (other === ev) return;
      if (other.start < ev.end && other.end > ev.start) maxLane = Math.max(maxLane, other.lane);
    });
    ev.totalLanes = maxLane + 1;
  });
  return sorted;
}
function renderAvailLegend() {
  document.getElementById('avail-cal-legend').innerHTML = Object.keys(AVAIL_ROOM_COLORS).map(function (room) {
    return '<span class="avail-cal-legend-item"><span class="avail-cal-legend-dot" style="background:' + AVAIL_ROOM_COLORS[room] + ';"></span>' + room + '</span>';
  }).join('');
}
function getEasternDateParts(date) {
  const parts = new Intl.DateTimeFormat('en-US', {
    timeZone: 'America/New_York', year: 'numeric', month: '2-digit', day: '2-digit'
  }).formatToParts(date).reduce(function (acc, p) { if (p.type !== 'literal') acc[p.type] = Number(p.value); return acc; }, {});
  return parts;
}
function getAvailWeekDates(offset) {
  const todayEastern = getEasternDateParts(new Date());
  const today = new Date(todayEastern.year, todayEastern.month - 1, todayEastern.day);
  const sunday = new Date(today.getFullYear(), today.getMonth(), today.getDate() - today.getDay() + (offset * 7));
  const dates = [];
  for (let i = 0; i < 7; i++) dates.push(new Date(sunday.getFullYear(), sunday.getMonth(), sunday.getDate() + i));
  return dates;
}
function toAvailDateStr(d) { return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0'); }

async function loadAvailabilityCalendar() {
  const weekDates = getAvailWeekDates(availWeekOffset);
  const startDate = toAvailDateStr(weekDates[0]);
  const endDate = toAvailDateStr(weekDates[6]);
  document.getElementById('avail-cal-week-label').textContent =
    weekDates[0].toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) + ' – ' + weekDates[6].toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

  const gridEl = document.getElementById('avail-week-grid');
  gridEl.innerHTML = '<div style="grid-column:1/-1;padding:20px;text-align:center;color:var(--muted);">Loading…</div>';

  let bookings = [];
  let loadError = null;
  try {
    const res = await authedFetch(API_BASE + '/bookings-availability?startDate=' + startDate + '&endDate=' + endDate);
    if (res.ok) bookings = await res.json();
    else {
      const errData = await res.json().catch(function () { return {}; });
      loadError = (errData.errors || [errData.error || ('Server returned ' + res.status)]).join(' ');
    }
  } catch (err) { loadError = err.message; }

  if (loadError) {
    gridEl.innerHTML = '<div style="grid-column:1/-1;padding:20px;text-align:center;color:#b3382c;font-size:0.8rem;">Could not load: ' + loadError + '</div>';
    return;
  }

  const byDate = {};
  bookings.forEach(function (b) {
    if (!byDate[b.eventDate]) byDate[b.eventDate] = [];
    (b.rooms || []).forEach(function (room) {
      byDate[b.eventDate].push({ room: room, start: b.startTime, end: b.endTime, renterName: b.renterName, eventName: b.eventName, paymentStatus: b.paymentStatus, isInternal: b.isInternal });
    });
  });

  const totalHours = AVAIL_DAY_END_HOUR - AVAIL_DAY_START_HOUR;
  const todayEasternParts = getEasternDateParts(new Date());
  const todayStr = todayEasternParts.year + '-' + String(todayEasternParts.month).padStart(2, '0') + '-' + String(todayEasternParts.day).padStart(2, '0');
  // Use whatever height the flex layout has actually given this
  // container (it fills the remaining space in the card via flex:1),
  // rather than guessing a fixed row height that leaves the rest of
  // that space blank. Falls back to a sane minimum if measured too early.
  const containerHeight = document.getElementById('avail-week-container').clientHeight;
  const rowHeightPx = Math.max(14, containerHeight / totalHours);
  const bodyHeight = totalHours * rowHeightPx;

  let html = '<div class="avail-week-corner"></div>';
  weekDates.forEach(function (d) {
    const dStr = toAvailDateStr(d);
    html += '<div class="avail-week-daylabel' + (dStr === todayStr ? ' is-today' : '') + '"><span class="dow">' + d.toLocaleDateString('en-US', { weekday: 'short' }) + '</span>' + d.getDate() + '</div>';
  });

  html += '<div class="avail-week-timecol" style="height:' + bodyHeight + 'px;">';
  for (let h = AVAIL_DAY_START_HOUR; h < AVAIL_DAY_END_HOUR; h++) {
    const pct = ((h - AVAIL_DAY_START_HOUR) / totalHours) * 100;
    const clockHour = h % 24;
    const label = clockHour === 0 ? '12a' : clockHour === 12 ? '12p' : clockHour < 12 ? clockHour + 'a' : (clockHour - 12) + 'p';
    html += '<div class="avail-week-timelabel" style="top:' + pct + '%;">' + label + '</div>';
  }
  html += '</div>';

  weekDates.forEach(function (d) {
    const dStr = toAvailDateStr(d);
    const dayBookingsRaw = (byDate[dStr] || []).map(function (bk) { return Object.assign({}, bk, { start: new Date(bk.start), end: new Date(bk.end) }); });
    const dayBookings = layoutDayEvents(dayBookingsRaw);
    let colHtml = '<div class="avail-week-daycol" style="height:' + bodyHeight + 'px;--hour-px:' + rowHeightPx + 'px;">';
    dayBookings.forEach(function (bk) {
      const startHM = getEasternHourMinute(bk.start);
      const endHM = getEasternHourMinute(bk.end);
      const startHour24 = startHM.hour < AVAIL_DAY_START_HOUR ? startHM.hour + 24 : startHM.hour;
      const endHour24 = endHM.hour < AVAIL_DAY_START_HOUR ? endHM.hour + 24 : endHM.hour;
      const startFrac = (startHour24 + startHM.minute / 60 - AVAIL_DAY_START_HOUR) / totalHours;
      const endFrac = (endHour24 + endHM.minute / 60 - AVAIL_DAY_START_HOUR) / totalHours;
      const clampedStart = Math.max(0, Math.min(1, startFrac));
      const clampedEnd = Math.max(0, Math.min(1, endFrac));
      if (clampedEnd <= clampedStart) return;
      const topPx = clampedStart * bodyHeight;
      const heightPx = Math.max(15, (clampedEnd - clampedStart) * bodyHeight);
      const widthPct = 100 / bk.totalLanes;
      const leftPct = bk.lane * widthPct;
      const timeLabel = bk.start.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', timeZone: 'America/New_York' }) + '–' + bk.end.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', timeZone: 'America/New_York' });
      const who = bk.isInternal ? (bk.eventName || 'HCCGC program') : (bk.renterName || 'Renter');
      const titleAttr = bk.room + ' — ' + who + (bk.eventName && !bk.isInternal ? ' (' + bk.eventName + ')' : '') + ' — ' + timeLabel + ' — ' + bk.paymentStatus;
      colHtml += '<div class="avail-week-chip" style="top:' + topPx + 'px;height:' + heightPx + 'px;left:' + leftPct + '%;width:calc(' + widthPct + '% - 2px);background:' + (AVAIL_ROOM_COLORS[bk.room] || '#8d6e63') + ';" title="' + titleAttr.replace(/"/g, '&quot;') + '">' +
        bk.room.replace(' Hall', '').replace(' Room', '') +
        (heightPx > 26 && bk.totalLanes === 1 ? '<span class="detail">' + who + '</span>' : '') +
      '</div>';
    });
    colHtml += '</div>';
    html += colHtml;
  });

  gridEl.innerHTML = html;
}

async function loadMonthView() {
  const today = new Date();
  const viewMonth = new Date(today.getFullYear(), today.getMonth() + availMonthOffset, 1);
  document.getElementById('avail-cal-week-label').textContent = viewMonth.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });

  const gridEl = document.getElementById('avail-month-grid');
  gridEl.innerHTML = '<div style="grid-column:1/-1;padding:20px;text-align:center;color:var(--muted);">Loading…</div>';

  const firstOfMonth = new Date(viewMonth.getFullYear(), viewMonth.getMonth(), 1);
  const lastOfMonth = new Date(viewMonth.getFullYear(), viewMonth.getMonth() + 1, 0);
  const startDate = toAvailDateStr(firstOfMonth);
  const endDate = toAvailDateStr(lastOfMonth);

  let bookings = [];
  let loadError = null;
  try {
    const res = await authedFetch(API_BASE + '/bookings-availability?startDate=' + startDate + '&endDate=' + endDate);
    if (res.ok) bookings = await res.json();
    else {
      const errData = await res.json().catch(function () { return {}; });
      loadError = (errData.errors || [errData.error || ('Server returned ' + res.status)]).join(' ');
    }
  } catch (err) { loadError = err.message; }

  if (loadError) {
    gridEl.innerHTML = '<div style="grid-column:1/-1;padding:20px;text-align:center;color:#b3382c;font-size:0.8rem;">Could not load: ' + loadError + '</div>';
    return;
  }

  const byDate = {};
  bookings.forEach(function (b) {
    if (!byDate[b.eventDate]) byDate[b.eventDate] = [];
    (b.rooms || []).forEach(function (room) {
      byDate[b.eventDate].push({ room: room, who: b.isInternal ? (b.eventName || 'HCCGC program') : (b.renterName || 'Renter'), status: b.paymentStatus, startTime: b.startTime, endTime: b.endTime });
    });
  });

  const startWeekday = firstOfMonth.getDay();
  const daysInMonth = lastOfMonth.getDate();
  const todayStr = toAvailDateStr(today);

  let html = ['S', 'M', 'T', 'W', 'T', 'F', 'S'].map(function (d) { return '<div class="avail-month-weekday">' + d + '</div>'; }).join('');
  for (let i = 0; i < startWeekday; i++) html += '<div class="avail-month-day empty"></div>';
  for (let d = 1; d <= daysInMonth; d++) {
    const dateStr = toAvailDateStr(new Date(viewMonth.getFullYear(), viewMonth.getMonth(), d));
    const dayBookings = byDate[dateStr] || [];
    const shown = dayBookings.slice(0, 3);
    const extra = dayBookings.length - shown.length;
    html += '<div class="avail-month-day' + (dateStr === todayStr ? ' is-today' : '') + '">' +
      '<div class="avail-month-day-num">' + d + '</div>' +
      shown.map(function (bk) {
        var timeLabel = new Date(bk.startTime).toLocaleTimeString('en-US', { hour: 'numeric', minute: bk.startTime.slice(14,16) === '00' ? undefined : '2-digit', timeZone: 'America/New_York' }).replace(' ', '').toLowerCase();
        var fullRange = formatTimeRangeEastern(bk.startTime, bk.endTime);
        return '<span class="avail-month-chip" style="background:' + (AVAIL_ROOM_COLORS[bk.room] || '#8d6e63') + ';" title="' + bk.room + ' — ' + bk.who + ' — ' + fullRange + ' — ' + bk.status + '">' + timeLabel + ' ' + bk.who + '</span>';
      }).join('') +
      (extra > 0 ? '<div class="avail-month-more">+' + extra + '</div>' : '') +
    '</div>';
  }
  gridEl.innerHTML = html;
}

function refreshAvailCalendar() {
  if (availViewMode === 'week') loadAvailabilityCalendar();
  else loadMonthView();
}
function setAvailViewMode(mode) {
  availViewMode = mode;
  document.getElementById('avail-view-week-btn').classList.toggle('active', mode === 'week');
  document.getElementById('avail-view-month-btn').classList.toggle('active', mode === 'month');
  document.getElementById('avail-week-container').style.display = mode === 'week' ? 'block' : 'none';

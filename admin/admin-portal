// GET /logs?startDate=&endDate=&app=&subPage=
async function listLogs(req, res) {
  const q = req.query || {};
  const startDate = q.startDate || '2000-01-01';
  const endDate = (q.endDate || '2100-01-01') + ' 23:59:59';
  const unwrap = v => (v && typeof v === 'object' && 'value' in v) ? v.value : v;

  const [rows] = await bigquery.query({
    query: `SELECT log_id, action, entity_type, entity_id, actor_email, details, created_at
            FROM \`${DATASET}.audit_log\`
            WHERE created_at BETWEEN TIMESTAMP(@startDate) AND TIMESTAMP(@endDate)
            ORDER BY created_at DESC
            LIMIT 1000`,
    params: { startDate, endDate }
  });

  let logs = rows.map(r => {
    const mapped = ACTION_APP_MAP[r.action] || { app: 'Other', subPage: 'Other', label: r.action };
    let detailsStr = r.details;
    try { detailsStr = JSON.stringify(JSON.parse(r.details)); } catch (e) { /* leave as-is if not valid JSON */ }
    return {
      logId: r.log_id, action: r.action, actionLabel: mapped.label, app: mapped.app, subPage: mapped.subPage,
      entityType: r.entity_type, entityId: r.entity_id, actorEmail: r.actor_email, details: detailsStr, createdAt: unwrap(r.created_at)
    };
  });

  if (q.app) logs = logs.filter(l => l.app === q.app);
  if (q.subPage) logs = logs.filter(l => l.subPage === q.subPage);

  res.json(logs);
}

// POST /transactions
async function logTransaction(req, res, actor) {
  const b = req.body || {};
  if (!b.date || !b.amount || !b.type || !b.initiativeName || !b.source) {
    return res.status(400).json({ errors: ['Date, amount, type, initiative, and source are all required.'] });
  }
  const transactionId = randomUUID();
  await bigquery.query({
    query: `INSERT INTO \`${DATASET}.transactions\`
      (transaction_id, date, amount, type, initiative_id, source, description, entered_by, reconciled, created_at)
      SELECT @transactionId, @date, @amount, @type, initiative_id, @source, @description, @enteredBy, FALSE, CURRENT_TIMESTAMP()
      FROM \`${DATASET}.initiatives\` WHERE name = @initiativeName`,
    params: {
      transactionId, date: b.date, amount: b.amount, type: b.type, source: b.source,
      description: b.description || null, enteredBy: actor.email, initiativeName: b.initiativeName
    },
    types: { description: 'STRING' }
  });
  await logAudit({ action: 'transaction_logged', entityType: 'transaction', entityId: transactionId, actorEmail: actor.email, details: { amount: b.amount, type: b.type, initiativeName: b.initiativeName, source: b.source } });
  res.json({ transactionId });
}

functions.http('api', async (req, res) => {
  setCors(res);
  if (req.method === 'OPTIONS') { res.status(204).send(''); return; }

  try {
    const path = req.path.replace(/\/+$/, '') || '/';

    // Public, unauthenticated routes — checked BEFORE requireAuthorizedUser,
    // since this one specifically needs to work for someone who's never
    // signed in at all (replaces the old public Google Form).
    if (path === '/public/facility-request' && req.method === 'POST') return await submitFacilityRequest(req, res);
    if (path === '/public/renter-lookup' && req.method === 'GET') return await lookupRenterByEmail(req, res);
    if (path === '/public/expense-submission' && req.method === 'POST') return await submitExpenses(req, res);

    const actor = await requireAuthorizedUser(req);

    const markPaidMatch = path.match(/^\/bookings\/([^/]+)\/mark-paid$/);
    const cancelMatch = path.match(/^\/bookings\/([^/]+)\/cancel$/);
    const sendInvoiceMatch = path.match(/^\/bookings\/([^/]+)\/send-invoice$/);
    const sendReceiptMatch = path.match(/^\/bookings\/([^/]+)\/send-receipt$/);
    const invoicePreviewMatch = path.match(/^\/bookings\/([^/]+)\/invoice-preview$/);
    const receiptPreviewMatch = path.match(/^\/bookings\/([^/]+)\/receipt-preview$/);
    const paymentMatchesMatch = path.match(/^\/bookings\/([^/]+)\/payment-matches$/);
    const linkPaymentMatch = path.match(/^\/bookings\/([^/]+)\/link-payment$/);
    const unlinkPaymentMatch = path.match(/^\/bookings\/([^/]+)\/unlink-payment$/);
    const seriesMarkPaidMatch = path.match(/^\/bookings\/series\/([^/]+)\/mark-paid$/);
    const seriesCancelMatch = path.match(/^\/bookings\/series\/([^/]+)\/cancel$/);
    const seriesDetailMatch = path.match(/^\/bookings\/series\/([^/]+)$/);
    const bookingDetailMatch = path.match(/^\/bookings\/([^/]+)$/);
    const roomPatchMatch = path.match(/^\/rooms\/([^/]+)$/);
    const renterPatchMatch = path.match(/^\/renters\/([^/]+)$/);
    const financeCategoryPatchMatch = path.match(/^\/finance\/categories\/([^/]+)$/);
    const balanceSheetItemPatchMatch = path.match(/^\/finance\/balance-sheet-items\/([^/]+)$/);
    const receiptImageMatch = path.match(/^\/finance\/expense-receipt-image\/([^/]+)$/);
    const issueResolveMatch = path.match(/^\/issues\/([^/]+)\/resolve$/);
    const expenseCategorizeMatch = path.match(/^\/finance\/expense-line-items\/([^/]+)\/categorize$/);
    const expenseMarkPaidMatch = path.match(/^\/finance\/expense-line-items\/([^/]+)\/mark-paid$/);
    const expenseBankMatchMatch = path.match(/^\/finance\/expense-line-items\/([^/]+)\/confirm-bank-match$/);
    const expenseApproveMatch = path.match(/^\/finance\/expense-submissions\/([^/]+)\/approve$/);
    const expenseRejectMatch = path.match(/^\/finance\/expense-submissions\/([^/]+)\/reject$/);
    const renterApproveMatch = path.match(/^\/renters\/([^/]+)\/approve$/);
    const renterRejectMatch = path.match(/^\/renters\/([^/]+)\/reject$/);
    const approveRequestMatch = path.match(/^\/bookings\/([^/]+)\/approve-request$/);
    const rejectRequestMatch = path.match(/^\/bookings\/([^/]+)\/reject-request$/);

    if (path === '/rooms' && req.method === 'GET') return await listRooms(req, res);
    if (path === '/rooms' && req.method === 'POST') return await addRoom(req, res, actor);
    if (roomPatchMatch && req.method === 'PATCH') return await updateRoom(req, res, decodeURIComponent(roomPatchMatch[1]), actor);
    if (path === '/renters' && req.method === 'GET') return await listRenters(req, res);
    if (path === '/renters' && req.method === 'POST') return await addRenter(req, res, actor);
    if (path === '/finance/categories' && req.method === 'GET') return await listFinanceCategories(req, res);

// ---- Submit ----
const API_BASE = 'https://facility-rental-api-217911937447.us-central1.run.app';

async function authedFetch(url, options) {
  options = options || {};
  var user = window.__hccgcFirebaseUser;
  if (!user) throw new Error('Not signed in.');
  var token = await user.getIdToken();
  options.headers = Object.assign({}, options.headers, { 'Authorization': 'Bearer ' + token });
  return fetch(url, options);
}

// ---- Renter directory: pick a returning contact instead of re-typing ----
// New Booking only ever selects from this list — there's no way to type a
// new contact here by design; that happens on Add A Renter instead. The
// backend looks up the renter's actual details by renterId, so nothing
// beyond the selected ID needs to travel with the booking request.
let RENTERS = [];
async function loadRenters() {
  try {
    const res = await authedFetch(API_BASE + '/renters');
    if (!res.ok) throw new Error('Server returned ' + res.status);
    RENTERS = await res.json();
  } catch (err) {
    RENTERS = [];
  }
  const select = document.getElementById('f-renter-select');
  select.innerHTML = '<option value="">Choose a renter…</option>' +
    RENTERS.map(function (r) {
      const label = r.contact_name + (r.email ? (' — ' + r.email) : '');
      return '<option value="' + r.renter_id + '">' + label.replace(/</g, '&lt;') + '</option>';
    }).join('');
}
// loadRenters() is intentionally NOT called here — this runs before Firebase
// has resolved who's signed in, so authedFetch would throw "Not signed in"
// every time. It's called instead inside the auth gate's success handler,
// below, once there's actually a valid token to send.


document.getElementById('btn-generate').addEventListener('click', async function () {
  const rooms = selectedRooms();
  const btn = this;
  if (rooms.length === 0) { showResult('error', 'Select at least one room first.'); return; }
  if (!occurrences.length) regenerateOccurrences();
  if (!occurrences.length) { showResult('error', 'Add a date and time first.'); return; }
  const isInternal = document.getElementById('f-internal-enabled').checked;
  const selectedRenterId = document.getElementById('f-renter-select').value;
  if (isInternal) {
    if (!document.getElementById('f-name').value.trim()) { showResult('error', 'Program/event name is required.'); return; }
    if (!document.getElementById('f-hccg-rep').value.trim()) { showResult('error', 'HCCGC representative name is required for internal bookings.'); return; }
    if (!document.getElementById('f-notes').value.trim()) { showResult('error', 'A description is required for internal bookings.'); return; }
  } else if (!selectedRenterId) {
    showResult('error', 'Select a renter from the list first.');
    return;
  } else if (!document.getElementById('f-event-name').value.trim()) {
    showResult('error', 'Event name is required.');
    return;
  }

  const payload = {
    rooms: rooms,
    isInternal: isInternal,
    renterId: !isInternal ? selectedRenterId : null,
    renterName: isInternal ? document.getElementById('f-name').value : null,
    eventName: !isInternal ? document.getElementById('f-event-name').value : null,
    hccgcRepresentativeName: isInternal ? document.getElementById('f-hccg-rep').value : null,
    publishAsEvent: isInternal ? document.getElementById('f-publish-event').checked : false,
    isNonprofit: !isInternal && !!(RENTERS.find(function (r) { return r.renter_id === document.getElementById('f-renter-select').value; }) || {}).is_nonprofit,
    notes: document.getElementById('f-notes').value,
    manualAdjustmentType: (!isInternal && document.getElementById('f-adjustment-enabled').checked) ? document.getElementById('f-adj-type').value : null,
    manualAdjustmentValue: (!isInternal && document.getElementById('f-adjustment-enabled').checked) ? parseFloat(document.getElementById('f-adj-value').value) || null : null,
    manualAdjustmentReason: (!isInternal && document.getElementById('f-adjustment-enabled').checked) ? document.getElementById('f-adj-reason').value : null,
    occurrences: occurrences,
    invoiceMode: (document.querySelector('input[name="f-invoice-mode"]:checked') || {}).value || 'combined',
    enteredBy: (window.__hccgcCurrentUser && window.__hccgcCurrentUser.email) || 'Unknown'
  };

  btn.disabled = true;
  btn.textContent = 'Creating booking…';
  try {
    const res = await authedFetch(API_BASE + '/bookings', {
      method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (!res.ok) {
      showResult('error', (data.errors || [data.error || 'Something went wrong.']).join(' '));
    } else {
      const occText = data.occurrenceCount > 1 ? (data.occurrenceCount + ' occurrences created, total $' + data.totalAcrossAllOccurrences.toFixed(2)) : ('Booking created — ID ' + data.bookingIds[0]);
      const syncWarning = data.calendarSyncErrors ? (' (Calendar sync had issues: ' + data.calendarSyncErrors.join('; ') + ')') : '';
      const eventNote = data.eventListingCreated ? ' Also added to Manage Events as a draft — edit it there if needed.'
        : (data.eventListingError ? (' Note: could not add to Manage Events (' + data.eventListingError + ') — add it there manually if needed.') : '');
      const statusNote = data.isInternal ? ' No charge — internal booking.' : ' Marked as Pending until invoiced.';
      showResult('success', occText + '.' + statusNote + syncWarning + eventNote);
      if (!isInternal && data.bookingIds && data.bookingIds.length) {
        openInvoicePreview(data.bookingIds[0], payload, data);
      }
      resetForm();
    }
  } catch (err) {
    showResult('error', 'Could not reach the booking system. ' + err.message);
  } finally {
    btn.disabled = false;
    btn.textContent = 'Create booking';
  }
});

function showResult(type, message) {
  const box = document.getElementById('result-box');
  box.style.display = 'block';
  box.className = 'result-box ' + type;
  box.textContent = message;
}

// ---- Invoice preview + send, right after creating a real (non-internal)
// booking. This is a client-side approximation of the same invoice the
// backend actually generates and sends — good enough for the admin to
// sanity-check before committing to sending it. ----
function openInvoicePreview(bookingId, payload, createResult) {
  const renterOption = Array.from(document.getElementById('f-renter-select').options).find(function (o) { return o.value === payload.renterId; });
  const renterLabel = renterOption ? renterOption.textContent : '';
  const total = createResult.occurrenceCount > 1 ? createResult.totalAcrossAllOccurrences : Number(document.getElementById('s-final').textContent.replace(/[^0-9.]/g, ''));
  const firstOcc = payload.occurrences[0];

  const overlay = document.getElementById('invoice-preview-overlay');
  document.getElementById('invoice-preview-body').innerHTML =
    '<div class="field"><label>To</label><div style="padding:9px 0;font-weight:700;">' + escHtmlLocal(renterLabel) + '</div></div>' +
    '<div class="field"><label>Event</label><div style="padding:9px 0;">' + escHtmlLocal(payload.eventName) + '</div></div>' +
    '<div class="field"><label>Rooms</label><div style="padding:9px 0;">' + escHtmlLocal(payload.rooms.join(', ')) + '</div></div>' +
    '<div class="field"><label>Date' + (payload.occurrences.length > 1 ? ' (first of ' + payload.occurrences.length + ')' : '') + '</label><div style="padding:9px 0;">' + escHtmlLocal(firstOcc.date) + ', ' + escHtmlLocal(firstOcc.startTime) + '–' + escHtmlLocal(firstOcc.endTime) + '</div></div>' +
    '<div class="field"><label>Amount due</label><div style="padding:9px 0;font-weight:700;font-size:1.1rem;color:var(--maroon);">$' + total.toFixed(2) + '</div></div>' +
    '<div class="card-sub">Once created, review and send the invoice from All Bookings.</div>';
  overlay.style.display = 'flex';
}
function escHtmlLocal(str) { return String(str || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;'); }

document.getElementById('btn-skip-invoice').addEventListener('click', function () {

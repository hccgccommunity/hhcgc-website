

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Facility Rental | Hindu Community Center of Greater Cincinnati</title>
  <meta name="description" content="Rent our halls and rooms at HCCGC for cultural programs, classes, celebrations, and community gatherings." />

  <link rel="icon" type="image/x-icon" href="favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="apple-touch-icon.png">
  <link rel="icon" type="image/svg+xml"
        href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='0.9em' x='50%25' text-anchor='middle' font-size='82'%3E%E0%A5%90%3C/text%3E%3C/svg%3E">

  <style>
    :root {
      --bg: #fff9f1;
      --surface: #ffffff;
      --surface-soft: #fff6ea;
      --border: rgba(121, 62, 17, 0.14);
      --text: #2c1b10;
      --muted: #6a5141;
      --saffron: #b55a18;
      --saffron-dark: #8d3e0d;
      --maroon: #7f2e16;
      --shadow: 0 18px 45px rgba(93, 43, 14, 0.10);
      --radius: 22px;
      --max: 1220px;
      --header-offset: 110px;
      --gold: #d9a441;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top left, rgba(217, 138, 30, 0.12), transparent 22%),
        radial-gradient(circle at top right, rgba(127, 46, 22, 0.05), transparent 20%),
        var(--bg);
      line-height: 1.65;
    }

    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }
    button, input, select, textarea { font: inherit; }

    .container {
      width: min(calc(100% - 32px), var(--max));
      margin: 0 auto;
    }

    .content-width { width: 100%; max-width: 100%; }

    /* ── HEADER (matches yoga-for-all exactly) ── */
    .site-header {
      position: sticky;
      top: 0;
      z-index: 50;
      background: rgba(255, 249, 241, 0.92);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
    }

    .nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      min-height: 92px;
      padding: 12px 0;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 16px;
      min-width: 0;
    }

    .brand-logo-wrap {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 8px;
      box-shadow: var(--shadow);
      flex-shrink: 0;
    }

    .brand-logo {
      width: 88px;
      height: auto;
      border-radius: 12px;
      object-fit: contain;
    }

    .brand-text h1 {
      margin: 0;
      font-size: 1.2rem;
      line-height: 1.15;
      color: var(--maroon);
    }

    .site-header nav ul {
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      gap: 18px;
      margin: 0;
      padding: 0;
      align-items: center;
      justify-content: flex-end;
    }

    .site-header nav a {
      font-weight: 700;
      color: var(--text);
      font-size: 0.96rem;
    }

    .site-header nav a:hover { color: var(--saffron-dark); }

    /* ── FOOTER (matches yoga-for-all exactly) ── */
    .site-footer .footer-top {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: 24px;
      padding: 8px 0 0;
    }

    .site-footer .footer-nav {
      display: flex;
      justify-content: flex-start;
      min-width: 0;
    }

    .site-footer .footer-nav ul {
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin: 0;
      padding: 0;
      justify-content: flex-start;
      align-items: center;
    }

    .site-footer .footer-nav a {
      font-weight: 700;
      color: var(--text);
      font-size: 0.95rem;
    }

    .site-footer .footer-nav a:hover { color: var(--saffron-dark); }

    .site-footer .footer-email {
      text-align: center;
      font-weight: 700;
      color: var(--text);
      white-space: nowrap;
    }

    .site-footer .footer-email a:hover { color: var(--saffron-dark); }

    .site-footer .footer-social {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 12px;
      min-width: 220px;
      color: var(--text);
      font-weight: 700;
    }

    .site-footer .footer-social-label { white-space: nowrap; }

    .site-footer .social-icons {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .site-footer .social-icon {
      width: 42px;
      height: 42px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      background: #fff;
      border: 1px solid var(--border);
      box-shadow: 0 6px 18px rgba(93, 43, 14, 0.10);
      transition: transform 0.18s ease, box-shadow 0.18s ease;
    }

    .site-footer .social-icon:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 22px rgba(93, 43, 14, 0.16);
    }

    .site-footer .social-icon svg { width: 20px; height: 20px; display: block; }

    .site-footer .footer-note {
      margin-top: 18px;
      padding-top: 18px;
      border-top: 1px solid var(--border);
      color: var(--muted);
      font-size: 0.7rem;
      text-align: center;
    }

    .site-footer .copyright-links a { text-decoration: none; }

    /* ── SHARED SECTIONS ── */
    .section {
      padding: 42px 0;
      scroll-margin-top: var(--header-offset);
    }

    .section-head {
      margin-bottom: 18px;
      text-align: center;
    }

    .section-kicker {
      display: inline-block;
      padding: 7px 14px;
      border-radius: 999px;
      background: rgba(217, 138, 30, 0.12);
      color: var(--saffron-dark);
      font-size: 0.83rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 8px;
    }

    .section-head h2 {
      margin: 8px 0 10px;
      line-height: 1.2;
      color: var(--maroon);
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(2rem, 3.4vw, 3rem);
    }

    .section-copy {
      margin: 0 auto;
      color: var(--muted);
      font-size: 1rem;
      max-width: 820px;
      text-align: center;
    }

    /* ── HERO ── */
    .hero-grid {
      display: grid;
      grid-template-columns: 1.08fr 0.92fr;
      gap: 26px;
      align-items: stretch;
      margin-top: 4px;
    }

    .hero-panel, .details-panel {
      min-height: 360px;
      border-radius: 26px;
      background: rgba(255, 255, 255, 0.74);
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
      padding: 34px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .hero-panel h1 {
      margin: 0 0 10px;
      color: var(--maroon);
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(2.8rem, 6vw, 5rem);
      line-height: 0.98;
      letter-spacing: -0.035em;
    }

    .hero-subtitle {
      margin: 0 0 16px;
      color: var(--saffron-dark);
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(1.2rem, 2.2vw, 1.7rem);
      font-weight: 700;
    }

    .hero-copy {
      margin: 0 0 24px;
      color: var(--muted);
      max-width: 720px;
      font-size: 1.05rem;
    }

    .cta-row { display: flex; gap: 14px; flex-wrap: wrap; }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 46px;
      padding: 11px 22px;
      border-radius: 999px;
      border: 1px solid transparent;
      font-weight: 800;
      text-decoration: none;
    }

    .btn.primary {
      background: linear-gradient(135deg, var(--saffron-dark), var(--saffron));
      color: #fff;
      box-shadow: 0 10px 24px rgba(127, 46, 22, 0.14);
    }

    .btn.secondary {
      background: rgba(255, 255, 255, 0.7);
      border-color: var(--border);
      color: var(--maroon);
    }

    .details-panel h2 {
      margin: 0 0 16px;
      color: var(--maroon);
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(1.7rem, 3vw, 2.35rem);
    }

    .details-grid { display: grid; gap: 12px; }

    .detail-item {
      padding: 14px 16px;
      border-radius: 18px;
      background: linear-gradient(135deg, rgba(255,246,234,0.92), rgba(255,255,255,0.86));
      border: 1px solid rgba(121, 62, 17, 0.12);
    }

    .detail-label {
      display: block;
      margin-bottom: 2px;
      color: var(--saffron-dark);
      font-size: 0.76rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .detail-value {
      display: block;
      color: var(--text);
      font-weight: 800;
      font-size: 1.08rem;
    }

    /* ── ROOM CARDS ── */
    .pill-row {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 18px;
      margin-top: 28px;
    }

    .pill-card, .info-box {
      border-radius: 24px;
      background: rgba(255, 255, 255, .74);
      border: 1px solid var(--border);
      padding: 24px;
      box-shadow: 0 12px 30px rgba(93, 43, 14, .08);
    }

    .pill-card h3, .info-box h3 {
      margin: 0 0 8px;
      color: var(--maroon);
      font-family: Georgia, "Times New Roman", serif;
      font-size: 1.35rem;
    }

    .pill-card p, .info-box p { margin: 0; color: var(--muted); }

    .room-img {
      width: 100%;
      height: 155px;
      object-fit: cover;
      border-radius: 14px;
      margin-bottom: 14px;
    }

    .rate-badge {
      display: inline-block;
      margin-top: 12px;
      padding: 5px 14px;
      border-radius: 999px;
      background: linear-gradient(135deg, var(--saffron-dark), var(--saffron));
      color: #fff;
      font-size: 0.82rem;
      font-weight: 900;
      letter-spacing: 0.04em;
    }

    /* ── ESTIMATOR ── */
    .estimator-card {
      border-radius: 28px;
      background: linear-gradient(180deg, rgba(255,255,255,.86), rgba(255,246,234,.94));
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
      padding: 34px;
    }

    .estimator-card .section-head { margin-bottom: 24px; }

    /* Mobile-first select styling */
    .select-group {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-bottom: 20px;
    }

    .select-group label {
      font-size: 0.78rem;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--saffron-dark);
      margin-bottom: 4px;
      display: block;
    }

    /* Big tap-friendly room selector buttons */
    .room-selector {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
      margin-bottom: 24px;
    }

    .room-btn {
      padding: 14px 12px;
      border-radius: 14px;
      border: 2px solid var(--border);
      background: rgba(255,255,255,0.82);
      color: var(--text);
      font-size: 0.92rem;
      font-weight: 700;
      cursor: pointer;
      text-align: center;
      transition: all 0.18s ease;
      line-height: 1.3;
    }

    .room-btn .room-btn-rate {
      display: block;
      font-size: 0.78rem;
      font-weight: 900;
      color: var(--saffron-dark);
      margin-top: 4px;
    }

    .room-btn:hover {
      border-color: var(--saffron);
      background: rgba(255,246,234,0.9);
    }

    .room-btn.active {
      border-color: var(--saffron-dark);
      background: linear-gradient(135deg, rgba(255,246,234,0.95), rgba(255,255,255,0.9));
      box-shadow: 0 4px 14px rgba(141,62,13,0.14);
    }

    /* Hours stepper */
    .hours-stepper {
      display: flex;
      align-items: center;
      gap: 0;
      border-radius: 14px;
      border: 2px solid var(--border);
      overflow: hidden;
      background: rgba(255,255,255,0.82);
      width: 100%;
      max-width: 280px;
    }

    .stepper-btn {
      width: 56px;
      min-height: 52px;
      border: none;
      background: rgba(255,246,234,0.9);
      color: var(--maroon);
      font-size: 1.5rem;
      font-weight: 900;
      cursor: pointer;
      flex-shrink: 0;
      transition: background 0.15s;
    }

    .stepper-btn:hover { background: rgba(181,90,24,0.15); }

    .stepper-display {
      flex: 1;
      text-align: center;
      font-size: 1.2rem;
      font-weight: 800;
      color: var(--text);
      padding: 0 8px;
      border: none;
      background: transparent;
      pointer-events: none;
    }

    /* Toggle checkboxes — big tap targets */
    .toggles-row {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-bottom: 24px;
    }

    .toggle-item {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 16px;
      border-radius: 14px;
      border: 2px solid var(--border);
      background: rgba(255,255,255,0.82);
      cursor: pointer;
      transition: border-color 0.18s, background 0.18s;
      -webkit-tap-highlight-color: transparent;
    }

    .toggle-item:hover {
      border-color: var(--saffron);
      background: rgba(255,246,234,0.9);
    }

    .toggle-item input[type="checkbox"] {
      width: 24px;
      height: 24px;
      accent-color: var(--saffron);
      cursor: pointer;
      flex-shrink: 0;
    }

    .toggle-item .toggle-label {
      color: var(--text);
      font-size: 0.97rem;
      font-weight: 700;
      line-height: 1.3;
    }

    .toggle-item .toggle-discount {
      display: block;
      font-size: 0.8rem;
      font-weight: 900;
      color: var(--saffron-dark);
      margin-top: 2px;
    }

    /* Result box */
    .result-box {
      border-radius: 20px;
      background: linear-gradient(135deg, rgba(127,46,22,0.07), rgba(181,90,24,0.09));
      border: 1px solid rgba(121,62,17,0.18);
      padding: 28px;
      text-align: center;
    }

    .result-label {
      font-size: 0.76rem;
      font-weight: 900;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--saffron-dark);
      margin-bottom: 8px;
    }

    .result-amount {
      font-family: Georgia, "Times New Roman", serif;
      font-size: clamp(2.6rem, 5vw, 3.8rem);
      font-weight: 700;
      color: var(--maroon);
      line-height: 1;
      margin-bottom: 10px;
    }

    .result-breakdown { color: var(--muted); font-size: 0.88rem; line-height: 1.7; }

    .discount-pills { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-top: 14px; }

    .disc-pill {
      padding: 4px 14px;
      border-radius: 999px;
      background: rgba(181,90,24,0.12);
      color: var(--saffron-dark);
      font-size: 0.78rem;
      font-weight: 800;
      border: 1px solid rgba(121,62,17,0.18);
    }

    /* ── CALENDAR ── */
    .calendar-wrap {
      border-radius: 22px;
      border: 1px solid var(--border);
      box-shadow: 0 12px 30px rgba(93,43,14,.08);
      background: #fff;
      overflow: hidden;
    }

    .calendar-wrap iframe { display: block; width: 100%; border: none; }

    /* ── TWO COL ── */
    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; }

    @media (max-width: 640px) {
      .two-col { grid-template-columns: 1fr; }
    }

    ul { margin: 0 0 0 20px; padding: 0; }
    li { color: var(--muted); margin-bottom: 7px; }
    li a { color: var(--saffron-dark); font-weight: 700; text-decoration: underline; }
    li a:hover { color: var(--maroon); }

    /* ── NOTICE BOX ── */
    .notice-box {
      padding: 18px 22px;
      border-radius: 16px;
      background: rgba(255,246,234,0.9);
      border: 1px solid rgba(121,62,17,0.18);
      border-left: 4px solid var(--saffron);
    }

    .notice-box h4 {
      margin: 0 0 6px;
      color: var(--maroon);
      font-family: Georgia, "Times New Roman", serif;
      font-size: 1.1rem;
    }

    .notice-box p { margin: 0; color: var(--muted); font-size: 0.92rem; line-height: 1.65; }
    .notice-box a { color: var(--saffron-dark); font-weight: 700; text-decoration: underline; }
    .notice-box a:hover { color: var(--maroon); }

    /* ── FORM EMBED (matches sangeet-sandhya exactly) ── */
    .embed-card {
      overflow: hidden;
      background: transparent;
      border-radius: var(--radius);
      box-shadow: none;
      border: 0;
      max-width: 980px;
      margin: 0 auto;
    }

    .embed-frame {
      position: relative;
      overflow: hidden;
      height: 1597px;
      width: 100%;
      background: transparent;
    }

    .embed-frame iframe {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      border: 0;
      background: transparent;
      display: block;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 1120px) {
      .site-footer .footer-top { grid-template-columns: 1fr; justify-items: start; }
      .site-footer .footer-email,
      .site-footer .footer-social { text-align: left; justify-content: flex-start; }
    }

    @media (max-width: 1100px) {
      .pill-row { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 900px) {
      .hero-grid, .two-col { grid-template-columns: 1fr; }
      .hero-panel, .details-panel { min-height: auto; padding: 26px; }
      .room-selector { grid-template-columns: repeat(2, 1fr); }
    }

    @media (max-width: 860px) {
      .nav { flex-direction: column; align-items: flex-start; }
      .site-header nav ul { justify-content: flex-start; gap: 14px; }
      .brand-logo { width: 74px; }
      .section { padding: 34px 0; }
      .embed-frame { height: 1700px; }
    }

    @media (max-width: 640px) {
      .container { width: min(calc(100% - 24px), var(--max)); }
      .hero-panel, .details-panel, .estimator-card { padding: 22px; border-radius: 22px; }
      .pill-row { grid-template-columns: 1fr; }
      .room-selector { grid-template-columns: 1fr 1fr; }
      .embed-frame { height: 1820px; }
    }
  </style>
</head>
<body>

  <div id="header-placeholder"></div>

  <main>

    <!-- HERO -->
    <section class="section">
      <div class="container">
        <div class="hero-grid">
          <div class="hero-panel">
            <h1>Facility Rental</h1>
            <p class="hero-subtitle">Reserve a Space for Your Gathering</p>
            <p class="hero-copy">Our halls and rooms are designed to bring people together for cultural programs, classes, celebrations, and community gatherings. Each space offers flexibility and warmth for every occasion — from large events to intimate meetings.</p>
            <div class="cta-row">
              <a class="btn secondary" href="#rooms">Our Spaces</a>
              <a class="btn secondary" href="#estimator">Pricing</a>
              <a class="btn secondary" href="#availability">Check Availability</a>
              <a class="btn secondary" href="HCCGC_Facility_Rental_Brochure.pdf" download style="gap:6px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Download Brochure
              </a>
              <a class="btn primary" href="#booking">Book Now</a>
            </div>
          </div>

          <aside class="details-panel" aria-label="Rental at a glance">
            <h2>At a Glance</h2>
            <div class="details-grid">
              <div class="detail-item">
                <span class="detail-label">Rooms Available</span>
                <span class="detail-value">4 Spaces — Various Sizes</span>
              </div>
              <div class="detail-item">
                <span class="detail-label">Visit Hours</span>
                <span class="detail-value">Mon &amp; Tue, 5 – 6 PM</span>
              </div>
              <div class="detail-item">
                <span class="detail-label">Weekday Discount</span>
                <span class="detail-value">20% Off (Mon – Fri)</span>
              </div>
              <div class="detail-item">
                <span class="detail-label">Extended Booking</span>
                <span class="detail-value">Extra 20% Off (4+ Hours)</span>
              </div>
              <div class="detail-item">
                <span class="detail-label">Nonprofit Rate</span>
                <span class="detail-value">Additional 25% Off</span>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- OUR SPACES -->
    <section class="section" id="rooms">
      <div class="container">
        <div class="section-head content-width">
          <span class="section-kicker">Our Spaces</span>
          <h2>Four Rooms, Endless Possibilities</h2>
          <p class="section-copy">From spacious halls for large community events to cozy rooms for focused gatherings — every space is designed with comfort and cultural purpose in mind.</p>
        </div>

        <div class="pill-row">
          <div class="pill-card">
            <img class="room-img" src="https://hccgc.org/big-room.jpeg" alt="Surya Hall" onerror="this.style.display='none'" />
            <h3>Surya Hall</h3>
            <p>Spacious and versatile hall for large gatherings, workshops, classes, and community events.</p>
            <div class="rate-badge">$45 / hour</div>
          </div>

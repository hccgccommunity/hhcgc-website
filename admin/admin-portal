// GET /finance/transactions?startDate=&endDate=&source=&status=
// Bank transactions are the single source of truth here — Zeffy's weekly
// lump-sum payout shows up as ONE row in bank_transactions, so a Zeffy
// "transaction" from fact_payments is never listed separately (that would
// double-count the same money once accounting runs off this list). Instead,
// any bank row that looks like a Zeffy payout gets split into up to three
// synthetic rows — Individual Donations, Facility Rental Income, and
// Fundraising Event Income — based on which campaigns fed that payout,
// each pre-tagged with its matching category. Every other bank row passes
// through unchanged.
// Shared by the Transactions list and the Statement of Activities — bank
// transactions are the source of truth, with Zeffy payout rows forked into
// categorized sub-entries. Statement of Activities can't just re-derive
// this with a SQL join, since the split amounts aren't stored anywhere;
// they're computed here the same way every time, so both endpoints stay
// consistent with each other.
// Finds every Zeffy-payout bank transaction in range and computes its
// underlying Sat-Fri activity window. Shared by the bank-transaction split
// AND the dashboard's per-campaign fundraising breakdown, so the two are
// mathematically guaranteed to add up to the same total — they're
// literally built from the same windows, not two separate calculations
// that happen to cover similar ground.
// Campaign-level Zeffy revenue — summed straight from fact_payments, not
// tied to bank deposit timing at all. Much simpler and more robust than
// trying to match payout windows, and it's what actually gets shown in the
// Transactions tab's Zeffy section: one row per campaign, not one per
// individual payment.
// Builds a lookup of every transaction currently linked to a booking's
// invoice, keyed the same way transactions are (source|sourceKey) — shared
// by every place that needs to show attach/send status on a transaction
// row, so there's exactly one place this gets computed.
async function getBookingMatchLookup() {
  const [rows] = await bigquery.query(
    `SELECT booking_id, renter_name, final_total, event_date, payment_status, invoice_sent_at, receipt_sent_at, payment_match_source, payment_match_id
     FROM \`${DATASET}.bookings\` WHERE payment_match_source IS NOT NULL AND payment_match_id IS NOT NULL`
  );
  const unwrap = v => (v && typeof v === 'object' && 'value' in v) ? v.value : v;
  const map = {};
  rows.forEach(r => {
    map[`${r.payment_match_source}|${r.payment_match_id}`] = {
      bookingId: r.booking_id, renterName: r.renter_name, finalTotal: Number(r.final_total),
      eventDate: unwrap(r.event_date), paymentStatus: r.payment_status,
      invoiceSentAt: unwrap(r.invoice_sent_at), receiptSentAt: unwrap(r.receipt_sent_at)
    };
  });
  return map;
}

async function getZeffyCampaignSummary(startDate, endDate) {
  const campaignMap = await getCampaignNameMap();
  const matchLookup = await getBookingMatchLookup();
  const unwrap = v => (v && typeof v === 'object' && 'value' in v) ? v.value : v;

  const [catRows] = await bigquery.query(
    `SELECT source, source_key, category_id, notes FROM \`${DATASET}.transaction_categorizations\` WHERE source IN ('zeffy-campaign', 'zeffy')`
  );
  const catMap = {}, notesMap = {};
  catRows.forEach(c => { catMap[`${c.source}|${c.source_key}`] = c.category_id; notesMap[`${c.source}|${c.source_key}`] = c.notes; });

  const donationCatId = await getCategoryIdByName('Donations & Contributions', 'income');
  const rentalCatId = await getCategoryIdByName('Facility Rental Income', 'income');
  const fundraisingCatId = await getCategoryIdByName('Fundraising Revenue', 'income');

  // Facility Rental — individual payments, not aggregated, since each one
  // can be attached to a specific booking's invoice.
  const [rentalRows] = await bigquery.query({
    query: `SELECT payment_id, payment_date, gross_amount, donor_name, donor_email
            FROM \`${PAYMENTS_DATASET}.fact_payments\`
            WHERE payment_date BETWEEN @startDate AND @endDate AND campaign_id = @rentalId
            ORDER BY payment_date DESC`,
    params: { startDate, endDate, rentalId: RENTAL_CAMPAIGN_ID }
  });
  const facilityRental = [];
  for (const r of rentalRows) {
    const key = `zeffy|${r.payment_id}`;
    if (!catMap[key]) {
      await bigquery.query({
        query: `INSERT INTO \`${DATASET}.transaction_categorizations\` (id, source, source_key, category_id, notes, categorized_by, categorized_at)
                VALUES (@id, 'zeffy', @paymentId, @categoryId, 'Auto-suggested — Facility Rental campaign', 'system-auto', CURRENT_TIMESTAMP())`,
        params: { id: randomUUID(), paymentId: r.payment_id, categoryId: rentalCatId }
      });
      catMap[key] = rentalCatId;
    }
    facilityRental.push({
      source: 'zeffy', sourceKey: r.payment_id,
      date: unwrap(r.payment_date), description: r.donor_name || r.donor_email || 'Zeffy payment',
      amount: Math.round(Number(r.gross_amount) / 100 * 100) / 100,
      categoryId: catMap[key], notes: notesMap[key] || null,
      matchedBooking: matchLookup[key] || null
    });
  }

  // Donations & everything else (fundraising) — stay as campaign-level
  // aggregates, same as before, since there's no per-payment invoice to
  // attach for these.
  const [campaignRows] = await bigquery.query({
    query: `SELECT campaign_id, SUM(gross_amount) / 100 AS total, COUNT(*) AS count
            FROM \`${PAYMENTS_DATASET}.fact_payments\`
            WHERE payment_date BETWEEN @startDate AND @endDate AND campaign_id != @rentalId
            GROUP BY campaign_id
            ORDER BY total DESC`,
    params: { startDate, endDate, rentalId: RENTAL_CAMPAIGN_ID }
  });
  const donations = [], fundraising = [];
  for (const r of campaignRows) {
    const key = `zeffy-campaign|${r.campaign_id}`;
    if (!catMap[key]) {
      const suggested = r.campaign_id === DONATION_CAMPAIGN_ID ? donationCatId : fundraisingCatId;
      await bigquery.query({
        query: `INSERT INTO \`${DATASET}.transaction_categorizations\` (id, source, source_key, category_id, notes, categorized_by, categorized_at)
                VALUES (@id, 'zeffy-campaign', @campaignId, @categoryId, 'Auto-suggested by campaign', 'system-auto', CURRENT_TIMESTAMP())`,
        params: { id: randomUUID(), campaignId: r.campaign_id, categoryId: suggested }
      });
      catMap[key] = suggested;
    }
    const entry = {
      source: 'zeffy-campaign', sourceKey: r.campaign_id,
      campaignId: r.campaign_id, name: campaignMap[r.campaign_id] || 'Unknown campaign',
      total: Math.round(Number(r.total) * 100) / 100, count: r.count,
      categoryId: catMap[key], notes: notesMap[key] || null
    };
    if (r.campaign_id === DONATION_CAMPAIGN_ID) donations.push(entry); else fundraising.push(entry);
  }

  return { facilityRental, donations, fundraising };
}

// Bank transactions split into Zelle, Zeffy refunds, and everything else.
// The Zeffy weekly payout deposit itself is deliberately excluded here —
// its content is already represented by the campaign summary above, so
// showing it too would double-count that revenue.
// Strips digits and collapses whitespace/punctuation so recurring
// transactions with the same vendor/description but different reference
// numbers or dates still match the same learned pattern.
function normalizeDescription(desc) {
  return (desc || '')
    .toLowerCase()
    .replace(/\d+/g, '')
    .replace(/[^a-z\s]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();
}

async function getBankTransactionsSplit(startDate, endDate) {
  const unwrap = v => (v && typeof v === 'object' && 'value' in v) ? v.value : v;
  const matchLookup = await getBookingMatchLookup();
  const [bankRows] = await bigquery.query({
    query: `SELECT date, description, amount, ingestion_timestamp
            FROM \`${PAYMENTS_DATASET}.bank_transactions\`
            WHERE date BETWEEN @startDate AND @endDate
            ORDER BY date DESC`,
    params: { startDate, endDate }
  });

  const [catRows] = await bigquery.query(
    `SELECT source, source_key, category_id, notes FROM \`${DATASET}.transaction_categorizations\` WHERE source = 'bank'`
  );
  const catMap = {}, notesMap = {};
  catRows.forEach(c => { catMap[c.source_key] = c.category_id; notesMap[c.source_key] = c.notes; });
  const feeCatId = await getCategoryIdByName('Bank Charges', 'expense');

  let ruleMap = {};
  try {
    const [ruleRows] = await bigquery.query(`SELECT pattern, category_id FROM \`${DATASET}.transaction_category_rules\``);
    ruleRows.forEach(r => { ruleMap[r.pattern] = r.category_id; });
  } catch (err) {
    console.error('transaction_category_rules lookup failed (has the migration run?):', err.message);
    // Learning suggestions just don't apply this time — everything else
    // about the transactions list still works normally.
  }

  const zelle = [], zeffyRefunds = [], other = [];
  for (const r of bankRows) {
    const key = bankTransactionKey(r);
    const desc = r.description || '';
    const isZeffy = /zeffy/i.test(desc);
    const isZelle = /zelle/i.test(desc);
    const isFee = (/zelle/i.test(desc) && /fee/i.test(desc)) || /monthly service fee/i.test(desc) || /wire transfer fees? \(incoming\)/i.test(desc);

    if (isZeffy && Number(r.amount) >= 0) continue; // the weekly payout deposit — excluded, see comment above

    // Explicit fee patterns take priority; otherwise fall back to whatever
    // category a user has previously and consistently chosen for
    // transactions with this same (digit-stripped) description.
    if (!catMap[key]) {
      let suggested = null;
      let suggestNote = null;
      if (isFee) { suggested = feeCatId; suggestNote = 'Auto-suggested — bank fee'; }
      else {
        const pattern = normalizeDescription(desc);
        if (pattern && ruleMap[pattern]) { suggested = ruleMap[pattern]; suggestNote = 'Auto-suggested — learned from past categorizations'; }
      }
      if (suggested) {
        await bigquery.query({
          query: `INSERT INTO \`${DATASET}.transaction_categorizations\` (id, source, source_key, category_id, notes, categorized_by, categorized_at)
                  VALUES (@id, 'bank', @key, @categoryId, @note, 'system-auto', CURRENT_TIMESTAMP())`,
          params: { id: randomUUID(), key, categoryId: suggested, note: suggestNote }
        });
        catMap[key] = suggested;
        notesMap[key] = suggestNote;
      }
    }

    const entry = {
      source: 'bank', sourceKey: key,
      date: unwrap(r.date), description: desc, amount: Number(r.amount),
      categoryId: catMap[key] || null, notes: notesMap[key] || null,
      matchedBooking: matchLookup[`bank|${key}`] || null
    };
    if (isZeffy) zeffyRefunds.push(entry);
    else if (isZelle) zelle.push(entry);
    else other.push(entry);
  }
  return { zelle, zeffyRefunds, other };
}

// Everything categorizable, flattened — used by Statements, Dashboard, and
// Cash Flow so they stay consistent with what the Transactions tab shows.
// Same underlying data, same categorization, just combined into one list.
async function getCategorizedBankTransactions(startDate, endDate) {
  const { facilityRental, donations, fundraising } = await getZeffyCampaignSummary(startDate, endDate);
  const { zelle, zeffyRefunds, other } = await getBankTransactionsSplit(startDate, endDate);
  const all = [
    ...facilityRental.map(c => ({ source: c.source, sourceKey: c.sourceKey, date: c.date, description: c.description, amount: c.amount, categoryId: c.categoryId })),
    ...donations.map(c => ({ source: c.source, sourceKey: c.sourceKey, date: startDate, description: `Zeffy — ${c.name}`, amount: c.total, categoryId: c.categoryId })),
    ...fundraising.map(c => ({ source: c.source, sourceKey: c.sourceKey, date: startDate, description: `Zeffy — ${c.name}`, amount: c.total, categoryId: c.categoryId })),
    ...zelle, ...zeffyRefunds, ...other
  ];
  all.sort((a, b) => (a.date < b.date ? 1 : -1));
  return all;
}

async function listFinanceTransactions(req, res) {
  const q = req.query || {};
  const startDate = q.startDate || '2000-01-01';
  const endDate = q.endDate || '2100-01-01';
  const applyStatus = list => {
    if (q.status === 'uncategorized') return list.filter(t => !t.categoryId);
    if (q.status === 'categorized') return list.filter(t => t.categoryId);
    return list;
  };
  const { facilityRental, donations, fundraising } = await getZeffyCampaignSummary(startDate, endDate);
  const { zelle, zeffyRefunds, other } = await getBankTransactionsSplit(startDate, endDate);
  res.json({
    facilityRental: applyStatus(facilityRental), donations: applyStatus(donations), fundraising: applyStatus(fundraising),
    zelle: applyStatus(zelle), zeffyRefunds: applyStatus(zeffyRefunds), other: applyStatus(other)
  });
}

// POST /finance/categorize — assign (or reassign) a category to one transaction.
async function categorizeTransaction(req, res, actor) {
  const b = req.body || {};
  if (!['bank', 'zeffy-campaign', 'zeffy'].includes(b.source)) return res.status(400).json({ errors: ['source must be bank, zeffy-campaign, or zeffy.'] });
  if (!b.sourceKey) return res.status(400).json({ errors: ['sourceKey is required.'] });
  if (!b.categoryId) return res.status(400).json({ errors: ['categoryId is required.'] });

  const [existing] = await bigquery.query({
    query: `SELECT id FROM \`${DATASET}.transaction_categorizations\` WHERE source = @source AND source_key = @sourceKey`,
    params: { source: b.source, sourceKey: b.sourceKey }
  });
  if (existing.length) {
    await bigquery.query({
      query: `UPDATE \`${DATASET}.transaction_categorizations\` SET category_id = @categoryId, notes = @notes, categorized_by = @actorEmail, categorized_at = CURRENT_TIMESTAMP()
              WHERE source = @source AND source_key = @sourceKey`,
      params: { categoryId: b.categoryId, notes: b.notes || null, actorEmail: actor.email, source: b.source, sourceKey: b.sourceKey },
      types: { notes: 'STRING' }
    });
  } else {
    await bigquery.query({
      query: `INSERT INTO \`${DATASET}.transaction_categorizations\` (id, source, source_key, category_id, notes, categorized_by, categorized_at)
              VALUES (@id, @source, @sourceKey, @categoryId, @notes, @actorEmail, CURRENT_TIMESTAMP())`,
      params: { id: randomUUID(), source: b.source, sourceKey: b.sourceKey, categoryId: b.categoryId, notes: b.notes || null, actorEmail: actor.email },
      types: { notes: 'STRING' }
    });
  }

  // Learn from this — a human just confirmed (or corrected) a category for
  // a bank transaction, so future transactions with the same (digit-
  // stripped) description get the same suggestion next time. Only for
  // real bank transactions with a description to learn from — the
  // campaign-level Zeffy rows already have their own suggestion logic.
  if (b.source === 'bank' && b.description) {
    try {
      const pattern = normalizeDescription(b.description);
      if (pattern) {
        const [existingRule] = await bigquery.query({
          query: `SELECT pattern FROM \`${DATASET}.transaction_category_rules\` WHERE pattern = @pattern`,
          params: { pattern }
        });
        if (existingRule.length) {
          await bigquery.query({
            query: `UPDATE \`${DATASET}.transaction_category_rules\` SET category_id = @categoryId, match_count = match_count + 1, updated_at = CURRENT_TIMESTAMP() WHERE pattern = @pattern`,
            params: { categoryId: b.categoryId, pattern }
          });
        } else {
          await bigquery.query({
            query: `INSERT INTO \`${DATASET}.transaction_category_rules\` (pattern, category_id, match_count, updated_at)
                    VALUES (@pattern, @categoryId, 1, CURRENT_TIMESTAMP())`,
            params: { pattern, categoryId: b.categoryId }
          });
        }
      }
    } catch (err) {
      console.error('transaction_category_rules update failed (has the migration run?):', err.message);
      // The category itself is already saved above — learning is a bonus,
      // not something that should block or fail the actual save.
    }
  }

  res.json({ ok: true });
}

// GET /finance/statement-of-activities?startDate=&endDate=
// A nonprofit's Statement of Activities is functionally the same report as
// a for-profit Income Statement / P&L — revenue by category, expenses by
// category, net result — just the term nonprofits typically use.
async function getStatementOfActivities(req, res) {
  const q = req.query || {};
  const startDate = q.startDate || '2000-01-01';
  const endDate = q.endDate || '2100-01-01';

  const transactions = await getCategorizedBankTransactions(startDate, endDate);
  const categorized = transactions.filter(t => t.categoryId);

  const [categories] = await bigquery.query(`SELECT category_id, name, type FROM \`${DATASET}.transaction_categories\``);
  const catInfo = {};
  categories.forEach(c => { catInfo[c.category_id] = c; });

  const byCategory = {};
  categorized.forEach(t => {
    if (!byCategory[t.categoryId]) byCategory[t.categoryId] = { total: 0, count: 0 };
    byCategory[t.categoryId].total += t.amount;
    byCategory[t.categoryId].count += 1;
  });

  const income = [], expense = [];
  Object.keys(byCategory).forEach(categoryId => {
    const info = catInfo[categoryId];
    if (!info) return; // category was deleted after being used — skip rather than crash
    const entry = { categoryId, name: info.name, total: Math.round(byCategory[categoryId].total * 100) / 100, count: byCategory[categoryId].count };
    if (info.type === 'income') income.push(entry); else expense.push(entry);
  });
  income.sort((a, b) => b.total - a.total);
  expense.sort((a, b) => b.total - a.total);

  const totalIncome = income.reduce((s, r) => s + r.total, 0);
  const totalExpense = expense.reduce((s, r) => s + r.total, 0);

  res.json({ startDate, endDate, income, expense, totalIncome: Math.round(totalIncome * 100) / 100, totalExpense: Math.round(totalExpense * 100) / 100, netIncome: Math.round((totalIncome - totalExpense) * 100) / 100 });
}

// GET /finance/cash-flow-statement?startDate=&endDate=
// A direct-method cash flow statement — beginning balance, cash in from
// categorized income, cash out from categorized expenses, ending balance.
// This system has no separate tracking for investing or financing
// activities (asset purchases, loans), so unlike a more complex
// organization's cash flow statement, everything here is effectively
// operating activity — which is an honest reflection of what data exists,
// not a simplification hiding something.
async function getCashFlowStatement(req, res) {
  const q = req.query || {};
  const startDate = q.startDate || '2000-01-01';
  const endDate = q.endDate || '2100-01-01';

  const [[beginRow]] = await bigquery.query({
    query: `SELECT SUM(amount) AS total FROM \`${PAYMENTS_DATASET}.bank_transactions\` WHERE date < @startDate`,
    params: { startDate }
  });
  const beginningCash = Math.round((Number(beginRow.total) || 0) * 100) / 100;

  const transactions = await getCategorizedBankTransactions(startDate, endDate);
  const categorized = transactions.filter(t => t.categoryId);
  const [categories] = await bigquery.query(`SELECT category_id, type FROM \`${DATASET}.transaction_categories\``);
  const typeById = {};
  categories.forEach(c => { typeById[c.category_id] = c.type; });

  let cashIn = 0, cashOut = 0, uncategorizedNet = 0;
  transactions.forEach(t => {
    const type = typeById[t.categoryId];
    if (type === 'income') cashIn += t.amount;
    else if (type === 'expense') cashOut += t.amount;
    else uncategorizedNet += t.amount; // not yet categorized — still real cash movement, shown separately
  });

  const netChange = cashIn - cashOut + uncategorizedNet;
  const endingCash = beginningCash + netChange;

  res.json({
    startDate, endDate,
    beginningCash,
    cashIn: Math.round(cashIn * 100) / 100,
    cashOut: Math.round(cashOut * 100) / 100,
    uncategorizedNet: Math.round(uncategorizedNet * 100) / 100,
    netChange: Math.round(netChange * 100) / 100,
    endingCash: Math.round(endingCash * 100) / 100
  });
}

// GET /finance/reconciliation — the weekly Zeffy payout problem: one lump
// bank deposit each Monday needs to net-match against that week's worth of
// individual fact_payments (minus Zeffy's fees). Groups by ISO week and
// surfaces both sides so the user can manually confirm the match.
const MINIMUM_BALANCE_REQUIREMENT = 37000;

// GET /finance/dashboard?startDate=&endDate= — the graphical overview:
// current cash against the board's minimum balance requirement, income
// broken down by category, future booked facility-rental revenue not yet
// collected, and a per-campaign breakdown of fundraising event income.
// GET /finance/monthly-cash-trend — cash balance at the end of each of the
// last 12 months, plotted against the sustainability threshold. Always the
// trailing 12 months regardless of whatever date range the rest of the
// dashboard is filtered to — this is a longer-term health check, not
// something that should shrink to a one-month view just because someone's
// looking at "This month" everywhere else.
async function getMonthlyCashTrend(req, res) {
  const months = [];
  const now = new Date();
  for (let i = 11; i >= 0; i--) {
    const d = new Date(now.getFullYear(), now.getMonth() - i + 1, 0); // last day of that month
    months.push(d.toISOString().slice(0, 10));
  }
  const results = [];
  for (const endOfMonth of months) {
    const [[row]] = await bigquery.query({
      query: `SELECT SUM(amount) AS cash FROM \`${PAYMENTS_DATASET}.bank_transactions\` WHERE date <= @endOfMonth`,
      params: { endOfMonth }
    });
    results.push({ month: endOfMonth.slice(0, 7), cash: Math.round((Number(row.cash) || 0) * 100) / 100 });
  }
  res.json({ minimumBalanceRequirement: MINIMUM_BALANCE_REQUIREMENT, months: results });
}

async function getFinanceDashboard(req, res) {
  const q = req.query || {};
  const startDate = q.startDate || '2000-01-01';
  const endDate = q.endDate || '2100-01-01';
  const today = new Date().toISOString().slice(0, 10);
  const unwrap = v => (v && typeof v === 'object' && 'value' in v) ? v.value : v;

  const [[cashRow]] = await bigquery.query(`SELECT SUM(amount) AS cash FROM \`${PAYMENTS_DATASET}.bank_transactions\` WHERE date <= '${today}'`);
  const currentCash = Math.round((Number(cashRow.cash) || 0) * 100) / 100;

  const transactions = await getCategorizedBankTransactions(startDate, endDate);
  const categorized = transactions.filter(t => t.categoryId);
  const [categories] = await bigquery.query(`SELECT category_id, name, type FROM \`${DATASET}.transaction_categories\``);
  const catInfo = {};
  categories.forEach(c => { catInfo[c.category_id] = c; });

  const incomeByCategory = {};
  const expenseByCategory = {};
  const byMonth = {};
  categorized.forEach(t => {
    const info = catInfo[t.categoryId];
    if (!info) return;
    const bucket = info.type === 'income' ? incomeByCategory : (info.type === 'expense' ? expenseByCategory : null);
    if (bucket) bucket[info.name] = (bucket[info.name] || 0) + t.amount;

    const monthKey = t.date.slice(0, 7); // YYYY-MM
    if (!byMonth[monthKey]) byMonth[monthKey] = { income: 0, expense: 0 };
    if (info.type === 'income') byMonth[monthKey].income += t.amount;
    else if (info.type === 'expense') byMonth[monthKey].expense += t.amount;
  });
  const incomeBreakdown = Object.keys(incomeByCategory)
    .map(name => ({ name, total: Math.round(incomeByCategory[name] * 100) / 100 }))
    .sort((a, b) => b.total - a.total);
  const expenseBreakdown = Object.keys(expenseByCategory)
    .map(name => ({ name, total: Math.round(expenseByCategory[name] * 100) / 100 }))
    .sort((a, b) => b.total - a.total);
  const monthlyTrend = Object.keys(byMonth).sort().map(month => ({
    month, income: Math.round(byMonth[month].income * 100) / 100, expense: Math.round(byMonth[month].expense * 100) / 100
  }));

  // How many months the sustainability metric would actually cover, based
  // on the average monthly expense over the selected range — gives the
  // raw dollar figure some real-world context.
  const monthsWithData = Object.keys(byMonth).length || 1;
  const totalExpenseInRange = Object.values(byMonth).reduce((s, m) => s + m.expense, 0);
  const avgMonthlyExpense = Math.round((totalExpenseInRange / monthsWithData) * 100) / 100;
  const monthsOfRunway = avgMonthlyExpense > 0 ? Math.round((MINIMUM_BALANCE_REQUIREMENT / avgMonthlyExpense) * 10) / 10 : null;

  const [futureBookingsRows] = await bigquery.query(
    `SELECT SUM(final_total) AS total, COUNT(*) AS count FROM \`${DATASET}.bookings\`
     WHERE event_date > CURRENT_DATE() AND payment_status IN ('pending', 'invoiced') AND is_internal = FALSE`
  );
  const futureBookedRevenue = Math.round((Number(futureBookingsRows[0].total) || 0) * 100) / 100;
  const futureBookingsCount = futureBookingsRows[0].count || 0;

  const [futureByMonthRows] = await bigquery.query(
    `SELECT FORMAT_DATE('%Y-%m', event_date) AS month, SUM(final_total) AS total, COUNT(*) AS count
     FROM \`${DATASET}.bookings\`
     WHERE event_date > CURRENT_DATE() AND payment_status IN ('pending', 'invoiced') AND is_internal = FALSE
     GROUP BY month
     ORDER BY month ASC`
  );
  const futureBookedRevenueByMonth = futureByMonthRows.map(r => ({
    month: r.month, total: Math.round(Number(r.total) * 100) / 100, count: r.count
  }));

  // Top donors — direct from fact_payments for the date range. This is a
  // "who's contributing" view, not an accounting figure, so it doesn't
  // need the same bank-reconciliation precision as the income totals above.
  const [donorRows] = await bigquery.query({
    query: `SELECT COALESCE(NULLIF(TRIM(donor_name), ''), donor_email, 'Unknown') AS donor, SUM(net_amount) / 100 AS total, COUNT(*) AS count
            FROM \`${PAYMENTS_DATASET}.fact_payments\`
            WHERE payment_date BETWEEN @startDate AND @endDate AND campaign_id = @donationId
            GROUP BY donor
            ORDER BY total DESC
            LIMIT 10`,
    params: { startDate, endDate, donationId: DONATION_CAMPAIGN_ID }
  });
  const topDonors = donorRows.map(r => ({ name: r.donor, total: Math.round(Number(r.total) * 100) / 100, count: r.count }));

  const [renterRows] = await bigquery.query({
    query: `SELECT renter_name, SUM(final_total) AS total, COUNT(*) AS count
            FROM \`${DATASET}.bookings\`
            WHERE event_date BETWEEN @startDate AND @endDate AND payment_status = 'paid' AND is_internal = FALSE
            GROUP BY renter_name
            ORDER BY total DESC
            LIMIT 10`,
    params: { startDate, endDate }
  });
  const topRenters = renterRows.map(r => ({ name: r.renter_name, total: Math.round(Number(r.total) * 100) / 100, count: r.count }));

  const zeffyCampaigns = await getZeffyCampaignSummary(startDate, endDate);
  const fundraisingBreakdown = zeffyCampaigns
    .filter(c => c.campaignId !== DONATION_CAMPAIGN_ID && c.campaignId !== RENTAL_CAMPAIGN_ID && Math.abs(c.total) >= 0.01)
    .map(c => ({ campaignId: c.campaignId, name: c.name, total: c.total, count: c.count }));

  res.json({
    startDate, endDate,
    currentCash, minimumBalanceRequirement: MINIMUM_BALANCE_REQUIREMENT,
    aboveMinimum: Math.round((currentCash - MINIMUM_BALANCE_REQUIREMENT) * 100) / 100,
    avgMonthlyExpense, monthsOfRunway,
    incomeBreakdown, expenseBreakdown, monthlyTrend,
    futureBookedRevenue, futureBookingsCount, futureBookedRevenueByMonth, fundraisingBreakdown,
    topDonors, topRenters
  });
}

// GET /finance/future-booked-revenue-detail — the actual bookings behind
// the dashboard's "Future booked facility rental revenue" figure.
async function getFutureBookedRevenueDetail(req, res) {
  const unwrap = v => (v && typeof v === 'object' && 'value' in v) ? v.value : v;
  const [rows] = await bigquery.query(
    `SELECT booking_id, renter_name, event_date, payment_status, final_total FROM \`${DATASET}.bookings\`
     WHERE event_date > CURRENT_DATE() AND payment_status IN ('pending', 'invoiced') AND is_internal = FALSE
     ORDER BY event_date ASC`
  );
